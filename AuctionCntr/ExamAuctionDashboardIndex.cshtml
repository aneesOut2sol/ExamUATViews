
@{
    ViewBag.Title = "Exam Auction Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .content{padding:0!important}
    * {
        --border: #e2e8f0;
    }
    /* ========= Theme (Light by default) ========= */

    /* ========= Scoped Theme: Light (default) ========= */
    .dashboard {
        /* theme variables only apply inside .dashboard */
        --bg: #f8fafc; /* slate-50 */
        --bg-elev: #ffffff;
        --card: #ffffff;
        --text: #0f172a;
        --muted: #475569;
        --border: #e2e8f0;
        --import: #16a34a; /* green-600 */
        --import-weak: #dcfce7;
        --export: #0ea5e9; /* sky-500 */
        --export-weak: #e0f2fe;
        --total: #d97706; /* amber-600 */
        --total-weak: #fef3c7;
        --auction: #7c3aed; /* violet-600 */
        --auction-weak: #ede9fe;
        background: linear-gradient(180deg, var(--bg) 0%, var(--bg-elev) 100%);
        color: var(--text);
        min-height: 100vh;
        padding: 24px;
        font-family: system-ui, -apple-system, Segoe UI, Roboto, "Helvetica Neue", Arial, "Noto Sans", "Liberation Sans", sans-serif;
    }

        /* ========= Scoped Theme: Dark (toggle this class on .dashboard) ========= */
        .dashboard.dark {
            --bg: #0f172a;
            --bg-elev: #111827;
            --card: #1f2937;
            --text: #e5e7eb;
            --muted: #9ca3af;
            --border: #334155;
            --import: #22c55e;
            --import-weak: rgba(34,197,94,0.12);
            --export: #06b6d4;
            --export-weak: rgba(6,182,212,0.12);
            --total: #f59e0b;
            --total-weak: rgba(245,158,11,0.12);
            --auction: #a855f7;
            --auction-weak: rgba(168,85,247,0.12);
        }

    /* (Keep the rest of your existing dashboard styles as-is) */
    .page-header.blur {
        /* stays light (or site default) and unaffected by dashboard theme */
        position: sticky;
        top: 0;
        z-index: 50;
        backdrop-filter: blur(8px);
        /* optional: use your site’s default colors here, not the dashboard variables */
        background: #ffffffcc; /* example */
        border-bottom: 1px solid #e2e8f0;
    }

    /* Print remains scoped too */
    @@media print {
        .page-header, .divider, .footer-note, .badge, .pill, .actions {
            display: none !important;
        }

        .dashboard {
            padding: 0;
            background: #fff;
            color: #111;
        }

        .card {
            box-shadow: none !important;
            border: 1px solid #ddd;
            break-inside: avoid;
            page-break-inside: avoid;
            margin-bottom: 12px;
        }

        .grid {
            display: block;
        }

        .row {
            border-color: #ddd;
        }

        .kpi-row {
            grid-template-columns: repeat(6, 1fr);
        }
    }


    .dashboard-header {
        display: flex;
        flex-wrap: wrap;
        align-items: baseline;
        gap: 16px;
        margin-bottom: 20px;
    }

    .dashboard-title {
        font-size: 1.5rem;
        font-weight: 700;
        letter-spacing: 0.2px;
    }

    .dashboard-subtitle {
        font-size: 0.95rem;
        color: var(--muted);
    }

    .grid {
        display: grid;
        gap: 16px;
    }

    .grid-4 {
        grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .grid-3 {
        grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .grid-2 {
        grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    @@media (max-width: 1200px) {
        .grid-4 {
            grid-template-columns: repeat(3, 1fr);
        }
    }

    @@media (max-width: 900px) {
        .grid-3, .grid-4 {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 600px) {
        .grid-2, .grid-3, .grid-4 {
            grid-template-columns: 1fr;
        }
    }

    /* ========= Card ========= */
    .card {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 16px;
        box-shadow: 0 8px 24px rgba(0,0,0,0.15);
    }

    .card-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 8px;
        margin-bottom: 10px;
    }

    .card-title {
        font-weight: 600;
        font-size: 1.05rem;
    }

    .card-meta {
        font-size: 0.85rem;
        color: var(--muted);
    }

    /* ========= Badges ========= */
    .badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 6px 10px;
        border-radius: 999px;
        font-size: 0.85rem;
        border: 1px solid var(--border);
        background: rgba(0,0,0,0.03);
    }

        .badge .dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
        }

    .badge-import {
        border-color: var(--import);
        color: var(--import);
        background: var(--import-weak);
    }

    .badge-export {
        border-color: var(--export);
        color: var(--export);
        background: var(--export-weak);
    }

    .badge-total {
        border-color: var(--total);
        color: var(--total);
        background: var(--total-weak);
    }

    .badge-auction {
        border-color: var(--auction);
        color: var(--auction);
        background: var(--auction-weak);
    }

    /* ========= KPI ========= */
    .kpi-row {
        display: grid;
        grid-template-columns: repeat(6, 1fr);
        gap: 10px;
        margin-top: 12px;
    }

    .kpi {
        background: rgba(0,0,0,0.03);
        border: 1px dashed var(--border);
        border-radius: 12px;
        padding: 10px;
        text-align: center;
    }

    .kpi-label {
        font-size: 0.85rem;
        color: var(--muted);
    }

    .kpi-value {
        font-size: 1.05rem;
        font-weight: 700;
    }

    .kpi-total .kpi-value {
        color: var(--total);
    }

    .kpi-import .kpi-value {
        color: var(--import);
    }

    .kpi-export .kpi-value {
        color: var(--export);
    }

    /* ========= Data rows ========= */
    .row {
        display: grid;
        grid-template-columns: 1.3fr 0.9fr repeat(5, 1fr);
        align-items: center;
        gap: 8px;
        padding: 10px 12px;
        border-radius: 12px;
        border: 1px solid var(--border);
        background: rgba(0,0,0,0.02);
    }

        .row + .row {
            margin-top: 8px;
        }

        .row .label {
            display: flex;
            align-items: center;
            text-align: center;
            gap: 8px;
            font-weight: 600;
        }

    .pill {
        font-size: 0.8rem;
        padding: 4px 10px;
        border-radius: 12px;
        border: 1px solid var(--border);

    }

    .pill-import {
        color: var(--import);
        background: var(--import-weak);
        border-color: var(--import);
    }

    .pill-export {
        color: var(--export);
        background: var(--export-weak);
        border-color: var(--export);
    }

    .value {
        text-align: center;
        font-variant-numeric: tabular-nums;
    }

    /* ========= Divider & actions ========= */
    .divider {
        height: 1px;
        background: var(--border);
        margin: 16px 0;
        opacity: 0.8;
    }

    .footer-note {
        font-size: 0.8rem;
        color: var(--muted);
        text-align: right;
    }

    .actions {
        display: flex;
        gap: 8px;
        align-items: center;
    }

        .actions .btn {
            padding: 8px 70px;
            font-size: medium;
            border-radius: 8px;
            border: 1px solid var(--border);
            background: var(--card);
            color: var(--text);
            cursor: pointer;
        }

            .actions .btn:hover {
                filter: brightness(0.95);
            }

    /* ========= Accessibility ========= */
    .sr-only {
        position: absolute !important;
        height: 1px;
        width: 1px;
        overflow: hidden;
        clip: rect(1px,1px,1px,1px);
        white-space: nowrap;
        border: 0;
        padding: 0;
        margin: -1px;
    }

    /* Make the 'Total Containers' cell pop visually */
    .value-total {
        font-weight: 800;
        color: var(--total); /* uses your KPI total color */
        background: var(--total-weak); /* soft highlight */
        border: 1px solid var(--border);
        border-radius: 8px;
        text-align: center
    }

    * {
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
    }


/* --- PRINT OVERRIDES: keep 3 cards per row --- */
@@media print {
  /* Ensure grid stays a grid in print */
  .grid {
    display: grid !important;
    gap: 16px !important;
  }

  /* Force 3 columns in print, regardless of page width */
  .grid-3 {
    grid-template-columns: repeat(3, 1fr) !important;
  }

  /* If you also have 4-col or 2-col sections, you can pin them too */
  .grid-4 {
    grid-template-columns: repeat(4, 1fr) !important;
  }
  .grid-2 {
    grid-template-columns: repeat(2, 1fr) !important;
  }

  /* Prevent items from being split across pages */
  .card {
    break-inside: avoid !important;
    page-break-inside: avoid !important;
  }

  /* If any card has a max-width that causes wrapping, remove it for print */
  .card { max-width: none !important; }

  /* If you use scaling in the print window, avoid clipping by keeping overflow visible */
  #print-wrapper { overflow: visible !important; }
  #print-scale { transform-origin: top left !important; }



    .pill,
    .badge {
        display: inline-flex !important;
        align-items: center !important;
        gap: 6px !important;
        padding: 4px 10px !important;
        border-radius: 12px !important;
        border: 1px solid var(--border) !important;
        visibility: visible !important;
        opacity: 1 !important;
    }



    /* Treat dashboard as light theme in print to keep text visible */
    .dashboard,
    .dashboard.dark {
        /* Light palette for print */
        --bg: #ffffff !important;
        --bg-elev: #ffffff !important;
        --card: #ffffff !important;
        --text: #111111 !important;
        --muted: #374151 !important;
        --border: #e5e7eb !important;
        /* Keep brand accents */
        --import: #16a34a !important; /* green-600 */
        --import-weak: #dcfce7 !important;
        --export: #0ea5e9 !important; /* sky-500 */
        --export-weak: #e0f2fe !important;
        --total: #d97706 !important; /* amber-600 */
        --total-weak: #fef3c7 !important;
        --auction: #7c3aed !important; /* violet-600 */
        --auction-weak: #ede9fe !important;
    }

    /* Ensure actual backgrounds are printed (not gradients that may be dropped) */
    .dashboard {
        background: #ffffff !important; /* solid background for print */
        color: var(--text) !important;
    }

    /* Cards and text use print-safe colors */
    .card {
        background: var(--card) !important;
        color: var(--text) !important;
        border: 1px solid var(--border) !important;
        box-shadow: none !important;
        break-inside: avoid !important;
        page-break-inside: avoid !important;
    }

    /* KPI text should be visible */
    .kpi-label,
    .kpi-value,
    .row .value,
    .row .label {
        color: var(--text) !important;
        text-align:center;
    }


    /* Force dashboard title to be visible and styled for print */
    .dashboard-title {
        font-size: 1.8rem !important; /* Slightly larger for print */
        font-weight: 700 !important; /* Bold for emphasis */
        color: #111111 !important; /* Dark text for white paper */
        text-align: left !important; /* Keep alignment consistent */
        margin-bottom: 12px !important; /* Add spacing before content */
        background: transparent !important; /* Remove any dark background */
        -webkit-print-color-adjust: exact; /* Ensure color prints correctly    -webkit-print-color-adjust: exact;  /* Ensure color prints correctly */
        print-color-adjust: exact;
    }

}
    .dashboard .card:hover, .dashboard .kpi:hover {
        transform: translateY(-2px);
        transition: transform 200ms ease, box-shadow 220ms ease, border-color 220ms ease;
        box-shadow: 0 10px 28px color-mix(in srgb, var(--text) 8%, transparent);
        border-color: color-mix(in srgb, var(--border) 65%, var(--primary, #60a5fa));
    }
    .dashboard .row .value:hover {
        transform: translateY(-2px);
        transition: transform 200ms ease, box-shadow 220ms ease, border-color 220ms ease;
        font-weight: bolder;
    }


    /*Change */

    .change-chip {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        /* margin-left: 6px; */
        /* padding: 2px 6px; */
        font-size: 0.78rem;
        /* border-radius: 999px; */
        /* border: 1px solid var(--border); */
        /* background: rgba(0, 0, 0, 0.06); */
        white-space: nowrap;
    }

/* Color logic: configure what "up" means */
.change-up {
  color: var(--import);            /* green tone */
/*  border-color: var(--import);
  background: var(--import-weak);*/
}
.change-down {
  color: #ef4444;                  /* red tone */
/*  border-color: #ef4444;
  background: rgba(239,68,68,0.12);*/
}
.change-flat {
  color: var(--muted);
/*  border-color: var(--border);
  background: rgba(0,0,0,0.04);*/
}

/* Optional micro-animation on change */
.change-chip {
  animation: chip-pop 280ms ease;
}
@@keyframes chip-pop {
  from { opacity: 0; transform: translateY(-2px) scale(0.98); }
  to   { opacity: 1; transform: translateY(0)    scale(1); }
}

/* Print: ensure chips show */
    @@media print {
        .change-chip {
            display: inline-flex !important;
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
        }
    }


    /*Header row*/

    /* Header Row Styling */
    .header-row {
        background-color: #f5f5f5; /* Light gray background for contrast */
        font-weight: bold; /* Bold text for emphasis */
        border-bottom: 2px solid #ddd; /* Separator line */
        /*padding: 8px 0;*/ /* Vertical padding */
   

    }
   

        .header-row .label {
            color: #333; /* Dark text for label */
            font-size: 14px;
            text-transform: uppercase; /* Optional: make 'Years' uppercase */
        }

        .header-row .value {
            text-align: center; /* Center align year labels */
            font-size: 13px;
            color: #555; /* Slightly muted text color */
            padding: 4px 8px; /* Spacing for readability */
        }

        /* Optional: Add pill styling for 'Years' */
        .header-row .pill {
            background-color: #007bff; /* Blue pill background */
            color: #fff; /* White text */
            padding: 4px 10px;
            border-radius: 12px;
            font-size: 12px;
        }

    .border-radius-bottom-right-left-0 {
        border-radius: 10px 10px 0px 0px;
    }


    .border-radius-top-right-left-0 {
        border-radius: 0px 0px 10px 10px;
    }

</style>



<div ng-controller="AuctionCntrCtrl" ng-cloak class="ng-cloak AuctionContainerExamDashboardPage" ng-init="GetAuctionDashboardData()">
    <div class="page-header border-bottom-0 blur">
        <div class="page-header-content header-elements-md-inline">
            <div class="page-title d-flex align-items-center w-100">
