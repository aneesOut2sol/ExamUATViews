
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Step Progress Bar</title>
    <style>


        .progress-container {
            display: flex;
            justify-content: space-between;
            align-items: center;
            width: 100%;
            margin: 10px auto;
            position: relative;
            background: #fff;
            border-radius: 10px;
            padding: 20px;
            box-shadow: inset -2px -2px 4px #808080a1;
        }

        .progress-bar {
            position: absolute;
            top: 50%;
            left: 0;
            width: 100%;
            height: 5px;
            background: #e0e0e0;
            z-index: 1;
        }

        .progress-bar-fill {
            height: 5px;
            background: #4caf50;
            width: 0%;
            transition: width 0.5s ease;
            z-index: 2;
        }

        .step {
            position: relative;
            z-index: 3;
            background: #e0e0e0;
            color: #333;
            border-radius: 50%;
            width: 30px;
            height: 30px;
            display: flex;
            justify-content: center;
            align-items: center;
            font-weight: bold;
            transition: background 0.5s ease, color 0.5s ease;
            margin-left: 30px;
        }

            .step.active {
                background: #4caf50;
                color: white;
            }

        .step-label {
            margin-top: 10px;
            font-size: 14px;
        }
    </style>
</head>
<body>

   
    <div class="progress-container">
        <div class="step-container">
            <div class="step" id="step-1">1</div>
            <div class="step-label">Fetching Data</div>
        </div>
        <div class="step-container">
            <div class="step" id="step-2">2</div>
            <div class="step-label">Validating Data</div>
        </div>
        <div class="step-container">
            <div class="step" id="step-3">3</div>
            <div class="step-label">Generating Invoice</div>
        </div>
        <div class="step-container">
            <div class="step" id="step-4">4</div>
            <div class="step-label">Completed</div>
        </div>
        <div class="progress-bar">
            <div class="progress-bar-fill" id="progress-bar-fill"></div>
        </div>
    </div>

    <button class="d-none" id="ProgressBarBtn" onclick="nextStep()">Next Step</button>

    <script>
    let currentStep = 0;
    const steps = document.querySelectorAll('.step');
    const progressBarFill = document.getElementById('progress-bar-fill');

        function nextStep(isreset) {
            if (isreset != undefined) {
                currentStep = 0;
                return;
            }
        if (currentStep < steps.length) {
            steps[currentStep].classList.add('active');
            progressBarFill.style.width = `${((currentStep + 1) / steps.length) * 100}%`;
            currentStep++;
        }
    }
    </script>

</body>
</html>
