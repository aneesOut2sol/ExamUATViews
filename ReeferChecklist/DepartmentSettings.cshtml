
@{
    ViewBag.Title = "DepartmentSettings";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    @@font-face {
        font-family: 'pilatwide-light';
        src: url('../../content/dpwfont/pilatwide-light.ttf') format('truetype');
    }
    @@font-face {
        font-family: 'pilatwide-heavy';
        src: url('../../content/dpwfont/pilatwide-heavy.ttf') format('truetype');
    }
    @@font-face {
        font-family: 'pilatwide-regular';
        src: url('../../content/dpwfont/pilatwide-regular.ttf') format('truetype');
    }
    .reeeferSetting * {
        font-family: 'pilatwide-regular';
    }
</style>


<link href="~/Scripts/SlimSelect/SlimSelectCustomStyle.css" rel="stylesheet" />
<link href="~/Scripts/SlimSelect/slimselect.min.css" rel="stylesheet" />
<script src="~/Scripts/SlimSelect/slimselect.min.js"></script>
<div ng-controller="ReeferChecklistCtrl" class="ng-cloak reeeferSetting" ng-cloak ng-init="SettingsInit()">
    <br />
    <div class="card shadow-sm">
        <div class="card-body row">
            <div class="col-md-6">
                <h3 style="font-family: 'pilatwide-heavy' ">Reefer checklist department setting</h3>
            </div>
            <div class="col-md-6">
                <input type="button" class="btn btn-secondary  pull-right" value="Filters" data-toggle="collapse" data-target="#demo" />
                <input type="button" id="AddDepartmentCollapseBtnID" class="btn btn-primary  pull-right mr-2" value="Add Email" data-toggle="collapse" data-target="#AddDepartmentCollapse" />
                <input type="button" id="AddDepartmentCollapseBtnID" class="btn btn-primary  pull-right mr-2" value="Add Department" ng-click="AddDepartment()" />
                <input type="hidden" id="EditDepartmentCollapseBtnID" class="btn btn-secondary  pull-right" value="Edit" data-toggle="collapse" data-target="#EditDepartmentCollapse" />
            </div>
        </div>
    </div>

    <div id="collapseGroup">


        <!--Search Filter Code Start-->
        <div class="card collapse" id="demo" data-parent="#collapseGroup">
            <h3 class="card-header" style="background-color:var( --dpw-bg-color) !important; color:#fff; padding:10px;">
                Filters
            </h3>
            <div class="card-body row pt-3">
                <div class="col-md-3">
                    <div class="form-group">
                        <label>Department</label>
                        <select data-placeholder="Department" class="form-control select-clear" id="FilterDD" ng-model="Departmentsearch.Department" aria-label="Default select example">
                            <option></option>
                            <option ng-repeat="d in  DepartmentList" value="{{d.Department}}">{{d.Department}}</option>
                        </select>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="form-group">
                        <label>Email</label>
                        <input type="text" class="form-control" placeholder="Department Email" ng-model="Departmentsearch.Email" />
                    </div>
                </div>
            </div>
        </div>
        <!--Search Filter Code End-->
        <!--Add Department Email Code Start-->
        <div class="card collapse" id="AddDepartmentCollapse" data-parent="#collapseGroup">
            <h3 class="card-header" style="background-color:var( --dpw-bg-color) !important; color:#fff; padding:10px;">
                Add Department Email
            </h3>
            <div class="card-body row pt-3">
                <div class="col-md-3">
                    <div class="form-group">
                        <label>Department</label>
                        <select data-placeholder="Department" class="form-control select-clear" id="AddDD" ng-model="Opr.Department" aria-label="Default select example">
                            <option></option>
                            <option ng-repeat="d in  DepartmentList" value="{{d.Department}}">{{d.Department}}</option>
                        </select>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="form-group">
                        <label>Email</label>
                        <input type="text" class="form-control" placeholder="Department Email" ng-model="Opr.Email" />
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="form-group">
                        <button class="btn btn-primary mt-3" ng-click="AddDepartmentEmail(Opr)">Add</button>
                    </div>
                </div>
            </div>
        </div>
        <!--Add Department Email Code End-->
        <!--Edit Department Email Code Start-->
        <div class="card collapse" id="EditDepartmentCollapse" data-parent="#collapseGroup">
            <h3 class="card-header" style="background-color:var( --dpw-bg-color) !important; color:#fff; padding:10px;">
                Update Department Email
            </h3>
            <div class="card-body row pt-3">
                <div class="col-md-3">
                    <div class="form-group">
                        <label>Department</label>
                        <input type="text" readonly class="form-control" ng-model="EditDepartmentRecord.Department" />
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="form-group">
                        <label>Email</label>
                        <input type="text" class="form-control" placeholder="Department Email" ng-model="EditDepartmentRecord.Email" />
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="form-group">
                        <button class="btn btn-primary mt-3" ng-click="UpdateDepartmentEmail(EditDepartmentRecord)">Update</button>
                    </div>
                </div>
            </div>
        </div>
        <!--Edit Department Email Code End-->
    </div>

    <div id="tblrep" class="card table-card scrollbar">
        <table class="table datatable-show-all text-center" id="table-id2">
            <thead>
                <tr class="table-card-head">
                    <th>SR#</th>
                    <th>Department</th>
                    <th>Email</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                <tr ng-repeat="row in GridArr | filter:Departmentsearch">
                    <td>{{$index+1}}</td>
                    <td>{{row.Department}}</td>
                    <td>{{row.Email}}</td>
                    <td><span ng-click="EditDepartmentEmail(row.Id,row.Email)"><i class="icon-pencil7" title="Edit"></i></span></td>
                </tr>
            </tbody>
        </table>
    </div>


</div>

<script src="@Url.Content("~/Scripts/crypto-js.min.js")"></script>
<script src="~/Scripts/jquery.min.js"></script>
<script>

    //Hide Side Menu
    window.onload = function () {
        document.getElementById('minisidebar').className = 'sidebar-xs';
    };
    $(document).ready(function () {
        var z = new SlimSelect({
            select: '#FilterDD',
            placeholder: 'Select Department',
            showSearch: true,
            allowDeselect: true,
        });

        var ze = new SlimSelect({
            select: '#AddDD',
            placeholder: 'Select Department',
            showSearch: true,
            allowDeselect: true,
        });
        //var z1 = new SlimSelect({
        //    select: '#UpdateDD',
        //    placeholder: 'Select Department',
        //    showSearch: true,
        //    allowDeselect: true,
        //});
    });

  
    

    var element = document.getElementById('ReeferService');
    element.classList.add("active");

</script>

