@model ExamPortal.Model.Features.AcitvityCapture.ReeferChecklist.getsubmittedCheckListResponse
@{
    Layout = null;
}

<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Reefer Module CE Inspection Checklist</title>
    <style>

        @@font-face {
            font-family: 'Lato';
            font-style: normal;
            font-weight: 400;
            src: local('Lato Regular'), local('Lato-Regular'), url(https://fonts.gstatic.com/s/lato/v11/qIIYRU-oROkIk8vfvxw6QvesZW2xOQ-xsNqO47m55DA.woff) format('woff');
        }

        @@font-face {
            font-family: 'Lato';
            font-style: normal;
            font-weight: 700;
            src: local('Lato Bold'), local('Lato-Bold'), url(https://fonts.gstatic.com/s/lato/v11/qdgUG4U09HnJwhYI-uK18wLUuEpTyoUstqEm5AMlJo4.woff) format('woff');
        }

        @@font-face {
            font-family: 'Lato';
            font-style: italic;
            font-weight: 400;
            src: local('Lato Italic'), local('Lato-Italic'), url(https://fonts.gstatic.com/s/lato/v11/RYyZNoeFgb0l7W3Vu1aSWOvvDin1pK8aKteLpeZ5c0A.woff) format('woff');
        }

        @@font-face {
            font-family: 'Lato';
            font-style: italic;
            font-weight: 700;
            src: local('Lato Bold Italic'), local('Lato-BoldItalic'), url(https://fonts.gstatic.com/s/lato/v11/HkF_qI1x_noxlxhrhMQYELO3LdcAZYWl9Si6vvxL-qU.woff) format('woff');
        }


        * {
            font-family: 'Lato';
            font-style: normal;
            font-weight: 400;
        }

        @@font-face {
            font-family: 'pilatwide-demibold';
            src: url('../../content/dpwfont/pilatwide-demibold.ttf') format('truetype');
        }

        @@font-face {
            font-family: 'pilatwide-black';
            src: url('../../content/dpwfont/pilatwide-black.ttf') format('truetype');
        }

        @@font-face {
            font-family: 'pilatwide-bold';
            src: url('../../content/dpwfont/pilatwide-bold.ttf') format('truetype');
        }

        @@font-face {
            font-family: 'pilatwide-book';
            src: url('../../content/dpwfont/pilatwide-book.ttf') format('truetype');
        }

        @@font-face {
            font-family: 'pilatwide-heavy';
            src: url('../../content/dpwfont/pilatwide-heavy.ttf') format('truetype');
        }

        @@font-face {
            font-family: 'pilatwide-regular';
            src: url('../../content/dpwfont/pilatwide-regular.ttf') format('truetype');
        }

        table {
            border-collapse: collapse;
            width: 100%;
        }

        .header img {
            height: 40px;
        }

        .header p {
            font-family: 'pilatwide-heavy';
            font-weight: bold;
            font-size: 24px;
            color: var( --dpw-bg-color);
        }

        .header-content {
            font-family: 'pilatwide-regular';
            border: 1px solid var( --dpw-bg-color);
            padding: 0;
        }

            .header-content th {
                width: 20%;
                background: var( --dpw-bg-color);
                color: #fff;
                padding: 7px 12px;
                border: 1px solid #333;
                text-align: left;
            }

            .header-content td {
                width: 30%;
                color: var( --dpw-bg-color);
                border: 1px solid #333;
            }

        .w-50 {
            width: 50% !important;
        }

        .w-10 {
            width: 10% !important;
        }

        .w-30 {
            width: 30% !important;
        }
        .w-40 {
            width: 40% !important;
        }

        .bodycontent {
            font-family: 'pilatwide-regular';
            border: 1px solid var( --dpw-bg-color);
            padding: 0;
        }

            .bodycontent th {
                background: var( --dpw-bg-color);
                color: #fff;
                padding: 7px;
                border: 1px solid #333;
            }

            .bodycontent td {
                color: var( --dpw-bg-color);
                border: 1px solid #333;
            }

        input[type="radio"] {
            transform: scale(1.5);
        }

            input[type="radio"]:checked {
                accent-color: var( --dpw-bg-color); /* Change color when checked */
            }

        .text-center {
            text-align: center;
        }
        .bodycontent tbody {
            font-family: 'pilatwide-regular';
            font-size:14px;
        }
        .bodycontent td {
            padding:3px 5px;
        }
        .p-0{
            padding:0 !important;
        }
        .border-bottom-dashed {
            border-bottom: 1px dashed var( --dpw-bg-color);
        }
        .h-20{
            height:25px;
        }
        .border-none{
            border:none !important;
        }
        .eye-icon {
            width: 20px;
            height: 20px;
            color: #1E1450; /* Green color */
        }
    </style>

</head>
<body>
    @if (Model != null && Model.Data != null && Model.Data.Count > 0)
    {


        <table class="header">
            <tr>
                <th><p>Reefer Module CE Inspection Checklist</p></th>
                <td>
                    <img src="~/Content/images/dpworldlogo.png" />
                </td>
            </tr>
        </table>
        <table class="header-content">
            <tr>
                <th>Date:</th>
                <td>@Model.Data[0].CheckinTime.Value.ToString("dd/MM/yyyy HH:mm:ss.fff")</td>
                <th>Name/ID:</th>
                <td>@Model.Data[0].CheckinBy</td>
            </tr>
            <tr>
                <th>Department:</th>
                <td>@Model.Data[0].Department</td>
                <th>Module No:</th>
                <td>@Model.Data[0].Module</td>
            </tr>
        </table>
        <table class="bodycontent">
            <thead>
                <tr>
                    <th class="w-50">Item</th>
                    <th class="w-10">Y</th>
                    <th class="w-10">N</th>
                    <th class="w-30">Remarks</th>
                    <th class="w-30">Attachment</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Data[0].data)
                {
                    <tr>
                        <td>@item.ReeferItem</td>

                        <td class="text-center">
                            @if (item.Action == true)
                            {
                                <input type="radio" checked />
                            }
                        </td>
                        <td class="text-center">
                            @if (item.Action == false || item.Action == null)
                            {
                                <input type="radio" checked />
                            }
                        </td>
                        <td>@item.Remarks</td>
                        <td class="text-center">
                            @if (item.Attachments.Any())
                            {
                                foreach (var attach in item.Attachments)
                                {
                                    <a href="@attach" target="_blank">
                                        <svg xmlns="http://www.w3.org/2000/svg" class="eye-icon" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                                            <circle cx="12" cy="12" r="3"></circle>
                                        </svg>
                                    </a>
                                }
                            }

                        </td>
                    </tr>
                }
                <tr>
                    <td colspan="4" class="p-0 border-none">
                        <table class="p-0">
                            <tr class="border-none">
                                <td class="border-none"><b class="font-family: 'pilatwide-heavy'">Comments:</b></td>
                            </tr>
                            <tr>
                                <td class="border-none">
                                    <div class="border-bottom-dashed h-20"></div>
                                    <div class="border-bottom-dashed h-20"></div>
                                    <div class="border-bottom-dashed h-20"></div>
                                    <div class="border-bottom-dashed h-20"></div>
                                    <div class="h-20"></div>
                                </td>
                            </tr>
                            
                        </table>
                    </td>
                </tr>
            </tbody>
        </table>
        <br />
        <table class="border-none">
            <tr>
                <td class="w-30 border-none"></td>
                <td class="w-40 border-none text-center">
                    <div>
                        <b><u>CE Sr. Supervisor Signature</u></b>
                    </div>
                    <div class="border-bottom-dashed h-20 "></div>
                </td>
                <td class="w-30 border-none"></td>
            </tr>
        </table>

    }
    else
    {
        <div>
            <h1 style="color: red; font-family: 'pilatwide-heavy';">No Record found!</h1>
        </div>
    }
</body>
</html>
