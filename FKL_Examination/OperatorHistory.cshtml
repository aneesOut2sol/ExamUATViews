
@{
    ViewBag.Title = "OperatorHistory";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<link href="~/Content/BootsrapDatetime/icon.css" rel="stylesheet" />
<link href="~/Content/BootsrapDatetime/bootstrap-material-datetimepicker.css" rel="stylesheet" />
<link href="~/Content/BootsrapDatetime/css.css" rel="stylesheet" />

<script src="~/Scripts/jquery.min.js"></script>
@*<script src="~/Content/BootsrapDatetime/ripples.min.js"></script>
    <script src="~/Content/BootsrapDatetime/material.min.js"></script>*@

<script src="~/Scripts/js/plugins/moment/moment_locales.min.js"></script>
@*<script src="~/Content/BootsrapDatetime/bootstrap-material-datetimepicker.js"></script>*@


<link href="~/Scripts/DatePicker/bootstrap-datepicker.css" rel="stylesheet" />
<link href="~/Scripts/DatePicker/bootstrap-datepicker.standalone.css" rel="stylesheet" />
<script src="~/Scripts/DatePicker/bootstrap-datepicker.js"></script>


<script src="~/Content/BootsrapDatetime/ripples.min.js"></script>
<script src="~/Content/BootsrapDatetime/material.min.js"></script>

<script src="~/Content/BootsrapDatetime/bootstrap-material-datetimepicker.js"></script>
<style>
    .modal-body {
        max-height: 70vh !important;
        overflow: auto !important;
    }

    .badge-Queued {
        background: var( --dpw-bg-color);
    }

    .table .table td, .table th {
        border-color: black !important;
    }

    .modal-content {
        background-color: #f4f2fa !important;
        border-radius: 16px !important;
        box-shadow: 0 2.8px 2.2px rgb(0 0 0 / 3%), 0 6.7px 5.3px rgb(0 0 0 / 5%), 0 12.5px 10px rgb(0 0 0 / 6%), 0 22.3px 17.9px rgb(0 0 0 / 7%), 0 41.8px 33.4px rgb(255 255 255 / 9%), 0 100px 80px rgb(255 255 255 / 12%);
    }

    .modal-header {
        text-align: center;
        border-bottom: none !important;
        justify-content: center !important;
    }

    .CloseModalBtn {
        color: #FFFFFF;
        line-height: 25px;
        position: absolute;
        right: -12px;
        z-index: 99999999999 !important;
        text-align: center;
        top: -10px;
        width: 45px;
        text-decoration: none;
        font-weight: bold;
        box-shadow: 1px 1px 3px #000;
        transition: all .3s;
        height: 45px;
        border-radius: 50%;
        font-size: 25px !important;
        padding: 8px;
        cursor: pointer;
        background: var( --dpw-bg-color);
        z-index: 99999999999 !important;
    }

    .modal-body {
        max-height: 60vh !important;
        overflow: auto !important;
    }

    .close {
        display: none;
    }

    .CloseModalBtn .fa-times-circle-o {
        color: #ffff !important;
    }

    .modal-title {
        font-weight: bolder !important;
        font-size: 24px;
        padding-top: 12px;
        padding-bottom: 4px;
        display: inline-block;
    }

    .modal-footer {
        border-top: none !important;
        align-content: center;
        text-align: center;
    }

    .Capture-Card {
        background: #ebebeb;
        padding: 11px 18px;
        box-shadow: 1px 1px 2px 1px #80808042 inset;
        border-radius: 4px;
        margin-bottom: 17px;
    }

    .Capture-CardFlex {
        display: flex;
        justify-content: space-between;
        flex-wrap: wrap;
        align-items: center;
    }

    .Laborbadge {
        font-size: 12px;
        padding: 4px 8px;
        color: white;
        font-weight: normal !important;
        border-radius: 3px;
        width: fit-content;
    }

    .badge-Assigned {
        background: #0094d7;
    }

    .badge-POWOUT, .badge-POWIN {
        background: #616161;
    }

    .badge-Working, .badge-Inprogress {
        background: var( --dpw-bg-color);
    }


    .badge-Reached {
        background: #ff5b00;
    }

    .ContainerTab {
        padding: 12px 17px;
        background: #ffffff;
        border-radius: 6px;
        box-shadow: 1px 1px 8px 0px #5353535e;
        border: 1px dashed;
    }

        .ContainerTab div {
            padding: 2px 1px;
        }

    .details {
        color: gray;
    }

    .tab button {
        border-top-right-radius: 10px;
        border-top-left-radius: 10px;
        background: #e9e9e9;
        padding: 15px;
        border: none;
        outline: none;
        cursor: pointer;
        transition: 0.3s;
        font-size: 13px;
    }

    .CardHeaderLink {
        display: inline-block;
        margin-right: 10px;
    }

    .tab button.active {
        background-color: #00946b;
        color: white;
        font-size: 13px;
    }

    .badge-Strip {
        background: #7d8800 !important;
    }

    .badge-Repack {
        background: #a10088 !important;
    }
</style>
<div class="ng-cloak" ng-cloak ng-controller="FKL_HistoryCtrl" ng-init="OperatorInit()">
    <!-- Page header -->
    <div class="page-header border-bottom-0">
        <div class="page-header-content header-elements-md-inline">
            <div class="page-title d-flex">
                <h4><i class="icon-stack-text mr-2"></i><span class="font-weight-semibold">Operator History</span></h4>
                <a href="#" class="header-elements-toggle text-default d-md-none"><i class="icon-more"></i></a>
            </div>
            <div class="page-title d-flex">

            </div>
        </div>
    </div><hr />
    <div class="row">
        <div class="col-md-12">
            <!--Tab Code Start -->
            <div class="tab">
                <div class="row">
                    <div class="col-md-4">
                        <div class="CardHeaderLink shadow-sm text-center ">
                            <button ng-class="{'active':StatusCompleted==true}" ng-click="ResetFilter(true)" class="tablinks"><i class="icon-file-check mr-2"></i> Completed</button>
                        </div>
                        <div class="CardHeaderLink shadow-sm text-center ">
                            <button ng-class="{'active':StatusCompleted==false}" ng-click="ResetFilter(false)" class="tablinks"><i class="icon-history"></i> Inprogress</button>
                        </div>
                    </div>
                    <div class="col-md-8 text-end">
                        <div class="">
                            <input type="button" class="btn btn-secondary  pull-right mt-2" value="Filters" data-toggle="collapse" data-target="#demo" />
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!--Tab Code End -->
    </div>
    <hr />
    <div class="card collapse" id="demo">
        <div class="card-body">
            <div class="col-md-12">
                <div class="row">
                    <div class="col-md-4">
                        <div class="form-group">
                            <label>Container #</label>
                            <input type="text" maxlength="200" min="1" class="form-control" placeholder="Search Container.." ng-model="Search.Cntr" />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label>Activity</label>
                            <select ng-model="Search.Activity" id="FilterActivity" class="form-control select-clear">
                                <option value="" selected disabled hidden>Select activity</option>
                                <option ng-selected="Search.Activity=='Repack'" value="Repack">Repack</option>
                                <option ng-selected="Search.Activity=='Strip'" value="Strip">Strip</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label>Forklift</label>
                            <select class="form-control select-clear" id="FilterForklift" ng-model="Search.ForkliftId">
                                <option value="" selected disabled hidden>Select forklift</option>
                                <option ng-repeat=" x in ForkliftList" ng-selected="Search.ForkliftId==x.Id" value="{{x.Id}}">{{x.Name}}-{{x.Number}}</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label>Operator</label>
                            <select class="form-control select-clear" id="FilterEMPId" ng-model="Search.EMPId">
                                <option value="" selected disabled hidden>Select operator</option>
                                <option ng-repeat=" x in OperatorList" ng-selected="Search.EMPId==x.EMPId" value="{{x.EMPId}}">{{x.EMPId}}-{{x.Name}}</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label>From Date</label>
                            <div class="input-group">
                                <input type="text" class="form-control date" id="FromDate" placeholder="DD/MM/YYYY HH:mm">
                                <span class="input-group-append">
                                    <span class="input-group-text"><i class="icon-calendar"></i></span>
                                </span>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-4">
                        <div class="form-group">
                            <label>To Date</label>
                            <div class="input-group">
                                <input type="text" class="form-control date" id="ToDate" placeholder="DD/MM/YYYY HH:mm">
                                <span class="input-group-append">
                                    <span class="input-group-text"><i class="icon-calendar"></i></span>
                                </span>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-12 mt-3" style="text-align:end;">
                        <button class="btn btn-success pull-right mr-2" ng-click="SearchFilter()">Search</button>
                        <button class="btn btn-primary pull-right mr-2" ng-click="ResetFilter(StatusCompleted)">Clear</button>
                    </div>
                </div>

            </div>
        </div>
    </div>


    <br />
    <div class="row accordion" id="acc">
        <div class="col-md-12 Capture-Card" ng-repeat="x in OperatorList">
            <div class="Capture-CardFlex" data-toggle="collapse" data-target="#col{{x.EMPId}}" ng-click="OpenCollapse(x.EMPId,x,$index)">
                <div class="mr-3"><img src="~/Content/images/LabourIcon.png" style="height: 49px;" /></div>
                <div style=" font-size: 14px; font-weight: 500;" data-togle="collapse">{{x.EMPId}} - {{x.Name}}</div>
                <div class="ml-auto">
                    <span>
                        <i ng-show="CurrentEMPId!=x.EMPId" class="icon-chevron-down"></i>
                        <i ng-show="CurrentEMPId==x.EMPId" class="icon-chevron-up"></i>
                    </span>

                </div>
            </div>
            <div class="collapse mt-3" data-parent="#acc" id="col{{x.EMPId}}">
                <div class="row">
                    <div class="col-md-4" ng-repeat="y in ConatinerList">
                        <div class="ContainerTab">
                            <div>
                                <b>{{y.Cntr}}</b>
                                <span title="Activity" ng-class="y.Activity == 'Strip' ? 'badge-Strip' : 'badge-Repack'" class="Laborbadge mr-2 pull-right">{{y.Activity}}</span>
                                <span title="Activity Status" class=" pull-right mr-2 Laborbadge badge-{{y.Status}}">{{y.Status}}</span>
                            </div>
                            <div class="details"><span>{{y.Location}}</span></div>
                            <div class="details">
                                {{y.JobDate | date:'dd-MM-yyyy HH:mm:ss'}}
                                <span class="pull-right" style=" color: black;" ng-click="OpenContainerDetails(y.ActivityId)"><i class="icon-info22"></i></span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
    @Html.Partial("~/Views/ActivityCapture/_InspDelay.cshtml")
    <!-- CntrDetails-->
    <div class="modal fade" id="ContainerDetails" tabindex="-1" role="dialog" data-backdrop="static" data-keyboard="false" aria-labelledby="exampleModalCenterTitle" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered" role="document" style="max-width:1000px;">
            <div class="modal-content">
                <div class="CloseModalBtn" data-dismiss="modal" aria-label="Close">
                    <button class="close" data-dismiss="modal" aria-label="Close"></button>
                    <i class="icon-cross"></i>
                </div>
                <div class="modal-header">
                    <h5 class="modal-title">{{ContainerDetails.Cntr}} <span class="pull-right ml-2" ng-click="OpenPrint(ContainerDetails.ActivityId)"><i class="icon-file-pdf"></i></span></h5>
                </div>
                <div class="modal-body">
                    <div class="container-fluid mt-3">
                        <!-- Container Details -->
                        <h6 class="mb-2 border-bottom pb-1">Container Details</h6>
                        <table class="table table-sm table-bordered mb-3">
                            <tbody>
                                <tr>
                                    <th style="width: 160px;">Container</th>
                                    <td>{{ContainerDetails.Cntr}}</td>
                                    <th style="width: 160px;">Location</th>
                                    <td>{{ContainerDetails.Location}}</td>
                                </tr>
                                <tr>
                                    <th>Activity Status</th>
                                    <td>
                                        <span class="Laborbadge badge-{{ContainerDetails.ActivityStatus}}">{{ContainerDetails.ActivityStatus}}</span>
                                    </td>
                                    <th>Activity</th>
                                    <td>{{ContainerDetails.Activity}}</td>
                                </tr>
                                <tr>
                                    <th>Activity Start Time</th>
                                    <td>{{(ContainerDetails.ActivityStartTime | date:'dd/MM/yyyy HH:mm:ss') || 'N/A'}}</td>
                                    <th>Activity End Time</th>
                                    <td>{{(ContainerDetails.ActivityEndTime | date:'dd/MM/yyyy HH:mm:ss') || 'N/A'}}</td>
                                </tr>
                                <tr>
                                    <th>Estimated Duration</th>
                                    <td>{{(ContainerDetails.ETA == ':' ? 'N/A' : ContainerDetails.ETA) || 'N/A'}}</td>
                                    <th>Actual Duration</th>
                                    <td>{{getTimeDifference(ContainerDetails.ActivityStartTime, ContainerDetails.ActivityEndTime) || 'N/A'}}</td>
                                </tr>
                            </tbody>
                        </table>

                        <!-- Operator Details -->
                        <h3 class="mb-2 border-bottom pb-1">Operator Details</h3>
                        <table class="table table-sm table-bordered">
                            <tbody>
                                <tr class="">
                                    <th colspan="4"><b>{{ContainerDetails.OperatorDatails.EMPId}} - {{ContainerDetails.OperatorDatails.Name}}</b></th>
                                </tr>
                                <tr>
                                    <th style="width: 160px;">Punch in Time</th>
                                    <td>{{(ContainerDetails.OperatorDatails.PunchInTime | date:'dd/MM/yyyy HH:mm:ss') || 'N/A'}}</td>
                                    <th>Status</th>
                                    <td>
                                        <span class="Laborbadge badge badge-{{ContainerDetails.OperatorDatails.Status}}">{{ContainerDetails.OperatorDatails.Status}}</span>
                                    </td>
                                </tr>
                                <tr>
                                    <th>Assigned at</th>
                                    <td>{{(ContainerDetails.OperatorDatails.AssignedAt | date:'dd/MM/yyyy HH:mm:ss') || 'N/A'}}</td>
                                    <th>Reached location at</th>
                                    <td>{{(ContainerDetails.OperatorDatails.ReachedLocationTime | date:'dd/MM/yyyy HH:mm:ss') || 'N/A'}}</td>
                                </tr>
                                <tr>
                                    <th>Drop by</th>
                                    <td>{{ContainerDetails.OperatorDatails.DropBy || 'N/A'}}</td>
                                    <th>Forklift number</th>
                                    <td>{{ContainerDetails.OperatorDatails.ForkLift_Number || 'N/A'}}</td>
                                </tr>
                                <tr>
                                    <th>POW in time</th>
                                    <td>{{(ContainerDetails.OperatorDatails.PowinTime | date:'dd/MM/yyyy HH:mm:ss') || 'N/A'}}</td>
                                    <th>Pow Out Time</th>
                                    <td>{{(ContainerDetails.OperatorDatails.PowoutTime | date:'dd/MM/yyyy HH:mm:ss') || 'N/A'}}</td>
                                </tr>
                                <tr>
                                    <th>POW in longitude</th>
                                    <td>{{ContainerDetails.OperatorDatails.PowInLongitude || 'N/A'}}</td>
                                    <th>POW in latitude</th>
                                    <td>{{ContainerDetails.OperatorDatails.PowInLatitude || 'N/A'}}</td>
                                </tr>
                                <tr>
                                    <th>POW out longitude</th>
                                    <td>{{ContainerDetails.OperatorDatails.PowOutLongitude || 'N/A'}}</td>
                                    <th>POW out latitude</th>
                                    <td>{{ContainerDetails.OperatorDatails.PowOutLatitude || 'N/A'}}</td>
                                </tr>
                                <tr>
                                    <th>Activity start time</th>
                                    <td>{{(ContainerDetails.OperatorDatails.LaborStartTime | date:'dd/MM/yyyy HH:mm:ss') || 'N/A'}}</td>
                                    <th>Activity end time</th>
                                    <td>{{(ContainerDetails.OperatorDatails.LaborEndTime | date:'dd/MM/yyyy HH:mm:ss') || 'N/A'}}</td>
                                </tr>
                                <tr>
                                    <th>Checklist</th>
                                    <td>
                                        <span ng-show="ContainerDetails.OperatorDatails.CheckListSubmitted==true " ng-click="OpenCheckListReport(ContainerDetails.OperatorDatails.ForkliftSelectionId)"> <i class="icon-file-check"></i></span>
                                    </td>
                                    <th ng-show="StatusCompleted==true">Delays</th>
                                    <td>
                                        <span ng-show="ContainerDetails.OperatorDatails.Delays==true && StatusCompleted==true" ng-click="ViewDelaysDelays(ContainerDetails.Unitgkey,'ContainerDetails')"> <i class="icon-file-check"></i></span>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="modal-footer">
                    <div class="row">
                        <div class="col-md-12" style="text-align:center">

                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<script>

    $('.date').bootstrapMaterialDatePicker({
        format: 'DD/MM/YYYY HH:mm',
        //maxDate: maxdate,
        //  endDate: moment(new Date()).format('DD/MM/YYYY HH:mm'),
        switchOnClick: true,
        nowButton: true,
        //currentDate: moment(),
    });
</script>
<script src="~/Scripts/DatePicker/CustomIntilizeJS.js"></script>