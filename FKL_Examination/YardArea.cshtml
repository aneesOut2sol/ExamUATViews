
@{
    ViewBag.Title = "YardArea";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    .modal-body {
        max-height: 70vh !important;
        overflow: auto !important;
    }
    span.badge.badge-Active {
        background: #00946b;
        color: white;
    }

    span.badge.badge-InActive {
        background: #cd0202;
        color: white;
    }

    .header-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .add-button {
        background-color: var( --dpw-bg-color);
        color: white;
        padding: 8px 16px;
        border: none;
        border-radius: 4px;
    }

    .CloseModalBtn {
        color: #FFFFFF;
        line-height: 25px;
        position: absolute;
        right: -12px;
        z-index: 99999999999 !important;
        text-align: center;
        top: -10px;
        width: 45px;
        text-decoration: none;
        font-weight: bold;
        box-shadow: 1px 1px 3px #000;
        transition: all .3s;
        height: 45px;
        border-radius: 50%;
        font-size: 25px !important;
        padding: 8px;
        cursor: pointer;
        background: var( --dpw-bg-color);
        z-index: 99999999999 !important;
    }

    .close {
        display: none;
    }

    .CloseModalBtn .fa-times-circle-o {
        color: #ffff !important;
    }

    .modal-content {
        background-color: #f4f2fa !important;
        border-radius: 16px !important;
        box-shadow: 0 2.8px 2.2px rgb(0 0 0 / 3%), 0 6.7px 5.3px rgb(0 0 0 / 5%), 0 12.5px 10px rgb(0 0 0 / 6%), 0 22.3px 17.9px rgb(0 0 0 / 7%), 0 41.8px 33.4px rgb(255 255 255 / 9%), 0 100px 80px rgb(255 255 255 / 12%);
    }

    .modal-header {
        text-align: center;
        border-bottom: none !important;
        justify-content: center !important;
    }

    .modal-title {
        font-weight: bolder !important;
        font-size: 24px;
        padding-top: 12px;
        padding-bottom: 4px;
        display: inline-block;
    }

    .modal-footer {
        border-top: none !important;
        align-content: center;
        text-align: center;
    }
</style>
<script src="~/Scripts/jquery.min.js"></script>
<link href="~/Scripts/SlimSelect/SlimSelectCustomStyle.css" rel="stylesheet" />
<link href="~/Scripts/SlimSelect/slimselect.min.css" rel="stylesheet" />
<script src="~/Scripts/SlimSelect/slimselect.min.js"></script>
<div class="ng-cloak" ng-cloak ng-controller="FKL_YardSetupCtrl" ng-init="init()">
    <div class="card mt-2 d-flex">
        <div class="card-body">
            <div class="header-row">
                <h2>Yard Area</h2>
                <div>
                    <input type="button" class="btn btn-secondary" value="Filters" data-toggle="collapse" data-target="#demo" />
                    <button class="add-button" ng-click="OpenAddArea()"><i class="icon-add m-r-5 text-white"></i> Add</button>
                </div>
            </div>
        </div>
    </div>

    <!--Search Filter Code Start-->
    <div class="card collapse" id="demo">
        <div class="card-body">
            <div class="col-md-12">
                <div class="row">
                    <div class="col-md-3">
                        <div class="form-group">
                            <label>Name</label>
                            <input type="text" class="form-control" ng-model="Search.Name" placeholder="Enter name" />
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group">
                            <label>Block</label>
                            <select data-placeholder="Block" class="form-control select-clear" id="FilterBlockSelect" ng-model="SearchBlocks" multiple ng-change="FilterBlock(SearchBlocks)">
                                <option></option>
                                <option value="{{x.Id}}" ng-repeat="x in BlockList">{{x.Name}}</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-md-12 mt-4">
                        <button class="btn btn-secondary pull-right mr-2" ng-click="ClearSearch()">Clear</button>
                    </div>
                </div>
            </div>
        </div>
    </div>




    <div class="row">
        <div id="tblrep" class="card table-card scrollbar">
            <table class="table datatable-show-all text-center" id="table-id">
                <thead>
                    <tr class="table-card-head">
                        <th>SR#</th>
                        <th>Area</th>
                        <th>Area subdivision</th>
                        <th>Block</th>
                        <th>Created at</th>
                        <th>Created by</th>   
                        <th>Updated at</th>
                        <th>FL per Bay</th>
                        <th>Updated by</th>
                        <th>Action</th>

                    </tr>
                </thead>
                <tbody class="ng-cloak" ng-cloak>
                    <tr ng-repeat="item in AreaList | filter:Search">
                        <td>{{$index+1}}</td>
                        <td>{{item.MasterArea}}</td>
                        <td>{{item.Name}}</td>
                        <td>
                            <ul class="m-0" style="width:fit-content">
                                <li ng-repeat="z in item.Blocks" style="width:fit-content">
                                    {{z.Name}}
                                </li>
                            </ul>
                        </td>

                        <td>{{item.CreatedAt | date :'dd/MM/yyyy HH:mm:ss'}}</td>
                        <td>{{item.CreatedBy}}</td>
                        <td>{{item.UpdatedAt | date :'dd/MM/yyyy HH:mm:ss'}}</td>
                        <td>{{item.SameBay==true?'Single':'Multiple'}}</td>
                        <td>{{item.UpdatedBy}}</td>
                        <td>
                            <span ng-click="EditArea(item)"><i class="icon-pencil" title="Click to Update" ></i></span>
                            <span ng-click="DeletedArea(item)"><i class="icon-bin" title="Click to Delete" ></i></span>
                        </td>
                    </tr>

                </tbody>
            </table>
        </div>

    </div>
    <!--modal-->
    <div class="modal fade" id="AddArea" tabindex="-1" role="dialog" data-backdrop="static" data-keyboard="false" aria-labelledby="exampleModalCenterTitle" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable modal-dialog-centered" role="document">
            <div class="modal-content" style="overflow:visible !important">
                <div class="CloseModalBtn" data-dismiss="modal">
                    <button class="close" data-dismiss="modal" aria-label="Close"></button>
                    <i class="icon-cross"></i>
                </div>
                <div class="modal-header">
                    <h5 class="modal-title">Add Area</h5>
                </div>
                <div class="modal-body overflow-visible" style="overflow: visible !important;">
                    <div class="row">
                        <div class="col-md-12">
                            <div class=" form-group">
                                <label class="Starick">Area</label>
                                <select data-placeholder="Area" class="form-control select-clear" id="select_masterarea" ng-model="AreaObj.MasterArea">
                                    <option></option>
                                    <option selected hidden value="">Enter Area</option>
                                    <option value="{{x}}" ng-repeat="x in YardArea">{{x}}</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-12">
                            <div class=" form-group">
                                <label class="Starick">Area subdivison</label>
                                <input type="text" class="form-control" ng-model="AreaObj.Name" placeholder="Enter name" value="" />
                            </div>
                        </div>
                        <div class="col-md-12">
                            <div class=" form-group">
                                <label class="Starick">Block</label>
                                <select data-placeholder="Block" class="form-control select-clear" id="AddBlockSelect" ng-model="AreaObj.Blocks" multiple>
                                    <option></option>
                                    <option value="{{x.Id}}" ng-repeat="x in BlockList">{{x.Name}}</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-12">
                            <div class=" form-group">
                                <input type="checkbox" ng-model="AreaObj.SameBay"  />
                                <label class="Starick">One forklift should work on one bay</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <div class="row">
                        <div class="col-md-12" style="text-align:end;">
                            <button class="btn btn-success" ng-click="AddArea(AreaObj)">
                                Submit
                            </button>
                            <button class="btn btn-primary" data-dismiss="modal">Cancel</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="modal fade" id="EditArea" tabindex="-1" role="dialog" data-backdrop="static" data-keyboard="false" aria-labelledby="exampleModalCenterTitle" aria-hidden="true">
        <div class="modal-dialog modal-dialog-scrollable modal-dialog-centered" role="document">
            <div class="modal-content" style="overflow:visible !important">
                <div class="CloseModalBtn" data-dismiss="modal">
                    <button class="close" data-dismiss="modal" aria-label="Close"></button>
                    <i class="icon-cross"></i>
                </div>
                <div class="modal-header">
                    <h5 class="modal-title">Edit Area</h5>
                </div>
                <div class="modal-body overflow-visible" style="overflow: visible !important;">
                    <div class="row">
                        <div class="col-md-12">
                            <div class=" form-group">
                                <label class="Starick">Area</label>
                                <select data-placeholder="Area" class="form-control select-clear" id="select_masterarea_2" ng-model="EditAreaObj.MasterArea">
                                    <option></option>
                                    <option selected hidden value="">Enter Area</option>
                                    <option value="{{x}}" ng-selected="EditAreaObj.MasterArea==x" ng-repeat="x in YardArea">{{x}}</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-12">
                            <div class=" form-group">
                                <label class="Starick">Area subdivison</label>
                                <input type="text" class="form-control" ng-model="EditAreaObj.Name" placeholder="Enter name" value="" />
                            </div>
                        </div>
                        <div class="col-md-12">
                            <div class=" form-group">
                                <label class="Starick">Block</label>
                                <select data-placeholder="Block" class="form-control select-clear" id="EditBlockSelect" ng-model="EditAreaObj.Blocks" multiple>
                                    <option></option>
                                    <option value="{{x.Id}}" ng-repeat="x in BlockList" ng-selected="EditAreaObj.Blocks.includes(x.Id)">{{x.Name}}</option>
                                </select>

                            </div>
                        </div>
                        <div class="col-md-12">
                            <div class=" form-group">
                                <input type="checkbox" ng-model="EditAreaObj.SameBay" ng-checked="EditAreaObj.SameBay==true" />
                                <label class="Starick">One forklift should work on one bay</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <div class="row">
                        <div class="col-md-12" style="text-align:end;">
                            <button class="btn btn-success" ng-click="UpdateArea(EditAreaObj)">
                                Submit
                            </button>
                            <button class="btn btn-primary" data-dismiss="modal">Cancel</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!--modal-->


</div>
<script>
   
</script>

