
@{
    ViewBag.Title = "ActivityPrint";
    Layout = null;
}
<!DOCTYPE html>
@model  ExamPortal.Model.Features.FKL_Examinxation.Operator.History.ActivityNCheckList
@{
    var ActualDuration = Model.obj.ActivityStartTime.HasValue && Model.obj.ActivityEndTime.HasValue
? (Model.obj.ActivityEndTime.Value - Model.obj.ActivityStartTime.Value).ToString(@"hh\:mm\:ss")
: "N/A";
}
<html>
<head>

    <title>Activity Details</title>
    <link rel="icon" type="~/Content/images/favicon.ico" sizes="16x16" href="~/Content/images/favicon.ico">
    <style>

        .Laborbadge {
            font-size: 12px;
            padding: 4px 8px;
            color: white;
            font-weight: normal !important;
            border-radius: 3px;
        }

        .badge-Assigned {
            background: #0094d7;
        }

        .badge-POWOUT, .badge-Completed {
            background: #616161;
        }

        .badge-Working, .badge-Inprogress {
            background: var( --dpw-bg-color);
        }

        .badge-POWIN {
            background: green;
        }

        .badge-Reached {
            background: #ff5b00;
        }

        .heading-print {
            color: var( --dpw-bg-color);
            font-weight: bold;
        }

        .row {
            margin: 0px !important;
        }

        .badge {
            font-size: 15px;
            width: 90px;
        }

        body {
            background-color: white !important;
        }

        .table-striped tbody tr:nth-of-type(odd) {
            background-color: white !important;
        }

        .table {
            border-collapse: collapse;
            width: 100%;
            margin-bottom: 23px;
        }

            .table thead th {
                background: #e7e7e7 !important;
            }

            .table th {
                background: #e7e7e7 !important;
            }

            .table tbody td {
                font-weight: 500;
            }

        .badge-size {
            width: 70px;
            padding: 8px 6px 5px 7px;
        }

        .table-bordered td, .table-bordered th {
            border: 1px solid #979797 !important;
        }

        .badge-xs {
            font-size: 9px;
            -webkit-transform: translate(0, -2px);
            -ms-transform: translate(0, -2px);
            -o-transform: translate(0, -2px);
            transform: translate(0, -2px);
        }

        .badge-sm {
            -webkit-transform: translate(0, -2px);
            -ms-transform: translate(0, -2px);
            -o-transform: translate(0, -2px);
            transform: translate(0, -2px);
        }
        /*All Table Badges*/

        .badge-Completed {
            /*background-color: #2cb97c!important;*/
            background-color: #6c757d !important;
            text-transform: uppercase;
        }

        .badge-InProgress {
            background-color: #65becc !important;
            text-transform: uppercase;
        }

        .badge-OverDue {
            background-color: red !important;
            text-transform: uppercase;
        }

        .badge-News {
            background-color: #c776aa !important;
            text-transform: uppercase;
        }

        .badge-Closed {
            background-color: #463d32 !important;
            text-transform: uppercase;
        }

        .badge-Rejected {
            background-color: #dc3545 !important;
            text-transform: uppercase;
        }

        img {
            height: 80px;
            border: none;
        }

        @@font-face {
            font-family: 'AvenirLTStd-Book';
            src: url('../../fonts/AvenirLTStd-Book.otf') format('opentype');
        }

        @@font-face {
            font-family: 'AvenirLTStd-Medium';
            src: url('../../fonts/AvenirLTStd-Medium.otf') format('opentype');
        }

        @@font-face {
            font-family: 'AvenirLTStd-Roman';
            src: url('../../fonts/AvenirLTStd-Roman.otf') format('opentype');
        }

        /*h2 {
            font-family: AvenirLTStd-Medium !important;
        }*/

        .testRotate {
            transform: rotate(180deg);
            writing-mode: vertical-rl;
        }

        #StudyHeading {
            margin-left: 20px;
            margin-top: 70px;
        }

        #otherheading {
            margin-left: 20px;
        }


        .tblue {
            color: var( --dpw-bg-color) !important;
        }

        .thWidht tr th {
            width: 22% !important;
        }

        .thWidht tr td {
            width: 22% !important;
        }

        /*.pageBreak {
            page-break-after: always;
        }*/
        .pull-textleft {
            text-align: left;
        }

        .sectionHeadingh2 {
            /* padding: 10px 8px;*/
            text-transform: uppercase;
            color: red;
            font-weight: 600;
            margin: 0px !important;
        }

        th, td {
            padding: 5px !important
        }

        p {
            margin: 0px !important
        }

        @@media Print {
            .general {
                page-break-inside: avoid !important;
            }

                .general table tr td {
                    page-break-inside: avoid !important;
                }
        }
    </style>
</head>

<body>
    <div>
        <div class="row page-titles">
            <table class="table-bordered tblue table" style="border: 1px solid black;">
                <tr style="border: 1px solid black; text-align:center">
                    <td style="width:25%;text-align:center">

                        <img src="~/Content/images/dpworldlogo.png" style="height:70px;margin: 17px;" />
                    </td>
                    <td align="center" style="vertical-align:inherit">
                        <h1 class="tblue" style="font-size:30px">
                            <b>FOS Activity Report</b>
                            @*<b>
                                    Forklift Checklist @Model.obj.li.FirstOrDefault().ForkliftName -@Model.obj.li.FirstOrDefault().ForkliftNumber
                                </b>*@

                        </h1>
                    </td>
                </tr>
            </table>
        </div>
    </div>

    <div class="container-fluid mt-3">
        <!-- Container Details -->
        <!-- Operator Details -->
        <h3 class="mb-2 border-bottom pb-1">Container Details</h3>
        <table class="table table-sm table-bordered mb-3">
            <tbody>
                <tr>
                    <th style="width: 160px;">Container</th>
                    <td>@Model.obj.Cntr</td>
                    <th style="width: 160px;">Location</th>
                    <td>@Model.obj.Location</td>
                </tr>
                <tr>
                    <th>Activity Status</th>
                    <td>
                        <span class="Laborbadge badge-@Model.obj.ActivityStatus">@Model.obj.ActivityStatus</span>
                    </td>
                    <th>Activity</th>
                    <td>@Model.obj.Activity</td>
                </tr>
                <tr>
                    <th>Activity Start Time</th>
                    <td>
                        @if (Model.obj.ActivityStartTime != null)
                        {
                            @(Model.obj.ActivityStartTime.Value.ToString("dd/MM/yyyy HH:mm:ss"))
                        }
                        else
                        {
                            <span>N/A</span>
                        }
                    </td>
                    <th>Activity End Time</th>
                    <td>
                        @if (Model.obj.ActivityEndTime != null)
                        {
                            @(Model.obj.ActivityEndTime.Value.ToString("dd/MM/yyyy HH:mm:ss"))
                        }
                        else
                        {
                            <span>N/A</span>
                        }
                    </td>
                </tr>
                <tr>
                    <th>Estimated Duration</th>
                    <td>@(!string.IsNullOrWhiteSpace(Model.obj.ETA) && Model.obj.ETA != ":" ? Model.obj.ETA : "N/A")</td>
                    <th>Actual Duration</th>
                    <td>@(ActualDuration ?? "N/A")</td>
                </tr>
            </tbody>
        </table>

        <!-- Operator Details -->
        <h3 class="mb-2 border-bottom pb-1">Operator Details</h3>
        <table class="table table-sm table-bordered">
            <tbody>
                <tr>
                    <th colspan="4" style="text-align:start"><b>@Model.obj.OperatorDatails.EMPId - @Model.obj.OperatorDatails.Name</b></th>
                </tr>
                <tr>
                    <th style="width: 160px;">Punch in Time</th>
                    <td>
                        @if (Model.obj.OperatorDatails.PunchInTime != null)
                        {
                            @(Model.obj.OperatorDatails.PunchInTime.Value.ToString("dd/MM/yyyy HH:mm:ss"))
                        }
                        else
                        {
                            <span>N/A</span>
                        }
                    </td>
                    <th>Status</th>
                    <td>
                        <span class="Laborbadge badge-@Model.obj.OperatorDatails.Status">@Model.obj.OperatorDatails.Status</span>
                    </td>
                </tr>
                <tr>
                    <th>Assigned at</th>
                    <td>
                        @if (Model.obj.OperatorDatails.AssignedAt != null)
                        {
                            @(Model.obj.OperatorDatails.AssignedAt.Value.ToString("dd/MM/yyyy HH:mm:ss"))
                        }
                        else
                        {
                            <span>N/A</span>
                        }

                    </td>
                    <th>Reached location at</th>
                    <td>
                        @if (Model.obj.OperatorDatails.ReachedLocationTime != null)
                        {
                            @(Model.obj.OperatorDatails.ReachedLocationTime.Value.ToString("dd/MM/yyyy HH:mm:ss"))
                        }
                        else
                        {
                            <span>N/A</span>
                        }

                    </td>
                </tr>
                <tr>
                    <th>Drop by</th>
                    <td>@(Model.obj.OperatorDatails.DropBy ?? "N/A")</td>
                    <th>Forklift number</th>
                    <td>@(Model.obj.OperatorDatails.ForkLift_Number ?? "N/A")</td>
                </tr>
                <tr>
                    <th>POW in time</th>
                    <td>
                        @if (Model.obj.OperatorDatails.PowinTime != null)
                        {
                            @(Model.obj.OperatorDatails.PowinTime.Value.ToString("dd/MM/yyyy HH:mm:ss"))
                        }
                        else
                        {
                            <span>N/A</span>
                        }
                    </td>
                    <th>POW out time</th>
                    <td>
                        @if (Model.obj.OperatorDatails.PowoutTime != null)
                        {
                            @(Model.obj.OperatorDatails.PowoutTime.Value.ToString("dd/MM/yyyy HH:mm:ss"))
                        }
                        else
                        {
                            <span>N/A</span>
                        }
                    </td>
                </tr>
                <tr>
                    <th>POW in longitude</th>
                    <td>@(Model.obj.OperatorDatails.PowInLongitude ?? "N/A")</td>
                    <th>POW in latitude</th>
                    <td>@(Model.obj.OperatorDatails.PowInLatitude ?? "N/A")</td>
                </tr>
                <tr>
                    <th>POW out longitude</th>
                    <td>@(Model.obj.OperatorDatails.PowOutLongitude ?? "N/A")</td>
                    <th>POW out latitude</th>
                    <td>@(Model.obj.OperatorDatails.PowOutLatitude ?? "N/A")</td>
                </tr>
                <tr>
                    <th>Activity start time</th>
                    <td>
                        @if (Model.obj.OperatorDatails.LaborStartTime != null)
                        {
                            @(Model.obj.OperatorDatails.LaborStartTime.Value.ToString("dd/MM/yyyy HH:mm:ss"))
                        }
                        else
                        {
                            <span>N/A</span>
                        }
                    </td>
                    <th>Activity end time</th>
                    <td>
                        @if (Model.obj.OperatorDatails.LaborEndTime != null)
                        {
                            @(Model.obj.OperatorDatails.LaborEndTime.Value.ToString("dd/MM/yyyy HH:mm:ss"))
                        }
                        else
                        {
                            <span>N/A</span>
                        }
                    </td>
                </tr>
                <tr>
                    <th>Checklist</th>
                    <td colspan="3">
                        @if (Model.obj.OperatorDatails.CheckListSubmitted)
                        {
                            <span>
                                Yes
                            </span>
                        }
                        else
                        {
                            <span>No</span>
                        }
                    </td>
                </tr>
            </tbody>
        </table>
        @if (Model.obj.OperatorDatails.CheckListSubmitted == true)
        {


            <h3 class="mb-2 border-bottom pb-1">Check List Details</h3>
            <div class="container-fluid general">
                <table class="table table_heading table-bordered table-striped text-center">
                    <tr>
                        <th width="20%">Forklift name	</th>
                        <td class="pull-textleft">@Model.li.FirstOrDefault().ForkliftName</td>
                    </tr>
                    <tr>
                        <th width="20%">Forklift number		</th>
                        <td class="pull-textleft">@Model.li.FirstOrDefault().ForkliftNumber</td>
                    </tr>
                    <tr>
                        <th width="20%">Container #		</th>
                        <td class="pull-textleft">@Model.li.FirstOrDefault().Cntr</td>
                    </tr>
                    <tr>
                        <th width="20%">Location		</th>
                        <td class="pull-textleft">@Model.li.FirstOrDefault().Location</td>
                    </tr>
                    <tr>
                        <th width="20%">Activity		</th>
                        <td class="pull-textleft">@Model.li.FirstOrDefault().Activity</td>
                    </tr>
                    <tr>
                        <th width="30%">Submitted by		</th>
                        <td class="pull-textleft">@Model.li.FirstOrDefault().SubmitteBy</td>
                    </tr>
                    <tr>
                        <th width="20%">Submitted at		</th>
                        <td class="pull-textleft">@Model.li.FirstOrDefault().SubmittedAt.ToString("yyyy-MM-dd HH:mm:ss")</td>
                    </tr>
                </table>
            </div>
            <div class="container-fluid general">
                <table class="table table_heading table-bordered table-striped text-center">
                    <tr>
                        <th width="50%">
                            Question
                        </th>
                        <th width="10%">
                            Anwser
                        </th>
                        <th width="10%">
                            Remarks
                        </th>
                        <th width="30%">
                            Photo
                        </th>
                    </tr>


                    @foreach (var item in Model.li)
                    {

                        <tr>
                            <td class="pull-textleft">
                                @item.Question
                            </td>
                            <td class="pull-textleft">
                                @item.Answer
                            </td>
                            <td class="pull-textleft">
                                @item.Remarks
                            </td>
                            <td class="pull-textleft">
                                @if (!string.IsNullOrEmpty(item.Photo))
                                {
                                    <img src="@item.Photo" />

                                }
                            </td>
                        </tr>

                    }
                </table>
            </div>
        }
    </div>
</body>
</html>

<script>

    window.print();
</script>
