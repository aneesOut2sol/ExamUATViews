

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!DOCTYPE html>
<style>
    .HistoryTable tr td, .HistoryTable tr th {
        background: white;
        border: 1px solid #bebebe !important;
    }

    .HistoryTable thead {
        position: sticky;
        top: -2px;
    }

    .HistoryTable tr th {
        background: var( --dpw-bg-color) !important;
        color: white !important;
    }
    .modal-body {
        max-height: 70vh !important;
        overflow: auto !important;
    }

    span.badge.badge-Active {
        background: #00946b;
        color: white;
    }

    span.badge.badge-Working {
        background: var( --dpw-bg-color);
        color: white;
    }

    span.badge.badge-InActive {
        background: #cd0202;
        color: white;
    }

    .badge-Blocked {
        background: #c30000;
        color: white;
    }

    .header-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .add-button {
        background-color: var( --dpw-bg-color);
        color: white;
        padding: 8px 16px;
        border: none;
        border-radius: 4px;
    }

    .CloseModalBtn {
        color: #FFFFFF;
        line-height: 25px;
        position: absolute;
        right: -12px;
        z-index: 99999999999 !important;
        text-align: center;
        top: -10px;
        width: 45px;
        text-decoration: none;
        font-weight: bold;
        box-shadow: 1px 1px 3px #000;
        transition: all .3s;
        height: 45px;
        border-radius: 50%;
        font-size: 25px !important;
        padding: 8px;
        cursor: pointer;
        background: var( --dpw-bg-color);
        z-index: 99999999999 !important;
    }

    .close {
        display: none;
    }

    .CloseModalBtn .fa-times-circle-o {
        color: #ffff !important;
    }

    .modal-content {
        background-color: #f4f2fa !important;
        border-radius: 16px !important;
        box-shadow: 0 2.8px 2.2px rgb(0 0 0 / 3%), 0 6.7px 5.3px rgb(0 0 0 / 5%), 0 12.5px 10px rgb(0 0 0 / 6%), 0 22.3px 17.9px rgb(0 0 0 / 7%), 0 41.8px 33.4px rgb(255 255 255 / 9%), 0 100px 80px rgb(255 255 255 / 12%);
    }

    .modal-header {
        text-align: center;
        border-bottom: none !important;
        justify-content: center !important;
    }

    .modal-title {
        font-weight: bolder !important;
        font-size: 24px;
        padding-top: 12px;
        padding-bottom: 4px;
        display: inline-block;
    }

    .modal-footer {
        border-top: none !important;
        align-content: center;
        text-align: center;
    }
</style>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <link href="~/Scripts/DatePicker/bootstrap-datepicker.css" rel="stylesheet" />
    <link href="~/Scripts/DatePicker/bootstrap-datepicker.standalone.css" rel="stylesheet" />
</head>

<body>
    <div class="ng-cloak" ng-cloak ng-controller="FKL_SetupCtrl" ng-init="init()">
        <div class="card mt-2 d-flex">
            <div class="card-body">
                <div class="header-row">
                    <h2>Forklift setup</h2>
                    <div>
                        <input type="button" class="btn btn-secondary" value="Filters" data-toggle="collapse" data-target="#demo" />
                        <button class="add-button" ng-click="OpenAdd()"><i class="icon-add m-r-5 text-white"></i> Add</button>
                    </div>
                </div>
            </div>
        </div>

        <!--Search Filter Code Start-->
        <div class="card collapse" id="demo">
            <div class="card-body">
                <div class="col-md-12">
                    <div class="row">
                        <div class="col-md-3">
                            <div class="form-group">
                                <label>Name</label>
                                <input type="text" class="form-control" ng-model="Search.Name" placeholder="Enter name" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label>Number</label>
                                <input type="text" class="form-control" ng-model="Search.Number" placeholder="Enter number" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label>IP Address</label>
                                <input type="text" class="form-control" ng-model="Search.IP_Address" placeholder="Enter ip address" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label>IP Address</label>
                                <select class="form-control" ng-model="Search.Status">
                                    <option value="" selected hidden disabled>Select Status</option>
                                    <option value="Active">Active</option>
                                    <option value="InActive">InActive</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-12 mt-4">

                            <button class="btn btn-secondary pull-right mr-2" ng-click="ClearFilter(Search)">Clear</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>




        <div class="row">
            <div id="tblrep" class="card table-card scrollbar">
                <table class="table datatable-show-all text-center" id="table-id">
                    <thead>
                        <tr class="table-card-head">
                            <th>SR#</th>
                            <th>Type</th>
                            <th>Area</th>
                            <th>Number</th>
                            <th>IP Address</th>
                            <th>Status</th>
                            <th>Created At</th>
                            <th>Created By</th>
                            <th>Updated At</th>
                            <th>Updated By</th>
                            <th>Last Working Location</th>
                            <th>Last User Assign</th>
                            <th>Action</th>

                        </tr>
                    </thead>
                    <tbody class="ng-cloak" ng-cloak>
                        <tr ng-repeat="item in ForkliftList | filter:Search">
                            <td>{{$index+1}}</td>
                            <td>{{item.TypeName}}</td>
                            <td>{{item.AreaName}}</td>
                            <td>{{item.Number}}</td>
                            <td>{{item.IP_Address}}</td>
                            <td>
                                <span class="badge badge-{{item.Status}}">{{item.Status}}</span>
                            </td>
                            <td>{{item.CreatedAt | date :'dd/MM/yyyy HH:mm:ss'}}</td>
                            <td>{{item.CreatedBy}}</td>
                            <td>{{(item.UpdatedAt | date :'dd/MM/yyyy HH:mm:ss') || '-'}}</td>
                            <td>{{item.UpdatedBy || '-'}}</td>
                            <td>{{item.LastWork || '-'}}</td>
                            <td>{{item.LastAssignUser || '-'}}</td>
                            <td>
                                <span ng-click="OpenEditForkLift(item)" title="Click to Update">
                                    <i class="icon-pencil"></i>
                                </span>
                                <span ng-show="(_currentUser.UserType.includes('SuperUser') || _currentUser.UserType.includes('Admin'))" title="History" ng-click="OpenForkliftHistory(item)">
                                    <i class="icon-history"></i>
                                </span>
                                <span ng-show="(_currentUser.UserType.includes('SuperUser') || _currentUser.UserType.includes('Admin'))" title="Delete" ng-click="DeleteForklift(item)">
                                    <i class="icon-bin"></i>
                                </span>

                            </td>
                        </tr>

                    </tbody>
                </table>
            </div>

        </div>
        <!--pagination Code Start-->
        <div class="row">
            <div class="col-md-3">
                <div class="form-group">
                    <label>Select Rows</label>
                    <select data-placeholder="Select Rows" name="state" id="maxRows" class="form-control select-clear" data-fouc>
                        <option></option>
                        <option value="5000">All Rows</option>
                        <option value="4">4</option>
                        <option value="10">10</option>
                        <option value="15">15</option>
                        <option value="20">20</option>
                        <option value="50">50</option>
                        <option value="70">70</option>
                        <option value="100">100</option>

                    </select>
                </div>
            </div>
        </div>
        <!--modal-->
        <div class="modal fade" id="ForkliftHistory" tabindex="-1" role="dialog" data-backdrop="static" data-keyboard="false" aria-labelledby="exampleModalCenterTitle" aria-hidden="true">
            <div class="modal-dialog modal-dialog-scrollable modal-dialog-centered" role="document" style=" max-width: 2000px; width: max-content;">
                <div class="modal-content" style="overflow:visible !important">
                    <div class="CloseModalBtn" data-dismiss="modal">
                        <button class="close" data-dismiss="modal" aria-label="Close"></button>
                        <i class="icon-cross"></i>
                    </div>
                    <div class="modal-header">
                        <h5 class="modal-title"> FK {{HistoryForklift.Number}} History</h5>
                    </div>
                    <div class="modal-body">
                        <div class="card">
                            <div class="card-body">
                                <div class="row">
                                    <div class="col-md-6">
                                        <label class="Starick">Date from</label>
                                        <div id="sandbox-container">
                                            <div class="input-group date">
                                                <input type="text" class="form-control" id="HistoryStartDate" placeholder="dd/mm/yyyy"><span class="input-group-addon"><i class="mi-insert-invitation"></i></span>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="Starick">Date to</label>
                                        <div id="sandbox-container">
                                            <div class="input-group date">
                                                <input type="text" class="form-control" id="HistoryEndDate" placeholder="dd/mm/yyyy"><span class="input-group-addon"><i class="mi-insert-invitation"></i></span>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-md-12 mt-2">
                                    <button class="btn btn-primary pull-right" ng-click="GetForkliftHistory()">History</button>
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="table-scrollable" ng-show="FKHistoryList!=null && FKHistoryList.length>0">
                                    <table class="table HistoryTable">
                                        <thead>
                                            <tr>
                                                <th>FL No</th>
                                                <th>Status</th>
                                                <th>IP Address</th>
                                                <th>Area</th>
                                                <th>Operator</th>
                                                <th>Activity</th>
                                                <th>Action</th>
                                                <th>Action Time</th>
                                                <th>Action By</th>

                                            </tr>
                                        </thead>
                                        <tr ng-repeat="x in FKHistoryList">
                                            <td>{{x.Number}}</td>
                                            <td>{{x.Status}}</td>
                                            <td>{{x.IP_Address}}</td>
                                            <td>{{x.Area}}</td>
                                            <td>{{x.EmpId}}</td>
                                            <td>{{x.Activity}}</td>
                                            <td>{{x.Action}}</td>
                                            <td>{{x.CreatedAt | date:'dd-MM-yyyy HH:mm:ss'}}</td>
                                            <td>{{x.CreatedBy}}</td>
                                        </tr>
                                    </table>
                                </div>
                            </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="modal fade" id="AddForklift" tabindex="-1" role="dialog" data-backdrop="static" data-keyboard="false" aria-labelledby="exampleModalCenterTitle" aria-hidden="true">
            <div class="modal-dialog modal-dialog-scrollable modal-dialog-centered" role="document">
                <div class="modal-content" style="overflow:visible !important">
                    <div class="CloseModalBtn" data-dismiss="modal">
                        <button class="close" data-dismiss="modal" aria-label="Close"></button>
                        <i class="icon-cross"></i>
                    </div>
                    <div class="modal-header">
                        <h5 class="modal-title">Add forklift</h5>
                    </div>
                    <div class="modal-body">
                        <div class="row">
                            <div class="col-md-12">
                                <label class="Starick">Forklift type</label>
                                <select data-placeholder="Please Select forklift type" class="form-control select-clear" id="AddFkTypeDD" ng-model="ForkliftObj.forklifttype" required data-fouc>
                                    <option></option>
                                    <option ng-repeat="item in ForkLiftTypeList" value="{{item.Id}}">{{item.Type}}</option>
                                </select>
                            </div>
                            <div class="col-md-12 mt-2">
                                <div class=" form-group">
                                    <label class="Starick">Area</label>
                                    <select data-placeholder="Please Select area" class="form-control select-clear" id="AddAreaDD" ng-model="ForkliftObj.AreaId" required data-fouc>
                                        <option></option>
                                        <option value="{{x.Id}}" ng-repeat="x in AreaList">{{x.Name}}</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-12">
                                <div class=" form-group">
                                    <label class="Starick">Number</label>
                                    <input type="text" class="form-control" ng-model="ForkliftObj.Number" placeholder="Enter number" value="" />
                                </div>
                            </div>
                            <div class="col-md-12">
                                <div class=" form-group">
                                    <label class="">IP Address</label>
                                    <input type="text" class="form-control" ng-model="ForkliftObj.IP_Address" placeholder="Enter ip address" value="" />
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <div class="row">
                            <div class="col-md-12" style="text-align:end;">
                                <button class="btn btn-success" ng-click="AddForklift(ForkliftObj)">
                                    Submit
                                </button>
                                <button class="btn btn-primary" data-dismiss="modal">Cancel</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="modal fade" id="EditForkLift" tabindex="-1" role="dialog" data-backdrop="static" data-keyboard="false" aria-labelledby="exampleModalCenterTitle" aria-hidden="true">
            <div class="modal-dialog modal-dialog-scrollable modal-dialog-centered" role="document">
                <div class="modal-content" style="overflow:visible !important">
                    <div class="CloseModalBtn" data-dismiss="modal">
                        <button class="close" data-dismiss="modal" aria-label="Close"></button>
                        <i class="icon-cross"></i>
                    </div>
                    <div class="modal-header">
                        <h5 class="modal-title">Edit forklift</h5>
                    </div>
                    <div class="modal-body">
                        <div class="row">
                            <div class="col-md-12">
                                <label class="Starick">Forklift type</label>
                                <select data-placeholder="Please Select forklift type" class="form-control select-clear" id="EditFkTypeDD" ng-model="EditForkLiftObj.TypeId" required data-fouc>
                                    <option></option>
                                    <option value="{{item.Id}}" ng-selected="EditForkLiftObj.TypeId==item.Id" ng-repeat="item in ForkLiftTypeList">{{item.Type}}</option>
                                </select>
                            </div>
                            <div class="col-md-12 mt-2">
                                <div class=" form-group">
                                    <label class="Starick">Area</label>
                                    <select data-placeholder="Please Select area" class="form-control select-clear" id="EditAreaDD" ng-model="EditForkLiftObj.AreaId" required data-fouc>
                                        <option></option>
                                        <option value="{{x.Id}}" ng-selected="x.Id===EditForkLiftObj.AreaId" ng-repeat="x in AreaList">{{x.Name}}</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-12">
                                <div class=" form-group">
                                    <label class="Starick">Number</label>
                                    <input type="text" class="form-control" disabled ng-model="EditForkLiftObj.Number" placeholder="Enter number" value="" />
                                </div>
                            </div>
                            <div class="col-md-12">
                                <div class=" form-group">
                                    <label class="">IP Address</label>
                                    <input type="text" class="form-control" ng-model="EditForkLiftObj.IP_Address" placeholder="Enter ip address" value="" />
                                </div>
                            </div>
                            <div class="col-md-12">
                                <div class=" form-group">
                                    <label class="Starick">Status</label>
                                    <select class="form-control" ng-model="EditForkLiftObj.Status">
                                        <option ng-selected="EditForkLiftObj.Status=='Active'" value="Active">Active</option>
                                        <option ng-selected="EditForkLiftObj.Status=='InActive'" value="InActive">InActive</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <div class="row">
                            <div class="col-md-12" style="text-align:end;">
                                <button class="btn btn-success" ng-click="UpdateForkLift(EditForkLiftObj)">
                                    Submit
                                </button>
                                <button class="btn btn-primary" data-dismiss="modal">Cancel</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!--modal-->


    </div>
    <!--pagination Code End-->
</body>
</html>
<script src="~/Scripts/jquery.min.js"></script>
<script src="~/Scripts/DatePicker/bootstrap-datepicker.js"></script>
<script src="~/Scripts/js/plugins/moment/moment_locales.min.js"></script>
<script src="~/Scripts/DatePicker/CustomIntilizeJS.js"></script>
