                                    <th>Activity</th>
                                    <td>{{ActivityInfo.Activity}}</td>
                                    <th>Start time</th>
                                    <td>{{ActivityInfo.StartTime  | date:'dd-MM-yyyy HH:mm:ss'}}</td>

                                </tr>
                                <tr>
                                    <th>Location</th>
                                    <td>{{ActivityInfo.Location}}</td>
                                    <th>End time</th>
                                    <td>{{ActivityInfo.EndTime  | date:'dd-MM-yyyy HH:mm:ss'}}</td>


                                </tr>
                                <tr>
                                    <th>Size</th>
                                    <td>{{ActivityInfo.Size}}</td>
                                    <th>Activity duration</th>
                                    <td>{{ActivityInfo.ActivityDuration}}</td>

                                </tr>
                                <tr>
                                    <th>Package type</th>
                                    <td>{{ActivityInfo.PackageType}}</td>
                                    <th>Activity SLA</th>
                                    <td>{{ActivityInfo.ActivityETC}}</td>


                                </tr>
                                <tr>
                                    <th>Forklift</th>
                                    <td>{{ActivityInfo.Forklift}}</td>
                                    <th>Delay duration</th>
                                    <td>{{ActivityInfo.DelayDuration}}</td>
                                </tr>
                                <tr>
                                    <th>Operator</th>
                                    <td>{{ActivityInfo.EmpId}}-{{ActivityInfo.Operator}}</td>
                                    <th>Shift</th>
                                    <td>{{ActivityInfo.Shift}}</td>

                                </tr>
                            </table>
                        </div>
                        <div ng-show="HistoryTab=='Delays'">
                            <table class="table HistoryTable">
                                <thead>
                                    <tr>
                                        <th>Delays</th>
                                        <th>Start at</th>
                                        <th>Start by</th>
                                        <th>Closed at</th>
                                        <th>Closed by</th>
                                        <th>Duration</th>
                                    </tr>
                                </thead>
                                <tr ng-repeat="x in ActivityInfo.Delays">
                                    <td>{{x.Reason}}</td>
                                    <td>{{x.DelayRaisedAt | date:'dd-MM-yyyy HH:mm:ss'}}</td>
                                    <td>{{x.CreatedBy}}</td>
                                    <td>{{x.DelayResolvedAt | date:'dd-MM-yyyy HH:mm:ss'}}</td>
                                    <td>{{x.UpdatedBy}}</td>
                                    <td>{{x.Duration}}</td>
                                </tr>
                            </table>

                        </div>
                        <div ng-show="HistoryTab=='History'">
                            <table class="table HistoryTable">
                                <tr>
                                    <th>Container</th>
                                    <th>Location</th>
                                    <th>Activity</th>
                                    <th>Operator</th>
                                    <th>Forklift</th>
                                    <th>Status</th>
                                    <th>Action</th>
                                    <th>Created at</th>
                                    <th>Created by</th>
                                </tr>
                                <tr ng-repeat="x in ActivityInfo.History">
                                    <td>{{x.Cntr}}</td>
                                    <td>{{ActivityInfo.Location}}</td>
                                    <td>{{ActivityInfo.Activity}}</td>
                                    <td>{{x.EmpId}}-{{x.Name}}</td>
                                    <td>{{x.Forklift}}</td>
                                    <td>{{x.Status}}</td>
                                    <td>{{x.Detail}}</td>
                                    <td>{{x.CreatedAt | date:'dd-MM-yyyy HH:mm:ss'}}</td>
                                    <td>{{x.CreatedBy}}</td>
                                </tr>
                            </table>
                        </div>
                        <div ng-show="HistoryTab=='Checklist'">
                            <table class="table HistoryTable">
                                <thead>
                                    <tr>
                                        <th>Forklift</th>
                                        <th>Pickup at</th>
                                        <th>Pickup by</th>
                                        <th>Action</th>
                                    </tr>
                                </thead>

                                <tbody ng-repeat="Fk in ActivityInfo.CheckList" ng-init="PIndex = $index">
                                    <!-- Main Row - Forklift Summary -->
                                    <tr>
                                        <td>{{Fk.Forklift}}</td>
                                        <td>{{Fk.CreatedAt | date:'dd-MM-yyyy HH:mm:ss'}}</td>
                                        <td>{{Fk.CreatedBy}}</td>
                                        <td>
                                            <span ng-show="CurrentCheckIndex != PIndex"
                                                  ng-click="CurrentCheckIndex = PIndex"
                                                  style="cursor: pointer;">
                                                <i class="icon-plus2"></i>
                                            </span>
                                            <span ng-show="CurrentCheckIndex == PIndex"
                                                  ng-click="CurrentCheckIndex = -1"
                                                  style="cursor: pointer;">
                                                <i class="icon-minus2"></i>
                                            </span>
                                        </td>
                                    </tr>

                                    <!-- Expanded Details - Only shown when this row is selected -->
                                    <tr ng-show="CurrentCheckIndex == PIndex">
                                        <td colspan="4" style=" background: #e0eeff;">
                                            <table class="table table-bordered table-sm">
                                                <thead>
                                                    <tr>
                                                        <th colspan="4" class="text-center bg-light">FL Checklist</th>
                                                    </tr>
                                                    <tr>
                                                        <th>Question</th>
                                                        <th>Answer</th>
                                                        <th>Uploaded photo</th>
                                                        <th>Remarks</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <tr ng-repeat="Chk in Fk.CheckList">
                                                        <td class="CheckListStyle">{{Chk.Question}}</td>
                                                        <td class="CheckListStyle">{{Chk.Answer}}</td>
                                                        <td class="CheckListStyle">
                                                            <a ng-if="Chk.UploadedPhoto"
                                                               href="{{Chk.UploadedPhoto}}"
                                                               target="_blank"
                                                               title="View Photo">
                                                                <i class="icon-eye"></i>
                                                            </a>
                                                            <span ng-if="!Chk.UploadedPhoto">-</span>
                                                        </td>
                                                        <td class="CheckListStyle">{{Chk.Remarks || '-'}}</td>
                                                    </tr>
                                                </tbody>
                                            </table>

                                            <!-- PSC Form Data - Categories and Questions -->
                                            <div ng-repeat="psc in Fk.PSCFormData.QuestionsCategory"
                                                 ng-if="Fk.PSCFormData && Fk.PSCFormData.QuestionsCategory && Fk.PSCFormData.QuestionsCategory.length > 0">
                                                <table class="table table-bordered table-sm">
                                                    <thead>
                                                        <tr>
                                                            <th colspan="4" class="text-center bg-info text-white">
                                                                {{psc.CategoryName}}
                                                            </th>
                                                        </tr>
                                                        <tr>
                                                            <th>Question</th>
                                                            <th>Answer</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        <tr ng-repeat="Pq in psc.QList">
                                                            <td class="CheckListStyle">{{Pq.Question}}</td>
                                                            <td class="CheckListStyle">{{Pq.Action || '-'}}</td>

                                                        </tr>
                                                    </tbody>
                                                </table>
                                            </div>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>



                </div>
                <div class="modal-footer">
                    <div class="row">
                        <div class="col-md-12" style="text-align:center">

                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>


</div>

<script src="@Url.Content("~/Scripts/crypto-js.min.js")"></script>
<script src="~/Scripts/jquery.min.js"></script>
<script src="~/Scripts/webcam.min.js"></script>
<script src="~/Scripts/SignPadJsCode.js"></script>

<script>
    $(document).ready(function () {
        var o = new SlimSelect({
            select: '#Forklift',
            placeholder: 'Select Forklift',
            showSearch: true,
            allowDeselect: true,
        });
    });
</script>