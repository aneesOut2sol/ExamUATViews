<div class="ng-cloak" ng-cloak ng-controller="FKL_OperatorCtrl" ng-init="init()">
    <div class="page-header border-bottom-0">
        <div class="page-header-content header-elements-md-inline">
            <div class="page-title d-flex">
                <h4><i class="icon-stack-text mr-2"></i><span class="font-weight-semibold">Operator Activity</span> </h4>
                <a href="#" class="header-elements-toggle text-default d-md-none"><i class="icon-more"></i></a>
            </div>
            <div class="page-title d-flex">
                <span class="pull-right Arealabel">{{AreaNJobs.Area}} <span class="AreaBadge">{{AreaNJobs.Count}}</span></span>
            </div>
        </div>
    </div><hr />
    <div class="row mt-2">
        <div class="col-md-12">
            <!--Tab Code Start -->
            <div class="tab">
                <div class="row">
                    <div class="col-md-4 col-lg-3 col-xl-2 col-sm-12 col-xs-12 col-12">
                        <div class="CardHeaderLink w-100 text-center ">
                            <button ng-click="SwitchTab('Pending')" ng-class="{'active':ActiveTab=='Pending'}" class="tablinks w-100">
                                <i class="icon-file-check mr-2"></i> Ongoing
                                <span class="CountTabBadge">{{TabCount.Pending}}</span>
                            </button>
                        </div>
                    </div>

                    <div class="col-md-4 col-lg-3 col-xl-2 col-sm-12 col-xs-12 col-12">
                        <div class="CardHeaderLink w-100  text-center ">
                            <button ng-click="SwitchTab('Queue')" ng-class="{'active':ActiveTab=='Queue'}" class="tablinks w-100">
                                <i class="icon-history mr-2"></i>Planned
                                <span class="CountTabBadge">{{TabCount.Queue}}</span>
                            </button>
                        </div>
                    </div>
                    <div class="col-md-4 col-lg-3 col-xl-2 col-sm-12 col-xs-12 col-12">
                        <div class="CardHeaderLink w-100  text-center ">
                            <button ng-click="SwitchTab('Completed')" ng-class="{'active':ActiveTab=='Completed'}" class="tablinks w-100">
                                <i class="icon-history mr-2"></i> Executed
                                <span class="CountTabBadge">{{TabCount.Completed}}</span>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!--Tab Code End -->
    <hr />
    <div class="card mt-2 mt-2">
        <div class="card-header" style=" background: var( --dpw-bg-color); color: white; padding: 8px;">
            <h5 class="mt-2">Block</h5>
        </div>
        <div class=" card-body shadow">
            <div class="row">
                <div ng-show="OperatorBlockList!=null && OperatorBlockList.length>0" class="Cardtabs" ng-repeat="B in OperatorBlockList">
                    <div class="Absoulte">
                        <div class="CountBadge">{{B.Cntrs}}</div>
                        <br />
                    </div>
                    <button ng-click="GetFKLContainerList(B,false)" ng-class="{'active' : B.Block == CurrentBlock.Block }" class="btn btn-primary Blocks" value="{{B.Block}}">
                        <span>{{B.Block}}</span>
                    </button>
                </div>
                <div class="mt-2" ng-show="OperatorBlockList==null||OperatorBlockList.length==0">
                    No block found
                </div>
            </div>
        </div>
    </div>
    <div class="row" ng-show="!stringNullorEmpty(ContainerList)">
        <div class="col-12 col-md-12 col-lg-6 col-xl-6 col-sm-12 col-xs-12" ng-repeat="x in ContainerList | filter :search" style="overflow:visible">
            <div class="card Custom-Card m-0 p-0">
                <div class="card-header">
                    <div class="d-lg-inline-block mr-2" style="color:gray" title="Actual time of activity"> <i class="icon-history"></i>ETC: {{x.ETA}}</div>
                    <div class="d-lg-inline-block" style="color:{{x.color}}" ng-show="x.ActualDuration!='' && x.ActualDuration!=null"> <i class="icon-history"></i>Duration: {{x.ActualDuration}}</div>

                    <div class="pull-right">
                        <span title="Multi skill operator" ng-class="{ 'text-danger': x.DifficultStrip, 'text-green': !x.DifficultStrip }">MSO : {{x.DifficultStrip}}</span>
                        <img title="{{x.CreatedBy}}" ng-show="x.CreatedBy=='Auto Assigned'" style="height:14px;" src="~/Content/images/Auto.png" />
                        <img title="{{x.CreatedBy}}" ng-show="x.CreatedBy!='Auto Assigned'" style="height:14px;" src="~/Content/images/Manual.png" />
                        <span title="Activity" ng-class="x.Activity == 'Strip' ? 'badge-Strip' : 'badge-Repack'" class="Laborbadge">{{x.Activity}}</span>
                        <span title="Activity Status" class="Laborbadge badge-{{x.ActivityStatus}}">{{x.ActivityStatus}}</span>


                        <span title="Operator Status " class="d-none Laborbadge badge-{{x.OperatorDatails.Status}}">{{x.OperatorDatails.Status}}</span>
                    </div>
                </div>
                <div class="card-body p-3">
                    <div class="d-inline-block vertical-center">
                        <img style="height: 60px;" src="~/Content/images/LabourIcon.png" />
                    </div>
                    <div class="d-inline-block vertical-center">
                        <b>{{x.OperatorDatails.EMPId}}-{{x.OperatorDatails.Name}}</b>
                        <div style="font-size: 11px; color: #898989;">Punch in Time:{{x.OperatorDatails.PunchInTime |date:'dd-MM-yyyy HH:mm:ss'}}</div>
                        <b>{{x.Cntr}}</b>
                        <div style="font-size: 11px; color: #898989;">Location: {{x.Location}}</div>
                        <div style="font-size: 11px; color: #898989;">Package type: {{x.PackageType}}</div>
                        <div style="font-size: 11px; color: #898989;">Size: {{x.Size}}</div>
                        <div style="font-size: 11px; color: #898989;">Estimated duration: {{x.ETA==':'?'N/A':x.ETA}}</div>
                    </div>
                </div>
                <div class="card-footer text-end" ng-show="ActiveTab=='Pending'">
                    @*Inspection delays*@
                    <button ng-show="x.OperatorDatails.Started==true" class="btn btn-sm btn-primary" ng-click="Inspectiondelay(x.InspectionDelayRPT==5||x.InspectionDelayRPT==2||x.InspectionDelayRPT==3,x.Unitgkey,x.Cntr,x.OperatorDatails.ActivityId,x.Activity,x.Location)"
                            ng-class="{'approvalrequierd' : x.InspectionDelayRPT==5 ,'approved' : x.InspectionDelayRPT==2,'Rejected':x.InspectionDelayRPT==3 }">
                        Inspection Delays
                        <div class="DelayBadge" style="position: absolute; bottom: 20px;" ng-if="GetOverallInspeDelayDuration(x) != '' && x.OperatorDatails.Started==true">
                            <div ng-class="{'approved' : x.InspectionDelayRPT==2,'Rejected':x.InspectionDelayRPT!=2 }" class="CountBadge">{{GetOverallInspeDelayDuration(x)}}</div>
                        </div>
                    </button>
                    <button ng-show="x.OperatorDatails.Started==true" class="btn btn-sm  btn-primary" ng-click="DamageReport(x.DamageStatus==5 || x.DamageStatus==1,x)"
                            ng-class="{'approvalrequierd' : x.DamageStatus==5 ,'approved' : x.DamageStatus==1,'Rejected':x.DamageStatus==3 }">
                        Cargo Report
                    </button>
                    <button class="btn btn-sm btn-primary" ng-click="GetDetails(x.ActivityId)"><i class="icon-info22"></i> Details</button>
                    <button ng-show="x.OperatorDatails.PowIn==false && CheckSameBlock(x.Location,x.LastLocation)==false" ng-click="POWINContainer(x.OperatorDatails.ActivityId,x.OperatorDatails.OperatorId)" class="btn btn-sm btn-primary">POW In</button>
                    <button ng-show="(x.OperatorDatails.PowIn==true || CheckSameBlock(x.Location,x.LastLocation)==true) && x.OperatorDatails.Started==false" ng-click="StartActivity(x.OperatorDatails.OperatorId,x.OperatorDatails.ActivityId,x.OperatorDatails.PowIn,x.OperatorDatails.EMPId)" class="btn btn-sm btn-success">Start Activity</button>
                    <button ng-show="(x.OperatorDatails.PowIn==true && x.OperatorDatails.Started==true && x.OperatorDatails.Ended==false) && x.InspectionDelayRPT!=5 && x.Activity == 'Strip'" ng-click="OpenEndActivity(x)" class="btn btn-sm btn-success">End Activity</button>
                    <button ng-show="(x.OperatorDatails.PowIn==true && x.OperatorDatails.Started==true && x.OperatorDatails.Ended==false) && x.InspectionDelayRPT!=5 && x.Activity == 'Repack' && x.Repack50Done==true" ng-click="OpenEndActivity(x)" class="btn btn-sm btn-success">End Activity</button>
                    <button ng-show="(x.OperatorDatails.PowIn==true && x.OperatorDatails.Started==true && x.OperatorDatails.Ended==false) && x.InspectionDelayRPT!=5 && x.Activity == 'Repack' && x.Repack50Done==false" ng-click="OpenEndActivity(x)" class="btn btn-sm btn-success">50% Repack</button>
                    <button ng-show="x.OperatorDatails.PowIn==true && x.OperatorDatails.Started==true && x.OperatorDatails.Ended==true && x.OperatorDatails.PowOut==false" ng-click="POWOUTContainer(x.OperatorDatails.OperatorId,x.OperatorDatails.ActivityId)" class="btn btn-sm btn-primary">POW out</button>

                </div>
            </div>
        </div>
    </div>
    @Html.Partial("~/Views/ActivityCapture/_InspDelay.cshtml")
    @Html.Partial("~/Views/ActivityCapture/_damageReport.cshtml")
