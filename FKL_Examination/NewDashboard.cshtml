                    <div class="filterSection" ng-show="BlockCountList!=null && BlockCountList.length>0">
                        <b class="filter-section-title">Block</b>
                        <div class="filter-pill-wrap">
                            <div class="filter-pill-item" ng-click="AddBlockFilter(x.Block)" filter-val="{{x.Block}}" ng-repeat="x in BlockCountList">
                                <span class="filter-count-badge">{{x.Count}}</span>
                                {{x.Block}}
                            </div>
                        </div>
                    </div>
                    @*Activity filter*@
                    <div class="filterSection">
                        <b class="filter-section-title">Activity</b>
                        <div class="filter-pill-wrap">
