                        <i class="icon-filter3" style="margin-right: 5px;"></i>Filter Options
                    </h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close" style="font-size: 1.2rem; color: #6c757d;">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>

                <div class="modal-body panel-body-sm">
