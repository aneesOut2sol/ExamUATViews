                                <span class="filter-count-badge">0</span>
                                Strip
                            </div>
                            <div class="filter-pill-item" filter-val="Repack">
                                <span class="filter-count-badge">0</span>
                                Repack
                            </div>
                            <div class="filter-pill-item" filter-val="Delays">
                                <span class="filter-count-badge">0</span>
                                Delays
                            </div>
                            <div class="filter-pill-item" filter-val="Auto">
                                <span class="filter-count-badge">0</span>
                                Auto
                            </div>
                            <div class="filter-pill-item" filter-val="Manual">
                                <span class="filter-count-badge">0</span>
                                Manual
                            </div>
                        </div>
                    </div>
                    @*Container *@
                    <div class="filterSection">
                        <b class="filter-section-title">Container</b>
                        <div class="filter-pill-wrap">
                            <div class="filter-pill-item" filter-val="MSO">
                                <span class="filter-count-badge">0</span>
                                MSO
                            </div>
                        </div>
                    </div>
                    @*Area filter*@
                    <div class="filterSection" ng-show="YardArea!=null && YardArea.length>0">
                        <b class="filter-section-title">Area</b>
                        <div class="filter-pill-wrap">
                            <div class="filter-pill-item" ng-click="AddYardFilter(x.Name)" filter-val="{{x.Name}}" ng-repeat="x in YardArea">
                                <span class="filter-count-badge">0</span>
                                {{x.Name}}
                            </div>
                        </div>
                    </div>
                    @*Operator filter*@
                    <div class="filterSection" ng-show="OPRFilterList!=null && OPRFilterList.length>0">
                        <b class="filter-section-title">Operator</b>
                        <div class="filter-pill-wrap">
                            <div class="filter-pill-item" ng-click="AddOperatorFilter(x.EmpId)" filter-val="{{x.EmpId}}" ng-repeat="x in OPRFilterList">
                                <span class="filter-count-badge">0</span>
                                {{x.EmpId}}-{{x.Name}}
                            </div>
                        </div>
                    </div>
                    @*Forklift filter*@
                    <div class="filterSection" ng-show="FKFilterList!=null && FKFilterList.length > 0">
                        <b class="filter-section-title">Forklift</b>
                        <div class="filter-pill-wrap">
                            <div class="filter-pill-item" ng-click="AddForkliftFilter(x)" filter-val="{{x}}" ng-repeat="x in FKFilterList">
                                <span class="filter-count-badge">0</span>
                                {{x}}
                            </div>
                        </div>
                    </div>
                </div>

                <div class="modal-footer panel-footer-sm">
                    <button data-dismiss="modal" class="btn btn-primary w-100" ng-click="ClearAllFilter()">
                        Clear All
                    </button>
                </div>
            </div>
        </div>
    </div>
