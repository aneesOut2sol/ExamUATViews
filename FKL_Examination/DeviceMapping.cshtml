
@{
    ViewBag.Title = "DeviceMapping";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .modal-body {
        max-height: 70vh !important;
        overflow: auto !important;
    }

    span.badge.badge-Active {
        background: #00946b;
        color: white;
    }

    span.badge.badge-InActive {
        background: #cd0202;
        color: white;
    }

    .header-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .add-button {
        background-color: var( --dpw-bg-color);
        color: white;
        padding: 8px 16px;
        border: none;
        border-radius: 4px;
    }

    .CloseModalBtn {
        color: #FFFFFF;
        line-height: 25px;
        position: absolute;
        right: -12px;
        z-index: 99999999999 !important;
        text-align: center;
        top: -10px;
        width: 45px;
        text-decoration: none;
        font-weight: bold;
        box-shadow: 1px 1px 3px #000;
        transition: all .3s;
        height: 45px;
        border-radius: 50%;
        font-size: 25px !important;
        padding: 8px;
        cursor: pointer;
        background: var( --dpw-bg-color);
        z-index: 99999999999 !important;
    }

    .close {
        display: none;
    }

    .CloseModalBtn .fa-times-circle-o {
        color: #ffff !important;
    }

    .modal-content {
        background-color: #f4f2fa !important;
        border-radius: 16px !important;
        box-shadow: 0 2.8px 2.2px rgb(0 0 0 / 3%), 0 6.7px 5.3px rgb(0 0 0 / 5%), 0 12.5px 10px rgb(0 0 0 / 6%), 0 22.3px 17.9px rgb(0 0 0 / 7%), 0 41.8px 33.4px rgb(255 255 255 / 9%), 0 100px 80px rgb(255 255 255 / 12%);
    }

    .modal-header {
        text-align: center;
        border-bottom: none !important;
        justify-content: center !important;
    }

    .modal-title {
        font-weight: bolder !important;
        font-size: 24px;
        padding-top: 12px;
        padding-bottom: 4px;
        display: inline-block;
    }

    .modal-footer {
        border-top: none !important;
        align-content: center;
        text-align: center;
    }
</style>
<script src="~/Scripts/jquery.min.js"></script>
<link href="~/Scripts/SlimSelect/SlimSelectCustomStyle.css" rel="stylesheet" />
<link href="~/Scripts/SlimSelect/slimselect.min.css" rel="stylesheet" />
<script src="~/Scripts/SlimSelect/slimselect.min.js"></script>
<div class="ng-cloak" ng-cloak ng-controller="FKL_ExaminationCtrl" ng-init="GetFKLMappedDevices()">
    <div class="card mt-2 d-flex">
        <div class="card-body">
            <div class="header-row">
                <h2>Device Mapping</h2>
                <div>
                    <input type="button" class="btn btn-secondary" value="Filters" data-toggle="collapse" data-target="#demo" />
                </div>
            </div>
        </div>
    </div>

    <!--Search Filter Code Start-->
    <div class="card collapse" id="demo">
        <div class="card-body">
            <div class="col-md-12">
                <div class="row">
                    <div class="col-md-3">
                        <div class="form-group">
                            <label>Forklift</label>
                            <input type="text" class="form-control" ng-model="Search.ForkliftName" placeholder="Enter Forklift" />
                        </div>
                    </div>
                    <div class="col-md-12 mt-4">
                        <button class="btn btn-secondary pull-right mr-2" ng-click="Search = {}">Clear</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div id="tblrep" class="card table-card scrollbar">
            <table class="table datatable-show-all text-center" id="table-id">
                <thead>
                    <tr class="table-card-head">
                        <th>SR#</th>
                        <th>Forklift</th>
                        <th>Device Id</th>
                        <th>Action</th>

                    </tr>
                </thead>
                <tbody class="ng-cloak" ng-cloak>
                    <tr ng-repeat="item in DeviceMppingList | filter:Search">
                        <td>{{$index+1}}</td>
                        <td>{{item.ForkliftName}}</td>
                        <td>{{item.UniqueId}}</td>
                        <td><i class="icon-bin colorRed" title="Click to unmap device" ng-click="DeleteFKLMapping(item.Id)"></i></td>
                    </tr>

                </tbody>
            </table>
        </div>

    </div>

</div>
<script>

</script>

