
@{
    ViewBag.Title = "Inventory";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!DOCTYPE html>
<style>
    .CheckInDevices {
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
        padding: 20px;
        text-align: center;
        margin-bottom: 20px;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

        .CheckInDevices:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 18px rgba(0, 0, 0, 0.15);
        }

        .CheckInDevices .header {
            font-size: 14px;
            font-weight: 600;
            color: var( --dpw-bg-color);
            margin-bottom: 10px;
        }

        .CheckInDevices .Count {
            font-size: 20px;
            font-weight: 700;
            color: #00be5e;
        }


    .modal-body {
        max-height: 70vh !important;
        overflow: visible !important;
    }

    span.badge.badge-Active {
        background: #00946b;
        color: white;
    }

    span.badge.badge-Working {
        background: var( --dpw-bg-color);
        color: white;
    }

    span.badge.badge-InActive {
        background: #cd0202;
        color: white;
    }

    .badge-Blocked {
        background: #c30000;
        color: white;
    }

    .header-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .add-button {
        background-color: var( --dpw-bg-color);
        color: white;
        padding: 8px 16px;
        border: none;
        border-radius: 4px;
    }

    .CloseModalBtn {
        color: #FFFFFF;
        line-height: 25px;
        position: absolute;
        right: -12px;
        z-index: 99999999999 !important;
        text-align: center;
        top: -10px;
        width: 45px;
        text-decoration: none;
        font-weight: bold;
        box-shadow: 1px 1px 3px #000;
        transition: all .3s;
        height: 45px;
        border-radius: 50%;
        font-size: 25px !important;
        padding: 8px;
        cursor: pointer;
        background: var( --dpw-bg-color);
        z-index: 99999999999 !important;
    }

    .close {
        display: none;
    }

    .CloseModalBtn .fa-times-circle-o {
        color: #ffff !important;
    }

    .modal-content {
        background-color: #f4f2fa !important;
        border-radius: 16px !important;
        box-shadow: 0 2.8px 2.2px rgb(0 0 0 / 3%), 0 6.7px 5.3px rgb(0 0 0 / 5%), 0 12.5px 10px rgb(0 0 0 / 6%), 0 22.3px 17.9px rgb(0 0 0 / 7%), 0 41.8px 33.4px rgb(255 255 255 / 9%), 0 100px 80px rgb(255 255 255 / 12%);
    }

    .modal-header {
        text-align: center;
        border-bottom: none !important;
        justify-content: center !important;
    }

    .modal-title {
        font-weight: bolder !important;
        font-size: 24px;
        padding-top: 12px;
        padding-bottom: 4px;
        display: inline-block;
    }

    .modal-footer {
        border-top: none !important;
        align-content: center;
        text-align: center;
    }
    .RedText {
        color: red !important;
    }
</style>
<div class="ng-cloak" ng-cloak ng-controller="FKL_InventoryCtrl" ng-init="HistoryInit()">
    <div class="card mt-2 d-flex">
        <div class="card-body">
            <div class="header-row">
                <h2>Inventory history</h2>
                <div>
                </div>
            </div>
        </div>
    </div>

    <!--Search Filter Code Start-->
    <div class="card collapse" id="demo">
        <div class="card-body">
            <div class="col-md-12">
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>Devices</label>
                            <input type="text" class="form-control" ng-model="Search.Device" placeholder="Enter device" />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>Operator</label>
                            <input type="text" class="form-control" ng-model="Search.Operator" placeholder="Enter operator" />
                        </div>
                    </div>
                   
                    <div class="col-md-12 mt-4">

                        <button class="btn btn-reset pull-right" ng-click="ClearFilter(Search)">Clear</button>
                    </div>
                </div>
            </div>
        </div>
    </div>


    <div class="row">
        <div class="col-md-4">
            <div class="CheckInDevices">
                <div class="header">Chcek in devices</div>
                <div class="Count">
                    {{ CheckInDevices }}
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="CheckInDevices">
                <div class="header">Checked out devices</div>
                <div class="Count">
                    {{ CheckOutDevices }}
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="CheckInDevices">
                <div class="header">Missing devices</div>
                <div class="Count" ng-class="{'RedText':MissingDevices>0}">
                    {{ MissingDevices }}
                </div>
            </div>
        </div>
    </div>


    <div class="row">
        <div id="tblrep" class="card table-card scrollbar">
            <table class="table datatable-show-all text-center" id="table-id">
                <thead>
                    <tr class="table-card-head">
                        <th>SR#</th>
                        <th>Device</th>
                        <th>Operator</th>
                        <th>CheckIn</th>
                        <th>CheckOut</th>
                        <th>Created By</th>
                        <th>Updated By</th>
                    </tr>
                </thead>
                <tbody class="ng-cloak" ng-cloak>
                    <tr ng-repeat="item in InventoryList | filter:Search">
                        <td>{{$index+1}}</td>
                        <td>{{item.Device}}</td>
                        <td>{{item.Operator}}</td>
                        <td>{{item.CheckInTime | date :'dd/MM/yyyy HH:mm:ss'}}</td>
                        <td>{{(item.CheckOutTime | date :'dd/MM/yyyy HH:mm:ss') || '-'}}</td>
                        <td>{{item.CreatedBy || '-'}}</td>
                        <td>{{item.UpdatedBy || '-'}}</td>
                    </tr>

                </tbody>
            </table>
        </div>

    </div>
</div>

<script src="~/Scripts/jquery.min.js"></script>



