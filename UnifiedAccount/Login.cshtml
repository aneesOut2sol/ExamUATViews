
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Login</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300&display=swap" rel="stylesheet">
    <style>

        .card {
            background: #fff;
            border-radius: 2px;
            padding: 20px;
            text-align: center;
            margin: 5rem auto;
            width: 25%;
            box-shadow: 0 19px 38px rgba(0,0,0,0.30), 0 15px 12px rgba(0,0,0,0.22);
            font-family: 'Poppins', sans-serif;
            font-size: 15px;
        }

        img {
            height: 150px;
        }
    </style>
</head>
<body>

    <div class="card">
        <img src="~/Content/images/DisableIcon.png" />
        <h2>@ViewBag.ErrorMessage</h2>
        <h2>@ViewBag.ExceptionMessage</h2>
        <h2>@ViewBag.IsNotActive</h2>
        <h2>@ViewBag.ApplicationBehaviour</h2>
    </div>
</body>
</html>
<script>
    var data = "@ViewBag.ApplicationBehaviour";
    if (data == "Direct Access is not allowed. Please login to easyme where you are redirecting.") {
        window.setTimeout(function () {
            window.location.href = "/UnifiedAccount/Redirect";
        }, 4000);
    }

</script>
