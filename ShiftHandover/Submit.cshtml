            I have comments or observations regarding the shift handover (please specify below):
        </label>
    </div>
    <textarea ng-show="formData.confirmation === 'comments'" class="form-control remarks-textarea mb-4" ng-model="formData.confirmationComments" placeholder="Comments / Observations..."></textarea>-->
        <!-- Submit -->
        <div class="text-center mt-5">
            <button class="btn btn-success btn-lg px-5" ng-click="submitForm()">Submit Handover</button>
        </div>


        <button class="btn btn-warning" ng-click="fillDummyData()" ng-if="_currentUser.UserName=='anees@out2sol.com'">
            Fill Dummy Data (Testing)
        </button>

    </div>

 

