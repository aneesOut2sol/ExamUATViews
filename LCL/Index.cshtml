
@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .CardHeaderLink {
        display: inline-block;
        margin-right: 10px;
    }

    .timeHeader {
        background: #00946b;
        padding: 15px;
        color: white;
        font-size: 17px;
        border-top-right-radius: 10px;
        border-top-left-radius: 10px;
    }

    .tab {
        overflow: hidden;
    }

    .tabheading {
        padding: 10px;
        background: #00946b;
        color: white;
    }
    .tab button {
        border-top-right-radius: 10px;
        border-top-left-radius: 10px;
        background: #e9e9e9;
        padding: 10px 35px;
        border: none;
        outline: none;
        cursor: pointer;
        transition: 0.3s;
        font-size: 13px;
    }
       
    .tab button:hover {
        background-color: #00946b;
        color: white;
        font-size: 13px;
    }

    .tab button.active {
        background-color: #00946b !important;
        color: white;
        font-size: 13px;
    }

    .tab button {
        width: 100%;
    }
    .tab .row {
        border-bottom: 1px dashed #3333332e;
    }

    .tabcontent {
        display: none;
        padding: 0px 10px;
        border-top: none;
    }

    tbody tr:nth-child(even) td {
        background: none !important;
    }

    tbody tr:nth-child(even) {
        background-color: #f7f7ff !important;
    }

    .table td, .table th {
        border: none !important;
    }

    .table td, .table tr {
        border: none;
    }
    .LCLCard{
        padding:15px;
        border-radius:12px;
    }
    .JsTable{
        padding :0px 12px;
    }
    .JsTable table{
        width:100%;
    }
    .JsTable tr {
        border-bottom: 1px solid #33333329;
    }
    .JsTable {
        user-select: none;
    }
    .font-size-lg{
        font-size:24px;
    }
    .icon-check:hover{
        color:green;
    }
    .icon-close2:hover{
        color:red;
    }
    textarea{
        width:100%;
    }
    .AttachmentSection a{
        text-decoration:none;
        color:black;
        cursor:pointer;
    }
    .AttachmentSection a:hover {
        color: royalblue;       
        text-decoration:underline;
    }
    i{
        cursor:pointer;
        text-decoration:none;
    }
    .LCLCard {
        max-height: 500px;
        overflow: auto;
    }

    .LCLCard th, .LCLCard td{
        white-space:nowrap;
    }

    .jqueryConfrim .modal-content {
        border-top: solid 7px #3498db;
        border-radius: 6px !IMPORTANT;
        background: white !important;
    }

    .jqueryConfrim .modal-header h5 {
        font-size: 22px;
    }

    .jqueryConfrim .modal-header {
        justify-content: center !important;
    }

    .jqueryConfrim .btn-primary {
        background: #3498db;
        padding: 5px 11px;
        text-transform: uppercase;
    }

    .jqueryConfrim .btn-reset {
        background: #363636;
        padding: 5px 11px;
        text-transform: uppercase;
    }

    @@keyframes zoomIn {
        0% {
            opacity: 0;
            -webkit-transform: scale3d(.3, .3, .3);
            transform: scale3d(.3, .3, .3);
        }

        50% {
            opacity: 1;
        }
    }

    .ZoominAnimate {
        animation: zoomIn 0.2s linear;
    }
    #overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: #111111de;
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 999;
        display: none;
        overflow: scroll;
    }

    #overlay img {
        max-width: 90%;
        max-height: 90%;
        transition: transform 0.5s ease;
    }

    #close-btn {
        position: absolute;
        top: 15px;
        right: 15px;
        color: #fff;
        font-size: 20px;
        cursor: pointer;
    }

    ul.Damage_Images {
        padding: 0px;
        border: 1px solid #ececec;
    }

    ul.Damage_Images li .Icon span {
        padding: 7px;
        border: 1px solid #343434;
        border-radius: 50%;
        color: #6b6868 !important;
    }

    ul.Damage_Images li {
        padding: 12px 18px;
        list-style: none;
        border-bottom: 1px solid #e8e8e8cf;
        color: #6b6868 !important;
    }

    .Icon {
        width: fit-content;
        float: right;
    }
</style>

<div ng-controller="LCLCtrl" ng-cloak class="ng-cloak" ng-init="init()">


    <!-- Page header -->
    <div class="page-header border-bottom-0 blurbg">
        <div class="page-header-content header-elements-md-inline">
            <div class="page-title d-flex">
                <h4><i class="icon-tree6 mr-2"></i><span class="font-weight-semibold">LCL Pending Containers</span></h4>
            </div>
            @*<div class="page-title d-flex">
                    <input type="button" class="btn btn-secondary  pull-right mr-2" value="Filters" data-toggle="collapse" data-target="#demo" />
                </div>*@
        </div>
    </div>
    <hr />

    <!--Search Filter Code Start-->
    <div class="card collapse blurbg" id="demo">
        <div class="card-body">

            <div class="row">
                <div class="col-md-12 col-lg-12 col-sm-12">

                    <button class="btn btn-reset pull-right" ng-click="ResetFilters()">
                        Reset
                    </button>
                    <button class="btn btn-primary pull-right mr-2" ng-click="SearchLCL(Search)">
                        Search
                    </button>
                </div>
            </div>
        </div>
    </div>
    <!--Search Filter Code End-->


    <div class="row">
        <div class="col-md-12">
            <!--Tab Code Start -->
            <div class="tab">
                <div class="row">
                    <div class="CardHeaderLink  shadow-sm text-center ">
                        <button class="tablinks active" id="InitialInprogress" ng-click="SwitchTabs('InitialInprogress')"><i class="icon-stack-down mr-2"></i> Initial Requests<span class="CountBadge">{{SealCutCount}}</span></button>
                    </div>
                    <div class="CardHeaderLink  shadow-sm text-center ">
                        <button class="tablinks" id="GatepassInprogress" ng-click="SwitchTabs('GatepassInprogress')"><i class="icon-task mr-2"></i> Gate Pass Requests<span class="CountBadge">{{CargoStripCount}}</span></button>
                    </div>
                    <div class="CardHeaderLink  shadow-sm text-center ">
                        <button class="tablinks" id="ApprovedRequests" ng-click="SwitchTabs('ApprovedRequests')"><i class="icon-check mr-2"></i> Approved Requests <span class="CountBadge">{{CargoStripCount}}</span></button>
                    </div>
                    <div class="CardHeaderLink  shadow-sm text-center ">
                        <button class="tablinks" id="RejectedRequests" ng-click="SwitchTabs('RejectedRequests')"><i class="icon-close2 mr-2"></i> Rejected Requests <span class="CountBadge">{{CargoStripCount}}</span></button>
                    </div>
                </div>
            </div>
            <!--Tab Code End -->
        </div>
    </div>
    <div class="card LCLCard shadow-sm">

        <table class="table table-striped" ng-if="CurrentStatus == 'InitialInprogress'">
            <thead>
                <tr class="table-card-head">                    
                    <th>BL </th>
                    <th>Container </th>
                    <th>Bayan </th>
                    <th>DO No. </th>
                    <th>Attachment</th>
                    <th>Broker Id</th>
                    <th>Created By</th>
                    <th>Created At</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                <tr ng-repeat="item in LCLRecords | filter:search ">                   
                    <td>{{item.BL_nbr}}</td>
                    <td>
                        @*<img src="~/Content/images/container.png"
        id="{{$index+1+'a'}}"
        ng-mouseover="changeicon($index+1+'a','move')"
        ng-mouseleave="changeicon($index+1+'a','leave')"
        class="onhover list-icons-item"
        width="25"
        title="Container Details"
        ng-click="ShowContainerDetails(item.TransactionId)" />*@
                        {{item.ContainerNumber}}
                    </td>
                    <td>{{item.Bayanno}}</td>
                    <td>{{item.DeliverOrderNumber}}</td>
                    <td><i class="icon-eye font-size-lg" ng-click="OpenAttachment(item)"></i> </td>
                    <td>{{item.BrokerId}}</td>

                    <td>{{item.CreatedBy}}</td>
                    <td>{{item.CreatedAt | date:'dd/MM/yyyy HH:mm'}}</td>
                    <td ng-if="CurrentStatus == 'InitialInprogress' || CurrentStatus == 'GatepassInprogress'">
                        <span ng-click="TakeLCLAction('Approve',item)">
                            <i class="icon-check d-inline-block font-size-lg" title="Approve"> </i>
                        </span>
                        <span ng-click="TakeLCLAction('Reject',item)">
                            <i class="icon-close2 d-inline-block  font-size-lg" title="Reject"></i>
                        </span>
                    </td>
                </tr>
            </tbody>
        </table>

        <table class="table table-striped" ng-if="CurrentStatus == 'GatepassInprogress'">
            <thead>
                <tr class="table-card-head">                   
                    <th>BL </th>
                    <th>Container </th>
                    <th>Bayan </th>
                    <th>DO No. </th>
                    <th>Attachment</th>
                    <th>Broker Id</th>
                    <th>Truck No</th>
                    <th>Driver</th>
                    <th>Driver Phone</th>
                    <th>Created By</th>
                    <th>Created At</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                <tr ng-repeat="item in LCLRecords | filter:search ">                  
                    <td>{{item.BL_nbr}}</td>
                    <td>
                        {{item.ContainerNumber}}
                    </td>
                    <td>{{item.Bayanno}}</td>
                    <td>{{item.DeliverOrderNumber}}</td>
                    <td><i class="icon-eye font-size-lg" ng-click="OpenAttachment(item)"></i> </td>
                    <td>{{item.BrokerId}}</td>
                    <td>{{item.TruckNo}}</td>
                    <td>{{item.DriverName}}</td>
                    <td>{{item.DriverPhone}}</td>
                    <td>{{item.CreatedBy}}</td>
                    <td>{{item.CreatedAt | date:'dd/MM/yyyy HH:mm'}}</td>
                    <td>
                        <span ng-click="TakeLCLAction('Approve',item)">
                            <i class="icon-check d-inline-block font-size-lg" title="Approve"> </i>
                        </span>
                        <span ng-click="TakeLCLAction('Reject',item)">
                            <i class="icon-close2 d-inline-block  font-size-lg" title="Reject"></i>
                        </span>
                    </td>
                </tr>
            </tbody>
        </table>


        <table class="table table-striped" ng-if="CurrentStatus == 'ApprovedRequests'">
            <thead>
                <tr class="table-card-head">                  
                    <th>Type </th>
                    <th>BL </th>
                    <th>Container </th>
                    <th>Bayan </th>
                    <th>DO No. </th>
                    <th>Attachment</th>
                    <th>Cargo Details</th>
                    <th>Broker Id</th>
                    <th>Truck No</th>
                    <th>Driver</th>
                    <th>Driver Phone</th>
                    <th>Created By</th>
                    <th>Created At</th>
                    <th>Approved By</th>
                    <th>Approved Time</th>
                </tr>
            </thead>
            <tbody>
                <tr ng-repeat="item in LCLRecords | filter:search ">                   
                    <td>
                        <span ng-if="item.Type == 'GatepassApproved'">Gatepass</span>
                        <span ng-if="item.Type == 'InitialApproved'">Initial</span>
                    </td>                   
                    <td>{{item.BL_nbr}}</td>
                    <td>
                        {{item.ContainerNumber}}
                    </td>
                    <td>{{item.Bayanno}}</td>
                    <td>{{item.DeliverOrderNumber}}</td>
                    <td><i class="icon-eye font-size-lg" ng-click="OpenAttachment(item)"></i> </td>
                    <td><i class="icon-eye font-size-lg" ng-if="item.CargoImages.length>0" ng-click="OpenCargoImages(item)"></i> </td>
                    <td>{{item.BrokerId}}</td>
                    <td>{{item.TruckNo}}</td>
                    <td>{{item.DriverName}}</td>
                    <td>{{item.DriverPhone}}</td>
                    <td>{{item.CreatedBy}}</td>
                    <td>{{item.CreatedAt | date:'dd/MM/yyyy HH:mm'}}</td>
                    <td>{{item.UpdatedBy}}</td>
                    <td>{{item.UpdatedAt | date:'dd/MM/yyyy HH:mm'}}</td>

                </tr>
            </tbody>
        </table>

        <table class="table table-striped" ng-if="CurrentStatus == 'RejectedRequests'">
            <thead>
                <tr class="table-card-head">                   
                    <th>Type </th>
                    <th>BL </th>
                    <th>Container </th>
                    <th>Bayan </th>
                    <th>DO No. </th>
                    <th>Attachment</th>
                    <th>Broker Id</th>
                    <th>Truck No</th>
                    <th>Driver</th>
                    <th>Driver Phone</th>
                    <th>Created By</th>
                    <th>Created At</th>
                    <th>Rejected By</th>
                    <th>Rejected Time</th>
                    <th>Reason</th>
                </tr>
            </thead>
            <tbody>
                <tr ng-repeat="item in LCLRecords | filter:search ">                   
                    <td>
                        <span ng-if="item.Type == 'InitialRejected'">Initial</span>
                        <span ng-if="item.Type == 'GatepassRejected'">Gatepass</span>
                    </td>                    
                    <td>{{item.BL_nbr}}</td>
                    <td>
                        {{item.ContainerNumber}}
                    </td>
                    <td>{{item.Bayanno}}</td>
                    <td>{{item.DeliverOrderNumber}}</td>
                    <td><i class="icon-eye font-size-lg" ng-click="OpenAttachment(item)"></i> </td>
                    <td>{{item.BrokerId}}</td>
                    <td>{{item.TruckNo}}</td>
                    <td>{{item.DriverName}}</td>
                    <td>{{item.DriverPhone}}</td>
                    <td>{{item.CreatedBy}}</td>
                    <td>{{item.CreatedAt | date:'dd/MM/yyyy HH:mm'}}</td>
                    <td>{{item.UpdatedBy}}</td>
                    <td>{{item.UpdatedAt | date:'dd/MM/yyyy HH:mm'}}</td>    
                    <td>{{item.RejectReason}}</td>
                </tr>
            </tbody>
        </table>
    </div>




    <div class="modal ZoominAnimate jqueryConfrim" id="InitalApprovalConfirmation" tabindex="-1" data-backdrop="static" data-keyboard="false" role="dialog" aria-labelledby="exampleModalCenterTitle">
        <div class="modal-dialog modal-dialog-centered" role="document" style="min-width:30%;">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="">
                        <b>Inital Approval Confirmation!</b>
                    </h5>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-6 col-sm-6 col-lg-6">
                            <div class="form-group">
                                <label>Cargo quantity</label>
                                <input type="text" class="form-control" autocomplete="off" onkeypress="return event.charCode>=48 && event.charCode<=57" ng-model="LCLItem.CargoQuantity" value="" />
                            </div>
                        </div>
                        <div class="col-md-12">
                            <label>LCL Images</label>
                            <ul class="Damage_Images">
                                <li ng-repeat="x in LCLItem.Images">
                                    <b>{{x.Label}}</b>
                                    <div class="Icon" ng-show="x.Url==null || x.Url==''">
                                        <label title="Upload Image" style="margin:0px;">
                                            <span><i class="icon-images2"></i></span>
                                            <input type="file" style="display:none" accept="image/*" id="Damg{{$index}}" index="{{$index}}" name="pic" accept="image/*" onchange="angular.element(this).scope().LCLImagesUpload(this,'LCLItem')">
                                        </label>

                                    </div>
                                    <div class="Icon" ng-show="x.Url!=null && x.Url!=''">
                                        <a title="View Image" ng-click="OpenImageView(x.Url,'InitalApprovalConfirmation')"><span><i class="icon-eye"></i></span></a>
                                        <span title="Delete Image" ng-click="RemoveImage($index,'LCLItem')"><i class="icon-bin"></i></span>
                                    </div>
                                </li>
                            </ul>
                        </div>

                    </div>


                </div>
                <div class="modal-footer" style=" padding: 9px; ">
                    <button class="btn btn-primary" ng-click="TakeLCLAction('Approve',LCLItem)">Approve</button>
                    <button class="btn btn-reset" data-dismiss="modal" ng-click="ModalSubmission=false;">Close</button>
                </div>
            </div>
        </div>
    </div>

    <div id="overlay">
        <span id="close-btn" ng-click="closeOverlay()">&#10006;</span>
        <img src="" id="LargeImageView" alt="Image">
    </div>


</div>
<script src="@Url.Content("~/Scripts/crypto-js.min.js")"></script>
<script>

    function copytoClipBoard(txt) {
        if (navigator.clipboard) {
            navigator.clipboard.writeText(txt);
            toastr.success("Copied to clipboard");
        }
    }

    window.onload = function () {
        document.getElementById('minisidebar').className = 'sidebar-xs';
    };
</script>