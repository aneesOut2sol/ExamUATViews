@model System.Web.Mvc.HandleErrorInfo
@{
    ViewBag.Title = "System Error";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <title>DPWorld Jeddah Exam - @ViewBag.Title</title>
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">

    <link href="~/Content/css/icons/icomoon/styles.min.css" rel="stylesheet" />
    <link rel="icon" type="image/x-icon" sizes="16x16" href="~/Content/images/favicon.ico">
    <link href="~/Content/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/Content/css/bootstrap_limitless.min.css" rel="stylesheet" />
    <link href="~/Content/css/layout.min.css" rel="stylesheet" />
    <link href="~/Content/css/colors.min.css" rel="stylesheet" />

    <style>
        :root {
            --dpw-primary-dark: #1E1450;
        }

        html, body {
            height: 100%;
            margin: 0;
            background: linear-gradient(to bottom right, #1E1450 0%, #3b2a8d 50%, #5c4aa8 100%);
        }

        .page-content {
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            padding: 20px;
        }

        .ErrorCard {
            width: 100%;
            max-width: 500px;
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.4);
            border-radius: 8px;
            overflow: hidden;
            background: transparent;
        }

        .card-body {
            background: #ffffff;
            padding: 40px 30px;
            border-radius: 8px;
            text-align: center;
        }

        .error-icon-container {
            margin-bottom: 25px;
        }

            .error-icon-container i {
                font-size: 72px;
                color: #f0ad4e; /* Warning Orange */
                padding: 20px;
                background: rgba(240, 173, 78, 0.1);
                border-radius: 50%;
            }

        .card-body h2 {
            color: var(--dpw-primary-dark);
            font-weight: 700;
            margin-bottom: 15px;
        }

        .card-body p {
            color: #666;
            font-size: 1.1rem;
            margin-bottom: 30px;
        }

        .error-details {
            background: #f8f9fa;
            border: 1px dashed #ccc;
            padding: 15px;
            text-align: left;
            margin-bottom: 25px;
            border-radius: 4px;
        }

            .error-details code {
                color: #d9534f;
                word-break: break-all;
            }

        .btn-primary {
            background-color: var(--dpw-primary-dark) !important;
            border-color: var(--dpw-primary-dark) !important;
            height: 48px;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 0 25px;
        }

        .footer-text {
            text-align: center;
            margin-top: 20px;
            color: rgba(255, 255, 255, 0.8);
            font-size: 0.85rem;
        }
    </style>
</head>
<body>
    <div class="page-content">
        <div class="ErrorCard">
            <div class="card mb-0">
                <div class="card-body">
                    <div class="error-icon-container">
                        <i class="icon-warning22"></i>
                    </div>

                    <h2>Something went wrong</h2>
                    <p>We encountered an unexpected error while processing your request. Our technical team has been notified.</p>

                    @if (Model != null && HttpContext.Current.IsDebuggingEnabled)
                    {
                        <div class="error-details">
                            <small class="text-uppercase font-weight-bold text-muted">Debug Info:</small><br />
                            <code>@Model.Exception.Message</code>
                        </div>
                    }

                    <div class="d-flex justify-content-center gap-2">
                        <a href="javascript:history.back()" class="btn btn-light mr-2">
                            <i class="icon-arrow-left8 mr-2"></i> Go Back
                        </a>                       
                    </div>
                </div>
            </div>
            <p class="footer-text">&copy; @DateTime.Now.Year DP World. All rights reserved.</p>
        </div>
    </div>
</body>
</html>