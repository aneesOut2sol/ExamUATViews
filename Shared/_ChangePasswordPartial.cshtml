<style>
    /* Side Panel Positioning */
    #ChangePasswordModel {
        z-index: 999999;
    }
    #ChangePasswordModel.modal.fade .modal-dialog {
        position: fixed;
        margin: auto;
        width: 400px;
        height: 100%;
        right: -400px; /* Hidden state */
        top: 0;
        transition: right 0.3s ease-out;
    }

    #ChangePasswordModel.modal.show .modal-dialog {
        right: 0; /* Visible state */
    }

    #ChangePasswordModel .modal-content {
        height: 100%;
        border-radius: 0 !important;
        border: none;
        display: flex;
        flex-direction: column;
        box-shadow: -5px 0 25px rgba(0,0,0,0.1);
    }

    /* Header Styling */
    #ChangePasswordModel .modal-header {
        padding: 24px;
        background: #ffffff;
        border-bottom: 1px solid #f1f5f9 !important;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    #ChangePasswordModel .modal-title {
        font-weight: 700 !important;
        color: #0f172a;
        font-size: 1.25rem;
    }

    /* Close Icon */
    #ChangePasswordModel .CloseModalBtn {
        cursor: pointer;
        padding: 8px;
        border-radius: 8px;
        transition: background 0.2s;
        line-height: 1;
    }

        #ChangePasswordModel .CloseModalBtn:hover {
            background: #f1f5f9;
        }

    /* Body/Scroll Area */
    #ChangePasswordModel .modal-body {
        flex: 1;
        overflow-y: auto;
        padding: 30px 24px;
    }

    #ChangePasswordModel label {
        display: block;
        font-weight: 600;
        font-size: 0.85rem;
        color: #64748b;
        margin-bottom: 8px;        
        letter-spacing: 0.025em;
    }

    #ChangePasswordModel .form-control {
        height: 48px;
        border-radius: 8px;
        border: 1px solid #e2e8f0;
        margin-bottom: 20px;
        font-size: 1rem;
        transition: all 0.2s;
    }

        #ChangePasswordModel .form-control:focus {
            border-color: #2563eb;
            box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
            outline: none;
        }

    /* Validation UI */
    .pg-validation-list {
        list-style: none;
        padding: 16px;
        margin: -10px 0 20px 0;
        background: #f8fafc;
        border-radius: 8px;
    }

        .pg-validation-list li {
            font-size: 0.85rem;
            margin-bottom: 8px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .pg-validation-list li:last-child {
                margin-bottom: 0;
            }

    .pg-invalid {
        color: #94a3b8;
    }

    .pg-valid {
        color: #10b981;
        font-weight: 600;
    }

    .pg-invalid::before {
        content: "○";
        font-size: 1.2rem;
    }

    .pg-valid::before {
        content: "●";
        font-size: 1.2rem;
    }

    /* Footer / Action Buttons */
    #ChangePasswordModel .modal-footer {
        padding: 20px 24px;
        border-top: 1px solid #f1f5f9 !important;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
        background: #ffffff;
    }

    .btn-update {
        background: #013765;
        color: white;
        border: none;
        padding: 12px;
        border-radius: 8px;
        font-weight: 600;
        transition: background 0.2s;
    }

        .btn-update:hover {
            background: #1d4ed8;
            color: white;
        }

    .btn-cancel {
        background: #ffffff;
        color: #64748b;
        border: 1px solid #e2e8f0;
        padding: 12px;
        border-radius: 8px;
        font-weight: 600;
        transition: all 0.2s;
    }

        .btn-cancel:hover {
            background: #f8fafc;
            color: #0f172a;
        }

    /* Fix for Bootstrap backdrop */
    .modal-backdrop.show {
        opacity: 0.4;
    }
    .ForcedPassword li::before{
        content:'x';
        font-size:10px;
    }
    .ForcedPassword li {
        font-size:10px;
    }
</style>

<div class="modal fade" id="ChangePasswordModel" data-backdrop="static" data-keyboard="false" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Change Password</h5>
                <div class="CloseModalBtn" data-dismiss="modal">
                    <span>✕</span>
                </div>
            </div>

            <div class="modal-body">
                <form autocomplete="off" id="ij">
                    <label>Current password</label>
                    <input type="password" class="form-control" ng-model="PChange.OldPassword" placeholder="Enter current password"/>

                    <label>New password</label>
                    <input type="password" class="form-control" id="pg-password-input" ng-model="PChange.NewPassword" placeholder="Enter new password" autocomplete="off"/>

                    <ul class="pg-validation-list">
                        <li id="pg-len" class="pg-invalid">At least 6 characters</li>
                        <li id="pg-upper" class="pg-invalid">One uppercase letter</li>
                        <li id="pg-lower" class="pg-invalid">One lowercase letter</li>
                        <li id="pg-digit" class="pg-invalid">One number</li>
                        <li id="pg-special" class="pg-invalid">One special character</li>
                    </ul>

                    <label>Confirm new password</label>
                    @*<input type="password" class="form-control" ng-model="PChange.ConfirmPassword" placeholder="Repeat new password"/>*@
                </form>
            </div>

            <div class="modal-footer">
                <button class="btn btn-cancel" data-dismiss="modal">Cancel</button>
                <button class="btn btn-update" ng-click="ChangeSelfPassword(PChange)">Update Password</button>
            </div>
        </div>
    </div>
</div>
<div class="modal fade" id="FPC" tabindex="-1" role="dialog" data-backdrop="static" data-keyboard="false" aria-labelledby="exampleModalCenterTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="CloseModalBtn" data-dismiss="modal" aria-label="Close" ng-show="PasswordExpiryResp.About2Expire==true">
                <button class="close" data-dismiss="modal" aria-label="Close"></button>
                <i class="icon-cross"></i>
            </div>
            <div class="modal-header">
                <h5 class="modal-title">
                    Warning: Password Expiry
                    
                </h5>

            </div>
            <div class="modal-body">
                <p ng-show="PasswordExpiryResp.About2Expire==true" style="color:red"><strong>Your current password will expire in {{PasswordExpiryResp.ExprieINDays}} days. For security reasons, you are required to change your password</strong></p>
                <p ng-show="PasswordExpiryResp.Expired==true" style="color:red"><strong>Your current password has been  expired. For security reasons, you are required to change your password</strong></p>
                <form autocomplete="off">
                    <label class="Starick">Current password</label>
                    <input type="password" class="form-control" ng-model="PChange.OldPassword" placeholder="Enter current password">
                    <br />
                    <label class="Starick">New password</label>
                    <input type="password" class="form-control" id="pg-password-input" ng-model="PChange.NewPassword" placeholder="Enter new password" autocomplete="off">

                    <ul class="pg-validation-list ForcedPassword">
                        <li id="pg-len" class="pg-invalid">At least 6 characters</li>
                        <li id="pg-upper" class="pg-invalid">One uppercase letter</li>
                        <li id="pg-lower" class="pg-invalid">One lowercase letter</li>
                        <li id="pg-digit" class="pg-invalid">One number</li>
                        <li id="pg-special" class="pg-invalid">One special character</li>
                    </ul>
                    
                    <label class="Starick">Confirm new password</label>
                    <input type="password" class="form-control" ng-model="PChange.ConfirmPassword" placeholder="Repeat new password">
                </form>
            </div>
            <div class="modal-footer">
                <div class="row">
                    <div class="col-md-12" style="text-align:end;">
                        <button class="btn btn-primary" ng-click="ChangeSelfPassword(PChange)">Update Password</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<script>
    // Logic remains exactly as provided
    const passwordInput = document.getElementById('pg-password-input');
    const requirements = {
        len: (val) => val.length >= 6,
        upper: (val) => /[A-Z]/.test(val),
        lower: (val) => /[a-z]/.test(val),
        digit: (val) => /[0-9]/.test(val),
        special: (val) => /[^A-Za-z0-9]/.test(val)
    };

    passwordInput.addEventListener('input', () => {
        const value = passwordInput.value;
        for (const [key, test] of Object.entries(requirements)) {
            const element = document.getElementById(`pg-${key}`);
            if (test(value)) {
                element.classList.remove('pg-invalid');
                element.classList.add('pg-valid');
            } else {
                element.classList.remove('pg-valid');
                element.classList.add('pg-invalid');
            }
        }
    });
</script>