                                        <tbody ng-repeat="c in TrainingList1.ModuleList1">
                                            <tr tabindex="0">
                                                <td>{{c.TrainingModule}}</td>
                                                <td>{{c.Hours}}</td>
                                                <td>{{c.Grade}}</td>


                                            </tr>

                                        </tbody>
                                    </table>*@
                 
                    
                   
