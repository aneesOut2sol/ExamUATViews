@using ExamPortal.Model.Resources
@using ExamPortal.Model.EntityModel.Enums
@{
    ViewBag.Title = "Reset Password";
}

<div ng-controller="UsersCtr" ng-init="initEdit()" class="container-fluid py-4 userresetpasspage">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div class="page-title">
            <h4 class="m-0 font-weight-bold text-dark">
                <i class="icon-key mr-2 text-primary"></i> Reset User Password
            </h4>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb bg-transparent p-0 mt-1" style="font-size: 0.85rem;">
                    <li class="breadcrumb-item"><a href="@Url.Action("Index","Users")">Users</a></li>
                    <li class="breadcrumb-item active">Reset Password</li>
                </ol>
            </nav>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-lg">
        <div class="card-body p-4">
            <div class="row">
                <div class="col-md-6 border-right">
                    <h6 class="text-muted mb-3 font-weight-semibold text-uppercase" style="letter-spacing: 1px; font-size: 0.75rem;">User Information</h6>
                    <div class="row">
                        <div class="col-md-12">
                            <div class="form-group mb-3">
                                <label class="text-muted small font-weight-bold">Email Address</label>
                                <div class="input-group">
                                    <div class="input-group-prepend">
                                        <span class="input-group-text bg-light border-0"><i class="icon-envelop5"></i></span>
                                    </div>
                                    <input type="text" id="Email" class="form-control bg-light border-0"
                                           placeholder="{{data.Email}}" ng-model="User.Email"
                                           value="{{data.Email}}" disabled>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-12">
                            <div class="form-group mb-3">
                                <label class="text-muted small font-weight-bold">Username</label>
                                <div class="input-group">
                                    <div class="input-group-prepend">
                                        <span class="input-group-text bg-light border-0"><i class="icon-user"></i></span>
                                    </div>
                                    <input type="text" id="Name" class="form-control bg-light border-0"
                                           placeholder="{{data.Username}}" ng-model="User.Username"
                                           value="{{data.Username}}" disabled>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-6 pl-md-4">
                    <h6 class="text-muted mb-3 font-weight-semibold text-uppercase" style="letter-spacing: 1px; font-size: 0.75rem;">Security Credentials</h6>
                    <div class="form-group mb-3">
                        <label class="font-weight-bold small" for="Password">New Password*</label>
                        <input type="password" id="pg-password-input" class="form-control shadow-none"
                               placeholder="Enter new password" ng-model="User.Password"
                               autofocus tabindex="1" style="border-radius: 6px;">
                        
                            <ul class="pg-validation-list">
                                <li id="pg-len" class="pg-invalid">At least 6 characters</li>
                                <li id="pg-upper" class="pg-invalid">One uppercase letter</li>
                                <li id="pg-lower" class="pg-invalid">One lowercase letter</li>
                                <li id="pg-digit" class="pg-invalid">One number</li>
                                <li id="pg-special" class="pg-invalid">One special character</li>
                            </ul>
                    </div>

                    <div class="form-group mb-4">
                        <label class="font-weight-bold small" for="Confirm_Password">Confirm New Password*</label>
                        <input type="password" id="Confirm_Password" class="form-control shadow-none"
                               placeholder="Repeat your password" ng-model="User.ConfirmPassword"
                               tabindex="2" style="border-radius: 6px;">
                    </div>

                    <div class="d-flex justify-content-end align-items-center pt-2">
                        <a onclick="window.location='@Url.Action("Index","Users")'"
                           class="btn btn-link text-muted mr-3" tabindex="4">
                            Cancel
                        </a>
                        <button type="button" ng-click="ResetPassword(User)"
                                class="btn btn-primary px-4 shadow-sm" tabindex="3"
                                style="border-radius: 6px; font-weight: 500;">
                            <i class="icon-checkmark3 mr-2"></i> Update Password
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Modern UI Enhancements */
    .form-control:focus {
        border-color: #1E1450;
        box-shadow: 0 0 0 0.2rem rgba(33, 150, 243, 0.1);
    }

    .card {
        transition: all 0.3s ease;
    }

    .btn-primary {
        background-color: #1E1450;
        border-color: #1E1450;
    }

        .btn-primary:hover {
            background-color: #7458ff;
        }

    .input-group-text {
        color: #999;
    }
    .text-primary {
        color: #1E1450 !important;
    }
    .breadcrumb-item a {
        color: #1E1450 !important;
    }
    .input-group-text i{
        color:#fff;
    }
    .userresetpasspage .pg-validation-list
    {
        padding: 6px;
        margin-top:6px;
    }
    .userresetpasspage .pg-validation-list li {
        font-size: 9px;        
        gap: 5px;
        margin-bottom:0px;
    }
    .userresetpasspage .pg-invalid::before {
        content: "x";
        font-size: 09px;
    }
    
</style>
<script>
    const passwordInput = document.getElementById('pg-password-input');
    const requirements = {
        len: (val) => val.length >= 6,
        upper: (val) => /[A-Z]/.test(val),
        lower: (val) => /[a-z]/.test(val),
        digit: (val) => /[0-9]/.test(val),
        special: (val) => /[^A-Za-z0-9]/.test(val)
    };

    passwordInput.addEventListener('input', () => {
        const value = passwordInput.value;
        for (const [key, test] of Object.entries(requirements)) {
            const element = document.getElementById(`pg-${key}`);
            if (test(value)) {
                element.classList.remove('pg-invalid');
                element.classList.add('pg-valid');
            } else {
                element.classList.remove('pg-valid');
                element.classList.add('pg-invalid');
            }
        }
    });
</script>