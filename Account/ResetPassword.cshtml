@model ExamPortal.Web.Models.ResetPasswordViewModel
@{
    ViewBag.Title = "Reset password";
    Layout = null;
    <link href="@Url.Content("~/Content/css/libs/bootstrap/bootstrap.min.css")" rel="stylesheet">
    <link href="@Url.Content("~/Content/css/style.css")" rel="stylesheet">
    <link href="@Url.Content("~/Content/css/helper.css")" rel="stylesheet">
}




<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <title>
        DPWorld Jeddah Exam - Forgot
    </title>
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="author" content="EXAM DpWorld">
    <link href="@Url.Content("~/Content/css/libs/bootstrap/bootstrap.min.css")" rel="stylesheet">
    <link href="@Url.Content("~/Content/css/style.css")" rel="stylesheet">
    <link href="@Url.Content("~/Content/css/helper.css")" rel="stylesheet">
    <link href="~/Content/css/icons/icomoon/styles.min.css" rel="stylesheet" />
    <link rel="icon" type="image/x-icon" sizes="16x16" href="~/Content/images/favicon.ico">
    <link href="~/Content/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/Content/css/bootstrap_limitless.min.css" rel="stylesheet" />
    <link href="~/Content/css/layout.min.css" rel="stylesheet" />
    <link href="~/Content/css/colors.min.css" rel="stylesheet" />
    <script src="~/Scripts/PasswordFields.js"></script>

    <style>
        @@keyframes loader {
            0% {
                transform: rotate(0deg);
            }

            100% {
                transform: rotate(360deg);
            }
        }

        .loader {
            animation: 0.7s loader linear infinite;
        }
        /* Define the primary color variable (Using the requested dark color for accents) */
        :root {
            --dpw-primary-dark: #1E1450; /* The requested dark indigo */
        }

        /* Full page background and centered content - NEW GRADIENT BACKGROUND */
        html, body {
            height: 100%;
            margin: 0;
            background: linear-gradient( to bottom right, #1E1450 0%, /* Deep Indigo */
            #3b2a8d 50%, /* Mid Purple */
            #5c4aa8 100% /* Medium Blue-Purple */
            );
        }

        .page-content {
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            padding: 20px;
        }

        /* Login Card Styling */
        .LoginCard {
            width: 100%;
            max-width: 400px;
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.4);
            border-radius: 8px;
            overflow: hidden;
            margin: 0;
            background: transparent;
        }

        /* Form Body Background - Set to white for high contrast */
        .card-body {
            background: #ffffff;
            padding: 30px;
        }

            /* Branding and Messaging */
            .card-body .text-center {
                /* Ensures proper spacing for the logo and text */
                margin-bottom: 20px;
            }

                .card-body .text-center h6 {
                    color: var(--dpw-primary-dark);
                    font-size: 1.5rem;
                    margin-top: 15px; /* Spacing below the logo */
                    margin-bottom: 5px;
                }

                /* Logo Styling */
                .card-body .text-center img {
                    max-height: 100px; /* Set a reasonable size for the logo */
                    width: auto;
                    margin-bottom: 5px;
                }


                .card-body .text-center span.d-block {
                    color: #666;
                    margin-bottom: 25px;
                }

        /* Form Controls */
        .form-control {
            border-radius: 4px;
            height: 48px;
            font-size: 16px;
            border: 1px solid #ccc;
        }

            .form-control:focus {
                border-color: var(--dpw-primary-dark);
                box-shadow: 0 0 0 0.2rem rgba(30, 20, 80, 0.25);
            }

        /* Feedback Icons */
        .form-group-feedback-left .form-control {
            padding-left: 3.5rem !important;
        }

        .form-control-feedback {
            background: transparent;
            color: var(--dpw-primary-dark);
            border-right: 1px solid #ccc;
            width: 3.0rem;
            line-height: 48px;
            height: 48px;
            padding: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            top: 0;
        }

        /* Primary Button Style (Using the requested dark color) */
        .btn-primary {
            background-color: var(--dpw-primary-dark) !important;
            border-color: var(--dpw-primary-dark) !important;
            height: 48px;
            font-size: 1rem;
            font-weight: 600;
            transition: background-color 0.2s;
        }

            .btn-primary:hover, .btn-primary:focus {
                background-color: #100b33 !important; /* Slightly darker on hover */
                border-color: #100b33 !important;
            }

        /* Error Messages */
        .validation-summary-errors, .text-danger {
            color: #d9534f !important;
        }

        .validation-summary-errors {
            border: 1px solid #d9534f;
            background-color: #f2dede;
            padding: 10px;
            border-radius: 4px;
            margin-bottom: 15px;
        }

        /* Footer text/link styling */
        .pull-right {
            color: var(--dpw-primary-dark);
            font-size: 0.9rem;
            margin-bottom: 10px;
            display: block;
            text-align: right;
        }

        /* Footer Copyright/Branding */
        .footer-text {
            text-align: center;
            margin-top: 20px;
            color: rgba(255, 255, 255, 0.8);
            font-size: 0.85rem;
        }
    </style>
</head>
<body>
    <div class="page-content">
        <div class="LoginCard">

            <div class="card mb-0">
                <div class="card-body">
                    <div class="text-center mb-3">
                        <img src="~/Content/images/dpworldlogo.png" alt="DPWorld Logo" />

                        <h6 class="mb-0 font-weight-bold">Find my account</h6>
                    </div>
                    @using (Html.BeginForm("ResetPassword", "Account", FormMethod.Post, new { @class = "form-horizontal", role = "form" }))
                    {

                        if (TempData["CustomErrorForgotPassword"] != null && TempData["CustomErrorForgotPassword"].ToString() != "")
                        {
                            <div class="validation-summary-errors">
                                <ul>
                                    <li>@TempData["CustomErrorForgotPassword"]</li>
                                    <li>
                                        @Html.ValidationSummary("", new { @class = "text-danger" })
                                    </li>
                                </ul>
                            </div>
                        }

                        @Html.AntiForgeryToken()
                        @Html.ValidationSummary("", new { @class = "text-danger" })
                        @Html.HiddenFor(model => model.Code)

                        <div class="form-group form-group-feedback form-group-feedback-left">
                            @Html.TextBoxFor(m => m.Email, new { @class = "form-control", placeholder = "Password" })
                            <div class="form-control-feedback">
                                <i class="icon-mail5"></i>
                            </div>

                        </div>
                        <div class="form-group form-group-feedback form-group-feedback-left">
                            @Html.PasswordFor(m => m.Password, new { @class = "form-control", placeholder = "Password" })
                            
                            <div class="form-control-feedback">
                                <i class="icon-lock2"></i>
                            </div>

                        </div>
                        <div class="form-group form-group-feedback form-group-feedback-left">
                            @Html.PasswordFor(m => m.ConfirmPassword, new { @class = "form-control", placeholder = "Confirm password" })


                            <div class="form-control-feedback">
                                <i class="icon-lock2"></i>
                            </div>

                        </div>
                        <div class="form-group mt-3">
                            <button type="submit" class="btn btn-primary btn-block" onclick="this.disabled=true;this.form.submit();this.innerHTML=`Processing... <i class='icon-spinner2 loader'></i>`" value="Email Link">
                                Reset <i class="icon-icon-circle-right2 ml-2"></i>

                            </button>
                        </div>

                    }

                </div>
            </div>

            <p class="footer-text">&copy; @DateTime.Now.Year DP World. All rights reserved.</p>
        </div>
    </div>
 
    @section Scripts {
        @Scripts.Render("~/bundles/jqueryval")
    }
    <script src="~/Scripts/js/plugins/blockui.min.js"></script>
    <script src="~/Scripts/js/plugins/uniform.min.js"></script>
    <script src="~/Scripts/js/app.js"></script>
    <script src="~/Scripts/js/plugins/login.js"></script>
</body>
</html>
