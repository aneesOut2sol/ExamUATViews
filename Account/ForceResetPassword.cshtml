@model ExamPortal.Web.Models.ForceResetPasswordViewModel
@{
    ViewBag.Title = "Reset Password";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <title>DPWorld Jeddah Exam - @ViewBag.Title</title>
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">

    <link href="~/Content/css/icons/icomoon/styles.min.css" rel="stylesheet" />
    <link rel="icon" type="image/x-icon" sizes="16x16" href="~/Content/images/favicon.ico">
    <link href="~/Content/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/Content/css/bootstrap_limitless.min.css" rel="stylesheet" />
    <link href="~/Content/css/layout.min.css" rel="stylesheet" />
    <link href="~/Content/css/colors.min.css" rel="stylesheet" />

    <style>
        :root {
            --dpw-primary-dark: #1E1450;
        }

        html, body {
            height: 100%;
            margin: 0;
            background: linear-gradient(to bottom right, #1E1450 0%, #3b2a8d 50%, #5c4aa8 100%);
        }

        .page-content {
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            padding: 20px;
        }

        .ResetCard {
            width: 100%;
            max-width: 450px;
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.4);
            border-radius: 8px;
            overflow: hidden;
            background: transparent;
        }

        .card-body {
            background: #ffffff;
            padding: 30px;
            border-radius: 8px;
        }

            .card-body .text-center img {
                max-height: 70px;
                width: auto;
                margin-bottom: 15px;
            }

        .form-control {
            height: 45px;
            border: 1px solid #ddd;
        }

        .btn-primary {
            background-color: var(--dpw-primary-dark) !important;
            border-color: var(--dpw-primary-dark) !important;
            height: 48px;
            font-weight: 600;
        }

        /* Password Validation Styling */
        #message {
            display: none;
            background: #f8f9fe;
            border: 1px solid #e1e6f0;
            padding: 15px;
            margin-bottom: 20px;
            border-radius: 4px;
        }

            #message div {
                font-size: 13px;
                margin-bottom: 5px;
                transition: all 0.3s ease;
            }

        .valid {
            color: #28a745;
            font-weight: 600;
        }

        .invalid {
            color: #dc3545;
        }

        .valid:before {
            content: "\e600"; /* Icomoon check */
            font-family: 'icomoon';
            margin-right: 10px;
        }

        .invalid:before {
            content: "\ed63"; /* Icomoon cross */
            font-family: 'icomoon';
            margin-right: 10px;
        }

        .starick:after {
            content: " *";
            color: red;
        }

        .footer-text {
            text-align: center;
            margin-top: 20px;
            color: rgba(255, 255, 255, 0.8);
            font-size: 0.85rem;
        }
    </style>
</head>
<body>
    <div class="page-content">
        <div class="ResetCard">
            @using (Html.BeginForm("ForceResetPassword", "Account", FormMethod.Post, new { role = "form" }))
            {
                @Html.AntiForgeryToken()

                <div class="card mb-0">
                    <div class="card-body">
                        <div class="text-center mb-3">
                            <img src="~/Content/images/dpworldlogo.png" alt="DPWorld Logo" />
                            <h6 class="font-weight-bold mb-0">Reset Your Password</h6>
                            <span class="d-block text-muted">Please update your credentials to continue.</span>
                        </div>

                        <div class="form-group">
                            @Html.LabelFor(m => m.OldPassword, new { @class = "form-label starick font-weight-semibold" })
                            <div class="form-group-feedback form-group-feedback-left">
                                @Html.PasswordFor(m => m.OldPassword, new { @class = "form-control", placeholder = "Current Password", id = "OldPassword" })
                                <div class="form-control-feedback"><i class="icon-lock2"></i></div>
                            </div>
                            @Html.ValidationMessageFor(m => m.OldPassword, "", new { @class = "text-danger small" })
                        </div>

                        <div class="form-group">
                            @Html.LabelFor(m => m.Password, new { @class = "form-label starick font-weight-semibold" })
                            <div class="form-group-feedback form-group-feedback-left">
                                @Html.PasswordFor(m => m.Password, new
                                {
                                    @class = "form-control",
                                    placeholder = "New Password",
                                    id = "Password",
                                    autocomplete = "new-password"
                                })
                                <div class="form-control-feedback"><i class="icon-key"></i></div>
                            </div>
                            @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger small" })
                        </div>

                        <div id="message">
                            <div id="oldpassword_check" class="invalid">Must differ from old password</div>
                            <div id="length" class="invalid">8-18 Characters</div>
                            <div id="letter" class="invalid">1-2 Special Characters (!, $, etc.)</div>
                            <div id="capital" class="invalid">1-2 Capital letters</div>
                            <div id="number" class="invalid">1-2 Numbers</div>
                            <div id="lowercase" class="invalid">1-2 Lowercase letters</div>
                        </div>

                        <div class="form-group">
                            @Html.LabelFor(m => m.ConfirmPassword, new { @class = "form-label starick font-weight-semibold" })
                            <div class="form-group-feedback form-group-feedback-left">
                                @Html.PasswordFor(m => m.ConfirmPassword, new { @class = "form-control", placeholder = "Repeat New Password", id = "ConfirmPassword" })
                                <div class="form-control-feedback"><i class="icon-shield-check"></i></div>
                            </div>
                            @Html.ValidationMessageFor(m => m.ConfirmPassword, "", new { @class = "text-danger small" })
                        </div>

                        <div class="form-group mt-4">
                            <button type="submit" class="btn btn-primary btn-block">
                                Update Password <i class="icon-circle-right2 ml-2"></i>
                            </button>
                        </div>
                    </div>
                </div>
            }
            <p class="footer-text">&copy; @DateTime.Now.Year DP World. All rights reserved.</p>
        </div>
    </div>

    <script>
        const oldPass = document.getElementById("OldPassword");
        const newPass = document.getElementById("Password");
        const msgBox = document.getElementById("message");

        const checks = {
            old: document.getElementById("oldpassword_check"),
            lower: document.getElementById("lowercase"),
            special: document.getElementById("letter"),
            upper: document.getElementById("capital"),
            num: document.getElementById("number"),
            len: document.getElementById("length")
        };

        newPass.onfocus = () => { msgBox.style.display = "block"; }
        newPass.onblur = () => { if (newPass.value === "") msgBox.style.display = "none"; }

        newPass.onkeyup = () => {
            const val = newPass.value;

            // Old password check
            toggleValid(checks.old, val !== oldPass.value && val !== "");

            // Lowercase check
            toggleValid(checks.lower, /[a-z]/.test(val));

            // Special Char check
            toggleValid(checks.special, /[^a-zA-Z\d]/.test(val));

            // Capital check
            toggleValid(checks.upper, /[A-Z]/.test(val));

            // Number check
            toggleValid(checks.num, /[0-9]/.test(val));

            // Length check
            toggleValid(checks.len, val.length >= 8 && val.length <= 18);
        };

        function toggleValid(el, isValid) {
            if (isValid) {
                el.classList.remove("invalid");
                el.classList.add("valid");
            } else {
                el.classList.remove("valid");
                el.classList.add("invalid");
            }
        }
    </script>
</body>
</html>