@using ExamPortal.Model.Resources
@using ExamPortal.Model.EntityModel.Enums
@{
    ViewBag.Title = "Password Reset Successful";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <title>DPWorld Jeddah Exam - @ViewBag.Title</title>
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">

    <link href="~/Content/css/icons/icomoon/styles.min.css" rel="stylesheet" />
    <link rel="icon" type="image/x-icon" sizes="16x16" href="~/Content/images/favicon.ico">
    <link href="~/Content/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/Content/css/bootstrap_limitless.min.css" rel="stylesheet" />
    <link href="~/Content/css/layout.min.css" rel="stylesheet" />
    <link href="~/Content/css/colors.min.css" rel="stylesheet" />

    <style>
        :root {
            --dpw-primary-dark: #1E1450;
        }

        html, body {
            height: 100%;
            margin: 0;
            background: linear-gradient(to bottom right, #1E1450 0%, #3b2a8d 50%, #5c4aa8 100%);
        }

        .page-content {
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            padding: 20px;
        }

        .SuccessCard {
            width: 100%;
            max-width: 400px;
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.4);
            border-radius: 8px;
            overflow: hidden;
            background: transparent;
        }

        .card-body {
            background: #ffffff;
            padding: 40px 30px;
            border-radius: 8px;
            text-align: center;
        }

        .success-icon-container {
            margin-bottom: 20px;
        }

            .success-icon-container i {
                font-size: 64px;
                color: #28a745; /* Success Green */
                padding: 20px;
                background: rgba(40, 167, 69, 0.1);
                border-radius: 50%;
                display: inline-block;
            }

        .card-body h5 {
            color: var(--dpw-primary-dark);
            font-weight: 700;
            font-size: 1.4rem;
            margin-bottom: 10px;
        }

        .card-body p {
            color: #666;
            line-height: 1.6;
            margin-bottom: 25px;
        }

        .btn-primary {
            background-color: var(--dpw-primary-dark) !important;
            border-color: var(--dpw-primary-dark) !important;
            height: 48px;
            font-weight: 600;
            display: flex;
            align-items: center;
            justify-content: center;
            text-decoration: none !important;
        }

            .btn-primary:hover {
                background-color: #100b33 !important;
                color: #ffffff !important;
            }

        .dpw-logo {
            max-height: 60px;
            margin-bottom: 25px;
        }

        .footer-text {
            text-align: center;
            margin-top: 20px;
            color: rgba(255, 255, 255, 0.8);
            font-size: 0.85rem;
        }
    </style>
</head>
<body>
    <div class="page-content">
        <div class="SuccessCard">
            <div class="card mb-0">
                <div class="card-body">
                    <img src="~/Content/images/dpworldlogo.png" class="dpw-logo" alt="DP World Logo" />

                    <div class="success-icon-container">
                        <i class="icon-checkmark-circle"></i>
                    </div>

                    <h5>Success!</h5>
                    <p>
                        Your password has been reset successfully. You can now use your new credentials to access the portal.
                    </p>

                    <div class="form-group">
                        <a href="@Url.Action("Login", "Account")" class="btn btn-primary btn-block">
                            Log In to Your Account <i class="icon-arrow-right8 ml-2"></i>
                        </a>
                    </div>
                </div>
            </div>
            <p class="footer-text">&copy; @DateTime.Now.Year DP World. All rights reserved.</p>
        </div>
    </div>
</body>
</html>