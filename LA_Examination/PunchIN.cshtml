
@{
    Layout = null;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
</head>
<body>
    <style>
        .modal-body {
            max-height: 70vh !important;
            overflow: auto !important;
        }

        .powout {
            background: linear-gradient(45deg, #f44336, #f44336);
            color: #ffffff;
            padding: 10px;
            width: 65% !important;
            font-size: 25px;
            border-radius: 13px;
            border: 2px solid #f44336;
            box-shadow: 0px 2px 10px 3px #4e4e4e7d;
            margin-bottom: 10px !important;
            cursor: pointer;
        }

        .MainCard {
            width: 90% !important;
            padding: 15px !important;
        }

        .modal-dialog {
            top: 10%;
        }

        .powin {
            background: linear-gradient(45deg, #00be5e, #4caf50);
            color: #ffffff;
            padding: 10px;
            width: 65% !important;
            font-size: 25px;
            border-radius: 13px;
            border: 2px solid #4caf50;
            box-shadow: 0px 2px 10px 3px #4e4e4e7d;
            margin-bottom: 10px !important;
            cursor: pointer;
        }
    </style>
    <div class="conatiner" ng-controller="LA_ExaminationCtrl" ng-init="init()">

        <div class="header mt-3">
            <div class="card">
                <div class="card-body" style="background-color: var( --dpw-bg-color); color: white; border-radius: 5px;">
                    <div>
                        <h3>Labor POW IN/OUT</h3>
                    </div>
                </div>

            </div>
        </div>


        <div class="card">
            <div class="card-body" style="background-color: #f2eeee;">
                <center>
                    <div class="MainCard">
                        <div class="row">
                            <div class="col-md-12 col-sm-12 col-lg-6">
                                <div ng-click="PostAttendanceAction('Clock in')" class="powin" title="POW IN"> <i class="icon-chevron-down"></i> <i class="icon"></i> (POW) in</div>
                            </div>
                            <div class="col-md-12 col-sm-12 col-lg-6">
                                <div ng-click="PostAttendanceAction('Clock out')" class="powout" title="POW OUT"> <i class="icon-chevron-up"></i> <i class="icon"></i> (POW) out</div>
                            </div>
                        </div>
                    </div>
                </center>
            </div>
        </div>


    </div>
</body>
</html>
