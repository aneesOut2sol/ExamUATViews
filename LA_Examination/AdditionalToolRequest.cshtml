    #AdditionalServiceDetails .tabs {
        display: flex;
        position: relative;
        background-color: #fff;
        box-shadow: 0 0 1px 0 rgba(24, 94, 224, 0.15), 0 6px 12px 0 rgba(24, 94, 224, 0.15);
        padding: 5px 10px;
        border-radius: 90px;
        align-items: center;
        vertical-align: middle;
    }

        #AdditionalServiceDetails .tabs * {
            z-index: 2;
        }

    #AdditionalServiceDetails .container input[type="radio"] {
        display: none;
    }

    #AdditionalServiceDetails .tab {
        display: flex;
        align-items: center;
        justify-content: center;
        height: 30px;
        width: 160px;
        font-size: .8rem;
        color: black;
        font-weight: 500;
        border-radius: 99px;
        cursor: pointer;
        transition: color 0.15s ease-in;
        margin: 0;
    }



    #AdditionalServiceDetails.container input[type="radio"]:checked + label {
        color: #185ee0;
    }

        #AdditionalServiceDetails .container input[type="radio"]:checked + label > .notification {
            background-color: #185ee0;
            color: #fff;
            margin: 0px;
        }

    #AdditionalServiceDetails .container input[id="radio-1"]:checked ~ .glider {
        transform: translateX(0);
    }

    #AdditionalServiceDetails .container input[id="radio-2"]:checked ~ .glider {
        transform: translateX(100%);
    }

    #AdditionalServiceDetails .container input[id="radio-3"]:checked ~ .glider {
        transform: translateX(200%);
    }

    #AdditionalServiceDetails .glider {
        position: absolute;
        display: flex;
        height: 30px;
        width: 160px;
        background-color: #e6eef9;
        z-index: 1;
        border-radius: 99px;
        transition: 0.25s ease-out;
    }

    @@media(max-width: 700px) {
        #AdditionalServiceDetails .tabs {
            transform: scale(0.6);
        }
    }

