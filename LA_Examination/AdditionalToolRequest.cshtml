<div class="ng-cloak" ng-cloak ng-controller="LA_AdditionalToolCtrl" ng-init="init()">
    <div class="card mt-2 mt-2" id="Block">
        <div class="card-header" style=" background: var( --dpw-bg-color); color: white; padding: 8px;">
            <h5 class="mt-2">Labor Activity</h5>
        </div>
        <div class=" card-body shadow">
            <div class="row">
                <div class="Cardtabs" ng-repeat="B in BlockList">
                    <div class="Absoulte">
                        <div class="CountBadge">{{B.Cntrs}}</div>
                        <br />
                    </div>
                    <button ng-click="GetPendingBlockConatiner(B)" ng-class="{'active' : B.Block == CurrentBlock.Block }" class="btn btn-primary Blocks" value="{{B.Block}}">
                        <span ng-show="B.Block!=983">{{B.Block}}</span>
                        <span ng-show="B.Block==983">  {{B.Block}}K</span>
                    </button>
                </div>
            </div>
        </div>
    </div>
    <div class="accordion scrollerdiv" id="accordionExample" ng-show="!stringNullorEmpty(ContainerList)">
        <div class="card Custom-Card m-0" ng-repeat="x in ContainerList | filter :search" style="overflow:visible">
            <!---Container Header-->
            <div class="" id="heading{{$index}}">
                <div class="collapsible-link">
                    <div class="row">
                        <div class="col-md-5 col-lg-6 col-sm-6 col-xs-12" id="OpenDetails{{$index}}">
                            <div style="display: inline-block; vertical-align: middle; margin-bottom: 4px;">
                                <img style="height:50px;" src="~/Content/images/container.png" />

                            </div>

                            <div style="display: inline-block; vertical-align: middle; margin-bottom: 4px; margin-left: 12px; font-family: 'Pilat Wide';">
                                {{x.Cntr}} <span style=" font-size: 10px; vertical-align: bottom;" class="badge" ng-class="x.Activity == 'Strip' ? 'badge-success' : 'badge-danger'">{{x.Activity}}</span>


                                <span ng-show="x.BayanNo!='' && x.BayanNo!=null" style="font-size: 11px; color: #898989;"> - {{x.BayanNo}} </span>
                                <div ng-show="x.Location!='' && x.Location!=null" style="font-size: 11px; color: #898989;">{{x.Location}} </div>

                            </div>
                        </div>

                        <div class="col-md-6 col-lg-5 col-sm-5 col-xs-12 mt-xs-2 DamageButton" style="align-self:center;line-height:2.4;">

                        </div>
                        <div class="col-md-1 col-lg-1 col-sm-1 col-xs-12 Chervronicon" style="cursor:pointer; align-self:center;text-align:end">

                            <div class="Indicatior">
                                <i class="icon-eye" ng-click="GetAdditionalToolRequestDetails(x.ActivityId)"></i>
                            </div>
                        </div>
                    </div>
                </div>
                <!---Container Header-->
                <!---Events-->
            </div>
        </div>
    </div>
    <!--Request Details-->
    <div class="modal fade" id="AdditionalServiceDetails" tabindex="-1" role="dialog" data-backdrop="static" data-keyboard="false" aria-labelledby="exampleModalCenterTitle" aria-hidden="true">

        <div class="modal-dialog modal-dialog-centered" role="document">
            <div class="modal-content">
                <div class="CloseModalBtn" data-dismiss="modal" aria-label="Close">
                    <button class="close" data-dismiss="modal" aria-label="Close"></button>
                    <i class="icon-cross"></i>
                </div>
                <div class="modal-header">
                    <h5 class="modal-title">Additional Tool / Service</h5>
                </div>
                <div class="modal-body" style=" min-height: 120px;">
                    <div class="row">
                        <div class="col-md-12 p-0">
                            <div class="container p-0">
                                <div class="tabs">
                                    <div class="box Detailbox-{{$index}}" ng-repeat=" x in AdditionalToolDetail.Departments" ng-click="SetToolDetails(x.Tools,$index,x.DepartmentStatus,x.Department)">
                                        <span style="">{{x.Department}} </span>

                                    </div>
                                    <div class="glider2 Detail"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="card ReportInspectionDelayModelCard">
                        <div class="text-end">
                            <span class="Laborbadge badge-{{CurrentDepartmentsStatus}}">{{CurrentDepartmentsStatus}}</span>
                        </div>
                        <div class="dpx">
                            <div class='py cursor-pointer w-100'>
                                <div ng-repeat="item in DetailsToolList" class="mb-2">

                                    <input type="checkbox" checked disabled class="option-input radio" name="pyradio" value="{{item}}" />
                                    {{item}}

                                </div>
                            </div>
                        </div>
                        <div class="text-end cursor-pointer">
                            <span ng-show="CurrentDepartmentsStatus=='Pending'" ng-click="SendToolToDepartment(CurrentDepartmentName,CurrentActivityId)" class="Laborbadge badge-Inprogress">Notify</span>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-12 p-0">
                            <div class="card mb-3 shadow-sm" style="border-radius:15px;">
                                <div class="card-body">
                                    <table class="table" style="border: none !important;">
                                        <tr>
                                            <th>Status</th>
                                            <td class="text-right">
                                                <span class="Laborbadge badge-{{AdditionalToolDetail.Status}}">{{AdditionalToolDetail.Status}}</span>
                                            </td>
                                        </tr>
                                        <tr>
                                            <th>Request By</th>
                                            <td class="text-right">{{AdditionalToolDetail.CreatedBy}}</td>
                                        </tr>
                                        <tr>
                                            <th>Request At</th>
                                            <td class="text-right">{{AdditionalToolDetail.CreatedAt | date:'dd/MM/yyyy HH:mm:ss'}}</td>
                                        </tr>
                                        <tr>
                                            <th>Remarks </th>
                                            <td class="text-right">{{AdditionalToolDetail.Remarks}}</td>
                                        </tr>
                                        <tr ng-if="AdditionalToolDetail.Status!='Pending' && AdditionalToolDetail.Status!='Rejected'">
                                            <th>Approved By</th>
                                            <td class="text-right">{{AdditionalToolDetail.UpdatedBy}}</td>
                                        </tr>
                                        <tr ng-if="AdditionalToolDetail.Status!='Pending' && AdditionalToolDetail.Status!='Rejected'">
                                            <th>Approved At</th>
                                            <td class="text-right">{{AdditionalToolDetail.UpdatedAt | date:'dd/MM/yyyy HH:mm:ss'}}</td>
                                        </tr>
                                        <tr ng-if="AdditionalToolDetail.Status!='Pending' && AdditionalToolDetail.Status=='Rejected'">
                                            <th>Rejected By</th>
                                            <td class="text-right">{{AdditionalToolDetail.UpdatedBy}}</td>
                                        </tr>
                                        <tr ng-if="AdditionalToolDetail.Status!='Pending' && AdditionalToolDetail.Status=='Rejected'">
                                            <th>Rejected At</th>
                                            <td class="text-right">{{AdditionalToolDetail.UpdatedAt | date:'dd/MM/yyyy HH:mm:ss'}}</td>
                                        </tr>
                                        <tr ng-if="AdditionalToolDetail.Status!='Pending' && AdditionalToolDetail.Status=='Rejected'">
                                            <th>Reason </th>
                                            <td class="text-right">{{AdditionalToolDetail.Reason}}</td>
                                        </tr>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <div class="row">
                        <div class="col-md-12" style="text-align:center">
                            <button class="btn btn-cancel" data-dismiss="modal">Cancel</button>
                            <button class="btn btn-success" ng-show="AllResloved==true && AdditionalToolDetail.Status!='Completed'" ng-click="ApprovedRejectRequest(CurrentActivityId,'Approve')">Approve </button>
                            <button class="btn btn-danger" ng-show="AdditionalToolDetail.Status!='Completed'"  ng-click="ApprovedRejectRequest(CurrentActivityId,'Reject')">Reject </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
