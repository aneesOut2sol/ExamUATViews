
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!DOCTYPE html>
<style>
    .header-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .add-button {
        background-color: var( --dpw-bg-color);
        color: white;
        padding: 8px 16px;
        border: none;
        border-radius: 4px;
    }
</style>
<html>
<head>
    <meta name="viewport" content="width=device-width" />

</head>
<body>
    <div class="ng-cloak" ng-cloak ng-controller="LA_ExaminationCtrl" ng-init="init()">
        <div class="card mt-2 d-flex">
            <div class="card-body">
                <div class="header-row">
                    <h2>Labor Assignment</h2>
                    <div>
                        <input type="button" class="btn btn-secondary" value="Filters" data-toggle="collapse" data-target="#demo" />
                        <button class="add-button" ng-click="Add()"><i class="icon-add m-r-5 text-white"></i> Add</button>
                    </div>
                </div>
            </div>
        </div>

            <!--Search Filter Code Start-->
            <div class="card collapse" id="demo">
                <div class="card-body">
                    <div class="col-md-12">
                        <div class="row">
                            <div class="col-md-3">
                                <div class="form-group">
                                    <label>Handled By</label>
                                    <select data-placeholder="Handled By" class="form-control select-clear" id="select_handledby" name="state" ng-model="search.HandledBy">
                                        <option></option>
                                        <option value="">Select Handle by</option>
                                        <option value="ForkLift">ForkLift</option>
                                        <option value="Crane">Mobile Crane</option>
                                        <option value="Labor">Labor</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="form-group">
                                    <label class="Starick">Package Type</label>
                                    <select data-placeholder="Package Type" class="form-control select-clear" id="select_packagetype" name="state" ng-model="search.PackageType">
                                        <option></option>
                                        <option value="">Select Package Type</option>
                                        <option ng-repeat="item in packageType" value="{{item}}">{{item}}</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="form-group">
                                    <label class="Starick">Container Size</label>
                                    <select data-placeholder="Container Size" class="form-control select-clear" id="select_cntrsize" name="state" ng-model="search.CntrSize">
                                        <option></option>
                                        <option value="">Container Size</option>
                                        <option value="20">20</option>
                                        <option value="40">40</option>
                                        <option value="45">45</option>
                                    </select>
                                </div>
                            </div>


                            <div class="col-md-3">
                                <div class="form-group">
                                    <label class="Starick">Strip or Stuff</label>
                                    <select data-placeholder="Strip or Stuff" class="form-control select-clear" id="select_stripnstuffaction" name="state" ng-model="search.StripNStuffAction">
                                        <option></option>
                                        <option value="">Select Strip or Stuff</option>
                                        <option value="Strip">Strip</option>
                                        <option value="Stuff">Stuff</option>
                                    </select>
                                </div>
                            </div>

                            <div class="col-md-12 mt-4">
                                <button class="btn btn-primary pull-right mr-2" ng-click="Search(search)">Search</button>
                                <button class="btn btn-secondary pull-right mr-2" ng-click="ClearFilter(search)">Clear</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
      

      

        <div class="row">
            <div id="tblrep" class="card table-card scrollbar">
                <table class="table datatable-show-all text-center" id="table-id">
                    <thead>
                        <tr class="table-card-head">
                            <th>SR#</th>
                            <th>Handled By </th>
                            <th>Container Size</th>
                            <th>Strip or Stuff</th>
                            <th>Package Type</th>
                            <th>Duration</th>
                            <th>Action</th>

                        </tr>
                    </thead>
                    <tbody class="ng-cloak" ng-cloak>
                        <tr ng-repeat="item in filteredData">
                            <td>{{$index+1}}</td>
                            <td>{{item.HandledBy}}</td>
                            <td>{{item.CntrSize}}</td>
                            <td>{{item.StripNStuffAction}}</td>
                            <td>{{item.PackageType}}</td>
                            <td>{{item.CntrHrs}}:{{item.CntrMins}}</td>
                            <td><i class="icon-pencil" title="Click to Update" ng-click="Edit(item.Id)"></i></td>
                        </tr>

                    </tbody>
                </table>
            </div>

        </div>
        <!--pagination Code Start-->
        <div class="row">
            <div class="col-md-3">
                <div class="form-group">
                    <label>Select Rows</label>
                    <select data-placeholder="Select Rows" class="form-control select-clear" id="maxRows" name="state" data-fouc>
                        <option></option>
                        <option value="5000">All Rows</option>
                        <option value="4">4</option>
                        <option value="10">10</option>
                        <option value="15">15</option>
                        <option value="20">20</option>
                        <option value="50">50</option>
                        <option value="70">70</option>
                        <option value="100">100</option>

                    </select>
                </div>
            </div>
        </div>
    </div>
    <!--pagination Code End-->
</body>
</html>

<script src="@Url.Content("~/Scripts/crypto-js.min.js")"></script>
<script src="~/Scripts/DatePicker/CustomIntilizeJS.js"></script>

<script src="~/Scripts/jquery.min.js"></script>
<script src="~/Scripts/PaganationScriptCustom.js"></script>
<script>

    $(document).ready(function () {
        getPagination('#table-id');

    });
</script>