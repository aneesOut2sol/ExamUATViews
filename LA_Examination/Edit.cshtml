                    <div class="col-md-12 mt-4">
                        <div class="form-group mt-3" style="float:inline-end">
                            <input type="button" class="btn btn-secondary" ng-click="Cancel()" value="Cancel" />
                            <input type="button" class="btn btn-primary" ng-click="UpdateLA_Examination(La_ExamList)" value="Save" />
