</body>
</html>
<script>
    const hrsInput = document.getElementById('cntrHrs');
    const minsInput = document.getElementById('cntrMins');
    const hrsError = document.getElementById('hrsError');
    const minsError = document.getElementById('minsError');

    hrsInput.addEventListener('input', function () {
        const value = parseInt(this.value, 10);
        if (isNaN(value) || value < 0 || value > 2000) {
            hrsError.textContent = 'Please enter between 1 and 2000 for Hours.';
        } else {
            hrsError.textContent = '';
        }
    });

    minsInput.addEventListener('input', function () {
        const value = parseInt(this.value, 10);
        if (isNaN(value) || value < 0 || value >= 60) {
            minsError.textContent = 'Please enter between 0 and 59 for Minutes.';
        } else {
            minsError.textContent = '';
        }
    });
</script>