                    </div>
                    <div class="col-md-3 mt-3">
                        <div class="form-group">
                            <label class="Starick">Size</label>
                            <select data-placeholder="Size" class="form-control select-clear" id="select_cntrsize_3" name="state" ng-model="La_ExamList.CntrSize">
                                <option></option>
                                <option value="20">20</option>
                                <option value="40">40</option>
                                <option value="45">45</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-md-3 mt-3">
                        <div class="form-group">
                            <label class="Starick">Strip or Stuff</label>
                            <select data-placeholder="Strip or Stuff" class="form-control select-clear" id="select_stripnstuffaction_3" name="state" ng-model="La_ExamList.StripNStuffAction">
                                <option></option>
                                <option value="Strip">Strip</option>
                                <option value="Stuff">Stuff</option>
                            </select>
                        </div>
                    </div>

                    <div class="col-md-3">
                        <div class="form-group"></div>
                        <label>Package Type</label>
                        <select data-placeholder="Package Type" class="form-control select-clear" id="select_packagetype_3" name="state" ng-model="La_ExamList.PackageType">
                            <option value=""></option>
                            <option ng-repeat="item in packageType" value="{{item}}">{{item}}</option>
                        </select>

                    </div>

                    <div class="col-md-3 mt-3" ng-if="La_ExamList.PackageType == 'Other'">
                        <div class="form-group">
                            <label>Other Package Type</label>
                            <input type="text" class="form-control" placeholder="Enter other package type" ng-model="La_ExamList.PackageType" />
                        </div>
                    </div>


                    <div class="col-md-3 mt-3">
                        <div class="form-group">
                            <label class="Starick" for="cntrHrs">Hrs</label>
