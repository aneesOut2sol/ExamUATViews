    .btn-danger-outline {
        border: 2px solid #c51f41 !important;
        background: none !important;
    }

    .btn-success-outline {
        border: 2px solid #00a172 !important;
        background: none !important;
    }

    .UIHrsSection p {
        display: inline-block;
        padding-bottom: 3px !important;
        padding-right: 10px;
        margin: 0 !important;
        font-family: 'Pilat Wide';
    }
</style>
<link href="~/Content/popup/jquery-confirm.min.css" rel="stylesheet" />
<!--Header-->
<div ng-controller="LA_RunnerCtrl" ng-init="init()" class="ng-cloak" ng-cloak>
    <!---Block-->
    <div class="card mt-2 mt-2" id="Block">
        <div class="card-header" style=" background: var( --dpw-bg-color); color: white; padding: 8px;">
            <h5 class="mt-2">Runner Activity</h5>
        </div>
        <div class=" card-body shadow">
            <div class="row">
                <div class="Cardtabs" ng-repeat="B in BlockList">
                    <div class="Absoulte">
                        <div class="CountBadge">{{B.Cntrs}}</div>
                        <br />
                    </div>
                    <button @*ng-click="GetLAContainerList(B)"*@ ng-click="GetLAContainerLabor2(B)" ng-class="{'active' : B.Block == CurrentBlock.Block }" class="btn btn-primary Blocks" value="{{B.Block}}">
                        <span ng-show="B.Block!=983">{{B.Block}}</span>
                        <span ng-show="B.Block==983">  {{B.Block}}K</span>
                    </button>
                </div>
            </div>
        </div>
    </div>



    <!---Block-->
    <!---Container-->
    <div class="accordion scrollerdiv" id="accordionExample" ng-show="!stringNullorEmpty(ContainerList)">
        <div class="card Custom-Card m-0" ng-repeat="x in ContainerList | filter :search" style="overflow:visible">
            <!---Container Header-->
            <div class="" id="heading{{$index}}">
                <div class="collapsible-link">
                    <div class="row">
                        <div class="col-md-5 col-lg-6 col-sm-6 col-xs-12" id="OpenDetails{{$index}}">
                            <div style="display: inline-block; vertical-align: middle; margin-bottom: 4px;">
                                <img style="height:50px;" src="~/Content/images/container.png" />

                            </div>
                            <div style="display: inline-block; vertical-align: middle; margin-bottom: 4px; margin-left: 12px; font-family: 'Pilat Wide';">
                                {{x.Cntr}} <span style=" font-size: 10px; vertical-align: bottom;" class="badge" ng-class="x.Activity == 'Strip' ? 'badge-success' : 'badge-danger'">{{x.Activity}}</span>


                                <span ng-show="x.BayanNo!='' && x.BayanNo!=null" style="font-size: 11px; color: #898989;"> - {{x.BayanNo}} </span>
                                <div ng-show="x.Location!='' && x.Location!=null" style="font-size: 11px; color: #898989;">{{x.Location}} </div>
                                <div class="position-absolute" style="top: 0px;width: 0px; white-space: nowrap;" ng-show="x.InspectionStatus!=null && x.InspectionStatus!=''">
                                    <div class="position-relative" style="bottom:30px;">
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6 col-lg-5 col-sm-5 col-xs-12 mt-xs-2 DamageButton" style="align-self:center;line-height:2.4;">
                            <span class="Laborbadge badge-{{x.ActivityStatus}}">{{x.ActivityStatus}}</span>
                        </div>
                        <div class="col-md-1 col-lg-1 col-sm-1 col-xs-12 Chervronicon" style="cursor:pointer; align-self:center;text-align:end">

                            <div class="Indicatior" ng-click="OpenContainerDetails(x)">
                                <i class="icon-info22"></i>

                            </div>
                        </div>
                        <div class="col-md-12 col-lg-12 col-sm-12 col-xs-12 p-0" style=" border-top: 1PX SOLID #e5e5e5; margin-top: 18px;">
                            <div class="row">
                                <div class="col-md-6 mt-3" ng-repeat=" z in x.laborDatails" ng-click="DropLabor(z.LaborId,'one',z.IsDropped,x.Location,z.Name);">
                                    <div class="card p-2 m-0" ng-class="{'active' : z.IsDropped==true }" style=" border-radius: 7px; border: none; box-shadow: rgba(0, 0, 0, 0.1) 0px 10px 50px;">
                                        <table border="0" class="Labortable">
                                            <tr>
                                                <td style="width:8%" rowspan="2"> <img style=" height: 40px; border-radius: 50%;" src="~/Content/images/profile-img.jpg" alt="Alternate Text" /></td>
                                                <td style="width:55%">
                                                    <b>{{z.EMPId}}-{{z.Name}}</b>
                                                    <br />
                                                    <span>Punch in Time:{{z.PunchInTime |date:'dd-MM-yyyy HH:mm:ss'}}</span>
                                                </td>
                                                <td>  <span class="Laborbadge badge badge-{{z.Status}}">{{z.Status}}</span></td>
                                                <td class="text-end " style="white-space:nowrap;">
                                                    <input ng-checked="z.IsDropped==true" ng-disabled="z.IsDropped==true" type="checkbox" name="name" value="" />

                                                </td>
                                            </tr>
                                        </table>
                                    </div>
                                </div>
                                <div class="col-md-12 text-end mt-3">
                                    <button class="btn btn-success" ng-show="x.AllDropped==false" ng-click="DropLabor(x.laborDatails,'many',false,x.Location,'All');">Drop All</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <!---Container Header-->
                <!---Events-->
            </div>
        </div>
    </div>
    <!--LaborModel-->
    <div class="modal fade" id="ContainerDetails" tabindex="-1" role="dialog" data-backdrop="static" data-keyboard="false" aria-labelledby="exampleModalCenterTitle" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered" role="document" style="max-width:1000px;">
            <div class="modal-content">
                <div class="CloseModalBtn" data-dismiss="modal" aria-label="Close">
                    <button class="close" data-dismiss="modal" aria-label="Close"></button>
                    <i class="icon-cross"></i>
                </div>
                <div class="modal-header">
                    <h5 class="modal-title">{{ContainerDetails.Cntr}}</h5>
                </div>
                <div class="modal-body" style="max-height:80vh!important">
                    <div>
                        <h2>Container Details</h2>
                        <table class="table">
                            <tr>
                                <th>Container</th>
                                <td>{{ContainerDetails.Cntr}}</td>
                            </tr>
                            <tr>
                                <th>Location</th>
                                <td>{{ContainerDetails.Location}}</td>
                            </tr>
                            <tr>
                                <th>Activity Status</th>
                                <td><span class="Laborbadge badge-{{ContainerDetails.ActivityStatus}}">{{ContainerDetails.ActivityStatus}}</span></td>
                            </tr>
                            <tr>
                                <th>Activity</th>
                                <td>{{ContainerDetails.Activity}}</td>
                            </tr>

                            <tr>
                                <th>Activity Start Time</th>
                                <td>{{(ContainerDetails.ActivityStartTime | date:'dd/MM/yyyy HH:mm:ss')||'N/A'}}</td>
                            </tr>
                            <tr>
                                <th>Activity End Time</th>
                                <td>
                                    {{(ContainerDetails.ActivityEndTime | date:'dd/MM/yyyy HH:mm:ss')||'N/A'}}
                                </td>
                            </tr>
                            <tr>
                                <th>Estimated Duration</th>
                                <td>
                                    {{(ContainerDetails.ETA)||'N/A'}}
                                </td>
                            </tr>
                            <tr>
                                <th>Actual Duration</th>
                                <td>{{(getTimeDifference(ContainerDetails.ActivityStartTime,ContainerDetails.ActivityEndTime))||'N/A'}}</td>
                            </tr>
                        </table>
                    </div>
                    <br />
                    <div>
                        <h2>Labor Details</h2>
                        <div class="row">
                            <div class="col-md-6 mb-3 pl-0" ng-repeat="x in ContainerDetails.laborDatails">
                                <table class="table">
                                    <tbody>
                                        <tr>
                                            <th style="background: #464545; color: white; font-size: 17px;" colspan="2">{{x.EMPId}}-{{x.Name}}</th>
                                        </tr>
                                        <tr>
                                            <th>Punch in Time</th>
                                            <td>{{(x.PunchInTime | date:'dd/MM/yyyy HH:mm:ss') ||'N/A'}}</td>
                                        </tr>
                                        <tr>
                                            <th>Status </th>
                                            <td> <span class="Laborbadge badge badge-{{x.Status}}">{{x.Status}}</span></td>
                                        </tr>
                                        <tr>
                                            <th>Assigned At</th>
                                            <td>{{(x.AssignedAt | date:'dd/MM/yyyy HH:mm:ss') ||'N/A'}}</td>
                                        </tr>
                                        <tr>
                                            <th>Reached Location At</th>
                                            <td>{{(x.ReachedLocationTime | date:'dd/MM/yyyy HH:mm:ss') ||'N/A'}}</td>
                                        </tr>

                                        <tr>
                                            <th>Drop by</th>
                                            <td>{{x.DropBy ||'N/A'}}</td>
                                        </tr>
                                        <tr>
                                            <th>Pow In Time</th>
                                            <td>{{(x.PowinTime | date:'dd/MM/yyyy HH:mm:ss')||'N/A'}}</td>
                                        </tr>
                                        <tr>
                                            <th>Pow In Longitude</th>
                                            <td>{{(x.PowInLongitude)||'N/A'}}</td>
                                        </tr>
                                        <tr>
                                            <th>Pow In Latitude</th>
                                            <td>{{(x.PowInLatitude)||'N/A'}}</td>
                                        </tr>
                                        <tr>
                                            <th>Container Photo</th>
                                            <td><a href="{{x.ContainerPhoto}}" ng-show="x.ContainerPhoto!='' && x.ContainerPhoto!=null" target="_blank"><i class="icon-eye"></i></a></td>
                                        </tr>
                                        <tr>
                                            <th>Activity Start Time</th>
                                            <td>{{(x.LaborStartTime | date:'dd/MM/yyyy HH:mm:ss')||'N/A'}}</td>
                                        </tr>
                                        <tr>
                                            <th>Activity End Time</th>
                                            <td>{{(x.LaborEndTime | date:'dd/MM/yyyy HH:mm:ss')||'N/A'}}</td>
                                        </tr>
                                        <tr>
                                            <th>Pow Out Time</th>
                                            <td>{{(x.PowoutTime | date:'dd/MM/yyyy HH:mm:ss')||'N/A'}}</td>
                                        </tr>
                                        <tr>
                                            <th>Pow Out Longitude</th>
                                            <td>{{(x.PowOutLongitude | date:'dd/MM/yyyy HH:mm:ss')||'N/A'}}</td>
                                        </tr>
                                        <tr>
                                            <th>Pow Out Latitude</th>
                                            <td>{{(x.PowOutLatitude | date:'dd/MM/yyyy HH:mm:ss')||'N/A'}}</td>
                                        </tr>
                                    </tbody>

                                </table>
                            </div>
                        </div>

                    </div>
                </div>
                <div class="modal-footer">
                    <div class="row">
                        <div class="col-md-12" style="text-align:center">

                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!--LaborModel-->
    <div class="modal fade" id="LaborModel" tabindex="-1" role="dialog" data-backdrop="static" data-keyboard="false" aria-labelledby="exampleModalCenterTitle" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered" role="document" style="max-width:800px;">
            <div class="modal-content">
                <div class="CloseModalBtn" data-dismiss="modal" aria-label="Close">
                    <button class="close" data-dismiss="modal" aria-label="Close"></button>
                    <i class="icon-cross"></i>
                </div>
                <div class="modal-header">
                    <h5 class="modal-title">{{ActiveCntr}}</h5>
                </div>
                <div class="modal-body">
                    <div class="row accordion" id="LaborAcc">
                        <div class="col-md-12" ng-repeat=" x in LaborList">
                            <div class="card p-2" style=" border-radius: 7px; border: none; box-shadow: rgba(0, 0, 0, 0.1) 0px 10px 50px;">
                                <table border="0" style="border:none!important">
                                    <tr style="border:none!important">
                                        <td style="width:8%"> <img style=" height: 40px; border-radius: 50%;" src="~/Content/images/profile-img.jpg" alt="Alternate Text" /></td>
                                        <td style="width:55%">
                                            <b>{{x.EMPId}}-{{x.Name}}</b>
                                            <br />
                                            <span>Punch in Time:{{x.PunchInTime |date:'dd-MM-yyyy HH:mm:ss'}}</span>
                                        </td>
                                        <td>  <span class="Laborbadge badge badge-{{x.Status}}">{{x.Status}}</span></td>
                                        <td class="text-end " style="white-space:nowrap;">

                                            <button ng-show="x.IsDropped==false" class="btn btn-primary btn-sm" ng-click="DropLabor(x.Id,'one');">Drop</button>
                                            @*<div data-toggle="collapse" data-target="#Laborcollapse{{$index}}">
                                                    <i class="icon-chevron-down"></i>
                                                </div>*@
                                        </td>
                                    </tr>
                                </table>
                                <div class="collapse" id="Laborcollapse{{$index}}" data-parent="#LaborAcc">
                                    <div style=" background: #ececec; padding: 11px; box-shadow: 2px 2px 4px -3px inset #808080; border-radius: 7px; margin-top: 11px;">
                                        <table class="DetailsTable" style="width:100%; border:none !important">
                                            <tr>
                                                <td>Total Labor:</td>
                                                <td>{{x.Labors}}</td>
                                                <td>Activity Status:</td>
                                                <td><span class="Laborbadge badge-{{x.Status}}">{{x.Status}}</span></td>
                                            </tr>
                                            <tr>
                                                <td>Activity Start Time:</td>
                                                <td>{{(x.ActivityStartTime | date:'dd/MM/yyyy HH:mm:ss')||'N/A'}}</td>
                                                <td>Activity End Time:</td>
                                                <td>{{(x.ActivityEndTime| date:'dd/MM/yyyy HH:mm:ss')||'N/A'}}</td>
                                            </tr>
                                            <tr>
                                                <td>Estimated Duration:</td>
                                                <td>{{x.ETA ||'N/A'}}</td>
                                                <td>Actual Duration:</td>
                                                <td>{{getTimeDifference(x.ActivityStartTime,x.ActivityEndTime) ||'N/A'}}</td>
                                            </tr>
                                        </table>
                                    </div>
                                </div>


                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <div class="row">
                        <div class="col-md-12" style="text-align:center">
                            <button class="btn btn-cancel" data-dismiss="modal">Cancel</button>
                            <button class="btn btn-success" ng-show="ShowDropAll" ng-click="DropLabor(null,'many');">Drop All</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<script src="@Url.Content("~/Scripts/crypto-js.min.js")"></script>
<script src="~/Content/popup/jquery-confirm.min.js"></script>
<script src="~/Scripts/jquery.min.js"></script>
<script src="~/Scripts/webcam.min.js"></script>

<script>
    $(document).ready(function () {
        var o = new SlimSelect({
            select: '#Occ',
            placeholder: 'Select Occures',
            showSearch: true,
            allowDeselect: true,
        });
        var ContractorDD = new SlimSelect({
            select: '#ContractorDD',
            placeholder: 'Select Contractor',
            showSearch: true,
            allowDeselect: true,
        });
    });
    window.addEventListener('click', function (e) {
        var Target = $(e.target).hasClass('optionIcon');
        var Targetparent = $(e.target).parent().hasClass('optionIcon');
        if (!Targetparent && !Target) {
            $('.DropOptionParent').css('display', 'none');
        }
    });

    var element = document.getElementById('RecordServices');
    element.classList.add("Active");
    //Hide Side Menu
    window.onload = function () {
        document.getElementById('minisidebar').className = 'sidebar-xs';
    };
</script>


