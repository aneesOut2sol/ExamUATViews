
@{
    ViewBag.Title = "PCRequestIndex";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>

    .pagination {
        display: inline-block;
        padding-left: 0;
        margin: 20px 0;
        border-radius: 4px;
    }

        .pagination > li {
            display: inline;
        }

    .nav {
        display: block;
    }

    .pagination > .active > a, .pagination > .active > span, .pagination > .active > a:hover, .pagination > .active > span:hover, .pagination > .active > a:focus, .pagination > .active > span:focus {
        z-index: 2;
        color: #fff;
        cursor: default;
        background-color: var( --dpw-bg-color);
        border-color: var( --dpw-bg-color);
    }

    .pagination > li > span:hover {
        color: lightgrey;
        cursor: grab;
    }

    .pagination > li > a, .pagination > li > span {
        position: relative;
        float: left;
        padding: 6px 12px;
        margin-left: -1px;
        line-height: 1.428571429;
        text-decoration: none;
        background-color: #fff;
        border: 1px solid #ddd;
    }

    .pagination > li:first-child > span {
        margin-left: 0;
        border-bottom-left-radius: 4px;
        border-top-left-radius: 4px;
    }

    .customOption {
        width: auto;
        display: initial;
        margin-left: 15px;
        border: 2px solid #bdc3c7;
        color: #34495e;
        font-family: Lato,Helvetica,Arial,sans-serif;
        font-size: 15px;
        line-height: 1.467;
        padding: 8px 12px;
        height: 42px;
        -webkit-appearance: listitem;
        border-radius: 6px;
        margin-bottom: 10px;
    }

    td {
        text-align: center;
        vertical-align: middle;
    }

    tr td:nth-child(2) {
        text-align: left;
    }

    tr {
        transition: 0.5s;
    }

        tr:hover {
            background-color: lightgrey;
        }

    .CloseModalBtn {
        background: var( --dpw-bg-color);
        color: #FFFFFF;
        line-height: 25px;
        position: absolute;
        right: -12px;
        text-align: center;
        top: -10px;
        width: 45px;
        text-decoration: none;
        font-weight: bold;
        box-shadow: 1px 1px 3px #000;
        transition: all .3s;
        height: 45px;
        border-radius: 50%;
        font-size: 25px;
        padding: 8px;
        cursor: pointer
    }

        .CloseModalBtn .fa-times-circle-o {
            color: #ffff !important;
        }

    .modal-title {
        color: var( --dpw-bg-color);
        font-weight: bolder !important;
        font-size: 24px;
        padding-top: 12px;
        padding-bottom: 4px;
        display: inline-block;
    }

    .Truncate {
        max-width: 200px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .badge-Inprocess {
        background: var( --dpw-bg-color) !important;
        color: white !important;
        font-size: 13px !important;
        width: fit-content !important;
    }

    .badge-Approved {
        background: #00a172 !important;
        color: white !important;
        font-size: 13px !important;
        width: fit-content !important;
    }

    .badge-Rejected {
        background: #c51f41 !important;
        color: white !important;
        font-size: 13px !important;
        width: fit-content !important;
    }
</style>
<script src="~/Scripts/DatePicker/jquery.min.js"></script>
<link href="~/Scripts/DatePicker/bootstrap-datepicker.css" rel="stylesheet" />
<link href="~/Scripts/DatePicker/bootstrap-datepicker.standalone.css" rel="stylesheet" />
<script src="~/Scripts/DatePicker/bootstrap-datepicker.js"></script>
<div class="page-header border-bottom-0 blur">
    <div class="page-header-content header-elements-md-inline">
        <div class="page-title d-flex">
            <h4><i class="icon-details mr-2"></i> <span class="font-weight-semibold"><i class="icon-stack-text"></i>&nbsp; PC Request</span></h4>
        </div>
        <div class="col-md-6">
            <div class="form-group">
                <button class="btn btn-success m-t-19 pull-right" data-toggle="collapse" data-target="#Filter">Filter</button>
                <input type="button" class="btn btn-primary  m-t-19 pull-right" value="Generate PC Request" onclick="window.open('/ActivityCapture/CreateRequest','_self')" />

            </div>
        </div>
    </div>
</div>
<hr />
<div ng-controller="TabadulPCRequestCtrl" ng-init="InitIndex()" ng-cloak class="ng-cloak ">
    <div class="collapse" id="Filter">
        <div class="card">
            <div class="card-body">
                <div class="row">
                    <div class="col-md-4">
                        <label>Request No #</label>
                        <input type="text" class="form-control" placeholder="Type Request No #" ng-model="Filter.RequestNo" />
                    </div>
                    <div class="col-md-4">
                        <label>Container #</label>
                        <input type="text" class="form-control" placeholder="Type Container #" ng-model="Filter.Cntr" />
                    </div>
                    <div class="col-md-4">
                        <label>Request Type</label>
                        <select id="pcrequestTypeDD" class="form-select shadow-sm rounded" required ng-model="Filter.PcRequestType" aria-label="Default select example" ng-change="TBD.CARTONS_OF_NO=null;TBD.Recife_Name = null;TBD.newContainerMark=null;">
                            <option data-placeholder="true"></option>
                            <option value="{{x.Name}}" ng-repeat="x in RequestTypeLi">{{x.Name}}</option>
                        </select>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-12">
                        <button class="btn btn-sm m-t-19 pull-right btn-primary" ng-click="ResetFilter()">Reset</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!--counter Start-->
    <div class="row blur">
        <div class="col-md-12 col-lg-12 col-sm-12">
            <div class="CounterCard">
                <b>Total item: </b>  <span id="counts">{{(PCReqData | filter:Filter).length}}</span>
            </div>
        </div>
    </div>
    <!--counter End-->
    <!--Table Start-->
    <div class="card table-card scrollbar blur">
        <table class="table datatable-show-all customers-list" id="table-id">
            <thead>
                <tr class="table-card-head" style="text-align:center;height:50px;">
                    <th>SR#</th>
                    <th>Request No #</th>
                    <th>Container #</th>
                    <th>Request Type </th>
                    <th>Requester Party</th>
                    <th>Status</th>
                    <th>Request Reason</th>
                    <th>Created At</th>
                    <th>Created By</th>
                </tr>
                <tr ng-show="PCReqData.length>0 && PCReqData!=null" ng-repeat="x in PCReqData|filter:Filter | orderBy:'-Id'">
                    <td>{{$index+1}}</td>
                    <td>{{x.RequestNo}}</td>
                    <td>{{x.Cntr}}</td>
                    <td>{{x.PcRequestType}}</td>
                    <td>{{x.RequesterParty}}</td>
                    <td>

                        <span class="badge badge-Inprocess" ng-show="x.Status=='InProcess'||x.Status==null">InProcess</span>
                        <span class="badge badge-Approved" ng-show="x.Status=='APPROVED'">{{x.Status}}</span>
                        <span class="badge badge-Rejected" ng-show="x.Status!='InProcess' && x.Status!='APPROVED' && x.Status!=null">Rejected</span>

                    </td>
                    <td><div title="{{x.RequestReason}}" class="Truncate">{{x.RequestReason}}</div></td>
                    <td>{{x.CreatedAt |date:'dd/MM/yyyy HH:mm'}}</td>
                    <td>{{x.CreatedBy}}</td>
                </tr>
                <tr ng-show="PCReqData.length==0 || PCReqData==null">
                    <td colspan="12">No Data Found</td>
                </tr>
            </thead>
            <tbody>
            </tbody>
        </table>
    </div>

</div>

<script src="@Url.Content("~/Scripts/crypto-js.min.js")"></script>
<script src="~/Scripts/DatePicker/CustomIntilizeJS.js"></script>
<script src="~/Scripts/jquery.min.js"></script>
<script>
    $(document).ready(function () {
        var o = new SlimSelect({
            select: '#pcrequestTypeDD',
            placeholder: 'Select Request type',
            showSearch: true,
            allowDeselect: true,
        });

    });
</script>
