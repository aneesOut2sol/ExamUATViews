<link href="~/Content/popup/jquery-confirm.min.css" rel="stylesheet" />
<!--Header-->
<div ng-controller="RecordEventCtrlV2" ng-init="init()" class="ng-cloak RecordEvent" ng-cloak>
    <!---Block-->
    <div class="card mt-2 mt-2" id="Block">
        <div class="card-header" style=" background: var( --dpw-bg-color); color: white; padding: 8px;">
            <h5 class="mt-2">Select Block</h5>
        </div>
        <div class=" card-body shadow">
            <div class="row">
                <div class="Cardtabs" ng-repeat="B in BlocList">
                    <div class="Absoulte">
                        <div class="CountBadge">{{B.Cntr}}</div>
                        <br />
                    </div>
                    <button ng-click="GetContainerList(B)" ng-class="{'active' : B.BlockNumber == CurrentBlock.BlockNumber }" class="btn btn-primary Blocks" value="{{B.BlockNumber}}">
                        <span ng-show="B.BlockNumber!=983">{{B.BlockNumber}}</span>
                        <span ng-show="B.BlockNumber==983">  {{B.BlockNumber}}K</span>
                    </button>
                    <div class="mt-1">
                        <button ng-click="GetContainerListByStatus(B,B.RejectedGkeys,'Rejected')" id="SEALOCSTSREJbtn{{$index}}"
                                class="btn btn-sm btn-danger LOCSTSStatusbutton">
                            {{B.RejectedGkeys.length}}
                        </button>
                        <button ng-click="GetContainerListByStatus(B,B.AcceptedGkeys,'Accepted')" id="SEALOCSTSACPbtn{{$index}}"
                                class="btn btn-sm btn-success LOCSTSStatusbutton">
