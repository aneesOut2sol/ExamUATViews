<script>

    function allowNumbersAndComma(e) {
        let char = String.fromCharCode(e.which || e.keyCode);

        // Allow: digits (0-9) and comma
        if (/^[0-9,]$/.test(char)) {
            return true;
        }

        // Allow control keys (Backspace, Delete, Arrow keys, Tab, Enter)
        if (e.keyCode === 8 || e.keyCode === 46 || e.keyCode === 37 || e.keyCode === 39 || e.keyCode === 9 || e.keyCode === 13) {
            return true;
        }

        return false;
    }
    window.onload = function () {
        document.getElementById('minisidebar').className = 'sidebar-xs';
    };

    // #region Blur background on modal opening and closing

    $(document).ready(function () {

        $(".modal").on("shown.bs.modal", function () {
            $(".Custom-Card").addClass("blurcontent");
            $("#Block").addClass("blurcontent");
        });

        $(".modal").on("hidden.bs.modal", function () {
            $(".Custom-Card").removeClass("blurcontent");
            $("#Block").removeClass("blurcontent");
        });
    })


    // #endregion

    $(document).ready(function () {
        var o = new SlimSelect({
            select: '#Occ',
            placeholder: 'Select Occures',
            showSearch: true,
            allowDeselect: true,
        });
        var ContractorDD = new SlimSelect({
            select: '#ContractorDD',
            placeholder: 'Select Contractor',
            showSearch: true,
            allowDeselect: true,
        });
    });
    window.addEventListener('click', function (e) {
        var Target = $(e.target).hasClass('optionIcon');
        var Targetparent = $(e.target).parent().hasClass('optionIcon');
        if (!Targetparent && !Target) {
            $('.DropOptionParent').css('display', 'none');
        }
    });


</script>