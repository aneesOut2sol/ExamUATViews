                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!---For choose Functionality Multiple end-->
    <!---For choose Functionality start-->
    <div class="modal fade" id="ChoseModal1" tabindex="-1" role="dialog" aria-labelledby="exampleModalCenterTitle" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered" role="document">
            <div class="modal-content">
                <div class="CloseModalBtn">
                    <button class="close" data-bs-dismiss="ChoseModal1" aria-label="Close"></button>
                    <i class="icon-cross"></i>
                </div>
                <div class="modal-header">
                    <h5 class="modal-title">Select Functionality</h5>
                </div>
