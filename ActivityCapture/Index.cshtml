                                                <div class="input-group">
                                                    <input type="text" class="form-control date2" id="{{$index+'applied'}}" placeholder="DD/MM/YYYY HH:mm" value="{{a.EventTime | date :'dd/MM/yyyy HH:mm'}}" disabled>
                                                    <span class="input-group-append">
                                                        <span class="input-group-text"><i class="icon-calendar"></i></span>
                                                    </span>
                                                </div>
                                            </div>

                                            <!-- Above div show when Exam Functionality found -->

                                            <div class="col-lg-12" ng-if="a.isApplied && a.IsManualEvent == true && a.HasLOV == true">

                                                @*<label>{{a.ManualFieldName}}</label>*@
                                                <select ng-if="a.LovList.length>0" ng-model="a.FieldValue" class="form-control">
                                                    <option ng-selected="x.Id == a.FieldValue" ng-repeat="x in a.LovList" value="{{x.Id}}">{{x.Name}}</option>
                                                </select>

                                            </div>
                                            <!-- Above div show when Other Functionality found with LOV Value -->

                                            <div class="col-lg-12" ng-if="a.isApplied && a.IsManualEvent == true && a.HasLOV == false">

                                                @*<label>{{a.ManualFieldName}}</label>*@
                                                <input ng-model="a.FieldValue" readonly class="form-control" type="text" />

                                            </div>
                                            <!-- Above div show when Other Functionality found with LOV Value -->


                                        </td>

                                        <td>
                                            <input ng-disabled="a.isApplied" ng-checked="a.isApplied" type="checkbox" id="{{a.EventName}}" name="{{a.EventName}}" value="{{a.EventName}}" ng-model="Evn.EventCheck" ng-change="GetEvent($index,a.EventName,a)" />
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </form>

                </div>
                <div class="modal-footer">
                    <button type="button" ng-click="OnModalClose()" class="btn btn-secondary pull-right" id="{{Containerdata}}" data-bs-dismiss="modal">Close</button>
                    <button ng-click="RecordEvent1(Containerdata)" type="submit" class="btn btn-primary pull-right">Save changes</button>
                </div>

            </div>
        </div>

    </div>
    <!---For single container exam modal start-->
    <!---For choose Functionality Multiple start-->
    <div class="modal fade" id="ChoseModal" tabindex="-1" role="dialog" aria-labelledby="exampleModalCenterTitle" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered" role="document">
            <div class="modal-content">
                <div class="CloseModalBtn">
                    <button class="close" data-bs-dismiss="modal" aria-label="Close"></button>
                    <i class="icon-cross"></i>
                </div>
                <div class="modal-header">
                    <h5 class="modal-title">Select Functionality</h5>
                </div>
                <div class="modal-body" style=" letter-spacing: 0.8px;">
                    <div class="row">
                        <div class="col-md-8 form-group">
                            <select data-placeholder="Please Select Functionality" id="Functionality" class="form-control select-clear" ng-model="Event.Functionality" data-fouc>
                                <option></option>
                                <option ng-repeat="E in CategoryList" value="{{E.Id}}">{{E.Category}}</option>
                            </select>
                        </div>
                        <div class="col-md-4  form-group">
