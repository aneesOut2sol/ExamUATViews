                <button class="btn btn-primary" ng-click="UploadLCL_CargoPhoto(LCL_BL_obj)">Submit</button>
                <button class="btn btn-reset" data-dismiss="modal">Close</button>
            </div>            
        </div>
    </div>
</div>


