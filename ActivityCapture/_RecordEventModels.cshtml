<!--Cargo Strip Confirmation-->
<div class="modal ZoominAnimate jqueryConfrim" id="cargostripConfrimation" tabindex="-1" data-backdrop="static" data-keyboard="false" role="dialog" aria-labelledby="exampleModalCenterTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document" style="min-width:30%;">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="">
                    <b>{{CurrentCntr}}</b>  Cargo Strip Confirmation!
                </h5>
            </div>
            <div class="modal-body">
                <div class="row">
                    <div class="col-md-6">
                        <label class="Starick">Container location</label>
                        <input type="text" ng-model="CargoStrip.location" ng-disabled="Cargostuffed.approvalRequired == true" class="form-control" value="" />
                    </div>
                    <div class="col-md-6" ng-show="CurrentBlockFilter!='LA'">
                        <label>Stripped by</label><br />
                        <div class="iconsDev">
                            <img src="/Content/images/ForkLift.png" ng-click="SetForkliftAction($event,'ForkLift','CargoStrip','StripAction')" class="iconDevimgs greyscale" title="ForkLift" />
                        </div>
                        <div class="iconsDev">
                            <img src="/Content/images/LabourIcon.png" ng-click="SetForkliftAction($event,'Labour','CargoStrip','StripAction')" class="iconDevimgs greyscale" title="Labour" />
                        </div>
                        <div class="iconsDev">
                            <img src="/Content/images/MobileCrane.png" ng-click="SetForkliftAction($event,'MobileCrane','CargoStrip','StripAction')" class="iconDevimgs greyscale" title="Mobile Crane" />
                        </div>
                        <div class="iconsDev">
                            <img src="/Content/images/NotAllowedIcon.png" ng-click="SetForkliftAction($event,'NoStrip','CargoStrip','StripAction')" class="iconDevimgs greyscale" title="No Strip" />
                        </div>
                    </div>
                    <div class="col-md-6" ng-show="CargoStrip.StripAction=='Labour' && CurrentBlockFilter=='LA'">
                        @*v5.8.1*@
                        <label>Labor handling</label>
                        <select disabled class="form-control select-clear" id="laborhandlingstrip2" ng-model="CargoStrip.LaborHandling" required data-fouc>

                            <option value="Labor">Labor</option>
                        </select>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6 mt-2" ng-show="CargoStrip.StripAction=='ForkLift'">
                        <label class="Starick">Forklift type</label>
                        <select data-placeholder="Please Select forklift type" class="form-control select-clear" id="ForkliftutilizedDD" ng-model="CargoStrip.forklifttype" required data-fouc>
                            <option></option>
                            <option ng-repeat="item in ForkLiftTypeList" value="{{item.Type}}">{{item.Type}}</option>
                            @*<option value="No attachment">No attachment</option>
                <option value="Push pull">Push pull</option>
                <option value="Clamp">Clamp</option>
                <option value="Boom">Boom</option>
                <option value="Forklift JIB">Forklift JIB</option>
                <option value="Forklift Shovel">Forklift Shovel</option>
                <option value="Forklift 5TON">Forklift 5TON</option>
                <option value="Forklift 12TON">Forklift 12TON</option>*@
                        </select>
                    </div>
                    <div class="col-md-6 mt-2" ng-show="CargoStrip.StripAction=='Labour' && CurrentBlockFilter!='LA'">
                        @*v5.8.1*@
                        <label>Labor handling</label>
                        <select  data-placeholder="Please select labor handling" class="form-control select-clear" id="laborhandlingstrip" ng-model="CargoStrip.LaborHandling" required data-fouc>
                            <option ></option>
                            <option value="Labor">Labor</option>
                            <option value="Labor Machine">Labor Machine</option>
                            <option value="Labor Car">Labor Car</option>
                            <option value="Hybrid">Hybrid</option>
                            <option value="Labor + Forklift">Labor + Forklift</option>
                        </select>
                    </div>
                   
                    <div class="col-md-6 mt-2">
                        <label class="Starick">Strip%</label>
                        <select data-placeholder="Please Select Strip Percentage" class="form-control select-clear" id="StripPerDD" ng-model="CargoStrip.StripPercentage" required data-fouc>
                            <option></option>
                            <option value="0">0</option>
                            <option value="15">15</option>
                            <option value="30">30</option>
                            <option value="50">50</option>
                            <option value="100">100</option>
                        </select>
                    </div>

                    <div class="col-md-6 mt-2" ng-show="!stringNullorEmpty(CargoStrip.StripAction) && CargoStrip.StripAction != 'NoStrip'">
                        <label class="Starick">Contractor</label>
                        <select ng-disabled="CurrentBlockFilter == 'LA' || CargoStrip.approvalRequired == true" ng-change="GetContractorMember(CargoStrip.Contractor,CargoStrip.StripAction)" data-placeholder="Please Select Contractor" class="form-control select-clear" id="ContractorDD" ng-model="CargoStrip.Contractor" required data-fouc>
                            <option></option>
                            <option ng-repeat="contrct in ContractorList" ng-selected="contrct == CargoStrip.Contractor" value="{{contrct}}">{{contrct}}</option>
                            <option value="Other">Other</option>
                        </select>
                    </div>
                    <div class="col-md-6 mt-2" ng-show="!stringNullorEmpty(CargoStrip.Contractor) && GetContractorNameinlower(CargoStrip.Contractor)!= 'other' && CurrentBlockFilter != 'LA'">
                        <label>Labor</label>
                        <select ng-model="CargoStrip.StripRepackLaborList" data-placeholder="Please Select labor" multiple class="form-control select-clear" id="ContractormemeberDD" required data-fouc>
                            <option></option>
                            <option ng-repeat="mem in ContractorMember" ng-value="mem.EmpId">{{mem.EmpId}} - {{mem.EmpName}}</option>
                        </select>
                    </div>
                    <div class="col-md-6" ng-show="!stringNullorEmpty(CargoStrip.Contractor) && GetContractorNameinlower(CargoStrip.Contractor)!= 'other' && CurrentBlockFilter == 'LA'">
                        <label>Labor</label>
                        <ul ng-show="CurrentBlockFilter == 'LA'" >
                            <li ng-repeat="x in LALabors">{{x.EmpId}}-{{x.EmpName}}</li>
                        </ul>
                    </div>
                    <div class="col-md-6 mt-2" ng-show="!stringNullorEmpty(CargoStrip.Contractor) && GetContractorNameinlower(CargoStrip.Contractor)== 'other'">
                        <label>Labor Id</label> <span> e.g (1001,1002)</span>
                        <input type="text" class="form-control" ng-model="CargoStrip.OtherContractor" onkeypress="return allowNumbersAndComma(event)" />
                    </div>
                </div>

                <br />
                <div class="row" ng-if="SealCutDetails != undefined && (SealCutDetails.DoorAfterSeal != null || SealCutDetails.CargoFrontView != null)">
                    <div class="col-md-6">
                        <label>Door after seal (SEAL CUT)</label>
                        <div class="imguplaoder" ng-show="SealCutDetails.DoorAfterSeal!=''&& SealCutDetails.DoorAfterSeal!=null">
                            <a style=" text-decoration: none; color: inherit;" href="#" ng-click="OpenImageView(SealCutDetails.DoorAfterSeal,'cargostripConfrimation')">
                                <span><i class="icon-eye"></i></span> View photo
                            </a>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <label>Cargo front view (SEAL CUT)</label>
                        <div class="imguplaoder" ng-show="SealCutDetails.CargoFrontView!=''&& SealCutDetails.CargoFrontView!=null">
                            <a style=" text-decoration: none; color: inherit;" ng-click="OpenImageView(SealCutDetails.CargoFrontView,'cargostripConfrimation')" href="#">
                                <span><i class="icon-eye"></i></span> View photo
                            </a>
                        </div>
                    </div>
                </div>
                <div class="LCL_strip_container" ng-if="CurrentCntrFreight_kind == 'LCL'">
                    <div class="LCL_strip_card_grid">
                        <div class="LCL_strip_card" ng-repeat="x in LCL_BL_List_eventbase">
                            <input type="checkbox" id="check_{{$index}}" class="LCL_strip_toggle_input" hidden>

                            <label for="check_{{$index}}" class="LCL_strip_card_header">
                                <div class="LCL_strip_header_content">
                                    <span class="LCL_strip_bl_label">B/L Number</span>
                                    <h3 class="LCL_strip_bl_number">{{x.bl_nbr}}</h3>
                                </div>
                                <div class="LCL_strip_arrow">
                                    <i class="icon-chevron-down"></i>
                                </div>
                            </label>

                            <div class="LCL_strip_card_body">
                                <div class="LCL_strip_photo_section">
                                    <div class="LCL_strip_photo_item" ng-repeat="y in x.Cargo_Photo_List">
                                        <div class="LCL_strip_photo_info">
                                            <span class="LCL_strip_label_text">{{y.Label}}</span>
                                            <button class="LCL_strip_view_btn" title="View Image" ng-click="OpenImageView(y.Url,'cargostripConfrimation')">
                                                <i class="icon-eye"></i> View
                                            </button>
                                        </div>
                                    </div>
                                </div>

                                <div class="LCL_strip_card_footer">
                                    <div class="LCL_strip_meta_item">
                                        <i class="icon-user"></i>
                                        <div>
                                            <small>Recorded by</small>
                                            <p>{{x.Cargo_Photo_List[0].createdby || 'N/A'}}</p>
                                        </div>
                                    </div>
                                    <div class="LCL_strip_meta_item">
                                        <i class="icon-clock"></i>
                                        <div>
                                            <small>Recorded at</small>
                                            <p>{{x.Cargo_Photo_List[0].createdAt | date:'dd/MM/yyyy HH:mm:ss'}}</p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="row" ng-show="!stringNullorEmpty(CargoStrip.Contractor) || CargoStrip.StripAction == 'NoStrip'">
                    <!--V5.8-->
                    <div class="col-md-12">
                        <ul class="Damage_Images">
                            <li ng-repeat="x in CargoStrip.PhotoLibrary">
                                <b>{{x.Label}}<span ng-if="x.required" class="Starick"></span> </b>
                                <div class="Icon" ng-show="x.Url==null || x.Url==''">
                                    <span title="Open Camera" ng-click="OpenCam($index,'CargoStrip')"><i class="icon-camera"></i></span>
                                    <label title="Upload Image" style="margin:0px;">
                                        <span><i class="icon-images2"></i></span>
                                        <input type="file" style="display:none" accept="image/*" id="{{x.Id}}" index="{{$index}}" name="pic" accept="image/*" onchange="angular.element(this).scope().CargoStripLibraryUpload(this)">
                                    </label>
                                </div>
                                <div class="Icon" ng-show="x.Url!=null && x.Url!=''">
                                    <a title="View Image" ng-click="OpenImageView(x.Url,'cargostripConfrimation')"><span><i class="icon-eye"></i></span></a>
                                    <span title="Delete Image" ng-click="RemovePhotoFromStripLibrary($index)"><i class="icon-bin"></i></span>
                                </div>
                            </li>
                        </ul>
                    </div>
                </div>
                <div class="row" ng-show=" !stringNullorEmpty(CargoStrip.Contractor) && CargoStrip.StripAction != 'MobileCrane' && CargoStrip.StripAction != 'NoStrip'">
                    <div class="col-md-12">
                        <div class="form-group mt-2 AdditionalServiceRadio">
                            <label>Additional Service</label><br />
                            <label class="switch">
                                <input type="checkbox" ng-model="ShowAdditionalService" ng-change="SetAdditionalServiceAction('CargoStrip')">
                                <span class="slider"></span>
                            </label>
                        </div>
                    </div>

                </div>
                <div class="row" ng-show="ShowAdditionalService == true && !stringNullorEmpty(CargoStrip.Contractor)">
                    <div class="col-md-12 col-sm-12 col-lg-12">
                        <div class="AdditionalServiceSection">
                            <table class="table text-center" ng-repeat="service in AdditionalServices">
                                <thead>
                                    <tr class="">
                                        <th>{{GetAdditionalService(service,'field')}}</th>
                                        <th>NUMBERS USED</th>
                                        <th>HOURS</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr ng-repeat="row in GetAdditionalService(service,'service')">
                                        <td width="50%"><span class="pl-15">{{row.field}}</span></td>
                                        <td class="p-0" width="25%">
                                            <select ng-model="row.NumberUsed">
                                                <option ng-disabled="row.disable == true" ng-repeat="num in NumberList" value="{{num}}">{{num}}</option>
                                            </select>
                                        </td>
                                        <td class="p-0" width="25%">
                                            <select ng-model="row.HourUsed">
                                                <option ng-if="row.EventName =='MATERIAL_SUPPLY_CAR' && row.NumberUsed>0" selected value="1">1</option>
                                                <option ng-repeat="num in NumberList" ng-if="row.EventName !='MATERIAL_SUPPLY_CAR'" value="{{num}}">{{num}}</option>
                                            </select>
