<!--Seal Cut Confirmation-->
<div class="modal ZoominAnimate jqueryConfrim" id="SealCutConfrimation" tabindex="-1" data-backdrop="static" data-keyboard="false" role="dialog" aria-labelledby="exampleModalCenterTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document" style="min-width:30%;">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="">
                    <b>{{CurrentCntr}}</b>        Seal Cut Confirmation!
                </h5>
            </div>
            <div class="modal-body">
                <div class="row">
                    <div class="col-md-6">
                        <label>Door after seal cut</label>
                        <label class="imguplaoder" for="DoorAfterSeal" ng-show="Sealcut.DoorAfterSeal==''||Sealcut.DoorAfterSeal==null">
                            <input style="display:none" type="file" id="DoorAfterSeal" accept="image/*" onchange="angular.element(this).scope().SeaCutPhoto(this,'DoorAfterSeal')" class="form-control" value="" />
                            <div class="">
                                Upload photo <span class="pull-right"><i class="icon-file-upload"></i></span>
                            </div>

                        </label>
                        <div class="imguplaoder" ng-show="Sealcut.DoorAfterSeal!=''&& Sealcut.DoorAfterSeal!=null" ng-click="OpenImageView(Sealcut.DoorAfterSeal, 'SealCutConfrimation')">
                            <span><i class="icon-eye"></i></span> View photo <span ng-click="Sealcut.DoorAfterSeal=''" class="pull-right"><i class="icon-bin"></i></span>
                        </div>

                    </div>
                    <div class="col-md-6">
                        <label>Front view of the cargo</label>
                        <label class="imguplaoder" for="CargoFront" ng-show="Sealcut.CargoFront==''||Sealcut.CargoFront==null">
                            <input style="display:none" type="file" id="CargoFront" accept="image/*" onchange="angular.element(this).scope().SeaCutPhoto(this,'CargoFront')" class="form-control" value="" />
                            <div class="">
                                Upload photo <span class="pull-right"><i class="icon-file-upload"></i></span>
                            </div>

                        </label>
                        <div class="imguplaoder" ng-show="Sealcut.CargoFront!=''&& Sealcut.CargoFront!=null" ng-click="OpenImageView(Sealcut.CargoFront, 'SealCutConfrimation')">
                            <span><i class="icon-eye"></i></span> View photo <span ng-click="Sealcut.CargoFront=''" class="pull-right"><i class="icon-bin"></i></span>
                        </div>

                    </div>
                    <div class="col-md-6">
                        <label>Risk Type</label>
                        <select data-placeholder="Please Select Risk type" class="form-control select-clear" id="RiskTypeDD_sealcut"
                                ng-model="Sealcut.RiskType"
                                ng-disabled="currentCntrRecord.HighRiskHold"
                                required data-fouc>
                            <option></option>
                            <option value="Low">Low</option>
                            <option value="High">High</option>
                        </select>
                    </div>
                    <div class="col-md-6" ng-show="Sealcut.RiskType=='High'">
                        <label>High risk reason</label>
                        <select data-placeholder="Select high risk reason" class="form-control select-clear" id="highriskReasondd2"
                                ng-model="Sealcut.HighRiskReason"
                                ng-disabled="currentCntrRecord.HighRiskHold"
                                required data-fouc>
                            <option></option>
                            <option value="DG Cargo">DG Cargo</option>
                            <option value="Liquids">Liquids</option>
                            <option value="Heavy Cargo">Heavy Cargo</option>
                            <option value="Sensitive Cargo">Sensitive Cargo</option>
                            <option value="Marble">Marble</option>
                            <option value="Glass">Glass</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label>Handle by</label>
                        <select data-placeholder="Please select handle by" class="form-control select-clear" id="HandlebyDD_sealcut" ng-model="Sealcut.Handleby" required data-fouc>
                            <option></option>
                            <option value="Forklift">Forklift</option>
                            <option value="Labor">Labor</option>
                            <option value="Mobilecrane">Mobilecrane</option>
                        </select>
                    </div>
                    <div class="col-md-6" ng-show="Sealcut.Handleby=='Labor'">
                        <label>Labor handling</label>
                        <select data-placeholder="Please select labor handling" class="form-control select-clear" id="laborhandlingDD2" ng-model="Sealcut.LaborHandling" required data-fouc>
                            <option></option>
                            <option value="Labor">Labor</option>
                            <option value="Labor Machine">Labor Machine</option>
                            <option value="Labor Car">Labor Car</option>
                            <option value="Hybrid">Hybrid</option>
                            <option value="Labor + Forklift">Labor + Forklift</option>
                        </select>
                    </div>
                    <div class="col-md-6 " ng-show="Sealcut.Handleby=='Forklift'">
                        <label class="Starick">Forklift type</label>
                        <select data-placeholder="Please Select forklift type" class="form-control select-clear" id="SCut_ForkliftutilizedDD" ng-model="Sealcut.forklifttype" required data-fouc>
                            <option></option>
                            <option ng-repeat="item in ForkLiftTypeList" value="{{item.Type}}">{{item.Type}}</option>
                            @*<option value="No attachment">No attachment</option>
                            <option value="Push pull">Push pull</option>
                            <option value="Clamp">Clamp</option>
                            <option value="Boom">Boom</option>
                            <option value="Forklift JIB">Forklift JIB</option>
                            <option value="Forklift Shovel">Forklift Shovel</option>
                            <option value="Forklift 5TON">Forklift 5TON</option>
                            <option value="Forklift 12TON">Forklift 12TON</option>*@
                        </select>
                    </div>
                </div>


            </div>
            <div class="modal-footer" style=" padding: 9px; ">
                <button class="btn btn-primary" ng-click="ApplySealCut(Sealcut)">Submit</button>
                <button class="btn btn-reset" ng-click="CloseSealCut()">Close</button>
            </div>
        </div>
    </div>
</div>
