<div class="modal fade" id="ResubmitPartialRequestModal" tabindex="-1" role="dialog" aria-labelledby="exampleModalCenterTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content" style="overflow:visible !important">
            <div class="CloseModalBtn" data-dismiss="modal">
                <button class="close" data-dismiss="modal" aria-label="Close"></button>
                <i class="icon-cross"></i>
            </div>
            <div class="modal-header">
                <div class="w-100">
                    <h5 class="modal-title">
                        #{{EventInfo.Cntr}}
                        <span ng-if="EventInfo.ApproveStatus == 0 && !EventInfo.PartialRejected" class="PendingApprovalEvent pull-right">Pending for approval</span>
                        <span ng-if="EventInfo.ApproveStatus == 1" class="Approvebadge pull-right">Approved</span>
                        <span ng-if="EventInfo.ApproveStatus == 2" class="RejectedApprovalEvent pull-right">Rejected</span>
                        <span ng-if="EventInfo.ApproveStatus == 0 && EventInfo.PartialRejected" class="RejectedApprovalEvent pull-right">Partial Rejected</span>
                    </h5>
                    <span class="modal-title-description">Resubmit cargo repack rejected fields</span>
                </div>
            </div>
            <div class="modal-body">
                <div class="row" ng-show="Repack_Partial_Rejected_Fields.includes('Stuffed By')">
                    <div class="col-md-12">
                        <label>Stuffed by</label><br />
                        <select data-placeholder="Please Select stuffed by" class="form-control select-clear" id="PR_stuffedby" ng-model="PR_OBJ.StripNStuffBy" required data-fouc>
                            <option></option>
                            <option value="Labour">Labor</option>
                            <option value="Forklift">Forklift</option>
                            <option value="MobileCrane">Mobile Crane</option>
                            <option value="NoRepack">No repack</option>
                        </select>
                    </div>
                </div>

                <div class="row" ng-if="Repack_Partial_Rejected_Fields.includes('Attachments')">
                    <div class="col-md-12">
                        <br />
                        <label>Attachments</label>
                        <ul class="Damage_Images">
                            <li ng-repeat="x in PR_OBJ.PhotoLibrary">
                                <b>{{x.Label}}<span ng-if="x.required" class="Starick"></span> </b>
                                <div class="Icon" ng-show="x.Url==null || x.Url==''">
                                    <label title="Upload Image" style="margin:0px;">
                                        <span><i class="icon-images2"></i></span>
                                        <input type="file" style="display:none" accept="image/*" id="{{x.Id}}" index="{{$index}}" name="pic" accept="image/*" onchange="angular.element(this).scope().PR_PhotoLibraryUpload(this)">
                                    </label>
                                </div>
                                <div class="Icon" ng-show="x.Url!=null && x.Url!=''">
                                    <a title="View Image" ng-click="OpenImageView(x.Url,'ResubmitPartialRequestModal')"><span><i class="icon-eye"></i></span></a>
                                    <span title="Delete Image" ng-click="PR_RemovePhotoFromLibrary($index)"><i class="icon-bin"></i></span>
                                </div>
                            </li>
                        </ul>
                    </div>
                </div>
                <div class="row" ng-if="Repack_Partial_Rejected_Fields.includes('Additional Service')">
                    <div class="col-md-12 col-sm-12 col-lg-12">
                        <div class="AdditionalServiceSection partialrejected_additionalService">
                            <table class="table text-center" ng-repeat="service in AdditionalServices">
                                <thead>
                                    <tr class="">
                                        <th>{{GetAdditionalService(service,'field')}}</th>
                                        <th>NUMBERS USED</th>
                                        <th>HOURS</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr ng-repeat="row in GetAdditionalService(service,'service')">
                                        <td width="50%"><span class="pl-15">{{row.field}}</span></td>
                                        <td class="p-0" width="25%">
                                            <select ng-model="row.NumberUsed">
                                                <option ng-repeat="num in NumberList" ng-value="{{num}}">{{num}}</option>
                                            </select>
                                        </td>
                                        <td class="p-0" width="25%">
                                            <select ng-model="row.HourUsed">
                                                <option ng-if="row.EventName =='MATERIAL_SUPPLY_CAR' && row.NumberUsed>0" ng-value="1">1</option>
                                                <option ng-selected="row.HourUsed==num" ng-repeat="num in NumberList" ng-show="row.EventName !='MATERIAL_SUPPLY_CAR'" ng-value="{{num}}">{{num}}</option>
                                            </select>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <div class="row">
                    <div class="col-md-12" style="text-align:end;">
                        <button class="btn btn-cancel" data-dismiss="modal">Cancel</button>
                        <button class="btn btn-primary" ng-click="PR_resubmit(PR_OBJ)">Resubmit request</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


