                            <td class="p-2">{{BadStowageData.strippingPercent}}</td>
                        </tr>*@
                    <tr ng-if="BadStowageData.ApproveStatus ==2">
                        <th class="p-2">Recorded By</th>
                        <td class="p-2">{{BadStowageData.CreatedBy}}</td>
