                            <table class="table text-center" ng-repeat="service in AdditionalServices">
                                <thead>
                                    <tr class="">
                                        <th>{{GetAdditionalService(service,'field')}}</th>
                                        <th>NUMBERS USED</th>
                                        <th>HOURS</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr ng-repeat="row in GetAdditionalService(service,'service')">
                                        <td width="50%"><span class="pl-15">{{row.field}}</span></td>
                                        <td class="p-0" width="25%">
                                            <select ng-model="row.NumberUsed" ng-disabled="row.disable">
                                                <option  ng-repeat="num in NumberList" ng-value="{{num}}">{{num}}</option>
                                            </select>
                                        </td>
                                        <td class="p-0" width="25%">
                                            <select ng-model="row.HourUsed"  ng-disabled="row.disable">
                                                <option ng-repeat="num in NumberList" ng-value="{{num}}">{{num}}</option>
                                            </select>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
