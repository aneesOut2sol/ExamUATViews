<!--Record Damage-->
<div class="modal fade" id="DamageReports" tabindex="-1" role="dialog" data-backdrop="static" data-keyboard="false" aria-labelledby="exampleModalCenterTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="CloseModalBtn" data-dismiss="modal" aria-label="Close">
                <button class="close" data-dismiss="modal" aria-label="Close"></button>
                <i class="icon-cross"></i>
            </div>
            <div class="modal-header">
                <h5 class="modal-title">
                    {{DamageCntr}}
                </h5>

            </div>
            <div class="modal-body">
                <div class="row text-center mb-2" ng-repeat="x in DamageReports">
                    <div class="card" style=" border-radius: 7px; overflow: hidden;">
                        <table class="detailstable">
                            <tr>
                                <th>Seq.No</th>
                                <th>{{$index+1}}</th>
                            </tr>
                            <tr ng-if="x.bl_nbr != null">
                                <th>B/L</th>
                                <th>{{x.bl_nbr}}</th>
                            </tr>
                            <tr>
                                <th>Capture date</th>
                                <th>{{x.CreatedAt |date:'dd/MM/yyyy HH:mm:ss'}}</th>
                            </tr>
                            <tr>
                                <th>Status</th>
                                <th>
                                    <span class="badge approvedStatus " ng-show="x.Status==2">Approved</span>
                                    <span class="badge waitingForApprovalStatus" ng-show="x.Status==5||x.Status==1">Waiting for approval </span>
                                    <span class="badge rejectStatus" ng-show="x.Status==3">Rejected</span>
                                </th>
                            </tr>
                            <tr>
                                <th>Action</th>
                                <th>
                                    <span ng-click="PrintDamage(x.Id)" class="mr-2" ng-show="x.Status==2"><i class="icon-printer"></i></span>
                                    <span ng-click="ShowDamageOnCntrById(x.Id)" class="mr-2"><i class="icon-info22"></i></span>
                                </th>
                            </tr>
                        </table>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <div class="row">
                    <div class="col-md-12" style="text-align:end;">
                        <button class="btn btn-cancel" data-dismiss="modal">Cancel</button>
                        <span class="btn btn-primary pull-right ml-2" ng-click="AddDamage(DamageCntr)">Record Damage</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!--Record Damage-->
<!--Show Damage--->
<div class="modal fade" id="ShowDamage" tabindex="-1" role="dialog" data-backdrop="static" data-keyboard="false" aria-labelledby="exampleModalCenterTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="CloseModalBtn" ng-click="closeDamageModel()" aria-label="Close">
                <button class="close" aria-label="Close"></button>
                <i class="icon-cross"></i>
            </div>
            <div class="modal-header">
                <h5 class="modal-title">
                    Cargo report
                    <span title="Print report" ng-show="ApproveStatus == 2" class="printBdage">
                        <a target="_blank" href="{{ShowDamageData.ReportLink}}">
                            <i class="icon-printer"></i>
                        </a>
                    </span>
                </h5>

            </div>
            <div class="modal-body">
                <table style="width: 100%; border: none !important;">
                    <tr ng-if="ShowDamageData.bl_nbr != null">
                        <th class="p-2">B/L</th>
                        <td class="p-2">{{ShowDamageData.bl_nbr}}</td>
                    </tr>
                    <tr>
                        <th class="p-2">Damage By</th>
                        <td class="p-2">{{ShowDamageData.DamageBy}}</td>
                    </tr>
                    <tr ng-if="!stringNullorEmpty(ShowDamageData.DamageByReason)">
                        <th class="p-2">Terminal (INCIDENT) Reason</th>
                        <td class="p-2">{{ShowDamageData.DamageByReason}}</td>
                    </tr>
                    <tr>
                        <th class="p-2">Damage Type</th>
                        <td class="p-2">{{ShowDamageData.DamageType}}</td>
                    </tr>
                    <tr ng-if="ApproveStatus !=1">
                        <th class="p-2">Approved By</th>
                        <td class="p-2">{{ShowDamageData.UpdatedBy}}</td>
                    </tr>
                    <tr ng-if="ShowDamageData.CargoType !=null && ShowDamageData.CargoType !=''">
                        <th class="p-2">Cargo type </th>
                        <td class="p-2">{{ShowDamageData.CargoType}}</td>
                    </tr>
                    <tr ng-if="ShowDamageData.CargoQuantity !=null && ShowDamageData.CargoQuantity !=''">
                        <th class="p-2">Cargo Quantity </th>
                        <td class="p-2">{{ShowDamageData.CargoQuantity}}</td>
                    </tr>
                    <tr>
                        <th class="p-2">Status</th>
                        <td class="p-2">
                            <b ng-show="ApproveStatus == 0" class="badge inProgressStatus">InProgress</b>
                            <b ng-show="ApproveStatus == 1" class="badge waitingForApprovalStatus">Waiting for approval</b>
                            <b ng-show="ApproveStatus == 2" class="badge approvedStatus">Approved</b>
                            <b ng-show="ApproveStatus == 3" class="badge rejectStatus">Rejected</b>
                        </td>
                    </tr>
                </table>
                <div class="row">
                    <div class="col-md-6" ng-repeat="c in ShowDamageData.Images">
                        <div class="imageBox">
                            <div class="Imgheader" title="{{c.Label}}">
                                <b>{{c.Label}}</b>
                            </div>
                            <div class="ImgContent" ng-click="OpenImageView(c.Url,'ShowDamage')">
                                <img src="{{c.Url}}" style="height:50px!important;cursor:pointer" />
                            </div>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-12" style="text-align:end">

                    </div>
                </div>


            </div>
            <div class="modal-footer">
                <div class="row">
                    <div class="col-md-12" style="text-align:end;">


                        @if (User.IsInRole(ExamPortal.Model.EntityModel.Enums.UserRole.Admin.ToString()) || User.IsInRole(ExamPortal.Model.EntityModel.Enums.UserRole.ExamSuperVisor.ToString()))
                        {
                            <button ng-show="ApproveStatus == 1" class="btn btn-danger" data-dismiss="modal" ng-click="ShowConfirmation(ShowDamageData,false)">Reject</button>
                            <button ng-show="ApproveStatus == 1" class="btn btn-success" data-dismiss="modal" ng-click="ShowConfirmation(ShowDamageData,true)">Approve</button>

                        }
                        <button class="btn btn-cancel" data-dismiss="modal">Cancel</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!--Show Damage end--->
<!--Damage History-->
<div class="modal fade" id="ShowDamageHistory" data-backdrop="static" data-keyboard="false" tabindex="-1" role="dialog" aria-labelledby="myLargeModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="CloseModalBtn" data-dismiss="modal" aria-label="Close">
                <button class="close" data-dismiss="modal" aria-label="Close"></button>
                <i class="icon-cross"></i>
            </div>
            <div class="modal-header">
                <h5 class="modal-title">Damage History</h5>
            </div>
            <div class="modal-body">
                <table ng-repeat="x in ConatinerDamageDataList">
                    <tr class="border-bottom">
                        <td class="font-weight-bold">Status</td>
                        <td><span class="badge rejectStatus" style="width:100px !important">Rejected</span></td>
                    </tr>
                    <tr class="border-bottom">
                        <td class="font-weight-bold">Rejected Reason</td>
                        <td>{{x.RejectedRemarks}}</td>
                    </tr>
                    <tr class="border-bottom">
                        <td class="font-weight-bold">Rejected At</td>
                        <td>{{x.UpdatedAt}}</td>
                    </tr>
                    <tr class="border-bottom">
                        <td class="font-weight-bold">Rejected By</td>
                        <td>{{x.UpdatedBy}}</td>
                    </tr>
                </table>
            </div>
            <div class="modal-footer">
                <div class="row">
                    <div class="col-md-12" style="text-align:end">
                        <button class="btn btn-cancel" data-dismiss="modal">Cancel</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!--Damage History end-->
<!--Captured Event History-->
<div class="modal fade" id="EventInfo" data-backdrop="static" data-keyboard="false" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="CloseModalBtn" data-dismiss="modal">
                <i data-dismiss="modal" class="icon-cross"></i>
            </div>
            <div class="modal-header">
                <div class="w-100">
                    <h5 class="modal-title">
                        #{{EventInfo.Cntr}}
                        <span ng-if="currentCapturedRecord.ApproveStatus == 0 && !currentCapturedRecord.PartialRejected" class="PendingApprovalEvent pull-right">Pending for approval</span>
                        <span ng-if="currentCapturedRecord.ApproveStatus == 1" class="Approvebadge pull-right">Approved</span>
                        <span ng-if="currentCapturedRecord.ApproveStatus == 2" class="RejectedApprovalEvent pull-right">Rejected</span>
                        <span ng-if="currentCapturedRecord.ApproveStatus == 0 && currentCapturedRecord.PartialRejected" class="RejectedApprovalEvent pull-right">Partial Rejected</span>
                    </h5>
                    <span class="modal-title-description">{{EventDetails}}</span>
                </div>
            </div>
            <div class="modal-body" style=" letter-spacing: 0.8px; max-height: 500px; overflow:auto">
                <div class="row">
                    <table class="DetailsTable">
                        <tr ng-if="!stringNullorEmpty(EventInfo.StripStatus)">
                            <th>Stripping Status</th>
                            <td>
                                <span ng-if="EventInfo.StripStatus == 'Inprocess'" class="PendingApprovalEvent">Inprocess</span>
                                <span ng-if="EventInfo.StripStatus == 'Completed'" class="Approvebadge">Completed</span>
                            </td>
                        </tr>
                        <tr ng-if="!stringNullorEmpty(EventInfo.StuffStatus)">
                            <th>Stripping Status</th>
                            <td>
                                <span ng-if="EventInfo.StuffStatus == 'Inprocess'" class="PendingApprovalEvent">Inprocess</span>
                                <span ng-if="EventInfo.StuffStatus == 'Completed'" class="Approvebadge">Completed</span>
                            </td>
                        </tr>
                        <tr>
                            <th>Container</th>
                            <td><span>{{EventInfo.Cntr}}</span></td>
                        </tr>
                        <tr ng-show="!stringNullorEmpty(EventInfo.RiskType)">
                            <th>Risk Type</th>
                            <td><span>{{EventInfo.RiskType}}</span></td>
                        </tr>
                        <tr ng-show="!stringNullorEmpty(EventInfo.Sealcut_HighRiskReason)">
                            <th>High risk Type</th>
                            <td><span>{{EventInfo.Sealcut_HighRiskReason}}</span></td>
                        </tr>
                        <tr ng-show="!stringNullorEmpty(EventInfo.Handleby)">
                            <th>Handle by</th>
                            <td><span>{{EventInfo.Handleby}}</span></td>
                        </tr>
                        <tr ng-show="!stringNullorEmpty(EventInfo.LaborHandling)">
                            <th>Labor handling</th>
                            <td><span>{{EventInfo.LaborHandling}}</span></td>
                        </tr>
                        <tr>
                            <th>Recorded by</th>
                            <td><span>{{EventInfo.CreatedBy}}</span></td>
                        </tr>
                        <tr>
                            <th>Recorded At</th>
                            <td><span>{{EventInfo.CreatedAt | date:'dd/MM/yyyy HH:mm:ss'}}</span></td>
                        </tr>
                        <tr ng-if="EventInfo.ApproveStatus == 1">
                            <th>Approved by</th>
                            <td><span>{{EventInfo.UpdatedBy}}</span></td>
                        </tr>
                        <tr ng-if="EventInfo.ApproveStatus == 1">
                            <th>Approved At</th>
                            <td><span>{{EventInfo.UpdatedAt | date:'dd/MM/yyyy HH:mm:ss'}}</span></td>
                        </tr>

                        <tr ng-show="!stringNullorEmpty(EventInfo.UpdatedBy) && !currentCapturedRecord.PartialRejected">
                            <th>Updated by</th>
                            <td><span>{{EventInfo.UpdatedBy}}</span></td>
                        </tr>
                        <tr ng-show="!stringNullorEmpty(EventInfo.UpdatedAt) && !currentCapturedRecord.PartialRejected">
                            <th>Updated At</th>
                            <td><span>{{EventInfo.UpdatedAt | date:'dd/MM/yyyy HH:mm:ss'}}</span></td>
                        </tr>
                        <tr ng-show="!stringNullorEmpty(EventInfo.UpdatedBy) && currentCapturedRecord.PartialRejected">
                            <th>Rejected by</th>
                            <td><span>{{EventInfo.UpdatedBy}}</span></td>
                        </tr>
                        <tr ng-show="!stringNullorEmpty(EventInfo.UpdatedAt) && currentCapturedRecord.PartialRejected">
                            <th>Rejected At</th>
                            <td><span>{{EventInfo.UpdatedAt | date:'dd/MM/yyyy HH:mm:ss'}}</span></td>
                        </tr>
                        <tr ng-show="!stringNullorEmpty(EventInfo.RejectReason) && currentCapturedRecord.PartialRejected">
                            <th ng-class="{'partialrejected_th':currentCapturedRecord.PartialRejected}">Reject Reason</th>
                            <td><span class="text-danger">{{EventInfo.RejectReason}}</span></td>
                        </tr>
                        <tr ng-show="!stringNullorEmpty(EventInfo.StripNStuffBy)">
                            <th ng-if="EventInfo.EventName == 'EXAM_CARGOSTRIP'">Stipped by</th>
                            <th ng-if="EventInfo.EventName != 'EXAM_CARGOSTRIP'" ng-class="{'partialrejected_th':Repack_Partial_Rejected_Fields.includes('Stuffed By')}">Stuffed by</th>
                            <td><span>{{EventInfo.StripNStuffBy}}</span></td>
                        </tr>
                        <tr ng-show="!stringNullorEmpty(EventInfo.forklifttype)">
                            <!---V.5.8-->
                            <th>Forklift Type</th>
                            <td><span>{{EventInfo.forklifttype}}</span></td>
                        </tr>
                        <tr ng-show="!stringNullorEmpty(EventInfo.Contractor)">
                            <th>Contractor</th>
                            <td><span>{{EventInfo.Contractor}}</span></td>
                        </tr>
                        <tr ng-show="EventInfo.StripRepackLaborList.length>0">
                            <th>Labor</th>
                            <td>
                                <ul ng-if="EventInfo.StripRepackLaborList.length >1">
                                    <li ng-repeat="x in EventInfo.StripRepackLaborList">
                                        <span ng-if="x.EmpId != '0'">{{x.EmpId}}-</span>{{x.EmpName}}
                                    </li>
                                </ul>
                                <span ng-if="EventInfo.StripRepackLaborList.length ==1" ng-repeat="x in EventInfo.StripRepackLaborList">
                                    <span ng-if="x.EmpId != '0'">{{x.EmpId}}-</span>{{x.EmpName}}
                                </span>
                            </td>
                        </tr>
                        <tr ng-show="!stringNullorEmpty(EventInfo.CargoStripDuration)">
                            <th>Stripping Duration</th>
                            <td><span>{{EventInfo.CargoStripDuration}}</span></td>
                        </tr>
                        <tr ng-show="!stringNullorEmpty(EventInfo.CargoStuffDuration)">
                            <th>Repacking Duration</th>
                            <td><span>{{EventInfo.CargoStuffDuration}}</span></td>
                        </tr>
                        <tr ng-show="EventInfo.Sealnumber!=null && EventInfo.Sealnumber!='' && EventInfo.Sealnumber!=undefined">
                            <th>Seal number</th>
                            <td>
                                <span>{{EventInfo.Sealnumber}}</span>
                            </td>
                        </tr>
                        <tr ng-if="EventInfo.AdditionalServiceRequired == true && EventInfo.EventName != 'EXAM_CARGOSTUFFED' &&  EventInfo.EventName != 'EXAM_CARGOSTRIP'">
                            <th>Additional Service Status</th>
                            <td>
                                <span ng-if="EventInfo.EXAM_INSEPCTED_SRVC_Status == 0" class="PendingApprovalEvent">Pending for approval</span>
                                <span ng-if="EventInfo.EXAM_INSEPCTED_SRVC_Status == 1" class="Approvebadge">Approved</span>
                                <span ng-if="EventInfo.EXAM_INSEPCTED_SRVC_Status == 2" class="RejectedApprovalEvent">Rejected</span>
                            </td>
                        </tr>
                        <tr ng-show="!stringNullorEmpty(EventInfo.EXAM_INSEPCTED_SRVC_RecordedAt)">
                            <th>Additional service reported at</th>
                            <td><span>{{EventInfo.EXAM_INSEPCTED_SRVC_RecordedAt | date:'dd/MM/yyyy HH:mm:ss'}}</span></td>
                        </tr>
                        <tr ng-show="!stringNullorEmpty(EventInfo.EXAM_INSEPCTED_SRVC_Recordedby)">
                            <th>Additional service reported by</th>
                            <td><span>{{EventInfo.EXAM_INSEPCTED_SRVC_Recordedby}}</span></td>
                        </tr>
                        <tr ng-show="!stringNullorEmpty(EventInfo.EXAM_INSEPCTED_SRVC_ActionTakeAt)">
                            <th>Additional service approved at</th>
                            <td><span>{{EventInfo.EXAM_INSEPCTED_SRVC_ActionTakeAt | date:'dd/MM/yyyy HH:mm:ss'}}</span></td>
                        </tr>
                        <tr ng-show="!stringNullorEmpty(EventInfo.EXAM_INSEPCTED_SRVC_ActionTakenby)">
                            <th>Additional service reported by</th>
                            <td><span>{{EventInfo.EXAM_INSEPCTED_SRVC_ActionTakenby}}</span></td>
                        </tr>

                        <tr ng-show="EventInfo.RepackPhotoLibrary!=null && EventInfo.RepackPhotoLibrary!=undefined && EventInfo.RepackPhotoLibrary.length > 0" ng-repeat="Libphoto in EventInfo.RepackPhotoLibrary track by $index">
                            <!---V.5.8.1-->
                            <th>{{Libphoto.Label}}</th>
                            <td ng-show="Libphoto.Url!='Required'">
                                <div ng-click="OpenImageView(Libphoto.Url, 'EventInfo')" class="viewImag d-inline-block"><i class="icon-eye"></i> View </div>
                            </td>
                        </tr>
                        <tr ng-show="EventInfo.PhotoLibrary!=null && EventInfo.PhotoLibrary!=undefined && EventInfo.PhotoLibrary.length > 0" ng-repeat="Libphoto in EventInfo.PhotoLibrary track by $index">
                            <!---V.5.8-->
                            <th>{{Libphoto.Label}}</th>
                            <td ng-show="Libphoto.Url!='Required'">
                                <div ng-click="OpenImageView(Libphoto.Url, 'EventInfo')" class="viewImag d-inline-block"><i class="icon-eye"></i> View </div>
                                <span class="pull-right text-danger cursor-pointer" ng-if="EventInfo.ApproveStatus!=1" title="Delete Image" ng-click="RemoveEventImage('PhotoLibrary',$index)"><i class="icon-bin"></i>Delete</span>
                            </td>
                            <td ng-show="Libphoto.Url=='Required'">
                                <div class="Icon">
                                    <label title="Upload Image" style="margin:0px;">
                                        <span><i class="icon-images2"></i></span>
                                        <input type="file" style="display:none" accept="image/*" Photoindex="{{$index}}" id="UploadEvent_Library{{$index}}" name="pic" accept="image/*" onchange="angular.element(this).scope().EventImagesReplacement(this, 'EventInfo', 'PhotoLibrary')">
                                    </label>

                                </div>
                            </td>
                        </tr>
                        <tr ng-show="EventInfo.Sealphoto!=null && EventInfo.Sealphoto!='' && EventInfo.Sealphoto!=undefined">
                            <th>Seal Photo</th>
                            <td ng-show="EventInfo.Sealphoto!='Required'">
                                <div ng-click="OpenImageView(EventInfo.Sealphoto, 'EventInfo')" class="viewImag d-inline-block"><i class="icon-eye"></i> View </div>
                                <span class="pull-right text-danger cursor-pointer" ng-if="EventInfo.ApproveStatus!=1" title="Delete Image" ng-click="RemoveEventImage('Sealphoto')"><i class="icon-bin"></i>Delete</span>
                            </td>
                            <td ng-show="EventInfo.Sealphoto=='Required'">
                                <div class="Icon">
                                    <label title="Upload Image" style="margin:0px;">
                                        <span><i class="icon-images2"></i></span>
                                        <input type="file" style="display:none" accept="image/*" id="UploadEvent_Sealphoto" name="pic" accept="image/*" onchange="angular.element(this).scope().EventImagesReplacement(this, 'EventInfo', 'Sealphoto')">
                                    </label>

                                </div>
                            </td>
                        </tr>
                        <tr ng-show="EventInfo.DoorAfterSeal!=null && EventInfo.DoorAfterSeal!='' && EventInfo.DoorAfterSeal!=undefined">
                            <th>Door after seal cut</th>
                            <td ng-show="EventInfo.DoorAfterSeal!='Required'">
                                <div ng-click="OpenImageView(EventInfo.DoorAfterSeal, 'EventInfo')" class="viewImag d-inline-block"><i class="icon-eye"></i> View </div>

                                <span class="pull-right text-danger cursor-pointer" ng-if="EventInfo.ApproveStatus!=1" title="Delete Image" ng-click="RemoveEventImage('DoorAfterSeal')"><i class="icon-bin"></i>Delete</span>
                            </td>
                            <td ng-show="EventInfo.DoorAfterSeal=='Required'">
                                <div class="Icon">
                                    <label title="Upload Image" style="margin:0px;">
                                        <span><i class="icon-images2"></i></span>
                                        <input type="file" style="display:none" accept="image/*" id="UploadEvent_DoorAfterSeal" name="pic" accept="image/*" onchange="angular.element(this).scope().EventImagesReplacement(this,'EventInfo','DoorAfterSeal')">
                                    </label>

                                </div>
                            </td>
                        </tr>
                        <tr ng-show="EventInfo.CargoFrontView!=null && EventInfo.CargoFrontView!='' && EventInfo.CargoFrontView!=undefined">
                            <th>Front view of the cargo</th>
                            <td ng-show="EventInfo.CargoFrontView!='Required'">
                                <div ng-click="OpenImageView(EventInfo.CargoFrontView, 'EventInfo')" class="viewImag d-inline-block"><i class="icon-eye"></i> View </div>
                                <span class="pull-right text-danger cursor-pointer" ng-if="EventInfo.ApproveStatus!=1" title="Delete Image" ng-click="RemoveEventImage('CargoFrontView')"><i class="icon-bin"></i>Delete</span>
                            </td>
                            <td ng-show="EventInfo.CargoFrontView=='Required'">
                                <div class="Icon">
                                    <label title="Upload Image" style="margin:0px;">
                                        <span><i class="icon-images2"></i></span>
                                        <input type="file" style="display:none" accept="image/*" id="UploadEvent_CargoFrontView" name="pic" accept="image/*" onchange="angular.element(this).scope().EventImagesReplacement(this,'EventInfo','CargoFrontView')">
                                    </label>

                                </div>
                            </td>
                        </tr>
                        <tr ng-show="EventInfo.ContainerImage!=null && EventInfo.ContainerImage!='' && EventInfo.ContainerImage!=undefined">
                            <th ng-class="{'partialrejected_th':Repack_Partial_Rejected_Fields.includes('Attachments') && currentCapturedRecord.PartialRejected}">
                                <span ng-if="EventInfo.RepackPhotoLibrary!=null && EventInfo.RepackPhotoLibrary!=undefined && EventInfo.RepackPhotoLibrary.length > 0">Repack </span>
                                Container number
                            </th>
                            <td ng-show="EventInfo.ContainerImage!='Required'">
                                <div ng-click="OpenImageView(EventInfo.ContainerImage, 'EventInfo')" class="viewImag d-inline-block"><i class="icon-eye"></i> View </div>
                                <span class="pull-right text-danger cursor-pointer" ng-if="EventInfo.ApproveStatus!=1" title="Delete Image" ng-click="RemoveEventImage('ContainerImage')"><i class="icon-bin"></i>Delete</span>
                            </td>
                            <td ng-show="EventInfo.ContainerImage=='Required'">
                                <div class="Icon">
                                    <label title="Upload Image" style="margin:0px;">
                                        <span><i class="icon-images2"></i></span>
                                        <input type="file" style="display:none" accept="image/*" id="UploadEvent_ContainerImage" name="pic" accept="image/*" onchange="angular.element(this).scope().EventImagesReplacement(this,'EventInfo','ContainerImage')">
                                    </label>
                                </div>
                            </td>
                        </tr>
                        <tr ng-show="EventInfo.CargoImage!=null && EventInfo.CargoImage!='' && EventInfo.CargoImage!=undefined">
                            <th ng-class="{'partialrejected_th':Repack_Partial_Rejected_Fields.includes('Attachments') && currentCapturedRecord.PartialRejected}">
                                <span ng-if="EventInfo.RepackPhotoLibrary!=null && EventInfo.RepackPhotoLibrary!=undefined && EventInfo.RepackPhotoLibrary.length > 0">Repack </span>
                                Cargo
                            </th>
                            <td ng-show="EventInfo.CargoImage!='Required'">
                                <div ng-click="OpenImageView(EventInfo.CargoImage, 'EventInfo')" class="viewImag d-inline-block"><i class="icon-eye"></i> View </div>

                                <span class="pull-right text-danger cursor-pointer" ng-if="EventInfo.ApproveStatus!=1" title="Delete Image" ng-click="RemoveEventImage('CargoImage')"><i class="icon-bin"></i>Delete</span>
                            </td>
                            <td ng-show="EventInfo.CargoImage=='Required'">
                                <div class="Icon">
                                    <label title="Upload Image" style="margin:0px;">
                                        <span><i class="icon-images2"></i></span>
                                        <input type="file" style="display:none" accept="image/*" id="UploadEvent_CargoImage" name="pic" accept="image/*" onchange="angular.element(this).scope().EventImagesReplacement(this,'EventInfo','CargoImage')">
                                    </label>

                                </div>
                            </td>
                        </tr>
