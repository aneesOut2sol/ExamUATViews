                        <div class="partial-rejection mt-2">
                            <div class="main-container">
                                <div class="checkbox-group">
                                    <label class="checkbox-item">
                                        <input type="checkbox" name="stuffed_by" ng-model="checked.stuffed_by" ng-change="updateSelected()">
                                        <span class="custom-checkbox"></span>
                                        <span class="checkbox-label">Stuffed By</span>
                                    </label>
                                    <label class="checkbox-item">
                                        <input type="checkbox" name="attachments" ng-model="checked.attachments" ng-change="updateSelected()">
                                        <span class="custom-checkbox"></span>
                                        <span class="checkbox-label">Attachments</span>
                                    </label>
                                    <label class="checkbox-item" ng-if="EventInfo.AdditionalServiceRequired == true">
                                        <input type="checkbox" name="additional_service" ng-model="checked.additional_service" ng-change="updateSelected()">
                                        <span class="custom-checkbox"></span>
                                        <span class="checkbox-label">Additional Service</span>
                                    </label>
                                </div>
                                <div class="partition"></div>
                                <div class="note-container">
                                    <div class="note">
                                        If you want to reject any of the details mentioned in request please use partial rejection option.
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer" style=" padding: 9px; ">
                @*<button class="btn btn-danger" ng-show="CheckSuperVisorSubmission(currentCapturedRecord,'@System.Configuration.ConfigurationManager.AppSettings["Exam_BayanLevelApproval"]')" ng-click="ApproveRejectEvent(currentCapturedRecord,'Reject')" data-dismiss="modal">Reject</button>
        <button class="btn btn-primary" ng-show="CheckSuperVisorSubmission(currentCapturedRecord,'@System.Configuration.ConfigurationManager.AppSettings["Exam_BayanLevelApproval"]')" ng-click="ApproveRejectEvent(currentCapturedRecord,'Approve')" data-dismiss="modal">Approve</button>*@

                <div ng-show="currentCapturedRecord.approvalRequired == true && currentCapturedRecord.ApproveStatus ==0 && ( !_currentUser.UserType.includes('TallyClerk') || _currentUser.UserType.includes('Admin'))">
                    <div ng-if="EventInfo.EventName != 'EXAM_CARGOSTRIP'">
                        <div class="d-inline-block"  ng-if="CheckSuperVisorSubmission(currentCapturedRecord,'@System.Configuration.ConfigurationManager.AppSettings["Exam_BayanLevelApproval"]')">
                            
                            <div class="d-inline-block" ng-show="EventInfo.EventName == 'EXAM_CARGOSTUFFED'">
                                <button class="btn btn-danger" ng-show="selectedOptions.length>0" ng-click="PartialRejection(currentCapturedRecord,EventInfo)">Partial Reject</button>
                                <button class="btn btn-secondary" ng-show="selectedOptions.length==0 && currentCapturedRecord.ExcessCargoId>0" ng-click="ViewExcessCargoReport(currentCapturedRecord.ExcessCargoId)">View Excess Cargo Report</button>
                            </div>

                            <div class="d-inline-block"  ng-show="selectedOptions.length==0">
                                <button class="btn btn-danger" ng-click="ApproveRejectEvent(currentCapturedRecord,'Reject')" data-dismiss="modal"   ng-disabled="disableApproveRejectForXS">Reject</button>
                                <button class="btn btn-primary" ng-click="ApproveRejectEvent(currentCapturedRecord,'Approve')" data-dismiss="modal" ng-disabled="disableApproveRejectForXS">Approve</button>
                            </div>
                        </div>
                    </div>
                </div>                
                <div ng-show="currentCapturedRecord.approvalRequired == true && currentCapturedRecord.ApproveStatus ==0 && CheckSuperVisorSubmission(currentCapturedRecord) && currentCapturedRecord.PartialRejected">
                    <button class="btn btn-primary" ng-click="openresubmitPartialRequestmodal(EventInfo,currentCapturedRecord)" data-dismiss="modal">Resubmit request</button>
                </div>

                <button class="btn btn-reset" data-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>
