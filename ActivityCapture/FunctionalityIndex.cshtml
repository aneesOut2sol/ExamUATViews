@using ExamPortal.Model.Resources

@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="ng-cloak" ng-cloak ng-controller="ActivityCaptureCtrl" ng-init="FuntionalityList()">
    <!-- Page header -->
    <div class="page-header border-bottom-0">
        <div class="page-header-content header-elements-md-inline">
            <div class="page-title d-flex">
                <h4><i class="icon-stack-text mr-2"></i><span class="font-weight-semibold">Functionality List</span></h4>
                <a href="#" class="header-elements-toggle text-default d-md-none"><i class="icon-more"></i></a>
            </div>
            <div class="col-md-6">
                <div class="text-right mt-4">
                    <a class="btn btn-primary" href="@Url.Action("AddFunctionality","ActivityCapture")">
                        <i class="icon-add m-r-5 text-white "></i> Add Functionality
                    </a>
                </div>
            </div>
        </div>
    </div><hr />
    <div class="row">
        <div class="col-md-12 col-lg-12 col-sm-12">
            <div class="CounterCard">
                <b>Total item: </b>  <span id="counts">{{CategoryList.length}}</span>
            </div>
        </div>
    </div>
    <!-- /Item Counter -->
    <div class="row">
        <div class="card table-card scrollbar w-100">
            <table class="table datatable-show-all" id="Table">
                <thead>
                    <tr class="table-card-head">

                        <th>SR.No</th>
                        <th>Functionality Name</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    <tr ng-repeat="item in CategoryList | filter: search">

                        <td>{{$index+1}}</td>
                        <td style="text-align:left;">{{item.Category}}</td>
                        <td>
                            <div class="list-icons">
                                <a class="list-icons-item color-gray" ng-click="OpenFunctionalityEdit(item.Id)"><i class="icon-pencil5" title="Edit Functionality"></i></a>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
    <!-- /basic datatable -->
</div>