        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 999;
        display: none;
        overflow: scroll;
    }

        #overlay img {
            max-width: 90%;
            max-height: 90%;
            transition: transform 0.5s ease;
        }

    #close-btn {
        position: absolute;
        top: 15px;
        right: 15px;
        color: #fff;
        font-size: 20px;
        cursor: pointer;
    }
</style>
<div ng-controller="InspDelayRPTCtrl" class="ng-cloak" ng-cloak ng-init="PendingDelaysInit()">
    <div id="overlay">
        <span id="close-btn" ng-click="closeOverlay()">&#10006;</span>
        <img src="" id="LargeImageView" alt="Image">
    </div>
    <!-- Page header -->
    <div class="page-header border-bottom-0">
        <div class="page-header-content header-elements-md-inline">
            <div class="page-title d-flex">
                <h4><i class="icon-stack-text mr-2"></i><span class="font-weight-semibold">Ongoing Delays</span></h4>
                <a href="#" class="header-elements-toggle text-default d-md-none"><i class="icon-more"></i></a>
            </div>
            <div class="page-title d-flex">
                <input type="button" class="btn btn-secondary  pull-right ml-2" value="Filters" data-toggle="collapse" data-target="#demo" />
            </div>
        </div>
    </div><hr />

    <!--Search Filter Code Start-->
    <div class="card collapse" id="demo">
        <div class="card-body">
            <div class="col-md-12  border-bottom">
                <div class="row">
                    <div class="col-md-4">
                        <div class="form-group">
                            <label>Container #</label>
                            <input type="text" maxlength="200" onkeyup="TableRowsCount()" min="1" class="form-control" placeholder="Search Container.." ng-model="search.Cntr" />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label>Event Name</label>
                            <input type="text" maxlength="200" min="1" class="form-control" placeholder="Search Event Name.." ng-model="search.EventName" />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label>From Date</label>
                            <div class="input-group">
                                <input type="text" class="form-control date" id="FromDate" placeholder="DD/MM/YYYY HH:mm">
                                <span class="input-group-append">
                                    <span class="input-group-text"><i class="icon-calendar"></i></span>
                                </span>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-4">
                        <div class="form-group">
                            <label>To Date</label>
                            <div class="input-group">
                                <input type="text" class="form-control date" id="ToDate" placeholder="DD/MM/YYYY HH:mm">
                                <span class="input-group-append">
                                    <span class="input-group-text"><i class="icon-calendar"></i></span>
                                </span>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-8 mt-3" style="text-align:end;">
                        <button class="btn btn-success pull-right mr-2" ng-click="CaptureEventSearch()">Search</button>
                        <button class="btn btn-primary pull-right mr-2" ng-click="ClearFilter()">Clear</button>
                    </div>
                </div>

            </div>
        </div>
    </div>
    <!--Search Filter Code End-->

    <div class="row">
        <div class="col-md-12 col-lg-12 col-sm-12">
            <div class="CounterCard">
                <b>Total item: </b>  <span id="counts">{{(Cntrlist | filter: d).length}}</span>
            </div>
        </div>
    </div>
    <div class="row accordion" id="acc">
        <div class="col-md-12 Capture-Card" ng-repeat="x in Cntrlist">
            <div class="Capture-CardFlex" data-toggle="collapse" data-target="#{{x.Cntr}}col" ng-click="GetDelayCntrReason(x.Unit_gkey,x.Cntr,$index)">
                <div class="mr-3"><img src="~/Content/images/output-onlinepngtools.png" style="height: 49px;" /></div>
                <div style=" font-size: 14px; font-weight: 500;" data-toggle="collapse">{{x.Cntr}} <br /> <small>{{x.Location}}</small></div>
                <div class="ml-auto">
                    <span>
                        <i ng-show="CurrentDelayCntr!=x.Cntr" class="icon-chevron-down"></i>
                        <i ng-show="CurrentDelayCntr==x.Cntr" class="icon-chevron-up"></i>
                    </span>

                </div>
            </div>
            <div class="collapse mt-3" data-parent="#acc" id="{{x.Cntr}}col">
                <div class="row">
                    <div class="col-md-4" ng-repeat="y in ReasonList">
                        <div class="evenetTab">
                            <div class="evenetTitle" title="{{y.Name}}">
                                {{y.Name}}
                                <span class="pull-right">{{PendingDelayDuartion(y.CreatedAt)}}</span>
                            </div>
                            <span>{{y.CreatedAt | date:'dd-MM-yyyy HH:mm:ss'}}</span>
                            <br />
                            <b>{{y.CreatedBy}}</b>
                            <br />
                            <span class="PendingApprovalEvent babge-sm">{{y.Status}}</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<script>
    var zoomLevel = 1.0;

    function handleScroll(event) {
        // Adjust the zoom level based on wheel direction
        if (event.deltaY < 0) {
            // Zoom in
            zoomLevel += 0.1;
        } else {
            // Zoom out
            zoomLevel = Math.max(0.1, zoomLevel - 0.1);
        }

        applyZoom();
    }

    function applyZoom() {
        var image = document.getElementById('LargeImageView');
        image.style.transform = 'scale(' + zoomLevel + ')';

    }

    // Attach the wheel event listener to the image container
    var zoomContainer = document.getElementById('overlay');
    zoomContainer.addEventListener('wheel', handleScroll);
</script>
