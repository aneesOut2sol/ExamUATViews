
@{
    ViewBag.Title = "AddCustomHold";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>

    .collapsible-link {
        width: 100%;
        position: relative;
        text-align: left;
    }

    #CntrTableHeader tr {
        background: var( --dpw-bg-color);
        color: #fff;
    }

    #CntrTableHeader td {
        text-align: left
    }

    #CardInnerTable {
        padding: 0;
    }

        #CardInnerTable tr {
            border: none;
        }

        #CardInnerTable td {
            text-align: left !important;
            border: none;
        }

    .event-table {
        max-height: 300px;
        overflow: auto;
    }

    .pad-5 {
        padding: 5px !important;
    }

    .m-0 {
        margin: 0 !important;
    }

    .evnetBox {
        padding: 11px;
        border: 2px solid #d1d1d145;
        margin: 5px;
        color: #7a7a7a;
        border-radius: 3px;
        background: whitesmoke;
        box-shadow: 1px 1px 1px #cbc9c9;
    }

        .evnetBox.Active {
            background: #00946b1f !important;
            border: 1px solid #00946b !important;
        }

    .Custom-Card {
        margin-bottom: 15px !important;
        padding: 16px 25px;
        border-radius: 7px !important;
        border: 1px solid #b8b8b866 !important;
        box-shadow: -2px -2px 3px 0px inset #989898a1;
        background: #fff;
    }

        .Custom-Card .card-header {
            background: none !important;
            border: 0;
        }

        .Custom-Card td {
            padding: 4px 10px;
        }

    .eventCheckBox {
        float: right;
        transform: scale(1);
        margin-top: 4px;
        box-shadow: 1px 1px 1px #ececec !important;
    }

    .EventNameTruncate {
        display: inline-block;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        width: 80%;
    }

    .labelChild {
        background: red;
        position: relative;
        width: 100px;
        /*z-index: 999;*/
        color: white;
        text-align: center;
        /*transform: rotate(325deg);*/
        /*right: 24px;*/
        /*top: 11px;*/
        top: 6px;
        font-size: 15px;
        display: flex;
        align-items: center !important;
        justify-content: center;
        border-radius: 5px;
    }

    .Bred {
        background: green !important;
    }

    .labelParent {
        /*position: absolute;*/
        /*height: 100px;*/
        height: 55px;
        /*width: 100px;*/
        width: auto;
        overflow: hidden;
        left: 0px;
    }

    .CloseModalBtn {
        color: #FFFFFF;
        line-height: 25px;
        position: absolute;
        right: -12px;
        text-align: center;
        top: -10px;
        width: 45px;
        text-decoration: none;
        font-weight: bold;
        box-shadow: 1px 1px 3px #000;
        transition: all .3s;
        height: 45px;
        border-radius: 50%;
        font-size: 25px !important;
        padding: 8px;
        cursor: pointer;
        background: var( --dpw-bg-color);
    }

    .close {
        display: none;
    }

    .CloseModalBtn .fa-times-circle-o {
        color: #ffff !important;
    }

    .modal-content {
        background-color: #f4f2fa !important;
        border-radius: 16px !important;
        box-shadow: 0 2.8px 2.2px rgb(0 0 0 / 3%), 0 6.7px 5.3px rgb(0 0 0 / 5%), 0 12.5px 10px rgb(0 0 0 / 6%), 0 22.3px 17.9px rgb(0 0 0 / 7%), 0 41.8px 33.4px rgb(255 255 255 / 9%), 0 100px 80px rgb(255 255 255 / 12%);
    }

    .modal-header {
        text-align: center;
        border-bottom: none !important;
        justify-content: center !important;
    }

    .modal-title {
        font-weight: bolder !important;
        font-size: 24px;
        padding-top: 12px;
        padding-bottom: 4px;
        display: inline-block;
    }

    .modal-footer {
        border-top: none !important;
        align-content: center;
        text-align: center;
    }

    table thead {
        box-shadow: none !important;
    }

    table {
        border: 1px solid var( --dpw-bg-color) !important;
    }

    .ImageUploader {
        border: 1px solid #959595;
        color: #707070;
        text-align: center;
        padding: 6px;
        height: fit-content;
        border-radius: 5px;
        background: #8b8b8b21;
    }

    .imageView {
        width: 100%;
        height: 100px;
        border: 1px solid #e3e3e3;
        border-radius: 8px;
        padding: 10px;
    }

    .disgnerLabel {
        margin: 0px;
        padding: 5px 10px;
        font-size: 15px;
        border-bottom: 1px solid #ededed;
    }

        .disgnerLabel:last-child {
            border-bottom: 0px;
        }

    .dlticon {
        background: #80808000;
        padding: 6px;
        border-radius: 6px;
        float: right;
        left: 10px;
    }

    .CamInput {
        padding: 5px 38px;
        background: #f0f0f0;
        border: 1px solid #959595;
        border-radius: 5px;
        color: #707070;
        cursor: pointer;
    }

    .Indicatior {
        cursor: pointer;
        float: right;
    }

    .MasterDropDown {
        position: absolute;
        z-index: 9999999;
    }

    .CustomDropDown ul {
        padding: 10px;
    }

    .CustomDropDown {
        display: none;
        position: relative;
        top: -39px;
        left: 13px;
        z-index: 9999;
        background: #f2f2f2f7;
        padding: 0px;
        border-radius: 7px;
        border: 1px #00000026 solid;
    }

    .MasterDropDown .CustomDropDown ul li {
        list-style-type: none;
        padding: 4px;
        color: #4a4848;
        font-weight: 500;
        cursor: pointer;
    }

    .Blocks {
        padding: 10px;
        box-shadow: 1px 3px 3px 1px gray;
    }

    button.btn.btn-primary.active {
        background: #00946b !important;
    }

    .Blocks:hover {
        box-shadow: none;
        background: #00946b
    }

    .Cardtabs {
        width: auto !important;
        display: inline-block;
        margin: 15px;
    }

    .Absoulte {
        position: absolute;
        height: 0px;
        width: 56px;
    }

    .CountBadge {
        position: relative;
        z-index: 99;
        color: #ffffff;
        padding: 0px 6px;
        background: #00946b;
        border-radius: 10px;
        float: right;
        bottom: 7px;
        left: 0px;
        width: fit-content;
        box-shadow: 1px 1px 5px -1px #000000cc;
    }

    .optionIcon img {
        height: 25px;
        filter: contrast(0.3);
    }

    .DropOptionParent {
        position: absolute;
        display: none;
        right: 7%;
        z-index: 99;
    }

        .DropOptionParent .OptionInner {
            Position: relative;
            background-color: #e4dbff;
            border-radius: 3px;
            box-shadow: 0px 0px 4px 4px #80808029;
            border: 1px solid #80808057;
            bottom: 13px;
        }

    .OptionInner ul {
        padding: 8px;
        border-radius: 20px;
    }

        .OptionInner ul li {
            list-style: none;
            padding: 8px;
            cursor: pointer;
            color: #221b62 !important;
        }

            .OptionInner ul li:hover {
                background: linear-gradient(180deg, #221b62, #431dc1) !important;
                color: #fff !important;
                border-radius: 8px;
            }

    .imageBox {
        border: 1px solid var( --dpw-bg-color)38;
        border-radius: 9px;
        overflow: hidden;
        background: #f2f2f2;
        margin-bottom: 10px;
    }

    .Imgheader {
        padding: 3px 13px;
        background: var( --dpw-bg-color);
        color: white;
        text-align: center;
        font-weight: 200;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .ImgContent {
        padding: 14px;
        text-align: center;
    }

        .ImgContent img {
            height: auto;
            max-width: 100%;
            height: 100px;
        }

    .DeleteIconInner {
        position: relative;
        padding: 49px 69px;
        background: radial-gradient(#0000008f, #00000052);
        color: white;
    }

    .DeleteIcon {
        position: absolute;
        display: none;
    }

    .imageBox:hover .DeleteIcon {
        display: block;
    }

    .DeleteIconInner i {
        font-size: 30px;
    }

    input[type=checkbox] {
        accent-color: #008963 !important;
    }

    .searchBox input {
        float: right;
        box-shadow: 0px 10px 15px -3px rgba(0,0,0,0.1);
        border-radius: 4px;
        border: 1px solid #d8d8d8;
        padding: 6px 11px;
    }

    .searchBox i {
        float: right;
        position: relative;
        left: 161px;
        top: 11px;
        font-size: 12px;
        color: gray;
    }

    ul.Damage_Images {
        padding: 0px;
        border: 1px solid #ececec;
    }

        ul.Damage_Images li .Icon span {
            padding: 7px;
            border: 1px solid #343434;
            border-radius: 50%;
            color: #6b6868 !important;
            /* font-size: 6px; */
        }

        ul.Damage_Images li {
            padding: 12px 18px;
            list-style: none;
            border-bottom: 1px solid #e8e8e8cf;
            color: #6b6868 !important;
        }

    .Icon {
        width: fit-content;
        float: right;
    }

    /*    .Custom-Card .collapse {
        padding-bottom: 10px;
    }*/

    .icon-cross {
        font-size: 25px;
    }

    .badge {
        font-size: 15px;
        width: 100% !important;
        border-radius: 4px !important;
    }

    .waitingForApprovalStatus {
        color: #fdfdfd;
        background-color: #769aff !important;
        font-weight: bolder;
        border: 1px solid #769aff;
    }

    .badge {
        font-size: 15px;
        width: 183px !important;
        border-radius: 4px !important;
    }

    .inProgressStatus {
        color: #212529;
        background-color: #fff816 !important;
        font-weight: bolder;
        border: 1px solid #fff816;
    }

    .approvedStatus {
        background-color: #198754 !important;
        font-weight: bolder;
        border: 1px solid #198754;
        color: #fff;
    }

    .rejectStatus {
        background-color: #dc3545 !important;
        font-weight: bolder;
        border: 1px solid #dc3545;
        color: #fff;
    }

    .badge {
        width: fit-content !important;
    }

    .approvalrequierd {
        background: #4f4f4f !important;
    }

    .approved {
        background: #00946b !important;
    }

    .Rejected {
        background: #d64a48 !important;
    }

    .pending {
        background: #d64a48 !important;
    }

    /*Excess cargo styling*/
    .SignBox {
        text-align: center;
        border: 1px solid;
        border-color: lightgray;
        padding: 0px 0px 10px 0px;
    }

    .Image-view img {
        height: 50% !important;
        width: 50% !important;
        float: none !important
    }

    .Image-view {
        float: none !IMPORTANT;
        margin: 0 !IMPORTANT;
        height: auto !IMPORTANT;
        width: auto !important;
    }
    /*Excess cargo styling end*/

    #overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: #111111de;
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 999;
        display: none;
        overflow: scroll;
    }

        #overlay img {
            max-width: 90%;
            max-height: 90%;
            transition: transform 0.5s ease;
        }

    #close-btn {
        position: absolute;
        top: 15px;
        right: 15px;
        color: #fff;
        font-size: 20px;
        cursor: pointer;
    }

    #my_camera, #my_camera video, #my_camera img {
        width: 100% !important;
    }

    .modal-body {
        max-height: 60vh !important;
        overflow: auto !important;
    }

    .printBdage {
        padding: 0px 8px;
        background: var( --dpw-bg-color);
        color: white !IMPORTANT;
        border-radius: 3px;
    }

        .printBdage a i {
            color: white !important;
        }

        .printBdage a {
            text-decoration: none !important;
            color: white;
        }

    .jqueryConfrim .modal-content {
        border-top: solid 7px #3498db;
        border-radius: 6px !IMPORTANT;
        background: white !important;
    }

    .jqueryConfrim .modal-header h5 {
        font-size: 22px;
    }

    .jqueryConfrim .modal-header {
        justify-content: start !important;
    }

    .jqueryConfrim .btn-primary {
        background: #3498db;
        padding: 5px 11px;
        text-transform: uppercase;
    }

    .jqueryConfrim .btn-reset {
        background: #363636;
        padding: 5px 11px;
        text-transform: uppercase;
    }

    .imguplaoder {
        width: 100%;
        padding: 7px 18px;
        border-radius: 5px;
        border: 1px solid #d7d7d7;
        color: gray;
        cursor: pointer;
    }

    @@keyframes zoomIn {
        0% {
            opacity: 0;
            -webkit-transform: scale3d(.3, .3, .3);
            transform: scale3d(.3, .3, .3);
        }

        50% {
            opacity: 1;
        }
    }

    .ZoominAnimate {
        animation: zoomIn 0.2s linear;
    }

    .scrollerdiv {
        height: 70vh;
        overflow: auto
    }

    .scrollerdiv::-webkit-scrollbar {
        display: none;
    }
    .InspectionStatusErrorDetails {
        background: #f6cfcf;
        color: #9e2828;
        border: 1px solid #afafaf;
    }

    .InspectionStatusSuccessDetails {
        background: #e0f2ed;
        color: #897a93;
        border: 1px solid #4CAF50;
    }

    .InspectionStatussection {
        padding: 2px 8px;
        width: fit-content;
        border-radius: 1px;
        border-bottom: 0px;
    }
</style>
<link href="~/Content/popup/jquery-confirm.min.css" rel="stylesheet" />
<!--Header-->
<div ng-controller="EventPageCtrl" ng-init="init()" class="ng-cloak RecordEvent" ng-cloak>
    <div class="page-header border-bottom-0">
        <div class="page-header-content header-elements-md-inline">
            <div class="page-title d-flex ml-4">
                <h4>

                    <span class="font-weight-semibold">{{CurrentEventData.DisplayName}}</span>
                </h4>
            </div>
        </div>
    </div>
    <hr />
    <!---Block-->
    <div class="card mt-2 mt-2" id="Block">
        <div class="card-header" style=" background: var( --dpw-bg-color); color: white; padding: 8px;">
            <h5 class="mt-2">Select Block</h5>
        </div>
        <div class=" card-body shadow">
            <div class="row">
                <div class="Cardtabs" ng-repeat="B in BlocList">
                    <div class="Absoulte">
                        <div class="CountBadge">{{B.Cntr}}</div>
                        <br />

                    </div>
                    <button ng-click="GetEventContainerList(B)" ng-class="{'active' : B.BlockNumber == CurrentBlock.BlockNumber }" class="btn btn-primary Blocks" value="{{B.BlockNumber}}">{{B.BlockNumber}} </button>
                </div>
            </div>
        </div>
    </div>
    <!---Block-->
    <!---Container-->
    <div class="row" ng-if="CurrentBlock.BlockNumber!=null && CurrentBlock.BlockNumber!=''" style="padding: 14px 0px; ">
        <div class="col-md-12 text-end searchBox">
            <input placeholder="Search Bayan.." type="text" ng-model="Fbayan" ng-keyup="Filtertext(Fbayan,'BayanNo')" />
            <i class="icon-search4"></i>
            <input placeholder="Search Container.." type="text" ng-model="FCntr" ng-keyup="Filtertext(FCntr,'Cntr')" />
            <i class="icon-search4"></i>
        </div>
    </div>
    <div class="accordion scrollerdiv" id="accordionExample" ng-if="!stringNullorEmpty(ContainerList)">
        <div class="card Custom-Card m-0" ng-repeat="x in ContainerList | filter :search" style="overflow:visible">

            <!---Container Header-->

            <div class="" id="heading{{$index}}">
                <div class="collapsible-link">
                    <div class="row">
                        <div class="col-md-5 col-lg-6 col-sm-6 col-xs-12" data-toggle="collapse" id="OpenDetails{{$index}}" data-target="#collapse{{$index}}" @*ng-click="GetContainerEvent($index,x.Cntr,x.gkey)"*@>
                            <div style="display: inline-block; vertical-align: middle; margin-bottom: 4px;">
                                <img style="height:50px;" src="~/Content/images/output-onlinepngtools.png" />
                            </div>
                            <div style="display: inline-block; vertical-align: middle; margin-bottom: 4px; margin-left: 12px; font-family: 'Pilat Wide';">
                                {{x.Cntr}} <span ng-show="x.BayanNo!='' && x.BayanNo!=null" style="font-size: 11px; color: #898989;"> - {{x.BayanNo}}</span>

                                <div ng-show="x.Position!='' && x.Position!=null" style="font-size: 11px; color: #898989;">{{x.Position}}</div>
                                <div class="position-absolute" style="top: 0px;width: 0px; white-space: nowrap;" ng-show="x.InspectionStatus!=null && x.InspectionStatus!=''">
                                    <div class="position-relative" style="bottom:30px;">
                                        <div class="InspectionStatussection" ng-class="{'InspectionStatusSuccessDetails' : x.InspectionAcceptStatus=='ACP','InspectionStatusErrorDetails' : x.InspectionAcceptStatus=='REJ'}">
                                            {{x.InspectionStatus}}
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>



                        <div class="col-md-7 col-lg-6 col-sm-6 col-xs-12 Chervronicon text-end" style="align-self:center;" ng-if="CurrentBlock.BlockNumber !='DDC' && CurrentBlock.BlockNumber !='OOG'">
                            <div class="Indicatior" id="toggler{{$index}}">
                                <input id="{{x.Cntr}}Chk0" type="checkbox" ng-click="EventAply(CurrentEventData,0,x.Position,x.gkey,x.Cntr)" class="eventCheckBox" style="float:right;" name="name" value="" />
                            </div>
                        </div>

                        <div class="col-md-7 col-lg-6 col-sm-6 col-xs-12 Chervronicon text-end" style="align-self:center;" ng-click="ToggleCol($index,x.Cntr,x.gkey)" ng-if="CurrentBlock.BlockNumber =='DDC' || CurrentBlock.BlockNumber =='OOG'">
                            <div class="Indicatior" id="toggler{{$index}}">
                                <i class="icon-chevron-down"></i>
                            </div>
                        </div>

                        <div class="col-md-12 col-lg-12 col-sm-12 col-xs-12 collapse" id="collapse{{$index}}" aria-labelledby="heading{{$index}}" data-parent="#accordionExample" ng-if="CurrentBlock.BlockNumber =='DDC' || CurrentBlock.BlockNumber =='OOG'">
                            <div class="row">
                                <div class="col-md-4 col-sm-12 col-12 p-0" ng-repeat="y in EventList | orderBy:'SortOrder'">
                                    <label for="{{x.Cntr}}Chk{{$index}}" class="d-block">
                                        <div ng-class="{'Active':y.isApplied==true}" class="evnetBox">
                                            <div title="{{y.DisplayName}}" class="EventNameTruncate" ng-show="y.DisplayName!=null && y.DisplayName!=''">{{y.DisplayName}}</div>
                                            <div title="{{y.EventName}}" class="EventNameTruncate" ng-show="y.DisplayName==null || y.DisplayName==''">{{y.EventName}}</div>

                                            <input id="{{x.Cntr}}Chk{{$index}}" type="checkbox" ng-click="ConfrimApplyEvent(y,$index,x.Position,x.gkey)" 
                                                   ng-checked="CheckEventEnable(EventList,y)" 
                                                   ng-disabled="CheckEventEnable(EventList,y)" class="eventCheckBox" style="float:right;" name="name" value="" />
                                        </div>
                                    </label>
                                </div>
                            </div>
                        </div>

                    </div>
                    <!--Drop Down Context Menu-->
                    <!--Drop Down Context Menu-->
                </div>
            </div>
            <!---Container Header-->
            <!---Events-->

        </div>
        <!--Seal Cut Confirmation-->
        <div class="modal ZoominAnimate jqueryConfrim" id="SealCutConfrimation" tabindex="-1" data-backdrop="static" data-keyboard="false" role="dialog" aria-labelledby="exampleModalCenterTitle" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered" role="document" style="min-width:30%;">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="">
                            <b>{{CurrentCntr}}</b>        Seal Cut Confirmation!
                        </h5>
                    </div>
                    <div class="modal-body">
                        <div class="row">
                            <div class="col-md-6">
                                <label>Door after seal cut</label>
                                <label class="imguplaoder" for="DoorAfterSeal" ng-show="Sealcut.DoorAfterSeal==''||Sealcut.DoorAfterSeal==null">
                                    <input style="display:none" type="file" id="DoorAfterSeal" accept="image/*" onchange="angular.element(this).scope().SeaCutPhoto(this,'DoorAfterSeal')" class="form-control" value="" />
                                    <div class="">
                                        Upload photo <span class="pull-right"><i class="icon-file-upload"></i></span>
                                    </div>

                                </label>
                                <div class="imguplaoder" ng-show="Sealcut.DoorAfterSeal!=''&& Sealcut.DoorAfterSeal!=null">
                                    <a style=" text-decoration: none; color: inherit;" href="{{Sealcut.DoorAfterSeal}}" target="_blank"> <span><i class="icon-eye"></i></span> View photo</a> <span ng-click="Sealcut.DoorAfterSeal=''" class="pull-right"><i class="icon-bin"></i></span>
                                </div>

                            </div>
                            <div class="col-md-6">
                                <label>Front view of the cargo</label>
                                <label class="imguplaoder" for="CargoFront" ng-show="Sealcut.CargoFront==''||Sealcut.CargoFront==null">
                                    <input style="display:none" type="file" id="CargoFront" accept="image/*" onchange="angular.element(this).scope().SeaCutPhoto(this,'CargoFront')" class="form-control" value="" />
                                    <div class="">
                                        Upload photo <span class="pull-right"><i class="icon-file-upload"></i></span>
                                    </div>

                                </label>
                                <div class="imguplaoder" ng-show="Sealcut.CargoFront!=''&& Sealcut.CargoFront!=null">
                                    <a style=" text-decoration: none; color: inherit;" href="{{Sealcut.CargoFront}}" target="_blank"> <span><i class="icon-eye"></i></span> View photo</a> <span ng-click="Sealcut.CargoFront=''" class="pull-right"><i class="icon-bin"></i></span>
                                </div>

                            </div>
                        </div>


                    </div>
                    <div class="modal-footer" style=" padding: 9px; ">
                        <button class="btn btn-primary" ng-click="ApplySealCut(Sealcut)">Submit</button>
                        <button class="btn btn-reset" ng-click="CloseSealCut()">Close</button>
                    </div>
                </div>
            </div>
        </div>
        <!--Seal apply Confirmation-->
        <div class="modal ZoominAnimate jqueryConfrim" id="SealApplyConfrimation" tabindex="-1" data-backdrop="static" data-keyboard="false" role="dialog" aria-labelledby="exampleModalCenterTitle" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered" role="document" style="min-width:30%;">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="">
                            <b>{{CurrentCntr}}</b>      Seal apply Confirmation!
                        </h5>
                    </div>
                    <div class="modal-body">
                        <div class="row">
                            <div class="col-md-6">
                                <label>Seal number</label>
                                <input type="text" ng-model="ApplySeal.number" class="form-control" value="" />
                            </div>
                            <div class="col-md-6">
                                <label>Seal photo</label>
                                <label class="imguplaoder" for="SealPhoto" ng-show="ApplySeal.sealphoto==''||ApplySeal.sealphoto==null">
                                    <input style="display:none" type="file" id="SealPhoto" accept="image/*" onchange="angular.element(this).scope().ApplySealPhoto(this,'SealPhoto')" class="form-control" value="" />
                                    <div class="">
                                        Upload photo <span class="pull-right"><i class="icon-file-upload"></i></span>
                                    </div>

                                </label>
                                <div class="imguplaoder" ng-show="ApplySeal.sealphoto!=''&& ApplySeal.sealphoto!=null">
                                    <a style=" text-decoration: none; color: inherit;" href="{{ApplySeal.sealphoto}}" target="_blank"> <span><i class="icon-eye"></i></span> View photo</a> <span ng-click="ApplySeal.sealphoto=''" class="pull-right"><i class="icon-bin"></i></span>
                                </div>

                            </div>
                        </div>
                        <div class="col-md-12">
                            <label>Container location</label>
                            <input type="text" ng-model="ApplySeal.location" class="form-control" value="" />
                        </div>

                    </div>
                    <div class="modal-footer" style=" padding: 9px; ">
                        <button class="btn btn-primary" ng-click="ApplyRepackAndSeal(ApplySeal)">Submit</button>
                        <button class="btn btn-reset" ng-click="CloseApplySeal()">Close</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!---Container-->
</div>
