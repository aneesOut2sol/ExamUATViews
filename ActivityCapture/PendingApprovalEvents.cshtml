
@{
    ViewBag.Title = "PendingApprovalEvents";
    Layout = "~/Views/Shared/_Layout.cshtml";
}



<script src="~/Scripts/jquery.min.js"></script>
<script src="~/Scripts/js/plugins/moment/moment_locales.min.js"></script>
<link href="~/Scripts/SlimSelect/SlimSelectCustomStyle.css" rel="stylesheet" />
<link href="~/Scripts/SlimSelect/slimselect.min.css" rel="stylesheet" />
<script src="~/Scripts/SlimSelect/slimselect.min.js"></script>
<link href="~/Content/ZoomInOut/ZoomInOut.css" rel="stylesheet" />
<link href="~/Content/css/ExamCSS.css" rel="stylesheet" />

<div ng-controller="PendingApprovalEventCtrl" ng-init="pendingApprovalEventInit()" class="PendingApproveReport">


    <div class="row ng-cloak" style="margin-top: 13px!important;" ng-cloak>
        <div class="col-md-12">
            <!--Tab Code Start -->
            <div class="tab">
                <div class="row">
                    <div class="CardHeaderLink  shadow-sm text-center ">
                        <button class="tablinks active" id="SealCutEvent" ng-click="GetPendingApprovalEventBlock('EXAM_SEALCUT')"><i class="icon-task mr-2"></i> Seal cut <span class="CountBadge">{{SealCutCount}}</span></button>
                    </div>
                    <div class="CardHeaderLink  shadow-sm text-center ">
                        <button class="tablinks" id="CargoStripEvent" ng-click="GetPendingApprovalEventBlock('EXAM_CARGOSTRIP')"><i class="icon-task mr-2"></i> Cargo Strip <span class="CountBadge">{{CargoStripCount}}</span></button>
                    </div>
                    <div class="CardHeaderLink  shadow-sm text-center ">
                        <button class="tablinks" id="ExamInspectedEvent" ng-click="GetPendingApprovalEventBlock('EXAM_INSPECTED')"><i class="icon-task mr-2"></i> Custom Inspection <span class="CountBadge">{{ExamInspectedCount}}</span></button>
                    </div>
                    <div class="CardHeaderLink  shadow-sm text-center ">
                        <button class="tablinks" id="CustomClearedEvent" ng-click="GetPendingApprovalEventBlock('UNIT_CUSTOMS_CLEARED')"><i class="icon-task mr-2"></i> Customs Cleared <span class="CountBadge">{{CustomClearedCount}}</span></button>
                    </div>
                    <div class="CardHeaderLink  shadow-sm text-center ">
                        <button class="tablinks" id="CargoRepackEvent" ng-click="GetPendingApprovalEventBlock('EXAM_CARGOSTUFFED')"><i class="icon-file-check mr-2"></i> Cargo Repack <span class="CountBadge">{{CargoStuffCount}}</span></button>
                    </div>

                </div>
            </div>
            <!--Tab Code End -->
        </div>

        <!---Block-->
        <div class="card mt-2 mt-2" id="Block" ng-if="CurrentEvent !='EXAM_CARGOSTRIP'">
            <div class="card-header" style=" background: var( --dpw-bg-color); color: white; padding: 8px;">
                <h5 class="mt-1">Select Block</h5>
            </div>
            <div class=" card-body shadow">
                <div class="row">
                    <div class="Cardtabs" ng-repeat="B in BlockList">

                        <div class="Absoulte">
                            <div class="CountBadge"
                                 title="{{B.Cntr}} pending for approval">
                                {{B.Cntr}}
                            </div>
                        </div>
                        <button ng-click="GetPendingContainerList(B)" ng-class="{'active' : B.BlockNumber == CurrentBlockRecord.BlockNumber }" class="btn btn-primary Blocks" value="{{B.BlockNumber}}">{{B.BlockNumber}} </button>
                    </div>
                </div>
            </div>
        </div>


        <div class="card mt-2" id="Block" ng-if="CurrentEvent =='EXAM_CARGOSTRIP'">

            <div class="card-header" style="background: var( --dpw-bg-color); color: white; padding: 8px;">
                <div class="d-inline-block mt-2">
                    <h5 class="">Select Bayan</h5>
                </div>
                <div class="pull-right">
                    <div class="bayan-radio-group ng-cloak">
                        <input type="radio" id="all" name="bayan-option" value="ALL" checked>
                        <label for="all" ng-click="FilterBayanByBlock('ALL')">ALL<span for="all" class="CountBadge">{{STRIP_AllCount}}</span></label>


                        <input type="radio" id="yard" name="bayan-option" value="YARD">
                        <label for="yard" ng-click="FilterBayanByBlock('Yard')">YARD <span for="all" class="CountBadge">{{STRIP_YardCount}}</span></label>

                        <input type="radio" id="warehouse" name="bayan-option" value="WAREHOUSE">
                        <label for="warehouse" ng-click="FilterBayanByBlock('Warehouse')">WAREHOUSE <span for="all" class="CountBadge">{{STRIP_WarehouseCount}}</span></label>

                        <input type="radio" id="reefer" name="bayan-option" value="REEFER">
                        <label for="reefer" ng-click="FilterBayanByBlock('Reefer')">REEFER <span for="all" class="CountBadge">{{STRIP_ReeferCount}}</span></label>
                    </div>
                </div>
            </div>
            <div class=" card-body shadow">
                <div class="row">
                    <div class="Cardtabs" ng-repeat="B in BlockList">
                        @if (System.Configuration.ConfigurationManager.AppSettings["Exam_BayanLevelApproval"] != "1")
                        {
                            <div class="Absoulte">
                                <div class="CountBadge"
                                     title="{{B.Cntr}} pending for approval">
                                    {{B.Cntr}}
                                </div>
                            </div>
                        }
                        <button ng-click="GetPendingContainerList(B)" ng-class="{'active' : B.BlockNumber == CurrentBlockRecord.BlockNumber }" class="btn btn-primary Blocks" value="{{B.BlockNumber}}">{{B.BlockNumber}} </button>
                        @if (System.Configuration.ConfigurationManager.AppSettings["Exam_BayanLevelApproval"] == "1")
                        {
                            <div class="mt-1" ng-click="GetPendingContainerList(B)">
                                <button class="btn btn-sm btn-primary Cargostripstatusbutton" title="{{showcargostriptitle(B,'TotalCntr')}}">
                                    {{B.BayanCntrCount}}
                                </button>
                                <button class="btn btn-sm btn-notsubmitted Cargostripstatusbutton" title="{{showcargostriptitle(B,'ReadyButNotSubmitted')}}">
                                    {{B.NotSubmittedCount}}
                                </button>
                                <button class="btn btn-sm btn-success Cargostripstatusbutton" title="{{showcargostriptitle(B,'Ready')}}">
                                    {{B.Cntr}}
                                </button>
                                <button class="btn btn-sm btn-danger Cargostripstatusbutton" title="{{showcargostriptitle(B,'NotReady')}}">
                                    {{B.BayanNotReadyCntrCount}}
                                </button>
                            </div>

                        }

                    </div>
                </div>
            </div>
        </div>
        <!---Block-->

        <div class="col-md-12 text-end" ng-if="CurrentEvent =='EXAM_CARGOSTRIP'">
            @if (System.Configuration.ConfigurationManager.AppSettings["Exam_BayanLevelApproval"] == "1")
            {
                <div ng-if="CurrentBlockRecord != undefined">
                    <div class="stripStatus d-inline-block shadow-sm pull-right">
                        <b class="d-inline-block">
                            Status :
                            <span ng-if="!CurrentBlockRecord.ReadyForStrip" title="Not ready to move" class="statusred"></span>
                            <span ng-if="CurrentBlockRecord.ReadyForStrip" title="Ready to move" class="statusgreen"></span>
                        </b>

                    </div>
                    <button class="btn btn-primary pull-right mr-2"
                            @*ng-show="ApproveRejectVisibility(CurrentBlockRecord)"*@
                            ng-click="ApproveRejectBayan(CurrentBlockRecord.BlockNumber,'Approve',CurrentBlockRecord.AskForLowStripBypass)"
                            @*ng-disabled="OpenContainerLst.length != ContainerList.length "*@>
                        Approve
                    </button>
                    <button class="btn btn-danger pull-right mr-2"
                            ng-show="ApproveRejectVisibility(CurrentBlockRecord)"
                            ng-click="ApproveRejectBayan(CurrentBlockRecord.BlockNumber,'Reject',CurrentBlockRecord.AskForLowStripBypass)"
                            ng-disabled="OpenContainerLst.length != ContainerList.length">
                        Reject
                    </button>
                </div>
            }
        </div>

        <!---Container-->

        <div class="accordion" id="accordionExample" ng-if="!stringNullorEmpty(ContainerList)">
            <div class="card Custom-Card m-0" ng-repeat="x in ContainerList | filter :search" style="overflow:visible">
                <div class="" id="heading{{$index}}">
                    <div class="collapsible-link">
                        <div class="row">
                            <div class="col-md-8 col-lg-8 col-sm-8 col-xs-12">
                                <div style="display:inline-block">
                                    <img style="height:50px;" src="~/Content/images/output-onlinepngtools.png" />
                                </div>
                                <div style="display: inline-block; position: relative; top: 10px; left: 5px; font-family: 'Pilat Wide';">
                                    {{x.Cntr}}
                                    <span title="{{checkBayanCntrStatus(x,true)}}% strip done" ng-if="checkBayanCntrStatus(x,true) != '100' && CurrentEvent=='EXAM_CARGOSTRIP'">
                                        <i class="icon-alert text-danger"></i>
                                    </span>
                                    <span title="{{x.CodeGroup}}" style="font-size:15px" ng-show="x.HighRiskCargo == true">
                                        <i class="ri-bug-fill text-danger"></i>
                                    </span>
                                    <br />
                                    <span style="font-size: 11px; color: #898989;">{{x.Position}}</span>
                                </div>
                                @if (System.Configuration.ConfigurationManager.AppSettings["Exam_BayanLevelApproval"] == "1")
                                {
                                    <div class="position-absolute" style="top: 0px;width: 0px; white-space: nowrap;" ng-if="CurrentEvent=='EXAM_CARGOSTRIP'">
                                        <div class="position-relative" style="bottom:30px;">
                                            <div class="InspectionStatussection" ng-class="{'InspectionStatusSuccessDetails' : checkBayanCntrStatus(x)=='Ready to Approve.','InspectionStatusErrorDetails' : checkBayanCntrStatus(x)!='Ready to Approve.'}">
                                                {{checkBayanCntrStatus(x)}}
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                            <div class="col-md-4 col-lg-4 col-sm-4 col-xs-12 DamageButton">
                                <div class="iconsection">
                                    @if (System.Configuration.ConfigurationManager.AppSettings["Exam_BayanLevelApproval"] == "1")
                                    {

                                        <i class="icon-info22" ng-if="CurrentEvent=='EXAM_CARGOSTRIP'" ng-click="ShowCntrDetailForStrip(x);" title="Container Inspection Details"></i>
                                    }
                                    <i class="icon-eye" ng-click="ShowEventDetail(x);RecordReadnessOfCntr(x);" title="Event Detail"></i>
                                   
                                </div>

                            </div>
                        </div>
                    </div>
                </div>
                <!---Container Header-->

                <div class="" style="margin-bottom: -30px;margin-left: -35px;">

                </div>

            </div>
        </div>
        <!---Container-->


    </div>

    <div id="overlay" style="flex-direction:column">
        @*<span id="close-btn" ng-click="closeOverlay()">&#10006;</span>
            <div style="height:90vh;overflow:auto;width:100%;text-align:center;">
                <img src="" id="LargeImageView" alt="Image">
            </div>*@
        <div id="zoomContainer">
            <img id="zoomImg" src="" alt="Zoomable" />
            <span id="close-btn" ng-click="closeOverlay()">&#10006;</span>
            <div class="zoom-controls">
                <button id="zoomIn">+</button>
                <button id="zoomOut">−</button>
                <button id="zoomReset">Reset</button>
            </div>
        </div>
        <br />
        <table class="sliderNav">
            <tr>
                <td ng-show="EventInfo.PhotoLibrary!=null && EventInfo.PhotoLibrary!=undefined && EventInfo.PhotoLibrary.length>0" ng-repeat="item in EventInfo.PhotoLibrary">
                    <img ng-class="{'Active': CurrentopenUrl == item.Url}"
                         ng-click="OpenImageView(item.Url, 'EventInfo')"
                         src="{{item.Url}}"
                         alt="Seal Number"
                         class="thumbnail" />
                    <div class="image-name">{{item.Label}}</div>
                </td>
                <td ng-show="EventInfo.Sealnumber!=null && EventInfo.Sealnumber!='' && EventInfo.Sealnumber!=undefined">
                    <img ng-class="{'Active': CurrentopenUrl == EventInfo.Sealnumber}"
                         ng-click="OpenImageView(EventInfo.Sealnumber, 'EventInfo')"
                         src="{{EventInfo.Sealphoto}}"
                         alt="Seal Number"
                         class="thumbnail" />
                    <div class="image-name">Seal Number</div>
                </td>
                <td ng-show="EventInfo.Sealphoto!=null && EventInfo.Sealphoto!='' && EventInfo.Sealphoto!=undefined">
                    <img ng-class="{'Active': CurrentopenUrl == EventInfo.Sealphoto}"
                         ng-click="OpenImageView(EventInfo.Sealphoto, 'EventInfo')"
                         src="{{EventInfo.Sealphoto}}"
                         alt="Seal Photo"
                         class="thumbnail" />
                    <div class="image-name">Seal Photo</div>
                </td>
                <td ng-show="EventInfo.DoorAfterSeal!=null && EventInfo.DoorAfterSeal!='' && EventInfo.DoorAfterSeal!=undefined">
                    <img ng-class="{'Active': CurrentopenUrl == EventInfo.DoorAfterSeal}"
                         ng-click="OpenImageView(EventInfo.DoorAfterSeal, 'EventInfo')"
                         src="{{EventInfo.DoorAfterSeal}}"
                         alt="Door After Seal"
                         class="thumbnail" />
                    <div class="image-name">Door After Seal</div>
                </td>
                <td ng-show="EventInfo.CargoFrontView!=null && EventInfo.CargoFrontView!='' && EventInfo.CargoFrontView!=undefined">
                    <img ng-class="{'Active': CurrentopenUrl == EventInfo.CargoFrontView}"
                         ng-click="OpenImageView(EventInfo.CargoFrontView, 'EventInfo')"
                         src="{{EventInfo.CargoFrontView}}"
                         alt="Cargo Front View"
                         class="thumbnail" />
                    <div class="image-name">Cargo Front View</div>
                </td>
                <td ng-show="EventInfo.ContainerImage!=null && EventInfo.ContainerImage!='' && EventInfo.ContainerImage!=undefined">
                    <img ng-class="{'Active': CurrentopenUrl == EventInfo.ContainerImage}"
                         ng-click="OpenImageView(EventInfo.ContainerImage, 'EventInfo')"
                         src="{{EventInfo.ContainerImage}}"
                         alt="Container Image"
                         class="thumbnail" />
                    <div class="image-name">Container Image</div>
                </td>
                <td ng-show="EventInfo.CargoImage!=null && EventInfo.CargoImage!='' && EventInfo.CargoImage!=undefined">
                    <img ng-class="{'Active': CurrentopenUrl == EventInfo.CargoImage}"
                         ng-click="OpenImageView(EventInfo.CargoImage, 'EventInfo')"
                         src="{{EventInfo.CargoImage}}"
                         alt="Cargo Image"
                         class="thumbnail" />
                    <div class="image-name">Cargo Image</div>
                </td>
                <td ng-show="EventInfo.CargoRearSide!=null && EventInfo.CargoRearSide!='' && EventInfo.CargoRearSide!=undefined">
                    <img ng-class="{'Active': CurrentopenUrl == EventInfo.CargoRearSide}"
                         ng-click="OpenImageView(EventInfo.CargoRearSide, 'EventInfo')"
                         src="{{EventInfo.CargoRearSide}}"
                         alt="Cargo Rear Side"
                         class="thumbnail" />
                    <div class="image-name">Cargo Rear Side</div>
                </td>
                <td ng-show="EventInfo.CargoLeftSide!=null && EventInfo.CargoLeftSide!='' && EventInfo.CargoLeftSide!=undefined">
                    <img ng-class="{'Active': CurrentopenUrl == EventInfo.CargoLeftSide}"
                         ng-click="OpenImageView(EventInfo.CargoLeftSide, 'EventInfo')"
                         src="{{EventInfo.CargoLeftSide}}"
                         alt="Cargo Left Side"
                         class="thumbnail" />
                    <div class="image-name">Cargo Left Side</div>
                </td>
                <td ng-show="EventInfo.CargoRightSide!=null && EventInfo.CargoRightSide!='' && EventInfo.CargoRightSide!=undefined">
                    <img ng-class="{'Active': CurrentopenUrl == EventInfo.CargoRightSide}"
                         ng-click="OpenImageView(EventInfo.CargoRightSide, 'EventInfo')"
                         src="{{EventInfo.CargoRightSide}}"
                         alt="Cargo Right Side"
                         class="thumbnail" />
                    <div class="image-name">Cargo Right Side</div>
                </td>
                <td ng-repeat="x in EventInfo.RepackPhotoLibrary" ng-show="x.Url!=null && x.Url !='' && x.Url!=undefined">
                    <img ng-class="{'Active': CurrentopenUrl == x.Url}"
                         ng-click="OpenImageView(x.Url, 'EventInfo')"
                         src="{{x.Url}}"
                         alt="Seal Number"
                         class="thumbnail" />
                    <div class="image-name">{{x.Label}}</div>
                </td>

            </tr>
        </table>
    </div>

    @Html.Partial("_RecordEventDetails")
    


    <!--Captured Event History-->
    <div class="modal fade" id="StripInspDetailModel" data-backdrop="static" data-keyboard="false" tabindex="-1" role="dialog">
        <div class="modal-dialog modal-dialog-centered" role="document">
            <div class="modal-content">
                <div class="CloseModalBtn" data-dismiss="modal">
                    <i data-dismiss="modal" class="icon-cross"></i>
                </div>
                <div class="modal-header">
                    <h5 class="modal-title">{{StripInspDetails.Cntr}} Insp Details</h5>
                </div>
                <div class="modal-body" style=" letter-spacing: 0.8px; max-height: 500px; overflow:auto">
                    <div class="row">
                        <table class="DetailsTable">
                            <tr>
                                <th>Bayan</th>
                                <td><span>{{StripInspDetails.Bayan}}</span></td>
                            </tr>
                            <tr>
                                <th>Container</th>
                                <td><span>{{StripInspDetails.Cntr}}</span></td>
                            </tr>
                            <tr>
                                <th>Container Status</th>
                                <td>
                                    <span ng-if="checkBayanCntrStatus(StripInspDetails.SelectedStripRecord)=='Ready to Approve.'" class="Approvebadge">{{checkBayanCntrStatus(StripInspDetails.SelectedStripRecord)}}</span>
                                    <span ng-if="checkBayanCntrStatus(StripInspDetails.SelectedStripRecord)!='Ready to Approve.'" class="RejectedApprovalEvent">{{checkBayanCntrStatus(StripInspDetails.SelectedStripRecord)}}</span>
                                </td>
                            </tr>
                            <tr>
                                <th>Category</th>
                                <td><span>{{StripInspDetails.category}}</span></td>
                            </tr>
                            <tr>
                                <th>INI Post Time</th>
                                <td><span>{{StripInspDetails.INIPostTime | date:'dd/MM/yyyy HH:mm:ss'}}</span></td>
                            </tr>
                            <tr>
                                <th>Seal Cut</th>
                                <td><span>{{StripInspDetails.SealCut | date:'dd/MM/yyyy HH:mm:ss'}}</span></td>
                            </tr>
                            <tr>
                                <th>Xray Status</th>
                                <td><span>{{StripInspDetails.XrayStatus}}</span></td>
                            </tr>
                            <tr>
                                <th>Custom Insp Type</th>
                                <td><span>{{StripInspDetails.CustmInspType}}</span></td>
                            </tr>
                        </table>
                    </div>
                </div>
                <div class="modal-footer" style=" padding: 9px;">
                    <button class="btn btn-reset" data-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>
    <!--Captured Event History end-->
</div>







<script>
    //Hide Side Menu
    window.onload = function () {
        document.getElementById('minisidebar').className = 'sidebar-xs';
    };


</script>

<script src="@Url.Content("~/Scripts/crypto-js.min.js")"></script>
<script src="~/Content/popup/jquery-confirm.min.js"></script>
<script src="~/Scripts/jquery.min.js"></script>
<script src="~/Scripts/webcam.min.js"></script>
<script src="~/Content/ZoomInOut/ZoomInOut.js"></script>
<script>

    window.addEventListener('click', function (e) {
        var Target = $(e.target).hasClass('optionIcon');
        var Targetparent = $(e.target).parent().hasClass('optionIcon');
        if (!Targetparent && !Target) {
            $('.DropOptionParent').css('display', 'none');
        }
    });
</script>

<script>



    (function () {
        window.requestAnimFrame = (function (callback) {
            return window.requestAnimationFrame ||
                window.webkitRequestAnimationFrame ||
                window.mozRequestAnimationFrame ||
                window.oRequestAnimationFrame ||
                window.msRequestAnimaitonFrame ||
                function (callback) {
                    window.setTimeout(callback, 1000 / 60);
                };
        })();

        var canvas = document.getElementById("sig-canvas");
        var ctx = canvas.getContext("2d");
        ctx.strokeStyle = "#222222";
        ctx.lineWidth = 1;

        var drawing = false;
        var mousePos = {
            x: 0,
            y: 0
        };
        var lastPos = mousePos;

        canvas.addEventListener("mousedown", function (e) {
            drawing = true;
            lastPos = getMousePos(canvas, e);
        }, false);

        canvas.addEventListener("mouseup", function (e) {
            drawing = false;
        }, false);

        canvas.addEventListener("mousemove", function (e) {
            mousePos = getMousePos(canvas, e);
        }, false);

        // Add touch event support for mobile
        canvas.addEventListener("touchstart", function (e) {

        }, false);

        canvas.addEventListener("touchmove", function (e) {
            var touch = e.touches[0];
            var me = new MouseEvent("mousemove", {
                clientX: touch.clientX,
                clientY: touch.clientY
            });
            canvas.dispatchEvent(me);
        }, false);

        canvas.addEventListener("touchstart", function (e) {
            mousePos = getTouchPos(canvas, e);
            var touch = e.touches[0];
            var me = new MouseEvent("mousedown", {
                clientX: touch.clientX,
                clientY: touch.clientY
            });
            canvas.dispatchEvent(me);
        }, false);

        canvas.addEventListener("touchend", function (e) {
            var me = new MouseEvent("mouseup", {});
            canvas.dispatchEvent(me);
        }, false);

        function getMousePos(canvasDom, mouseEvent) {
            var rect = canvasDom.getBoundingClientRect();
            return {
                x: mouseEvent.clientX - rect.left,
                y: mouseEvent.clientY - rect.top
            }
        }

        function getTouchPos(canvasDom, touchEvent) {
            var rect = canvasDom.getBoundingClientRect();
            return {
                x: touchEvent.touches[0].clientX - rect.left,
                y: touchEvent.touches[0].clientY - rect.top
            }
        }

        function renderCanvas() {
            if (drawing) {
                ctx.moveTo(lastPos.x, lastPos.y);
                ctx.lineTo(mousePos.x, mousePos.y);
                ctx.stroke();
                lastPos = mousePos;
            }
        }

        // Prevent scrolling when touching the canvas
        document.body.addEventListener("touchstart", function (e) {
            if (e.target == canvas) {
                e.preventDefault();
            }
        }, false);
        document.body.addEventListener("touchend", function (e) {
            if (e.target == canvas) {
                e.preventDefault();
            }
        }, false);
        document.body.addEventListener("touchmove", function (e) {
            if (e.target == canvas) {
                e.preventDefault();
            }
        }, false);

        (function drawLoop() {
            requestAnimFrame(drawLoop);
            renderCanvas();
        })();

        function clearCanvas() {
            canvas.width = canvas.width;
        }

        // Set up the UI
        var clearBtn = document.getElementById("sig-clearBtn");
        var submitBtn = document.getElementById("sig-submitBtn");
        clearBtn.addEventListener("click", function (e) {
            clearCanvas();
        }, false);
        submitBtn.addEventListener("click", function (e) {
            var dataUrl = canvas.toDataURL();
            //sigText.innerHTML = dataUrl;
            //sigImage.setAttribute("src", dataUrl);
        }, false);

    })();

    var element = document.getElementById('RecordServices');
    element.classList.add("Active");

</script>
