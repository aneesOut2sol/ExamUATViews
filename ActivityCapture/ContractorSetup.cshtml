@{
    ViewBag.Title = "Contractor Setup";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<script src="~/Scripts/jquery.min.js"></script>
<script src="~/Content/popup/jquery-confirm.min.js"></script>
<link href="~/Content/popup/jquery-confirm.min.css" rel="stylesheet" />
@*<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/jquery-confirm/3.3.4/jquery-confirm.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-confirm/3.3.4/jquery-confirm.min.js"></script>*@
<style>
    :root {
        --dpw-primary: #1E1450;
        --dpw-secondary: #00B2A9; /* DP World secondary teal for accents */
        --bg-light: #F4F7F9;
    }

    /* Page Container */
    .contractor-container {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        background-color: var(--bg-light);
        padding: 20px;
    }

    /* Card Styling */
    .card-custom {
        border-radius: 12px;
        border: none;
        box-shadow: 0 10px 30px rgba(30, 20, 80, 0.05);
        background: #ffffff;
        margin-bottom: 1.5rem;
    }

    .card-header-flex {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1.25rem 1.5rem;
        border-bottom: 1px solid #edf2f7;
    }

    /* DP World Button */
    .btn-dpw-main {
        background-color: var(--dpw-primary);
        color: white;
        border-radius: 6px;
        padding: 10px 24px;
        font-weight: 600;
        border: none;
        transition: all 0.2s;
    }

        .btn-dpw-main:hover:not(:disabled) {
            background-color: #2a1d6e;
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(30, 20, 80, 0.2);
        }

    /* Search Bar Styling */
    .search-wrapper {
        position: relative;
        max-width: 400px;
    }

        .search-wrapper i {
            position: absolute;
            left: 12px;
            top: 50%;
            transform: translateY(-50%);
            color: #a0aec0;
        }

    .search-input {
        padding-left: 38px !important;
        border-radius: 8px !important;
        border: 1px solid #e2e8f0 !important;
        background-color: #f8fafc !important;
    }

    /* Scrollable Table Container */
    .table-fixed-height {
        max-height: 450px; /* Adjust height as needed */
        overflow-y: auto;
        position: relative;
    }

    .table-custom {
        margin-bottom: 0;
    }

        /* Sticky Header */
        .table-custom thead th {
            position: sticky;
            top: 0;
            background-color: #1E1450;
            z-index: 10;
            border-top: none;
            border-bottom: 2px solid #edf2f7;
            color: #fff;
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        /* Row Hover and Styling */
        .table-custom tbody tr {
            transition: background 0.2s;
        }

            .table-custom tbody tr:hover {
                background-color: #fcfdfe;
            }

    .contractor-id {
        font-family: 'Monaco', 'Consolas', monospace;
        color: #718096;
        font-size: 0.85rem;
    }

    /* Inline Edit Styling */
    .inline-edit-input {
        border: 2px solid #e2e8f0;
        padding: 6px 12px;
        border-radius: 6px;
        width: 100%;
        transition: border-color 0.2s;
    }

        .inline-edit-input:focus {
            border-color: var(--dpw-primary);
            outline: none;
        }
    /* Styling the jquery-confirm box to match DP World theme */
    .jconfirm.jconfirm-modern .jconfirm-box {
        border-radius: 12px;
        padding: 20px;
    }

    .jconfirm.jconfirm-modern .jconfirm-title-c {
        color: #1E1450;
        font-weight: 700;
    }

    .jconfirm .jconfirm-buttons button.btn-danger {
        background-color: #e53e3e; /* Standard danger red */
        border: none;
        font-weight: 600;
    }

    .jconfirm .jconfirm-buttons button.btn-light {
        background-color: #f7fafc;
        border: 1px solid #e2e8f0;
        color: #4a5568;
        font-weight: 600;
    }
</style>

<div class="contractor-container" ng-controller="ContractorSetupCtrl" ng-init="Contractorpageinit()">

    <div class="card card-custom">
        <div class="card-body p-4">
            <div class="row align-items-center">
                <div class="col-lg-7">
                    <h4 class="mb-1 font-weight-bold" style="color: var(--dpw-primary)">Contractor Management</h4>

                    <div class="row mt-3">
                        <div class="col-md-8">
                            <div class="form-group mb-0">
                                <label class="small font-weight-bold text-uppercase text-muted">New Contractor Name</label>
                                <input type="text" class="form-control form-control-lg border-light shadow-none"
                                       ng-model="newContractor.Name"
                                       placeholder="Enter company name..."
                                       style="background: #f8fafc; border: 1px solid #e2e8f0;">
                            </div>
                        </div>
                        <div class="col-md-4 d-flex align-items-end">
                            <button class="btn btn-dpw-main btn-block py-2" ng-click="AddContractor(newContractor.Name)" ng-disabled="!newContractor.Name">
                                <i class="icon-plus2 mr-2"></i> Register
                            </button>
                        </div>
                    </div>
                </div>
                <div class="col-lg-5 d-none d-lg-block text-right">
                    <div class="p-3 bg-light rounded-lg d-inline-block text-left" style="border-left: 4px solid var(--dpw-primary)">
                        <span class="text-muted small d-block">Total Active</span>
                        <h3 class="mb-0 font-weight-bold">{{ContractorList.length}}</h3>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card card-custom">
        <div class="card-header-flex">


            <div class="search-wrapper">
                <i class="icon-search4"></i>
                <input type="text" class="form-control search-input"
                       placeholder="Search contractors..."
                       ng-model="searchText">
            </div>
        </div>

        <div class="table-fixed-height">
            <table class="table table-custom align-middle">
                <thead>
                    <tr>
                        <th class="pl-4">ID</th>
                        <th>Contractor Name</th>
                        <th class="text-right pr-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <tr ng-repeat="c in ContractorList | filter:searchText">
                        <td class="pl-4">
                            <span class="contractor-id">#{{$index+1}}</span>
                        </td>
                        <td>
                            <div ng-if="!c.isEditing">
                                <span class="font-weight-bold text-dark">{{c.Contractor}}</span>
                            </div>
                            <div ng-if="c.isEditing">
                                <input type="text" class="inline-edit-input" ng-model="c.tempName" />
                            </div>
                        </td>
                        <td class="text-right pr-4">
                            <div ng-show="!c.isEditing">
                                <button class="btn btn-light btn-icon btn-sm rounded-round border-0" ng-click="EditRow(c)" title="Edit">
                                    <i class="icon-pencil7 text-indigo-400"></i>
                                </button>
                                <button class="btn btn-light btn-icon btn-sm rounded-round border-0 ml-1"
                                        ng-click="ConfirmDelete(c)"
                                        title="Delete">
                                    <i class="icon-trash text-danger-400"></i>
                                </button>
                            </div>

                            <div ng-show="c.isEditing">
                                <button class="btn btn-success btn-sm px-3 shadow-sm mr-1" ng-click="UpdateContractor(c)">
                                    SAVE
                                </button>
                                <button class="btn btn-link btn-sm text-muted" ng-click="CancelEdit(c)">
                                    Cancel
                                </button>
                            </div>
                        </td>
                    </tr>

                    <tr ng-if="(ContractorList | filter:searchText).length == 0">
                        <td colspan="3" class="text-center py-5">
                            <i class="icon-search4 mb-2 text-light" style="font-size: 3rem; display: block;"></i>
                            <p class="text-muted">No contractors found matching your criteria.</p>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
        <div class="card-footer bg-white text-muted small border-top-0">
            Showing {{ (ContractorList | filter:searchText).length }} total entries
        </div>
    </div>
</div>