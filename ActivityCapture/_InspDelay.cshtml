                            <button class="btn btn-danger"
                                    ng-if="CheckApproveRejectAll(InspdelayRecordList)"
                                    ng-show="InspDelayBtnsVerification(InspdelayRecord)"
                                    ng-click="ApproveRejectBlockInspectionDelay(InspdelayRecord,false)">
                                Reject all delays
                            </button>
                            <button class="btn btn-success"
                                    ng-if="CheckApproveRejectAll(InspdelayRecordList)"
                                    ng-show="InspDelayBtnsVerification(InspdelayRecord)"
                                    ng-click="ApproveRejectBlockInspectionDelay(InspdelayRecord,true)">
                                Close delays
                            </button>
                            <button class="btn btn-cancel" data-dismiss="modal">Cancel</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>



    <div class="modal fade" id="ReReportInspectionDelayModel" tabindex="-1" role="dialog" data-backdrop="static" data-keyboard="false" aria-labelledby="exampleModalCenterTitle" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered " role="document">
            <div class="modal-content">
                <div class="CloseModalBtn" data-dismiss="modal" aria-label="Close">
                    <button class="close" data-dismiss="modal" aria-label="Close"></button>
                    <i class="icon-cross"></i>
                </div>
                <div class="modal-header">
                    <h5 class="modal-title">{{InspDelay.Cntr}} Inspection Delays</h5>
                </div>
                <div class="modal-body" style="max-height:500px;overflow-x:auto;">
                    <div class="row">
                        <div class="col-md-12">
                            <div class="container">
                                <div class="tabs">
                                    <input type="radio" id="radio-7" name="tabs" checked="" onchange="angular.element(this).scope().InspectionDelayTabChange(this,true)">
                                    <label class="tab" for="radio-7">Operational Delays</label>

                                    <input type="radio" id="radio-8" name="tabs" onchange="angular.element(this).scope().InspectionDelayTabChange(this,true)">
                                    <label class="tab" for="radio-8">Custom Delays</label>

                                    <input type="radio" id="radio-9" name="tabs" onchange="angular.element(this).scope().InspectionDelayTabChange(this,true)">
                                    <label class="tab" for="radio-9">Other</label>
                                    <span class="glider"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-12">
                            <div class="card ReportInspectionDelayModelCard">
                                <div class="dpx">
                                    <div class='py cursor-pointer'>
                                        <label ng-repeat="item in InspectionDelayDD">
                                            <input type="checkbox"
                                                   ng-checked="item.disable"
                                                   ng-disabled="item.disable"
                                                   ng-class="{'active' : B.BlockNumber == CurrentBlock.BlockNumber }"
                                                   class="option-input radio"
                                                   name="pyradio"
                                                   value="{{item.Content}}"
                                                   title="Already Reported"
                                                   ng-model="item.action" />
                                            {{item.Content}}
                                        </label>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
                <div class="modal-footer">
                    <div class="row">
                        <div class="col-md-12" style="text-align:end;">
                            <button class="btn btn-success" ng-click="SubmitInspectionDelays()">Submit</button>
                            <button class="btn btn-cancel" data-dismiss="modal">Cancel</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
@*Inspection delays end*@