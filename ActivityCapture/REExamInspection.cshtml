<script>
    var zoomLevel = 1.0;

    function handleScroll(event) {
        // Adjust the zoom level based on wheel direction
        if (event.deltaY < 0) {
            // Zoom in
            zoomLevel += 0.1;
        } else {
            // Zoom out
            zoomLevel = Math.max(0.1, zoomLevel - 0.1);
        }

        applyZoom();
    }

    function applyZoom() {
        var image = document.getElementById('LargeImageView');
        image.style.transform = 'scale(' + zoomLevel + ')';
    }

    // Attach the wheel event listener to the image container
    var zoomContainer = document.getElementById('overlay');
    zoomContainer.addEventListener('wheel', handleScroll);
</script>
<script>
    $(document).ready(function () {
        var o = new SlimSelect({
            select: '#Occ',
            placeholder: 'Select Occures',
            showSearch: true,
