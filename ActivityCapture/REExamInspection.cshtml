</style>
<link href="~/Content/popup/jquery-confirm.min.css" rel="stylesheet" />
<!--Header-->
<div ng-controller="ReExamCtrl" ng-init="init()" class="ng-cloak RecordEvent" ng-cloak>
    <div class="page-header border-bottom-0">
        <div class="page-header-content header-elements-md-inline">
            <div class="page-title d-flex">
                <h4><i class="icon-copy mr-2"></i> <span class="font-weight-semibold">ReExam Inspection</span></h4>
                <a href="#" class="header-elements-toggle text-default d-md-none"><i class="icon-more"></i></a>
            </div>
        </div>
    </div>
    <!---Block-->
    <div class="card mt-2 mt-2" id="Block">
        <div class="card-header" style=" background: var( --dpw-bg-color); color: white; padding: 8px;">
            <h5 class="mt-2">Select Block</h5>
        </div>
        <div class=" card-body shadow">
            <div class="row">
                <div class="Cardtabs" ng-repeat="B in BlocList">
                    <div class="Absoulte">
                        <div class="CountBadge">{{B.Cntr}}</div>
                    </div>
                    <button ng-click="GetContainerList(B)" ng-class="{'active' : B.BlockNumber == CurrentBlock.BlockNumber }" class="btn btn-primary Blocks" value="{{B.BlockNumber}}">{{B.BlockNumber}} </button>
                </div>
            </div>
        </div>
    </div>
    <!---Block-->
    <!---Container-->
    <div class="row" ng-if="CurrentBlock.BlockNumber!=null && CurrentBlock.BlockNumber!=''" style="padding: 14px 0px; ">

        <div class="col-md-12 text-end searchBox">
            <input placeholder="Search Bayan.." type="text" ng-model="Fbayan" ng-keyup="Filtertext(Fbayan,'BayanNo')" />
            <i class="icon-search4"></i>
            <input placeholder="Search Container.." type="text" ng-model="FCntr" ng-keyup="Filtertext(FCntr)" />
            <i class="icon-search4"></i>

        </div>

    </div>
    <div class="accordion" id="accordionExample" ng-if="!stringNullorEmpty(ContainerList)">
        <div class="card Custom-Card m-0" ng-repeat="x in ContainerList | filter :search" style="overflow:visible">

            <!---Container Header-->

            <div class="" id="heading{{$index}}">
                <div class="collapsible-link">
                    <div class="row">
                        <div class="col-md-3 col-lg-3 col-sm-3 col-xs-12" data-toggle="collapse" id="OpenDetails{{$index}}" data-target="#collapse{{$index}}" ng-click="GetContainerEvent($index,x.Cntr)">
                            <div style="display:inline-block">
                                <img style="height:50px;" src="~/Content/images/output-onlinepngtools.png" />
                            </div>
                            <div style="display: inline-block; position: relative; top: 10px; left: 5px; font-family: 'Pilat Wide';">
                                {{x.Cntr}} <span ng-show="x.BayanNo!='' && x.BayanNo!=null" style="font-size: 11px; color: #898989;"> - {{x.BayanNo}}</span>
                                <br />
                                <span style="font-size: 11px; color: #898989;">{{x.Position}}</span>
                            </div>
                        </div>

                        @if (System.Configuration.ConfigurationManager.AppSettings["ReExamBadStowageExcessCargoOptions"].ToLower() == "on")
                        {

                            <div class="col-md-8 col-lg-8 col-sm-8 col-xs-12 mt-xs-2 DamageButton" style="align-self:center;">
                                <button class="btn btn-primary" ng-click="ContainerActionOpen('Damage',x.IsDamage==5 || x.IsDamage==1,x.Cntr)"
                                        ng-class="{'approvalrequierd' : x.IsDamage==5 ,'approved' : x.IsDamage==1,'Rejected':x.IsDamage==3 }">
                                    Damage
                                </button>

                                <button class="btn btn-primary" ng-click="ContainerActionOpen('ExcessCargo',x.IsExcessCargo==5 || x.IsExcessCargo==1,x.Cntr)"
                                        ng-class="{'approvalrequierd' : x.IsExcessCargo==5,'approved' : x.IsExcessCargo==1,'Rejected':x.IsExcessCargo==3 }">
                                    Excess
                                </button>
                                <button class="btn btn-primary" ng-click="ContainerActionOpen('BadStowage',x.IsBadStowage==5 || x.IsBadStowage==1,x.Cntr)"
                                        ng-class="{'approvalrequierd' : x.IsBadStowage==5,'approved' : x.IsBadStowage==1,'Rejected':x.IsBadStowage==3 }">
                                    Bad Stowage
                                </button>

                                <button class="btn btn-primary" ng-click="ContainerActionOpen('RequestTechnician',x.IsRequestTechnician==5 || x.IsRequestTechnician==1,x.Cntr)"
                                        ng-class="{'approvalrequierd' : x.IsRequestTechnician==5,'approved' : x.IsRequestTechnician==1,'Rejected':x.IsRequestTechnician==3 }">
                                    Request Technicain
                                </button>

                            </div>
                        }
                        else
                        {
                            <div class="col-md-8 col-lg-8 col-sm-4 col-xs-12 DamageButton"></div>
                        }


                        <div class="col-md-1 col-lg-1 col-sm-1 col-xs-12 Chervronicon text-center" style="align-self:center;">
                            <div class="Indicatior" id="toggler{{$index}}" ng-click="ToggleCol($index,x.Cntr)">
                                <i class="icon-chevron-down"></i>
                            </div>
                        </div>

                        <div class="col-md-12 col-lg-12 col-sm-12 col-xs-12 collapse" id="collapse{{$index}}" aria-labelledby="heading{{$index}}" data-parent="#accordionExample">
                            <div class="row">
                                <div class="col-md-4 col-sm-12 col-12 p-0" ng-repeat="y in EventList | orderBy:'SortOrder'" ng-if="CheckCargoStripByBlock(y.EventName,CurrentBlock.BlockNumber)">
                                    <label for="{{x.Cntr}}Chk{{$index}}" class="d-block">
                                        <div ng-class="{'Active':y.IsCaptureBefore==true}" class="evnetBox">
                                            <div title="{{y.DisplayName}}" class="EventNameTruncate" ng-show="y.DisplayName!=null && y.DisplayName!=''">{{y.DisplayName}}</div>
                                            <div title="{{y.EventName}}" class="EventNameTruncate" ng-show="y.DisplayName==null || y.DisplayName==''">{{y.EventName}}</div>
                                            <input id="{{x.Cntr}}Chk{{$index}}" type="checkbox" ng-click="ConfrimApplyEvent(y,$index,x.Position,x.gkey)" ng-checked="y.isApplied" ng-disabled="y.isApplied" class="eventCheckBox" style="float:right;" name="name" value="" />
                                        </div>
                                    </label>
                                </div>
                            </div>
                        </div>

                    </div>
                    <!--Drop Down Context Menu-->
                    <!--Drop Down Context Menu-->
                </div>
            </div>
            <!---Container Header-->
            <!---Events-->

        </div>
        <!---Events-->
        <div class="" style="margin-bottom: -30px;margin-left: -35px;">

        </div>

    </div>

    <!---Container-->
    <!--Damage--->
    <div class="modal fade" id="AddDamageModel" tabindex="-1" role="dialog" data-backdrop="static" data-keyboard="false" aria-labelledby="exampleModalCenterTitle" aria-hidden="true">
        <div class="modal-dialog " role="document">
            <div class="modal-content">
                <div class="CloseModalBtn" data-dismiss="modal" aria-label="Close">
                    <button class="close" data-dismiss="modal" aria-label="Close"></button>
                    <i class="icon-cross"></i>
                </div>
                <div class="modal-header">
                    <h5 class="modal-title">Report Damage</h5>
                </div>
                <div ng-show="ApproveStatus == 3" style="margin-right: 30px !important;">
                    <button class="btn btn-primary pull-right" ng-show="ApproveStatus == 3" ng-click="ShowDamageHistory(ShowDamageData.Cntr)">History</button>

                </div>
                <div class="modal-body" style="max-height:500px;overflow-x:auto;">
                    <div class="row">
                        <div class="col-md-12 form-group">
                            <label>Damage By</label><span class="required-starig">*</span>
                            <select data-placeholder="Please Select option" class="form-control select-clear" id="Occ" ng-model="Damage.Occurs" required data-fouc>
                                <option></option>
                                <option value="Origin">Damage by origin</option>
                                <option value="Customs">Damage by customs </option>
                                <option value="Bad Stowage">Damage by bad stowage</option>
                            </select>
                        </div>
                        <div class="col-md-12 form-group">
                            <label>Remarks</label>
                            <select data-placeholder="Please Select option" class="form-control select-clear" id="dreamks" ng-model="Damage.Remarks" required data-fouc>
                                <option></option>
                                <option value="While opening the container  door cargo found in bad stowage status causing damage">While opening the container  door cargo found in bad stowage status causing damage</option>
                                <option value="While opening the container door cargo found without proper lashing causing damages">While opening the container door cargo found without proper lashing causing damages </option>
                                <option value="Cargo was damaged by Customs inspectors during the inspection process">Cargo was damaged by Customs inspectors during the inspection process.</option>
                            </select>

                        </div>

                        <div class="col-md-6 col-sm-6 col-lg-6">
                            <div class="form-group">
                                <label>Cargo type</label><span class="required-starig">*</span>
                                <select data-placeholder="Please Select option" class="form-control select-clear" id="Pck" ng-model="Damage.CargoType" required data-fouc>
                                    <option></option>
                                    <option value="CARTON - CT">CARTON - CT</option>
                                    <option value="PALLET - PL">PALLET - PL</option>
                                    <option value="BUNDLE - BE">BUNDLE - BE</option>
                                    <option value="PIECES - PCS">PIECES - PCS</option>
                                    <option value="PACKAGE - PKG">PACKAGE - PKG</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-6 col-sm-6 col-lg-6">
                            <div class="form-group">
                                <label>Cargo quantity</label><span class="required-starig">*</span>
                                <input type="text" class="form-control" oninput="" ng-model="Damage.CargoQuantity" value="" />
                            </div>
                        </div>
                        <div class="col-md-12">
                            <label class="Starick">Damage Images</label>
                            <ul class="Damage_Images">
                                <li ng-repeat="x in Damage.Images">
                                    <b>{{x.Label}}</b>
                                    <div class="Icon" ng-show="x.Url==null || x.Url==''">
                                        <span title="Open Camera" ng-click="OpenCam($index,'Damage')"><i class="icon-camera"></i></span>
                                        <label title="Upload Image" style="margin:0px;">
                                            <span><i class="icon-images2"></i></span>
