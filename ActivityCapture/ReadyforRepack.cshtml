
<style>

    .collapsible-link {
        width: 100%;
        position: relative;
        text-align: left;
    }

    #CntrTableHeader tr {
        background: var( --dpw-bg-color);
        color: #fff;
    }

    #CntrTableHeader td {
        text-align: left
    }

    #CardInnerTable {
        padding: 0;
    }

        #CardInnerTable tr {
            border: none;
        }

        #CardInnerTable td {
            text-align: left !important;
            border: none;
        }

    .event-table {
        max-height: 300px;
        overflow: auto;
    }

    .pad-5 {
        padding: 5px !important;
    }

    .m-0 {
        margin: 0 !important;
    }

    .evnetBox {
        padding: 11px;
        border: 2px solid #d1d1d145;
        margin: 5px;
        color: #7a7a7a;
        border-radius: 3px;
        background: whitesmoke;
        box-shadow: 1px 1px 1px #cbc9c9;
    }

        .evnetBox.Active {
            background: #00946b1f !important;
            border: 1px solid #00946b !important;
        }

    .Custom-Card {
        margin-bottom: 15px !important;
        padding: 16px 25px;
        border-radius: 7px !important;
        border: 1px solid #b8b8b866 !important;
        box-shadow: -2px -2px 3px 0px inset #989898a1;
        background: #fff;
    }

        .Custom-Card .card-header {
            background: none !important;
            border: 0;
        }

        .Custom-Card td {
            padding: 4px 10px;
        }

    .eventCheckBox {
        float: right;
        transform: scale(1);
        margin-top: 4px;
        box-shadow: 1px 1px 1px #ececec !important;
    }

    .EventNameTruncate {
        display: inline-block;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        width: 80%;
    }

    .labelChild {
        background: red;
        position: relative;
        width: 100px;
        /*z-index: 999;*/
        color: white;
        text-align: center;
        /*transform: rotate(325deg);*/
        /*right: 24px;*/
        /*top: 11px;*/
        top: 6px;
        font-size: 15px;
        display: flex;
        align-items: center !important;
        justify-content: center;
        border-radius: 5px;
    }

    .Bred {
        background: green !important;
    }

    .labelParent {
        /*position: absolute;*/
        /*height: 100px;*/
        height: 55px;
        /*width: 100px;*/
        width: auto;
        overflow: hidden;
        left: 0px;
    }



    table thead {
        box-shadow: none !important;
    }

    table {
        border: 1px solid var( --dpw-bg-color) !important;
    }

    .Blocks {
        padding: 10px;
        box-shadow: 1px 3px 3px 1px gray;
    }

    button.btn.btn-primary.active {
        background: #00946b !important;
    }

    .Blocks:hover {
        box-shadow: none;
        background: #00946b
    }

    .Cardtabs {
        width: auto !important;
        display: inline-block;
        margin: 15px;
    }

    .Absoulte {
        position: absolute;
        height: 0px;
        width: 56px;
    }

    .CountBadge {
        position: relative;
        z-index: 99;
        color: #ffffff;
        padding: 0px 6px;
        background: #00946b;
        border-radius: 10px;
        float: right;
        bottom: 7px;
        left: 0px;
        width: fit-content;
        box-shadow: 1px 1px 5px -1px #000000cc;
    }

    .Indicatior {
        margin-left: auto;
        width: fit-content;
    }

    .modal-header {
        text-align: center;
        border-bottom: none !important;
        justify-content: center !important;
    }

    .modal-title {
        font-weight: bolder !important;
        font-size: 24px;
        padding-top: 12px;
        padding-bottom: 4px;
        display: inline-block;
    }

    .CloseModalBtn {
        color: #FFFFFF;
        line-height: 25px;
        position: absolute;
        right: -12px;
        text-align: center;
        top: -10px;
        width: 45px;
        text-decoration: none;
        font-weight: bold;
        box-shadow: 1px 1px 3px #000;
        transition: all .3s;
        height: 45px;
        border-radius: 50%;
        font-size: 25px !important;
        padding: 8px;
        cursor: pointer;
        background: var( --dpw-bg-color);
    }
</style>
<div ng-controller="ReadyforRepackCtrl" ng-init="init()" class="ng-cloak RecordEvent" ng-cloak>
    <br />
    <div class="page-header border-bottom-0">
        <div class="page-header-content header-elements-md-inline">
            <div class="page-title d-flex">
                <h4><i class="icon-stack-text mr-2"></i><span class="font-weight-semibold">Pending for Repack</span></h4>
            </div>
            <div class="page-title d-flex">

            </div>
        </div>
    </div>
    <hr />
    <!---Block-->
    <div class="card mt-2 mt-2" id="Block">
        <div class="card-header" style=" background: var( --dpw-bg-color); color: white; padding: 8px;">
            <h5 class="mt-2">Select Block</h5>
        </div>
        <div class=" card-body shadow">
            <div class="row">
                <div class="Cardtabs" ng-repeat="B in BlockList">
                    <div class="Absoulte">
                        <div class="CountBadge">{{B.Count}}</div>
                        <br />

                    </div>
                    <button ng-click="GetContainerList(B,true)" ng-class="{'active' : B.Block == CurrentBlock.Block }" class="btn btn-primary Blocks" value="{{B.Block}}">{{B.Block}} </button>
                </div>
            </div>
        </div>
    </div>
    <!---Block-->
    <div class="accordion" id="accordionExample" ng-if="!stringNullorEmpty(ContainerList)">
        <div class="card Custom-Card m-0" ng-repeat="x in ContainerList | filter :search" style="overflow:visible">

            <!---Container Header-->

            <div class="" id="heading{{$index}}">
                <div class="collapsible-link">
                    <div class="row">
                        <div class="col-md-5 col-lg-6 col-sm-6 col-xs-12" data-toggle="collapse" id="OpenDetails{{$index}}" data-target="#collapse{{$index}}" ng-click="GetContainerEvent($index,x.Cntr)">
                            <div style="display: inline-block; vertical-align: middle; margin-bottom: 4px;">
                                <img style="height:50px;" src="~/Content/images/output-onlinepngtools.png" />
                            </div>
                            <div style="display: inline-block; vertical-align: middle; margin-bottom: 4px; margin-left: 12px; font-family: 'Pilat Wide';">
                                {{x.Cntr}} <span ng-show="x.BayanNo!='' && x.BayanNo!=null" style="font-size: 11px; color: #898989;"> - {{x.BayanNo}}</span>
                                <div ng-show="x.Location!='' && x.Location!=null" style="font-size: 11px; color: #898989;">{{x.Location}}</div>
                            </div>
                        </div>

                        <div class="col-md-6 col-lg-5 col-sm-5 col-xs-12 mt-xs-2 DamageButton" style="align-self:center;">
                        </div>

                        <div class="col-md-1 col-lg-1 col-sm-1 col-xs-12 Chervronicon text-center" style="align-self:center;">
                            <div class="Indicatior" ng-click="GetContainerHold(x.Cntr,x.gkey)">
                                <img style=" height: 33px;" src="~/Content/images/N4HoldRelease.png" />
                            </div>
                        </div>


                    </div>
                    <!--Drop Down Context Menu-->
                    <!--Drop Down Context Menu-->
                </div>
            </div>
            <!---Container Header-->
            <!---Events-->

        </div>
    </div>
    <div class="modal fade" id="ActiveHold" tabindex="-1" data-backdrop="static" data-keyboard="false" role="dialog" aria-labelledby="exampleModalCenterTitle" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered" role="document" style="max-width:400px;">
            <div class="modal-content">
                <div class="CloseModalBtn" data-dismiss="modal" aria-label="Close">
                    <button class="close" data-dismiss="modal" aria-label="Close"></button>
                    <i class="icon-cross"></i>
                </div>
                <div class="modal-header">
                    <h5 class="modal-title">
                        Active hold
                    </h5>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-12">
                            <p> Following holds are active on container ({{CurrentCntr}})</p>
                            <ul>
                                <li ng-repeat="x in HoldList">{{x}}</li>
                            </ul>
                            @*<div class="btn btn-primary" ng-repeat="x in HoldList"><i class="icon-lock"></i> {{x}}</div>*@
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-success" ng-click="ReleaseContainerHold(CurrentCntr)">Release Holds</button>
                    <button class="btn btn-cancel">Cancel</button>
                </div>
            </div>
        </div>
    </div>
</div>