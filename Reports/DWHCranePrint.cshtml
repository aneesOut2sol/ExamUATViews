
@model ExamPortal.Model.Features.DWH.GetCranesListResponse
@{
    ViewBag.Title = "DPWTicketPrint";
    Layout = null;
}

<!DOCTYPE html>

<html>
<head>

    <title>Crane Details |  Print</title>
    <link rel="icon" type="~/Content/images/favicon.ico" sizes="16x16" href="~/Content/images/favicon.ico">
    <style>
     @@import url('https://fonts.googleapis.com/css2?family=Lato:wght@300&display=swap');

        .heading-print {
            color: black;
            font-weight: bold;
            margin: 0px;
        }

        * {
            font-family: 'Lato', sans-serif;
        }

        .text-center {
            text-align: center !important;
        }

        table {
            width: 100%;
            box-sizing: border-box;
            border-collapse: collapse;
            margin: 15px 0px;
        }

        th {
            font-weight: bold;
        }

        td, th {
            padding: 10px !important;
            border: 1px solid #191919;
            font-weight:bolder;
            text-align:center
        }
        .badge {
            width: auto !important;
            display: inline-block;
            color: white;
            padding: 0.3125rem 0.585rem;
            font-size: auto; /*75%;*/
            font-weight: bolder;
            line-height: 1.3;
            text-align: center;
            white-space: nowrap;
            vertical-align: baseline;
            border-radius: .125rem;
            transition: color .15s ease-in-out,background-color .15s ease-in-out,border-color .15s ease-in-out,box-shadow .15s ease-in-out;
        }

     .badge-success {
    color: #fff;
    background-color: #28a745;
}
.badge-danger {
    color: #fff;
   background-color: #c51f41!important;
}
.badge-warning {
    color: #fff;
    background-color: #ff7043!important;
}
.badge-info {
    color: #fff;
    background-color: var( --dpw-bg-color)!important;
}
 
        .badge-Completed {
            /*background-color: #2cb97c!important;*/
            background-color: #6c757d !important;
            text-transform: uppercase;
        }

        .badge-InProgress {
            background-color: #65becc !important;
            text-transform: uppercase;
        }

        .badge-OverDue {
            background-color: red !important;
            text-transform: uppercase;
        }

        .badge-News {
            background-color: #c776aa !important;
            text-transform: uppercase;
        }

        .badge-Closed {
            background-color: #463d32 !important;
            text-transform: uppercase;
        }

        .badge-standby {
            background-color: rgba(59, 85, 96, 0.7);
            color: white;
        }

        .badge-Rejected {
            background-color: #dc3545 !important;
            text-transform: uppercase;
        }

   

        img {
            height: 70px;
            border: none;
        }

     

        .HeaderTr {
            background: #f3f3f3;
        }

        @@media print {
            table {
                width: 100%;
                box-sizing: border-box;
                border-collapse: collapse;
                margin: 15px 0px;
            }
        }
    </style>
</head>
<body>


    <table>
        <tr class="HeaderTr">
            <td class="text-center">
                <img src="~/Content/images/dpworldlogo.png" />
            </td>
            <td colspan="6">
                <h1 class="text-center heading-print">
                    Crane Details Print
                </h1>
            </td>
            <td colspan="3">
                <table>
                    <tr>
                        <th>
                            <span>Print</span> Date
                        </th>
                        <td>@DateTime.Now.ToString("dd-MM-yyyy")</td>
                    </tr>
                    <tr>
                        <th>
                            @*@if (Model.Print == true)*@
                            <span>Print</span> Time
                        </th>
                        <td>@DateTime.Now.ToString("HH:mm")</td>
                    </tr>
                </table>
            </td>
        </tr>
        <tr class="HeaderTr">
            <th colspan="3">Reference No</th>
            <td>@Model.VesselCraneList.FirstOrDefault().RefNo</td>
            <th>Vessel Name</th>
            <td>@Model.VesselName</td>
            <th colspan="2">Status</th>
            <td>
                <div>
                    @if (Model.StatusCode == "invalid")
                    {
                        <span class="badge badge-danger"> @Model.Status</span>

                    }
                    @if (Model.StatusCode == "valid")
                    {
                        <span class="badge badge-success"> @Model.Status </span>
                    }
                    @if (Model.StatusCode == "cntrO")
                    {
                        <span class="badge badge-warning"> @Model.Status </span>
                    }
                    @if (Model.StatusCode == "cntrF")
                    {
                        <span class="badge badge-info"> @Model.Status </span>
                    }
                </div>


            </td>
        </tr>
    </table>
    @{
        int x = 0;
    }
<table>
    <thead>
        <tr>
            <th>Sr #</th>
            <th>Crane No</th>
            <th>First Time</th>
            <th>Last Time</th>
            <th>Crane Hrs</th>
            <th>A Delay</th>
            <th>B Delay</th>
            <th>C Delay</th>
            <th>Opertaions Hrs</th>
            <th>Move Count</th>
            <th>Status</th>
        </tr>
    </thead>
    @foreach (var item in Model.VesselCraneList)
    {
        {
            x++;
        }


<tr>
    <td>@x</td>
    <td>@item.ShortName</td>
    <td>@item.FirstTime.Value.ToString("dd-MM-yyyy HH:mm:ss")</td>
    <td>@item.LastTime.Value.ToString("dd-MM-yyyy HH:mm:ss")</td>
    <td> @item.CraneHrs</td>
    <td>
        @foreach (var item2 in item.CraneDelayHrsList)
        {
            if (item2.Type == "A Type" || item2.Type == "A")
            {
                <span>@item2.DelayHrs</span>
            }
        }
    </td>
    <td>
        @foreach (var item2 in item.CraneDelayHrsList)
        {
            if (item2.Type == "B Type" || item2.Type == "B")
            {
                <span>@item2.DelayHrs</span>
            }
        }
    </td>
    <td>
        @foreach (var item2 in item.CraneDelayHrsList)
        {
            if (item2.Type == "C Type" || item2.Type == "C")
            {
                <span>@item2.DelayHrs</span>
            }
        }
    </td>
    <td><span style="color:green">@item.OprHrs</span></td>
    <td>@item.MoveCount</td>
    <td>
        <div>
            @if (item.StatusCode == "invalid")
            {
                <span class="badge badge-danger"> @item.Status</span>
            }
            else
            {
                <span class="badge badge-success"> @item.Status </span>
            }
        </div>
    </td>

</tr>


    }
</table>
    </body>
</html>




<script>
    window.print();
</script>




