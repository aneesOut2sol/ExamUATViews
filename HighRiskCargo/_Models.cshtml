
<div class="modal ZoominAnimate jqueryConfrim" id="ImageViewModel" tabindex="-1" data-backdrop="static" data-keyboard="false" role="dialog" aria-labelledby="exampleModalCenterTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document" style="min-width:30%;">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="">
                    <b>#{{CurrentCntr}}</b> Cut seal photos!
                </h5>
            </div>
            <div class="modal-body">
                <div class="row">
                    <div class="col-md-12">
                        <ul class="Damage_Images">
                            <li ng-repeat="x in PhotoLibrary">
                                <b>{{x.Label}}</b>
                                <div class="Icon" ng-show="x.Url!=null && x.Url!=''">
                                    <a title="View Image" ng-click="OpenImageView(x.Url,'ImageViewModel')"><span><i class="icon-eye"></i></span></a>
                                </div>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
            <div class="modal-footer" style="padding:9px;">
                <button class="btn btn-reset" data-dismiss="modal">Close</button>
            </div>

        </div>
    </div>
</div>

<div class="modal fade" id="modal_checklist" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-indigo-800 text-white">
                <h6 class="modal-title"><i class="icon-list mr-2"></i> Cargo Safety Checklist - {{selectedItem.Cntr}}</h6>
                <button type="button" class="close text-white" data-dismiss="modal">&times;</button>
            </div>

            <div class="modal-body">
                <div class="table-responsive">
                    <table class="table table-bordered table-striped">
                        <thead class="bg-light">
                            <tr>
                                <th style="width: 40%;">EN Question</th>
                                <th style="width: 40%; text-align: right;">AR Question</th>
                                <th class="text-center" style="width: 20%;">Answer</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr ng-repeat="q in checkData.questions">
                                <td class="text-left">{{q.en}}</td>
                                <td class="text-right">{{q.ar}}</td>
                                <td class="text-center">
                                    <div class="d-inline-flex align-items-center">
                                        <div class="custom-control custom-radio mr-2">
                                            <input type="radio" name="q_{{q.id}}" id="y_{{q.id}}"
                                                   class="custom-control-input" value="Yes" ng-model="q.answer">
                                            <label class="custom-control-label" for="y_{{q.id}}">Yes</label>
                                        </div>
                                        <div class="custom-control custom-radio">
                                            <input type="radio" name="q_{{q.id}}" id="n_{{q.id}}"
                                                   class="custom-control-input" value="No" ng-model="q.answer">
                                            <label class="custom-control-label" for="n_{{q.id}}">No</label>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <div class="mt-3 p-3 bg-light border-round"
                     ng-show="checkData.questions[3].answer === 'Yes'">
                    <div class="form-group mb-0">
                        <label class="font-weight-bold text-indigo-800">
                            <i class="icon-user-tie mr-2"></i>Select Senior Supervisor / Supervisor Name:
                        </label>
                        <select data-placeholder="-- Choose Supervisor --" class="form-control select-clear" id="CHKLST_SPRVSR" ng-model="checkData.assignedSupervisor" required data-fouc>
                            <option></option>
                            <option ng-repeat="s in supervisorsList" value="{{s.Username}}">{{s.name}} - {{s.role}}</option>
                        </select>
                    </div>
                </div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-link text-indigo-800" data-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary px-4" ng-click="saveChecklist()">
                    SUBMIT CHECKLIST
                </button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="view_modal_checklist" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-indigo-800 text-white">
                <h6 class="modal-title"><i class="icon-list mr-2"></i> Cargo Safety Checklist - {{ViewcheckData.Cntr}}</h6>
                <button type="button" class="close text-white" data-dismiss="modal">&times;</button>
            </div>

            <div class="modal-body">
                <div class="table-responsive">
                    <table class="table table-bordered table-striped">
                        <thead class="bg-light">
                            <tr>
                                <th style="width: 40%;">EN Question</th>
                                <th style="width: 40%; text-align: right;">AR Question</th>
                                <th class="text-center" style="width: 20%;">Answer</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr ng-repeat="q in ViewcheckData.questions">
                                <td class="text-left">{{q.en}}</td>
                                <td class="text-right">{{q.ar}}</td>
                                <td class="text-center">
                                    <div class="d-inline-flex align-items-center">
                                        <div class="custom-control custom-radio mr-2">
                                            <input type="radio" name="q_{{$index+1}}" id="y_{{$index+1}}"
                                                   class="custom-control-input" value="Yes" ng-model="q.answer">
                                            <label class="custom-control-label" for="y_{{$index+1}}">Yes</label>
                                        </div>
                                        <div class="custom-control custom-radio">
                                            <input type="radio" name="q_{{$index+1}}" id="n_{{$index+1}}"
                                                   class="custom-control-input" value="No" ng-model="q.answer">
                                            <label class="custom-control-label" for="n_{{$index+1}}">No</label>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <div class="mt-3 p-3 bg-light border-round"
                     ng-show="ViewcheckData.questions[3].answer === 'Yes'">
                    <div class="form-group mb-0">
                        <label class="font-weight-bold text-indigo-800">
                            <i class="icon-user-tie mr-2"></i>Senior Supervisor / Supervisor:
                        </label>
                        <input type="text" class="form-control" disabled readonly ng-model="ViewcheckData.assignedSupervisor" />
                    </div>
                </div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-link text-indigo-800" ng-click="closeViewCheckListModal()">Close</button>               
            </div>
        </div>
    </div>
</div>




<div class="modal fade" id="modal_history" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-indigo-800 text-white">
                <h6 class="modal-title"><i class="icon-history mr-2"></i> Container History - {{selectedItem.Cntr}}</h6>
                <button type="button" class="close text-white" data-dismiss="modal">&times;</button>
            </div>

            <div class="modal-body">
                <div class="card-group-control card-group-control-right" id="history-accordion">

                    <div class="card border-left-3 border-left-indigo" ng-repeat="log in historyList">
                        <div class="card-header bg-light">
                            <h6 class="card-title">
                                <a data-toggle="collapse" class="text-default d-flex justify-content-between align-items-center w-100 collapsed" href="#log_{{$index}}">

                                    <div class="row w-100">
                                        <div class="col-md-4">
                                            <i class="icon-calendar3 mr-2 text-indigo-400"></i>
                                            <span class="font-weight-semibold">{{log.CreatedAt | date:'dd-MMM-yyyy HH:mm'}}</span>
                                        </div>
                                        <div class="col-md-4">
                                            <i class="icon-user mr-2 text-muted"></i>
                                            <span>{{log.CreatedBy}}</span>
                                        </div>
                                        <div class="col-md-4">
                                            <span class="badge badge-success" ng-if="log.ActivityHold ==0">PROCEED</span>
                                            <span class="badge badge-danger" ng-if="log.ActivityHold ==1">HOLD</span>                                           
                                        </div>
                                    </div>

                                </a>
                            </h6>
                        </div>

                        <div id="log_{{$index}}" class="collapse" data-parent="#history-accordion">
                            <div class="card-body border-top-1 border-light bg-white">
                                <div class="card">
                                   
                                        <table class="table table-bordered table-striped table-hover">
                                            <thead class="bg-indigo-800 text-white sticky-header">
                                                <tr>
                                                    <th class="font-weight-bold">Location</th>                                                                                                        
                                                    <th class="font-weight-bold text-center">Q&A</th>
                                                    <th class="font-weight-bold">Supervision Assigned</th>                                                    
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <tr>
                                                    <td>{{log.Location}}</td>                                                                                                      
                                                    <td class="text-center">
                                                        <button type="button" class="btn btn-sm alpha-primary text-primary-800 border-primary" ng-click="viewCheckList(log,true)"
                                                                ng-if="log.Questions != null && log.Questions.length>0">
                                                            View
                                                        </button>
                                                    </td>
                                                    <td>
                                                        <div class="d-flex align-items-center" ng-if="log.SuperVisorAssigned==true">
                                                            <div class="btn bg-indigo-400 rounded-round btn-icon btn-sm mr-2 initital-text">
                                                                <span class="letter-icon" style="font-size: 10px;">{{getSuperVisorInitial(log.SuperVisorLoginId)}}</span>
                                                            </div>
                                                            <span class="font-size-sm">{{getSuperVisorName(log.SuperVisorLoginId)}}</span>
                                                        </div>
                                                    </td>
                                                </tr>
                                            </tbody>
                                        </table>
                                  
                                </div>
                            </div>
                        </div>
                    </div>
                    <div ng-if="historyList.length === 0" class="text-center py-4">
                        <i class="icon-database-empty icon-3x text-muted opacity-25 mb-2"></i>
                        <p class="text-muted">No history found for this container.</p>
                    </div>

                </div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-link text-indigo-800" data-dismiss="modal">Close History</button>
            </div>
        </div>
    </div>
</div>