
<style>
    .Indicator {
        display: flex;
        justify-content: space-between;
        font-size: 10px;
        font-weight: 700;
        margin-bottom: 7px;
    }

        .Indicator div::before {
            content: '';
            height: 8px;
            width: 8px;
            display: inline-block;
            border-radius: 50%;
            vertical-align: middle;
        }

    .AssignedIndicator::before {
        background: #1e1450;
    }

    .MissingIndicator::before {
        background: red;
    }

    .ArrivedIndicator::before {
        background: #85b9a5;
    }

    .TransferedIndicator::before {
        background: #cccccc;
    }

    li.Transfered {
        background: #b7b7b7 !IMPORTANT;
        opacity: 0.7;
    }

    .Camuploader {
        width: fit-content;
        /* width: 100%; */
        padding: 7px 14px;
        border-radius: 5px;
        height: fit-content;
        border: 1px solid #d7d7d7;
        color: gray;
        cursor: pointer;
    }

    .HistoryTab .tab {
        padding: 6px 22px;
        border-bottom: 1px solid #b4b4b4;
        cursor: pointer;
        background: #ffffff;
    }

    .HistoryTab {
        display: flex;
        width: 100%;
        margin-bottom: 15px;
    }

    .tabActive {
        border: 1px solid #b4b4b4 !important;
        border-bottom: none !important;
        background: #f4f2fa !important;
        font-weight: 600;
    }

    .lasttab {
        border-bottom: 1px solid #b4b4b4;
    }

    .HistoryTable tr td, .HistoryTable tr th {
        background: white;
        border: 1px solid #bebebe !important;
    }

    .HistoryTable tr th {
        background: var( --dpw-bg-color) !important;
        color: white !important;
    }

    input[type="checkbox"] {
        float: right;
        margin-top: 7px;
    }

    .Selected {
        background: #1e1450 !important;
        color: white !IMPORTANT;
    }

    .Arrived {
        background: #85b9a5 !important;
        color: white;
    }

    .MissingLabor {
        background: #de7e91 !important;
        text-decoration: line-through;
    }

    li.ng-scope.MissingLabor label {
        text-decoration: line-through;
    }
</style>

@*Container Info*@
<div class="modal fade" id="ContainerDetails" tabindex="-1" role="dialog" data-backdrop="static" data-keyboard="false" aria-labelledby="exampleModalCenterTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="CloseModalBtn" data-dismiss="modal">
                <button class="close" data-dismiss="modal" aria-label="Close"></button>
                <i class="icon-cross"></i>
            </div>
            <div class="modal-header">
                <h5 class="modal-title">Container Action</h5>
            </div>
            <div class="modal-body" style=" min-height: 0px;overflow:visible !important">
                <div class="row">
                    <div class="col-md-12">
                        <button ng-show="ContainerDetails.Started==true" class="btn btn-sm btn-primary" ng-click="Inspectiondelay(x.InspectionDelayRPT==5||x.InspectionDelayRPT==2||x.InspectionDelayRPT==3,x.Unitgkey,x.Cntr,x.OperatorDatails.ActivityId,x.Activity,x.Location)"
                                ng-class="{'approvalrequierd' : ContainerDetails.InspectionDelayRPT==5 ,'approved' : ContainerDetails.InspectionDelayRPT==2,'Rejected':ContainerDetails.InspectionDelayRPT==3 }">
                            Inspection Delays
                            <div class="DelayBadge" style="position: absolute; bottom: 20px;" ng-if="GetOverallInspeDelayDuration(x) != '' && ContainerDetails.Started==true">
                                <div ng-class="{'approved' : ContainerDetails.InspectionDelayRPT==2,'Rejected':ContainerDetails.InspectionDelayRPT!=2 }" class="CountBadge">{{GetOverallInspeDelayDuration(x)}}</div>
                            </div>
                        </button>
                        <button ng-show="ContainerDetails.Started==true" class="btn btn-sm  btn-primary" ng-click="DamageReport(x.DamageStatus==5 || x.DamageStatus==1,x)"
                                ng-class="{'approvalrequierd' : ContainerDetails.DamageStatus==5 ,'approved' : ContainerDetails.DamageStatus==1,'Rejected':x.DamageStatus==3 }">
                            Cargo Report
                        </button>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <div class="row">
                    <div class="col-md-12" style="text-align:center">
                        <button ng-show="ContainerDetails.Started==false" ng-click="StartActivity(ContainerDetails)" class="btn btn-primary">Start Activity</button>
                        <button ng-show="ContainerDetails.Started==true && ContainerDetails.Repack50Done==false" ng-click="EndActivity(ContainerDetails)" class="btn btn-primary">Repack 50%</button>
                        <button ng-show="ContainerDetails.Started==true && ContainerDetails.Repack50Done==true" ng-click="EndActivity(ContainerDetails)" class="btn btn-primary">End Activity</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
