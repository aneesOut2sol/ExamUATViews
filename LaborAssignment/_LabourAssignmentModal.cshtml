<div class="modal fade" id="ActivityInfo" tabindex="-1" role="dialog" data-backdrop="static" data-keyboard="false" aria-labelledby="exampleModalCenterTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document" style="max-width:1000px;">
        <div class="modal-content">
            <div class="CloseModalBtn" data-dismiss="modal" aria-label="Close">
                <button class="close" data-dismiss="modal" aria-label="Close"></button>
                <i class="icon-cross"></i>
            </div>
            <div class="modal-header">
                <h5 class="modal-title">{{ActivityInfo.Cntr}}</h5>
            </div>
            <div class="modal-body">
                <div class="row">
                    <div class="HistoryTab">
                        <div ng-class="{'tabActive':HistoryTab=='Summary'}" ng-click="HistoryTab='Summary'" class="tab">Summary</div>
                        <div ng-class="{'tabActive':HistoryTab=='History'}" ng-click="HistoryTab='History'" class="tab">History</div>
                        <div ng-class="{'tabActive':HistoryTab=='Labors'}" ng-click="HistoryTab='Labors'" class="tab">Labors</div>
                    </div>
                </div>

                <div>
                    <div ng-show="HistoryTab=='Summary'">
                        <table class="table HistoryTable">
                            <tr>
                                <th>Container</th>
                                <td>{{ActivityInfo.Cntr}}</td>
                                <th>Created at</th>
                                <td>{{ActivityInfo.CreatedAt | date:'dd-MM-yyyy HH:mm:ss'}}</td>


                            </tr>
                            <tr>
                                <th>Activity</th>
                                <td>{{ActivityInfo.Activity}}</td>
                                <th>Start time</th>
                                <td>{{ActivityInfo.StartTime  | date:'dd-MM-yyyy HH:mm:ss'}}</td>

                            </tr>
                            <tr>
                                <th>Location</th>
                                <td>{{ActivityInfo.Location}}</td>
                                <th>End time</th>
                                <td>{{ActivityInfo.EndTime  | date:'dd-MM-yyyy HH:mm:ss'}}</td>


                            </tr>
                            <tr>
                                <th>Size</th>
                                <td>{{ActivityInfo.Size}}</td>
                                <th>Activity duration</th>
                                <td>{{ActivityInfo.ActivityDuration}}</td>

                            </tr>
                            <tr>
                                <th>Package type</th>
                                <td>{{ActivityInfo.PackageType}}</td>
                                <th>Activity SLA</th>
                                <td>{{ActivityInfo.ActivityETC}}</td>


                            </tr>
                            <tr>
                                <th>Required Labor</th>
                                <td>{{ActivityInfo.AssignedLabor}}</td>
                                <th>Assigned Labor</th>
                                <td>{{ActivityInfo.AssignedLabor}}</td>
                            </tr>

                        </table>
                    </div>
                    <div ng-show="HistoryTab=='Delays'">
                        <table class="table HistoryTable">
                            <thead>
                                <tr>
                                    <th>Delays</th>
                                    <th>Start at</th>
                                    <th>Start by</th>
                                    <th>Closed at</th>
                                    <th>Closed by</th>
                                    <th>Duration</th>
                                </tr>
                            </thead>
                            <tr ng-repeat="x in ActivityInfo.Delays">
                                <td>{{x.Reason}}</td>
                                <td>{{x.DelayRaisedAt | date:'dd-MM-yyyy HH:mm:ss'}}</td>
                                <td>{{x.CreatedBy}}</td>
                                <td>{{x.DelayResolvedAt | date:'dd-MM-yyyy HH:mm:ss'}}</td>
                                <td>{{x.UpdatedBy}}</td>
                                <td>{{x.Duration}}</td>
                            </tr>
                        </table>

                    </div>
                    <div ng-show="HistoryTab=='History'">
                        <table class="table HistoryTable">
                            <tr>
                                <th>Container</th>
                                <th>Location</th>
                                <th>Activity</th>
                                <th>Status</th>
                                <th>Action</th>
                                <th>Created at</th>
                                <th>Created by</th>
                            </tr>
                            <tr ng-repeat="x in ActivityInfo.History">
                                <td>{{x.Cntr}}</td>
                                <td>{{ActivityInfo.Location}}</td>
                                <td>{{ActivityInfo.Activity}}</td>
                                <td>{{x.Status}}</td>
                                <td>{{x.Detail}}</td>
                                <td>{{x.CreatedAt | date:'dd-MM-yyyy HH:mm:ss'}}</td>
                                <td>{{x.CreatedBy}}</td>
                            </tr>
                        </table>
                    </div>
                    <div ng-show="HistoryTab=='Labors'">
                        <table class="table HistoryTable">
                            <tr>
                                <th>Action</th>
                                <th>Empoyee</th>
                                <th>Status</th>
                                <th>Arrived at</th>
                                <th>Missing at</th>
                                <th>Assigned at</th>
                                <th>Assigned by</th>
                            </tr>
                            <tr ng-repeat="x in ActivityInfo.Labors| orderBy: '-AssignedAt'">
                                <td>
                                    <span ng-show="x.Status=='Assigned'||x.Status=='Arrived'" title="Transfer labor" ng-click="OpenTransferLabor(x)"><i class="icon-history"></i></span>
                                    <span ng-show="ActivityInfo.Status=='Assigned' && (x.Status=='Assigned'||x.Status=='Arrived')" title="Cancel labor" ng-click="CancelJob(x)"><i class="icon-cross"></i></span>
                                </td>
                                <td>{{x.Employee}}</td>
                                <td>{{x.Status}}</td>
                                <td>{{x.ArrivedAt | date:'dd-MM-yyyy HH:mm:ss'}}</td>
                                <td>{{x.MissingAt | date:'dd-MM-yyyy HH:mm:ss'}}</td>
                                <td>{{x.AssignedAt | date:'dd-MM-yyyy HH:mm:ss'}}</td>
                                <td>{{x.AssignedBy}}</td>
                            </tr>
                        </table>
                    </div>

                </div>



            </div>
            <div class="modal-footer">
                <div class="row">
                    <div class="col-md-12" style="text-align:center">

                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
@*Transfer labor*@
<div class="modal fade" id="TransferLabor" tabindex="-1" role="dialog" data-backdrop="static" data-keyboard="false" aria-labelledby="exampleModalCenterTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="CloseModalBtn" data-dismiss="modal">
                <button class="close" data-dismiss="modal" aria-label="Close"></button>
                <i class="icon-cross"></i>
            </div>
            <div class="modal-header">
                <h5 class="modal-title">Transfer {{TransferLabor.EmpId}} to {{ActivityInfo.Cntr}}</h5>
            </div>
            <div class="modal-body" style=" min-height: 120px;overflow:visible !important">
                <div class="row">
                    <div class="col-md-12">
                        <label class="Starick">Container</label>
                        <select id="TransferCntrDD" ng-model="TransferToUnitgkey">
                            <option ng-repeat="x in TransferCntrList" value="{{x.Unitgkey}}">{{x.Cntr}}</option>
                        </select>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <div class="row">
                    <div class="col-md-12" style="text-align:center">
                        <button class="btn btn-primary" ng-click="SubmitTransferLabor()">Transfer</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>