@*strip*@
<div class="modal ZoominAnimate jqueryConfrim" id="cargostripConfrimationLabor" tabindex="-1" data-backdrop="static" data-keyboard="false" role="dialog" aria-labelledby="exampleModalCenterTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document" style="min-width:30%;">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="">
                    <b>{{CurrentCntr}}</b>  Cargo Strip Confirmation!
                </h5>
            </div>
            <div class="modal-body">
                <div class="row">
                    <div class="col-md-6">
                        <label>Container location</label>
                        <input type="text" ng-model="CargoStrip.location" ng-disabled="Cargostuffed.approvalRequired == true" class="form-control" value="" />
                    </div>
                    <div class="col-md-6">
                        <label class="Starick">Strip%</label>
                        <select data-placeholder="Please Select Strip Percentage" class="form-control select-clear" id="StripPerDD" ng-model="CargoStrip.StripPercentage" required data-fouc>
                            <option></option>
                            <option value="0">0</option>
                            <option value="15">15</option>
                            <option value="30">30</option>
                            <option value="50">50</option>
                            <option value="100">100</option>
                        </select>
                    </div>
                </div>
                <div class="row" ng-if="SealCutDetails != undefined && (SealCutDetails.DoorAfterSeal != null || SealCutDetails.CargoFrontView != null)">
                    <div class="col-md-6">
                        <label>Door after seal (SEAL CUT)</label>
                        <div class="imguplaoder" ng-show="SealCutDetails.DoorAfterSeal!=''&& SealCutDetails.DoorAfterSeal!=null">
                            <a style=" text-decoration: none; color: inherit;" href="#" ng-click="OpenImageView(SealCutDetails.DoorAfterSeal,'cargostripConfrimation')">
                                <span><i class="icon-eye"></i></span> View photo
                            </a>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <label>Cargo front view (SEAL CUT)</label>
                        <div class="imguplaoder" ng-show="SealCutDetails.CargoFrontView!=''&& SealCutDetails.CargoFrontView!=null">
                            <a style=" text-decoration: none; color: inherit;" ng-click="OpenImageView(SealCutDetails.CargoFrontView,'cargostripConfrimation')" href="#">
                                <span><i class="icon-eye"></i></span> View photo
                            </a>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <!--V5.8-->
                    <div class="col-md-12">
                        <ul class="Damage_Images">
                            <li ng-repeat="x in CargoStrip.PhotoLibrary">
                                <b>{{x.Label}}<span ng-if="x.required" class="Starick"></span> </b>
                                <div class="Icon" ng-show="x.Url==null || x.Url==''">
                                    <span title="Open Camera" ng-click="OpenCam($index,'CargoStrip')"><i class="icon-camera"></i></span>
                                    <label title="Upload Image" style="margin:0px;">
                                        <span><i class="icon-images2"></i></span>
                                        <input type="file" style="display:none" accept="image/*" id="{{x.Id}}" index="{{$index}}" name="pic" accept="image/*" onchange="angular.element(this).scope().CargoStripLibraryUpload(this)">
                                    </label>
                                </div>
                                <div class="Icon" ng-show="x.Url!=null && x.Url!=''">
                                    <a title="View Image" ng-click="OpenImageView(x.Url,'cargostripConfrimation')"><span><i class="icon-eye"></i></span></a>
                                    <span title="Delete Image" ng-click="RemovePhotoFromStripLibrary($index)"><i class="icon-bin"></i></span>
                                </div>
                            </li>
                        </ul>
                    </div>
                </div>

            </div>

            <div class="modal-footer" style=" padding: 9px;">
                <button class="btn btn-primary" ng-click="Applycargostrip(CargoStrip,'Approve')">End Activity</button>
                <button class="btn btn-reset" data-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>
