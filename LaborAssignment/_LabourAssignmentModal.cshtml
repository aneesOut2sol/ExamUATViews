@*Repack*@
<div class="modal ZoominAnimate jqueryConfrim" id="cargostuffedConfrimationLabor" tabindex="-1" data-backdrop="static" data-keyboard="false" role="dialog" aria-labelledby="exampleModalCenterTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document" style="min-width:30%;">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="">
                    <b>Transfer {}
                </h5>
            </div>
            <div class="modal-body">
                <div class="row">
                    <div class="col-md-6">
                        <label>Container location</label>
                        <input type="text" ng-model="Cargostuffed.location" class="form-control" value="" />
                    </div>
                </div>
                <br />
                <div class="row" ng-show="!stringNullorEmpty(Cargostuffed.Contractor) || Cargostuffed.StuffAction == 'NoRepack'">
                    <div class="col-md-6">
                        <label class="Starick">Cargo</label>
                        <div class="imguplaoderwithCam d-flex">
                            <label class="imguplaoder" for="StuffedCargoImage" ng-show="Cargostuffed.CargoImage==''||Cargostuffed.CargoImage==null">
                                <input style="display:none" type="file" id="StuffedCargoImage" accept="image/*" onchange="angular.element(this).scope().CargostuffedPhoto(this,'StuffedCargoImage','CargoImage')" class="form-control" value="" />
                                <div class="">
                                    Upload photo <span class="pull-right"><i class="icon-file-upload"></i></span>
                                </div>
                            </label>
                            <div class="Camuploader" ng-show="Cargostuffed.CargoImage==''||Cargostuffed.CargoImage==null" ng-click="OpenCam($index,'Cargostuffed-CargoImage')">
                                <span><i class="icon-camera"></i></span>
                            </div>
                        </div>
                        <div class="imguplaoder" ng-show="Cargostuffed.CargoImage!=''&& Cargostuffed.CargoImage!=null">
                            <a style=" text-decoration: none; color: inherit;" href="{{Cargostuffed.CargoImage}}" target="_blank"> <span><i class="icon-eye"></i></span> View photo</a> <span ng-click="Cargostuffed.CargoImage=''" class="pull-right"><i class="icon-bin" ng-if="Cargostuffed.approvalRequired != true"></i></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <label class="Starick">Container number</label>
                        <div class="imguplaoderwithCam d-flex">
                            <label class="imguplaoder" for="CargostuffedContainerNumberImage" ng-show="Cargostuffed.ContainerNumberImage==''||Cargostuffed.ContainerNumberImage==null">
                                <input style="display:none" type="file" id="CargostuffedContainerNumberImage" accept="image/*" onchange="angular.element(this).scope().CargostuffedPhoto(this,'CargostuffedContainerNumberImage','ContainerNumberImage')" class="form-control" value="" />
                                <div class="">
                                    Upload photo <span class="pull-right"><i class="icon-file-upload"></i></span>
                                </div>
                            </label>
                            <div class="Camuploader" ng-show="Cargostuffed.ContainerNumberImage==''||Cargostuffed.ContainerNumberImage==null" ng-click="OpenCam($index,'Cargostuffed-ContainerNumberImage')">
                                <span><i class="icon-camera"></i></span>
                            </div>
                        </div>
                        <div class="imguplaoder" ng-show="Cargostuffed.ContainerNumberImage!=''&& Cargostuffed.ContainerNumberImage!=null">
                            <a style=" text-decoration: none; color: inherit;" href="{{Cargostuffed.ContainerNumberImage}}" target="_blank"> <span><i class="icon-eye"></i></span> View photo</a> <span ng-click="Cargostuffed.ContainerNumberImage=''" class="pull-right"><i class="icon-bin" ng-if="Cargostuffed.approvalRequired != true"></i></span>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-12">
                        <!-- === REPACK CHECKLIST COMPONENT === -->
                        <div class="repack-checklist">
                            <h3>Repack Verification Checklist</h3>

                            <div ng-repeat="item in Cargostuffed.RepackCheckList"
                                 class="repack-item"
                                 ng-class="{ 'required-missing': item.yesnoMandatory && item.selectedAnswer === null }">

                                <div class="repack-question">
                                    <div class="row">
                                        <div class="col-6 p-0">
                                            {{item.question}} <span ng-show="item.yesnoMandatory" style="color:#e67e22; font-weight:bold;"> *</span>
                                        </div>
                                        <div class="col-6 p-0 text-right" dir="rtl">
                                            {{item.arquestion}} <span ng-show="item.yesnoMandatory" style="color:#e67e22; font-weight:bold;"> *</span>
                                        </div>
                                    </div>
                                </div>

                                <div class="repack-radio-group">
                                    <label class="repack-radio">
                                        <input type="radio"
                                               ng-model="item.selectedAnswer"
                                               ng-value="true">
                                        <span>Yes</span>
                                    </label>
                                    <label class="repack-radio">
                                        <input type="radio"
                                               ng-model="item.selectedAnswer"
                                               ng-value="false">
                                        <span>No</span>
                                    </label>
                                </div>

                                <span class="repack-required"
                                      ng-show="item.yesnoMandatory && item.selectedAnswer === null">
                                    This field is required
                                </span>
                            </div>

                            <div class="repack-footer">
                                All mandatory fields must be answered before submission.
                            </div>
                        </div>
                    </div>
                </div>


            </div>
            <div class="modal-footer" style=" padding: 9px; " ng-show="Cargostuffed.approvalRequired != true">
                <button class="btn btn-primary" ng-click="Applycargostuffed(Cargostuffed,'Approve')">End Activity</button>
                <button class="btn btn-reset" data-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>
@*ArrivedLabor*@
<div class="modal fade" id="ArrivedLabor" tabindex="-1" role="dialog" data-backdrop="static" data-keyboard="false" aria-labelledby="exampleModalCenterTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="CloseModalBtn" data-dismiss="modal">
                <button class="close" data-dismiss="modal" aria-label="Close"></button>
                <i class="icon-cross"></i>
            </div>
            <div class="modal-header">
                <h5 class="modal-title">Assigned Labor</h5>
            </div>
            <div class="modal-body" style=" min-height: 120px;overflow:auto !important">
                <div class="row">
                    <div class="col-md-12">
                        <div class="Indicator">
                            <div class="AssignedIndicator">   Assigned Labor : {{ (AssignedLaborList | filter:{ Status: 'Assigned'}).length }}</div>
                            <div class="ArrivedIndicator">   Arrived Labor : {{ (AssignedLaborList | filter:{ Status: 'Arrived'}).length }}</div>
                            <div class="MissingIndicator">   Missing Labor : {{ (AssignedLaborList | filter:{ Status: 'Missing'}).length }}</div>
                            <div class="TransferedIndicator">   Transfered Labor : {{ (AssignedLaborList | filter:{ Status: 'Transfered'}).length }}</div>

                        </div>
                        <div class="LaborCard">
                            <ul>
                                <li ng-class="{'MissingLabor':x.Status=='Missing','Selected':x.Checked==true,'Arrived':x.Status=='Arrived','Transfered':x.Status=='Transfered'}" ng-repeat="x in AssignedLaborList">
                                    <label class="w-100 mb-0" for="labor{{$index+1}}">
                                        <img style=" height: 26px; border-radius: 50%; margin-right: 11px;" src="~/Content/images/profile.jpg" /> {{x.EmpId}}-{{x.EmpName}}
                                        <input ng-show="x.Status=='Assigned'" type="checkbox" id="labor{{$index+1}}" ng-model="x.Checked" ng-disabled="x.Status!='Assigned'" ng-checked="x.IsArrived==true" value="" />
                                    </label>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <div class="row">
                    <div class="col-md-12" style="text-align:center">
                        <button class="btn btn-primary" ng-click="MarkLabor(AssignedLaborList,'Arrived')">Arrived</button>
                        <button class="btn btn-danger" ng-click="MarkLabor(AssignedLaborList,'Missing')">Missing</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
