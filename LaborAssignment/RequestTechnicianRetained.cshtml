


@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!DOCTYPE html>
<style>
    .HistoryTable tr td, .HistoryTable tr th {
        background: white;
        border: 1px solid #bebebe !important;
    }

    .HistoryTable thead {
        position: sticky;
        top: -2px;
    }

    .HistoryTable tr th {
        background: var( --dpw-bg-color) !important;
        color: white !important;
    }

    .modal-body {
        max-height: 70vh !important;
        overflow: auto !important;
    }

    span.badge.badge-Active {
        background: #00946b;
        color: white;
    }

    span.badge.badge-Working {
        background: var( --dpw-bg-color);
        color: white;
    }

    span.badge.badge-InActive {
        background: #cd0202;
        color: white;
    }

    .badge-Blocked {
        background: #c30000;
        color: white;
    }

    .header-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .add-button {
        background-color: var( --dpw-bg-color);
        color: white;
        padding: 8px 16px;
        border: none;
        border-radius: 4px;
    }

    .CloseModalBtn {
        color: #FFFFFF;
        line-height: 25px;
        position: absolute;
        right: -12px;
        z-index: 99999999999 !important;
        text-align: center;
        top: -10px;
        width: 45px;
        text-decoration: none;
        font-weight: bold;
        box-shadow: 1px 1px 3px #000;
        transition: all .3s;
        height: 45px;
        border-radius: 50%;
        font-size: 25px !important;
        padding: 8px;
        cursor: pointer;
        background: var( --dpw-bg-color);
        z-index: 99999999999 !important;
    }

    .close {
        display: none;
    }

    .CloseModalBtn .fa-times-circle-o {
        color: #ffff !important;
    }

    .modal-content {
        background-color: #f4f2fa !important;
        border-radius: 16px !important;
        box-shadow: 0 2.8px 2.2px rgb(0 0 0 / 3%), 0 6.7px 5.3px rgb(0 0 0 / 5%), 0 12.5px 10px rgb(0 0 0 / 6%), 0 22.3px 17.9px rgb(0 0 0 / 7%), 0 41.8px 33.4px rgb(255 255 255 / 9%), 0 100px 80px rgb(255 255 255 / 12%);
    }

    .modal-header {
        text-align: center;
        border-bottom: none !important;
        justify-content: center !important;
    }

    .modal-title {
        font-weight: bolder !important;
        font-size: 24px;
        padding-top: 12px;
        padding-bottom: 4px;
        display: inline-block;
    }

    .modal-footer {
        border-top: none !important;
        align-content: center;
        text-align: center;
    }
</style>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <link href="~/Scripts/DatePicker/bootstrap-datepicker.css" rel="stylesheet" />
    <link href="~/Scripts/DatePicker/bootstrap-datepicker.standalone.css" rel="stylesheet" />
</head>

<body>
    <div class="ng-cloak" ng-cloak ng-controller="LA_RequestTechnicianCtrl" ng-init="init()">
        <div class="card mt-2 d-flex">
            <div class="card-body">
                <div class="header-row">
                    <h2>Forklift setup</h2>
                    <div>
                        <input type="button" class="btn btn-secondary" value="Filters" data-toggle="collapse" data-target="#demo" />
                        <button class="add-button" ng-click="OpenAdd()"><i class="icon-add m-r-5 text-white"></i> Add</button>
                    </div>
                </div>
            </div>
        </div>

        <!--Search Filter Code Start-->
        <div class="card collapse" id="demo">
            <div class="card-body">
                <div class="col-md-12">
                    <div class="row">
                        <div class="col-md-3">
                            <div class="form-group">
                                <label>Name</label>
                                <input type="text" class="form-control" ng-model="Search.Name" placeholder="Enter name" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label>Number</label>
                                <input type="text" class="form-control" ng-model="Search.Number" placeholder="Enter number" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label>IP Address</label>
                                <input type="text" class="form-control" ng-model="Search.IP_Address" placeholder="Enter ip address" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group">
                                <label>IP Address</label>
                                <select class="form-control" ng-model="Search.Status">
                                    <option value="" selected hidden disabled>Select Status</option>
                                    <option value="Active">Active</option>
                                    <option value="InActive">InActive</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-12 mt-4">

                            <button class="btn btn-secondary pull-right mr-2" ng-click="ClearFilter(Search)">Clear</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>




        <div class="row">
            <div id="tblrep" class="card table-card scrollbar">
                <table class="table datatable-show-all text-center" id="table-id">
                    <thead>
                        <tr class="table-card-head">
                            <th>SR#</th>
                            <th>Area</th>
                            <th>Number</th>
                            <th>IP Address</th>
                            <th>Status</th>
                            <th>Created At</th>
                            <th>Created By</th>
                            <th>Updated At</th>
                            <th>Updated By</th>
                            <th>Last Working Location</th>
                            <th>Last User Assign</th>
                            <th>Action</th>

                        </tr>
                    </thead>
                    <tbody class="ng-cloak" ng-cloak>
                        <tr ng-repeat="item in ForkliftList | filter:Search">
                            <td>{{$index+1}}</td>
                            <td>{{item.AreaName}}</td>
                            <td>{{item.Number}}</td>
                            <td>{{item.IP_Address}}</td>
                            <td>
                                <span class="badge badge-{{item.Status}}">{{item.Status}}</span>
                            </td>
                            <td>{{item.CreatedAt | date :'dd/MM/yyyy HH:mm:ss'}}</td>
                            <td>{{item.CreatedBy}}</td>
                            <td>{{(item.UpdatedAt | date :'dd/MM/yyyy HH:mm:ss') || '-'}}</td>
                            <td>{{item.UpdatedBy || '-'}}</td>
                            <td>{{item.LastWork || '-'}}</td>
                            <td>{{item.LastAssignUser || '-'}}</td>
                            <td>
                                <span ng-click="OpenEditForkLift(item)" title="Click to Update">
                                    <i class="icon-pencil"></i>
                                </span>
                                <span ng-show="(_currentUser.UserType.includes('SuperUser') || _currentUser.UserType.includes('Admin'))" title="History" ng-click="OpenForkliftHistory(item)">
                                    <i class="icon-history"></i>
                                </span>
                                <span ng-show="(_currentUser.UserType.includes('SuperUser') || _currentUser.UserType.includes('Admin'))" title="Delete" ng-click="DeleteForklift(item)">
                                    <i class="icon-bin"></i>
                                </span>

                            </td>
                        </tr>

                    </tbody>
                </table>
            </div>

        </div>
   


    </div>
    <!--pagination Code End-->
</body>
</html>
<script src="~/Scripts/jquery.min.js"></script>
<script src="~/Scripts/DatePicker/bootstrap-datepicker.js"></script>
<script src="~/Scripts/js/plugins/moment/moment_locales.min.js"></script>
<script src="~/Scripts/DatePicker/CustomIntilizeJS.js"></script>
