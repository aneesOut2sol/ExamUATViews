                                </div>
                                <div class="form-group mb-0">
                                    <input ng-checked="WTCI==true" ng-model="WTCI" type="checkbox" />
                                    <label>Waiting Time Custom Inspection</label>
                                </div>
                                <div class="form-group mb-0">
                                    <input ng-checked="CRIP==true" ng-model="CRIP" type="checkbox" />
                                    <label>Cargo Repack In Progress</label>
                                </div>
                                <div class="form-group mb-0">
                                    <input ng-checked="CSIP==true" ng-model="CSIP" type="checkbox" />
                                    <label>Cargo Strip In Progress</label>
                                </div>
                                <div class="form-group mb-0">
                                    <input ng-checked="WTAS==true" ng-model="WTAS" type="checkbox" />
                                    <label>Waiting to Apply Seal</label>
                                </div>
                            </div>*@
                        <div class="col-md-12" style="text-align:end">
                            <button class="btn btn-primary" ng-click="SendEmailReport()">Send Email</button>
                            @*<button class="btn btn-primary" ng-show="CurrentCard!='UI (Under Inspection) Details'" ng-click="SendEmailReport()">Send Email</button>
