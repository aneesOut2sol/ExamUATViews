@if (System.Configuration.ConfigurationManager.AppSettings["ManagementOptionDashboard"] == "on")
{

    <div class="ng-cloack DashboardDiv" id="MainDiv" ng-cloak ng-controller="ExamActivityDashboardCtrl" ng-init="ExamActivityDashboard_Init('@System.Configuration.ConfigurationManager.AppSettings["ManagementOptionDashboard_RefreshTime"]')">

        <div class="page-header border-bottom-0">
            <div class="page-header-content header-elements-md-inline" style="padding:0px;">
                <div class="page-title d-flex">
                    <h4> <span class="font-weight-semibold">Examination Building / Mobile Scan</span></h4>

                </div>
                <div class="col-md-6 p-0">

                    <div class="row">
                        <div class="offset-sm-2 col-sm-5 offset-lg-2 col-lg-5 offset-md-2 col-md-5 mb-2" ng-if="Utilization.Exam!=undefined">
                            <div class="utilization">
                                <div class="UHeader">
                                    Total Yard Utilization
                                </div>
                                <div class="Chart"></div>
                                <b>{{Utilization.Yard | number:2}}%</b>
                                <div class="progressp">
                                    <div class="inner" style="width:{{ Utilization.Yard | number:2 }}%"></div>
                                </div>
                            </div>
                        </div>
                        <div class=" col-sm-5  col-lg-5 col-md-5 mb-2" ng-if="Utilization.Exam!=undefined" style=" padding-right:0px;">
                            <div class="utilization">
                                <div class="UHeader">
                                    Exam Yard Utilization
                                </div>
                                <div class="Chart"></div>
                                <b>{{Utilization.Exam | number:2}}%</b>
                                <div class="progressp">
                                    <div class="inner" style="width:{{ Utilization.Exam | number:2 }}%"></div>
                                </div>
                            </div>
                        </div>
                        @*<div class="col-md-4" ng-if="Dashboard_UI_List!=undefined">
                                <div class="utilization">
                                    <div class="UHeader">
                                        UI Yard Utilization
                                    </div>
                                    <div class="Chart"></div>
                                    <b>{{(Dashboard_UI_List.length*100/totalCapacity) | number:2}}%</b>
                                    <div class="progressp">
                                        <div class="inner" style="width:{{(Dashboard_UI_List.length*100/totalCapacity) | number:2}}%"></div>
                                    </div>
                                </div>
                            </div>*@
                    </div>

                </div>
            </div>
        </div>
        <br />
        <div class="row fullMode">
            <div class="col-md-12 p-0">

                <div class="MainBtn">
                    <i class="icon-enlarge pull-right" onclick="Hideheader()"></i>
                    <i class="icon-shrink6 pull-right" onclick="showHeader()"></i>
                </div>
                @if (System.Configuration.ConfigurationManager.AppSettings["SEALOCDashboardIntegeration"] == "1")
                {
                    <div class="MainBtn pull-right" ng-click="OpenMarkContainerModal()">Mark Container for testing</div>
                }
            </div>
        </div>
        <div class="row">
            <div class="col-md-6 col-sm-6 col-lg-6 offset-lg-3" style="padding-right:0px;">
                <div class="DashboardContainersSection">
                    <div class="text-center Cutsom-Table-title">
                        Building / Mobile Scan
                        <div class="pull-right contextMenu"><i class="icon-list2"></i></div>
                        <div class="submain" style=" position: absolute; height: 0px; width: 100%">
                            <div class="Context">
                                <div class="Head">
                                    Reports
                                </div>
                                <ul>
                                    <li ng-click="OpenExcelModal('Building / Mobile Scan')"><i class="icon-file-excel"></i><span class="mr-2">Export to Excel</span></li>
                                    <li ng-click="OpenEmailModal('Building / Mobile Scan')"><i class="icon-paperplane"></i> <span class="mr-2">Send Email Report</span></li>
                                    <li ng-click="PrintReport('Building / Mobile Scan',Dashboard_Exam_List)"><i class="icon-file-pdf"></i><span class="mr-2">Print Report</span></li>
                                </ul>
                            </div>
                        </div>
                    </div>
                    <div class="custom-table-header">
                        <table>
                            <thead>
                                <tr>
                                    <th>Container</th>
                                    <th class="w-35">
                                        <span class="Dsc" ng-click="SortDetailsNew('Exam','Location','Asc',$event)">
                                            Location
                                            <i class="icon-arrow-down22"></i>

                                        </span>
                                        <span class="Asc" style="display:none;" ng-click="SortDetailsNew('Exam','Location','Dsc',$event)">
                                            Location
                                            <i class="icon-arrow-up22"></i>
                                        </span>
                                    </th>
                                    <th class="w-30">
                                        <span class="Dsc" ng-click="SortDetailsNew('Exam','hrs','Asc',$event)">
                                            Elapsed HRS
                                            <i class="icon-arrow-down22"></i>
                                        </span>
                                        <span class="Asc" style="display:none;" ng-click="SortDetailsNew('Exam','hrs','Dsc',$event)">
                                            Elapsed HRS
                                            <i class="icon-arrow-up22"></i>
                                        </span>
                                    </th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr ng-repeat="item in Dashboard_Exam_List" ng-click="OpenContainerEvnets(item.Container)" style="cursor:pointer;">
                                    <td ng-class="{'imprtbg':item.category == 'IMPRT','exprtbg':item.category =='EXPRT'}">
                                        {{item.Container}}

                                    </td>
                                    <td class="text-center" ng-class="{'bgColdStore':item.result == 'Cold Store','bgoog':item.result == 'Others','bgdry':item.result =='Dry','bgReefer':item.result =='Reefer'}">{{item.Location}}</td>
                                    <td class="text-center" ng-class="{'bgdogsniffing':item.RescanType == 'Dog Sniffing','bgmobilescan':item.RescanType == 'MobileScan','bgBuidling':item.RescanType =='BuildingScan'}">{{item.DwellHrs}}</td>
                                </tr>
                            </tbody>
                        </table>

                    </div>
                    <div class="total-container-count-section">
                        <div class="row">
                            <div class="col-md-6 p-0 text-center">
                                <b>Total</b>
                            </div>
                            <div class="col-md-6 p-0 text-center">
                                <b>{{Dashboard_Exam_List.length}}</b>
                            </div>
                        </div>
                    </div>
                    @*<div class="color-highlighter-section">
                            <div class="row p-0">
                                <div class="col-md-6 col-sm-12">

                                </div>
                                <div class="col-md-6 col-sm-12">
                                    <div id="MobileScanFlag" ng-click="FilterDetailDashboard('Exam','MobileScanFlag')">
                                        <i style="color: #ff4565;" class="icon-flag3"></i>Mobile Scan
                                    </div>
                                    <div id="BuildingScanFlag" ng-click="FilterDetailDashboard('Exam','BuildingScanFlag')">
                                        <i style="color: #141eeb; " class="icon-flag3"></i>Building Scan
                                    </div>
                                </div>
                            </div>
                        </div>*@
                    @*<div class="more-detail-section">
                            <p class="text-center" style="visibility:hidden">
                                &nbsp;
                            </p>
                        </div>*@

                </div>
            </div>
        </div>

        <div class="BaseFilter">
            <div class="row">
                <div class="col-md-12 p-0">
                    <div>
                        <input type="checkbox" value="IMPRT" class="imprtbg" /> Import
                    </div>
                    <div>
                        <input type="checkbox" value="EXPRT" class="exprtbg" /> Export
                    </div>
                    <div>
                        <input type="checkbox" class="bgColdStore" value="Cold Store" /> Cold Store
                    </div>
                    <div>
                        <input type="checkbox" class="bgdry" value="Dry" /> Dry
                    </div>
                    <div>
                        <input type="checkbox" class="bgoog" value="OOG" /> OOG
                    </div>
                    @*<div>
                            <input type="checkbox" class="bgReefer" value="Reefer" /> Reefer
                        </div>*@
                    <div>
                        <input type="checkbox" class="bgdogsniffing" value="Dog_sniffing" />K-9
                    </div>
                    <div>
                        <input type="checkbox" class="Reexambg" value="Re_exam" /> Re Exam
                    </div>
                    <div>
                        <input type="checkbox" class="foodbg" value="Food" /> Food
                    </div>
                    <div>
                        <input type="checkbox" class="pallattebg" value="Pallatte" /> Pallet
                    </div>
                    @*<div>
                            <input type="checkbox" class="UTCCSbg" value="UTC COLD Store" /> UTC-CS
                        </div>
                        <div>
                            <input type="checkbox" class="DPWCSbg" value="DPW ColdStore" /> DPW-CS
                        </div>*@
                    <div>
                        <input type="checkbox" class="bgmobilescan" value="MobileScan" /> Mobile Scan
                    </div>
                    <div>
                        <input type="checkbox" class="bgBuidling" value="BuildingScan" /> Building Scan
                    </div>
                </div>
            </div>
