<script>
    $('.date').bootstrapMaterialDatePicker({
        format: 'DD/MM/YYYY HH:mm',
        switchOnClick: true,
        nowButton: true,
    });

    function Hideheader() {
        fullMode = true;
        $(".icon-enlarge").css("display", "none");
        $('.page-title h4').css("color", "white");
        $(".icon-shrink6").css("display", "block");
        $('.MainBtn').css('color', 'white');

        const content = document.getElementById('MainDiv');
        if (content.requestFullscreen) {
            content.requestFullscreen();
        } else if (content.mozRequestFullScreen) { // Firefox
            content.mozRequestFullScreen();
        } else if (content.webkitRequestFullscreen) { // Chrome, Safari, Opera
            content.webkitRequestFullscreen();
        } else if (content.msRequestFullscreen) { // Internet Explorer and Edge
            content.msRequestFullscreen();
        }

    }
    document.addEventListener('fullscreenchange', onFullScreenChange);
    function onFullScreenChange() {
        console.log(document.fullscreenElement);

        if (document.fullscreenElement == null) {
            $(".icon-enlarge").css("display", "block");
            $(".icon-shrink6").css("display", "none");
            $('.page-title h4').css("color", "black");

            $('.MainBtn').css('color', 'black');

        }
    }
    function showHeader() {
        //$('.page-title h4').css("color", "White");
        $(".icon-enlarge").css("display", "block");
        $(".icon-shrink6").css("display", "none");
        $('.MainBtn').css('color', 'black');
        if (document.exitFullscreen) {
            document.exitFullscreen();
        } else if (document.mozCancelFullScreen) {
            document.mozCancelFullScreen();
        } else if (document.webkitExitFullscreen) {
            document.webkitExitFullscreen();
        } else if (document.msExitFullscreen) {
            document.msExitFullscreen();
        }
    }

    window.onload = function () {
        document.getElementById('minisidebar').className = 'sidebar-xs';
    };
    $('.contextMenu').on('click', function () {
        if ($(this).next('.submain').css('display') == 'block') {
            $('.submain').css('display', 'none');
        }
        else {
            $('.submain').css('display', 'none');
            $(this).next('.submain').css('display', 'block');
        }
    })
    $('body').on('click', function (e) {
        console.log(e.target.classList.contains('icon-list2'));
        if (e.target.classList.contains('icon-list2') || e.target.classList.contains('contextMenu')) {
        }
        else {
            $('.submain').css('display', 'none');
        }
    })
</script>