
@{
    ViewBag.Title = "DashboardPrintReport";
    Layout = null;
    int gridIndex = 0;
    int MultipleIndex = 0;
    var UIAwaitingsealcutRecords = new List<ExamPortal.Model.Features.ExamActivityDashboard.ExamActivityDashboard_N4Views>();
    var UIAwaitingInspctionRecords = new List<ExamPortal.Model.Features.ExamActivityDashboard.ExamActivityDashboard_N4Views>();
    var UIAwatingCargoStripRecords = new List<ExamPortal.Model.Features.ExamActivityDashboard.ExamActivityDashboard_N4Views>();
    var UIStartCargoStripRecords = new List<ExamPortal.Model.Features.ExamActivityDashboard.ExamActivityDashboard_N4Views>();
    var UIStartRepackandSealRecords = new List<ExamPortal.Model.Features.ExamActivityDashboard.ExamActivityDashboard_N4Views>();
    var UIRepackandSealRecords = new List<ExamPortal.Model.Features.ExamActivityDashboard.ExamActivityDashboard_N4Views>();
    var UIWaitingtoApplySealRecords = new List<ExamPortal.Model.Features.ExamActivityDashboard.ExamActivityDashboard_N4Views>();
    var FIHolding = new List<ExamPortal.Model.Features.ExamActivityDashboard.ExamActivityDashboard_N4Views>();
    var FIYard = new List<ExamPortal.Model.Features.ExamActivityDashboard.ExamActivityDashboard_N4Views>();
    var TIYardRed = new List<ExamPortal.Model.Features.ExamActivityDashboard.TIYard>();
    var TIYardGreen = new List<ExamPortal.Model.Features.ExamActivityDashboard.TIYard>();
    if (Model.Card == "UI (Under Inspection) Details")
    {
        var Data = Model.li as List<ExamPortal.Model.Features.ExamActivityDashboard.ExamActivityDashboard_N4Views>;

        UIAwaitingsealcutRecords = Data
      .Where(a => a.CustomsStage == "Awaiting sealcut" && a.WaitingtoApplySeal == 0)
      .ToList();

        // Awaiting Inspection / Clearance
        UIAwaitingInspctionRecords = Data
           .Where(a => (a.CustomsStage == "Awaiting Inspction" || a.CustomsStage == "Awaiting Clearance")
                       && a.WaitingtoApplySeal == 0)
           .ToList();

        // Awaiting CargoStrip
        UIAwatingCargoStripRecords = Data
           .Where(a => a.CustomsStage == "Awaiting CargoStrip" && a.WaitingtoApplySeal == 0)
           .ToList();

        // Awaiting Start CargoStrip
        UIStartCargoStripRecords = Data
           .Where(a => a.CustomsStage == "Awaiting Start CargoStrip")
           .ToList();

        // Awaiting Repack and Seal
        UIRepackandSealRecords = Data
           .Where(a => a.CustomsStage == "Awaiting Repack and Seal" && a.WaitingtoApplySeal == 0)
           .ToList();

        // Awaiting Start Repack and Seal
        UIStartRepackandSealRecords = Data
           .Where(a => a.CustomsStage == "Awaiting Start Repack and Seal")
           .ToList();

        // Waiting to Apply Seal
        UIWaitingtoApplySealRecords = Data
           .Where(a => a.WaitingtoApplySeal == 1)
           .ToList();
    }
    if (Model.Card == "TI (To Inspection) Details")
    {
        var Data = Model.TI as List<ExamPortal.Model.Features.ExamActivityDashboard.TIYard>;
        TIYardRed = Data.Where(a => a.lst.Where(x => CheckForStatus(x, "red")).Count() > 0).ToList();
        TIYardGreen = Data.Where(a => a.lst.Where(x => CheckForStatus(x, "green")).Count() > 0).ToList();
    }
    if (Model.Card == "FI (From Inspection) Details")
    {
        var Data = Model.li as List<ExamPortal.Model.Features.ExamActivityDashboard.ExamActivityDashboard_N4Views>;
        FIHolding = Data.Where(x => x.Position == "CI-T2").ToList();
        FIYard = Data.Where(x => x.Position == "CI-T1").ToList();
    }
    @functions {
        public bool CheckForStatus(dynamic item, string status)
        {
            if (status == "green")
            {
                if (item.category != "EXPRT" && item.TotalContainer == item.TotalXrayResultReceived)
                {
                    return true;
                }
                else if (item.category == "EXPRT" && item.InspectionType == "Manual")
                {
                    return true;
                }
                else
                {
                    return false;
                }
            }
            else
            {
                if (item.category != "EXPRT" && item.TotalContainer != item.TotalXrayResultReceived)
                {
                    return true;
                }
                else if (item.category == "EXPRT" && item.InspectionType != "Manual")
                {
                    return true;
                }
                else
                {
                    return false;
                }
            }
        }
    }


}

<style>
    .textGreen {
        color: green;
    }

    .textRed {
        color: red;
    }

    @@import url('https://fonts.googleapis.com/css2?family=Lato:wght@300&display=swap');

    .red-dot {
        background: red;
        height: 10px;
        width: 10px;
        display: inline-block;
        border-radius: 10px;
    }

    .heading-print {
        color: black;
        font-weight: bold;
        margin: 0px;
    }


    * {
        font-family: 'Lato-regular', sans-serif;
        color: black;
    }

    .text-center {
        text-align: center !important;
    }

    table {
        width: 100%;
        box-sizing: border-box;
        border-collapse: collapse;
        margin: 15px 0px;
    }

    th {
        font-weight: bold;
    }

    td, th {
        padding: 10px !important;
        border: 1px solid #191919;
        text-align: center !important;
    }

    .HeaderTr {
        background: #f3f3f3;
    }

    img {
        height: 70px;
        border: none;
    }

    @@media print {
        table {
            width: 100%;
            box-sizing: border-box;
            border-collapse: collapse;
            margin: 15px 0px;
        }
    }

    .statusred {
        width: 20px;
        height: 20px;
        border-radius: 40px;
        background-color: red;
    }

    .statusgreen {
        width: 20px;
        height: 20px;
        border-radius: 40px;
        background-color: green;
    }
    .Planned-dot {
        background: orange;
        border-radius: 50%;
        text-align: center;
        width: fit-content;
        padding: 1px 4px;
        display: inline-block;
    }
</style>

<table>
    <tr class="HeaderTr">
        <td class="text-center">
            <img src="~/Content/images/dpworldlogo.png" />
        </td>
        <td colspan="3">
            <h1 class="text-center heading-print">
                @Model.Card
            </h1>
        </td>
        <td colspan="3">
            <table border="0">
                <tr>
                    <th> Date</th>
                    <td>@DateTime.Now.ToString("dd-MM-yyyy")</td>
                </tr>
                <tr>
                    <th>
                        Time
                    </th>
                    <td>@DateTime.Now.ToString("HH:mm")</td>
                </tr>
            </table>
        </td>
    </tr>
</table>

@if (Model.Multiple != null)
{

    foreach (var x in Model.Multiple)
    {

        <table>

            <tr>
                @if (MultipleIndex == 0)
                {
                    <th colspan="7">TI (To Inspection)</th>
                }
                @if (MultipleIndex == 1)
                {
                    <th colspan="7">UI (Under Inspection)</th>
                }
                @if (MultipleIndex == 2)
                {
                    <th colspan="7">FI (From Inspection)</th>
                }
                @if (MultipleIndex == 3)
                {
                    <th colspan="7">Building / Mobile Scan</th>
                }
            </tr>
            <tr>
                <th>Seq.No</th>
                <th>Container</th>
                <th>Location</th>
                <th>Elapsed Hrs</th>
                @if (MultipleIndex == 1 || MultipleIndex == 2)
                {
                    <th>Overall Hrs</th>
                }

            </tr>
            @foreach (var item in x)
            {
                gridIndex++;
                <tr>
                    <td>@gridIndex</td>
                    <td>@item.Container</td>
                    <td>@item.Location</td>
                    <td>@item.DwellHrs</td>
                    @if (MultipleIndex == 1 || MultipleIndex == 2)
                    {
                        <td>@item.OverallHrs</td>
                    }
                </tr>
            }
            @{gridIndex = 0; }
            @{MultipleIndex++;}
        </table>
    }


}
