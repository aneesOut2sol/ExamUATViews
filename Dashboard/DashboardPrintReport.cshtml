                                @if (item.Temp != null)
                                {
                                    <td>@item.Temp</td>
                                }
                                else
                                {
                                    <td>-</td>
                                }
                                <td>

                                    @if (item.category != "EXPRT")
                                    {
                                        if (item.TotalContainer != item.TotalXrayResultReceived)
                                        {
                                            <div title="Not ready to move" class="statusred"></div>
                                        }
                                        else
                                        {
                                            <div title="Ready to move" class="statusgreen"></div>
                                        }
                                    }
                                    else if (item.category == "EXPRT" && item.InspectionType == "Manual")
                                    {
                                        <div title="Ready to move" class="statusgreen"></div>
                                    }
                                    else if (item.category == "EXPRT" && item.InspectionType != "Manual")
                                    {
                                        <div title="Not ready to move" class="statusred"></div>
                                    }

                                </td>

                            </tr>
                            ChildIndex++;
                        }
                    </tbody>
                }
            }
        </table>
    }
    if (Model.Card == "FI-Holding Area")
    {
        <table>
            <tr>
                <th>Seq.No</th>
                <th>Container</th>
                <th>Location</th>
                <th>Elapsed HRS</th>
                <th>Overall HRS</th>
            </tr>
            @if (Model.li != null && Model.li.Count > 0)
            {
                foreach (var item in Model.li)
                {
                    <tr>
                        <td>@(++Index)</td>
                        <td>@item.Container</td>
                        <td>@item.Location</td>
                        <td>@item.DwellHrs</td>
                        <td>@item.OverallHrs</td>

                    </tr>
                }
            }
        </table>
    }
    if (Model.Card == "FI-Yard")
    {
        <table>
            <tr>
                <th>Seq.No</th>
                <th>Container</th>
                <th>Location</th>
                <th>Elapsed HRS</th>
                <th>Overall HRS</th>
            </tr>
            @if (Model.li != null && Model.li.Count > 0)
            {
                foreach (var item in Model.li)
                {
                    <tr>
                        <td>@(++Index)</td>
                        <td>@item.Container</td>
                        <td>@item.Location</td>
                        <td>@item.DwellHrs</td>
                        <td>@item.OverallHrs</td>

                    </tr>
                }
            }
        </table>
    }
    if (Model.Card == "FI (From Inspection) Details")
    {
        //Yard
        <table>
            <tr>
                <th colspan="5">FI Yard</th>
            </tr>
            <tr>
                <th>Seq.No</th>
                <th>Container</th>
                <th>Location</th>
                <th>Elapsed HRS</th>
                <th>Overall HRS</th>
            </tr>
            @if (FIYard != null && FIYard.Count > 0)
            {
                foreach (var item in FIYard)
                {
                    <tr>
                        <td>@(++Index)</td>
                        <td>@item.Container</td>
                        <td>@item.Location</td>
                        <td>@item.DwellHrs</td>
                        <td>@item.OverallHrs</td>

                    </tr>
                }
            }
        </table>
        //Holding Area
        <table>
            <tr>
                <th colspan="5">FI Holding Area</th>
            </tr>
            <tr>
                <th>Seq.No</th>
                <th>Container</th>
                <th>Location</th>
                <th>Elapsed HRS</th>
                <th>Overall HRS</th>
            </tr>
            @if (FIHolding != null && FIHolding.Count > 0)
            {
                foreach (var item in FIHolding)
                {
                    <tr>
                        <td>@(++Index)</td>
                        <td>@item.Container</td>
                        <td>@item.Location</td>
                        <td>@item.DwellHrs</td>
                        <td>@item.OverallHrs</td>

                    </tr>
                }
            }
        </table>
    }
}

<script>
    window.print();
</script>
