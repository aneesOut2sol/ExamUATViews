                                                <div class="ctx-menu-header">
                                                    <button class="ctx-btn-copy-all" ng-click="copyAll(item.ManualInspCntrList, $event)">
                                                        Copy All to Clipboard
                                                    </button>
                                                </div>
                                                <ul class="ctx-menu-list">
                                                    <li class="ctx-menu-item" ng-repeat="id in item.ManualInspCntrList" ng-click="copySingle(id, $event)">
                                                        <span>{{id}}</span>
                                                        <span class="ctx-menu-badge">Copy</span>
                                                    </li>
                                                </ul>
                                            </div>
                                        </div>
                                    </td>

                                    @*<td class="w-30 text-center Green_Column_13" ng-if="Cindex==0" rowspan="{{x.lst.length}}" ng-class="{'bgdogsniffing':item.InspectionType == 'Dog Sniffing','bgmobilescan':item.InspectionType == 'MobileScan','bgBuidling':item.InspectionType =='BuildingScan'}">{{item.DwellHrs}}</td>*@
                                    <td class="w-30 text-center Green_Column_13" ng-class="{'bgdogsniffing':item.InspectionType == 'Dog Sniffing','bgmobilescan':item.InspectionType == 'MobileScan','bgBuidling':item.InspectionType =='BuildingScan'}">{{item.DwellHrs}}</td>

                                    <td class="w-35  text-center Green_Column_14">
                                        <span ng-if="item.Temp == null || item.Temp == undefined">-</span>
