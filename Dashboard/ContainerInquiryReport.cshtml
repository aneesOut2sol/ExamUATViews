
@{
    ViewBag.Title = "ContainerInquiryReport";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.2.1/css/all.min.css" />

<link href="~/Scripts/AnyChart/anychart-font.min.css" rel="stylesheet" />
<link href="~/Scripts/AnyChart/anychart-ui.min.css" rel="stylesheet" />
<script src="~/Scripts/AnyChart/anychart-base.min.js"></script>
<script src="~/Scripts/AnyChart/anychart-data-adapter.min.js"></script>
<script src="~/Scripts/AnyChart/anychart-exports.min.js"></script>
<script src="~/Scripts/AnyChart/anychart-gantt.min.js"></script>
<script src="~/Scripts/AnyChart/anychart-ui.min.js"></script>
<link href="~/Content/BootsrapDatetime/icon.css" rel="stylesheet" />
<link href="~/Content/BootsrapDatetime/bootstrap-material-datetimepicker.css" rel="stylesheet" />
<link href="~/Content/BootsrapDatetime/css.css" rel="stylesheet" />


<style>
    #container {
        width: 100%;
        height: 500px;
        margin: 0;
        padding: 0;
    }

    .modal-content {
        background-color: #f4f2fa !important;
        border-radius: 16px !important;
        box-shadow: 0 2.8px 2.2px rgb(0 0 0 / 3%), 0 6.7px 5.3px rgb(0 0 0 / 5%), 0 12.5px 10px rgb(0 0 0 / 6%), 0 22.3px 17.9px rgb(0 0 0 / 7%), 0 41.8px 33.4px rgb(255 255 255 / 9%), 0 100px 80px rgb(255 255 255 / 12%);
    }

    .modal-header {
        text-align: center;
        border-bottom: none !important;
        justify-content: center !important;
    }

    .modal-title {
        color: var( --dpw-bg-color);
        font-weight: bolder !important;
        font-size: 24px;
        padding-top: 12px;
        padding-bottom: 4px;
        display: inline-block;
    }

    .CloseModalBtn {
        background: var( --dpw-bg-color) !IMPORTANT;
        color: #FFFFFF;
        line-height: 25px;
        position: absolute;
        right: -12px;
        text-align: center;
        top: -10px;
        width: 45px;
        text-decoration: none;
        font-weight: bold;
        box-shadow: 1px 1px 3px #000;
        transition: all .3s;
        height: 45px;
        border-radius: 50%;
        font-size: 25px !important;
        padding: 8px;
        cursor: pointer;
        z-index: 9999;
    }

    .anychart-credits {
        display: none
    }

    .ss-main .ss-multi-selected .ss-values .ss-value {
        background-color: var( --dpw-bg-color) !important;
    }

    .windowmode tbody tr:nth-child(even) td {
        background: none !important;
    }

    .windowmode tbody tr:nth-child(even) {
        background-color: #f7f7ff !important;
    }

    .windowmode .table td, .table th {
        border: none !important;
    }

    .windowmode .table td, .table tr {
        border: none;
    }

    #FiltersCollapse .card-body {
        background: none !important;
    }

    .windowmode {
        max-height: 300px;
        overflow-y: auto;
        overflow-x: visible !important;
        padding: 0px;
        width: 100%;
    }

    .mobileview {
        height: 450px;
        overflow-y: auto;
        overflow-x: visible !important;
        padding: 0px;
        width: 100%;
        background: #fff !important;
        display: none;
    }

    .mobileviewcontent {
        display: inline-block;
        position: relative;
        top: 10px;
        left: 5px;
        font-family: 'Pilat Wide';
    }

    .mobileview .card {
        margin-bottom: 18px !important;
    }

    .mobileview td {
        font-size: 10px;
        color: #898989
    }

    @@media(min-width: 300px) and (max-width: 790px) {
        .windowmode {
            display: none;
        }

        .mobileview {
            display: block;
        }
    }

</style>


@if (System.Configuration.ConfigurationManager.AppSettings["ManagementOptionDashboard"] == "on")
{

<div class="ng-cloak" ng-cloak ng-controller="ContainerInquiryReportCtrl" ng-init="init()">
    <div class="page-header border-bottom-0">
        <div class="page-header-content header-elements-md-inline">
            <div class="page-title d-flex">
                <h4> <span class="font-weight-semibold">Container Inquiry Report</span></h4>
            </div>
        </div>
    </div>
    <br />
    <div class="row">

        <div class="col-lg-3">
            <div class="form-group">
                <label class="Starick">From Date</label>
                <div class="input-group">
                    <input type="text" class="form-control date" id="FromDate" placeholder="DD/MM/YYYY HH:mm">
                    <span class="input-group-append">
                        <span class="input-group-text"><i class="icon-calendar"></i></span>
                    </span>
                </div>
            </div>
        </div>

        <div class="col-lg-3">
            <div class="form-group">
                <label class="Starick">To Date</label>
                <div class="input-group">
                    <input type="text" class="form-control date" id="ToDate" placeholder="DD/MM/YYYY HH:mm">
                    <span class="input-group-append">
                        <span class="input-group-text"><i class="icon-calendar"></i></span>
                    </span>
                </div>
            </div>
        </div>
        <div class="col-lg-3">
            <div class="form-group">
                <label>Stages</label>
                <select ng-model="Stages" id="StageSelect" data-placeholder="Select Stages" multiple="multiple">
                    <option></option>
                    <option value="Dsch to Xray"></option>
                    <option value="Xray to Grounded">Xray to Grounded</option>
                    <option value="Grounded To SealCut">Grounded to SealCut</option>
                    <option value="SealCut To CargoStrip">SealCut to CargoStrip</option>
                    <option value="CargoStrip To CClearance">CargoStrip to C.Clearance</option>
                    <option value="CClearance To Repack">C.Clearance to Repack </option>
                    <option value="Repack To SealApply">Repack to Sealapply </option>
                    <option value="SealApply To Delivered">Sealapply to Delivered </option>
                </select>
            </div>
        </div>
        <div class="col-md-3 form-group">
            <button class="btn btn-primary mt-4" ng-click="SearchRecords(Stages)"><i class="icon-search4"></i> Search </button>
        </div>
    </div>
    <div class="row">
        <div id="container"></div>
    </div>

    <div class="modal fade bd-example-modal-lg" data-backdrop="static" data-keyboard="false" id="StageWiseModal" tabindex="-1" role="dialog" aria-labelledby="myLargeModalLabel" aria-hidden="true">
        <div class="modal-dialog" style="min-width: 60%;">
            <div class="modal-content">
                <div class="CloseModalBtn" data-dismiss="modal">
                    <button class="close" data-dismiss="modal" aria-label="Close"></button>
                    <i class="icon-cross"></i>
                </div>
                <div class="modal-header">
                    <h5 class="modal-title">{{ModalName}}</h5>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div id="Stages" style="height:300px;width:100%"></div>
                    </div>
                    <div class="row CustomCard collapse" id="Details">

                        <div class="windowmode">
                            <table class="table table-striped">
                                <thead>
                                    <tr class="table-card-head">
                                        <th>Container</th>
                                        <th>Category</th>
                                        <th>Dwell Hrs</th>
                                        <th>Overall Hrs</th>
                                        <th>Inspecton Type</th>
                                        <th style="cursor:pointer;" ng-show="CurrentSort=='Dsc'||CurrentSort==null" ng-click="SortDurtaion('Asc',$event)">Duration <i class="icon-chevron-down"></i></th>
                                        <th style="cursor:pointer;" ng-show="CurrentSort=='Asc'" ng-click="SortDurtaion('Dsc',$event)">Duration <i class="icon-chevron-up"></i></th>

                                    </tr>
                                </thead>
                                <tbody>
                                    <tr ng-repeat="item in Containerlist_3rdlayer">
                                        <td>{{item.id}}</td>
                                        <td>IMPRT</td>
                                        <td>{{item.DwellHrs}}</td>
                                        <td>{{item.OverallHrs}}</td>
                                        <td>{{item.inspectionType}}</td>
                                        <td>{{item.Duration}}</td>
                                    </tr>
                                </tbody>
                            </table>


                        </div>

                        <div class="mobileview">

                            <div class="card shadow m-0" ng-repeat="x in Containerlist_3rdlayer" style="overflow:visible">
                                <table width="100%">
                                    <thead class="shadow">
                                        <tr>
                                            <th style="padding: 5px 18px; color: var( --dpw-bg-color) " colspan="3">{{x.id}}</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td style="text-align:center">
                                                <img style="height:30px;" src="~/Content/images/output-onlinepngtools.png" />
                                            </td>
                                            <td>
                                                <table width="100%">
                                                    <tr>
                                                        <td>Category : </td>
                                                        <td>IMPRT</td>
                                                    </tr>
                                                    <tr>
                                                        <td>Dwell Hrs : </td>
                                                        <td>{{x.DwellHrs}}</td>
                                                    </tr>
                                                    <tr>
                                                        <td>Overal lHrs : </td>
                                                        <td>{{x.OverallHrs}}</td>
                                                    </tr>
                                                    <tr>
                                                        <td>Inspecton Type : </td>
                                                        <td>{{x.inspectionType}}</td>
                                                    </tr>
                                                    <tr>
                                                        <td>{{SLAColumn}} : </td>
                                                        <td>{{x.Duration}}</td>
                                                    </tr>

                                                </table>
                                            </td>
                                        </tr>

                                    </tbody>
                                </table>
                            </div>

                        </div>

                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

}
<script src="~/Scripts/jquery.min.js"></script>
<script src="~/Scripts/js/plugins/moment/moment_locales.min.js"></script>
<script src="~/Content/BootsrapDatetime/ripples.min.js"></script>
<script src="~/Content/BootsrapDatetime/material.min.js"></script>
<script src="~/Content/BootsrapDatetime/bootstrap-material-datetimepicker.js"></script>

<script>
    $(document).ready(function () {
        var t = new SlimSelect({
            select: '#StageSelect',
            placeholder: 'Select Stages',
        });

    })

    //DAte Time
    $('.date').bootstrapMaterialDatePicker({
        format: 'DD/MM/YYYY HH:mm',
        //maxDate: maxdate,
        //  endDate: moment(new Date()).format('DD/MM/YYYY HH:mm'),
        switchOnClick: true,
        nowButton: true,
        //currentDate: moment(),
    });
    window.onload = function () {
        document.getElementById('minisidebar').className = 'sidebar-xs';
    };
</script>
