                        <div class="col-md-6">
                            <h6 class="text-center"><b>Total</b></h6>
                        </div>
                        <div class="col-md-6">
                            <h6 class="text-center"><b>{{Dashboard_Exam_List.length}}</b></h6>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <div class="row p-0">
        <div class="col-md-12 col-sm-12 filterationSection">
            <div class="filterDiv d-inline-block"><input type="checkbox" class="ch-coldstore" id="ch-coldstore" checked value="Cold Store" ng-click="FilterOperationView('CI','ch-coldstore')" /> Cold Store </div>
            <div class="filterDiv d-inline-block"><input type="checkbox" class="ch-dry" id="ch-dry" checked value="Dry" ng-click="FilterOperationView('CI','ch-dry')" /> Dry </div>
            <div class="filterDiv d-inline-block"><input type="checkbox" class="ch-oog" id="ch-oog" checked value="OOG" ng-click="FilterOperationView('CI','ch-oog')" /> OOG </div>
            <div class="filterDiv d-inline-block"><input type="checkbox" class="ch-reefer" id="ch-reefer" checked value="Reefer" ng-click="FilterOperationView('CI','ch-reefer')" /> Reefer </div>

            <div id="DogSniffingFlag" class="d-inline-block" ng-click="FilterOperationView('CI','DogSniffingFlag')">
                <i style="color: #141eeb;" class="icon-flag3"></i>Dog Sniffing
            </div>
            <div id="PalletteFlag" class="d-inline-block" ng-click="FilterOperationView('CI','PalletteFlag')">
                <i style="color: #ff8d00; " class="icon-flag3"></i>Pallette
            </div>
            <div id="UTCFlag" class="d-inline-block" ng-click="FilterOperationView('CI','UTCFlag')">
                <i style="color: #ff00df9e; " class="icon-flag3"></i>UTC -CS
            </div>
            <div id="FoodFlag" class="d-inline-block" ng-click="FilterOperationView('CI','FoodFlag')">
                <i style="color: #754343; " class="icon-flag3"></i>Food
            </div>
            <div id="MobileScanFlag" class="d-inline-block"  ng-click="FilterOperationView('Exam','MobileScanFlag')">
                <i style="color: #ff4565;" class="icon-flag3"></i>Mobile Scan
            </div>
            <div id="BuildingScanFlag" class="d-inline-block"  ng-click="FilterOperationView('Exam','BuildingScanFlag')">
                <i style="color: #141eeb; " class="icon-flag3"></i>Building Scan
            </div>
        </div>
    </div>

    




</div>
