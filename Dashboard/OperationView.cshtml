                                    <i class="icon-arrow-up22" ng-show="FI_Location_Sort =='+'"></i>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr ng-repeat="item in FIT1Records">

                                <td class="w-35" ng-class="{'coldstorebg':item.result == 'Cold Store','drybg':item.result =='Dry','oogbg':item.is_oog ==true,'reeferbg':item.result =='Reefer'}">
                                    {{item.Container}}
                                </td>
                                <td class="w-30 text-center">{{item.DwellHrs}}</td>
                                <td class="w-35">{{item.Location}}</td>
                                @*<td>
                                    <i style="color: #ff4565; " ng-if="item.ReExamFlag ==1" class="icon-flag3"></i>
                                    <i style="color: #141eeb; " ng-if="item.InspectionType =='Dog Sniffing'" class="icon-flag3"></i>
                                    <i style="color: #ff8d00; " ng-if="item.packageType =='Pallette'" class="icon-flag3"></i>
                                    <i style="color: #ff00df9e; " ng-if="item.YardLoc =='UTC COldStore'" class="icon-flag3"></i>
                                    <i style="color: #0f655c; " ng-if="item.YardLoc =='DPW ColdStore'" class="icon-flag3"></i>
                                    <i style="color: #754343; " ng-if="item.FoodFlag ==1" class="icon-flag3"></i>
                                </td>*@
                            </tr>
                        </tbody>
                    </table>
                </div>
                <div class="total-container-count-section">
                    <div class="row">
                        <div class="col-md-6">
                            <h6 class="text-center"><b>Total</b></h6>
                        </div>
                        <div class="col-md-6">
                            <h6 class="text-center"><b>{{FIT1Length}}</b></h6>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-2 col-md-2">
            <div class="DashboardContainersSection">
                <div class="text-center">
                    <h5 class="DPWBold">FI-Holding Area</h5>
                </div>
                <div class="custom-table-header">
                    <table>
                        <thead>
                            <tr>
                                <th class="w-35">Container</th>
                                <th class="w-30" ng-click="SortDetails('FI','hrs','FI-T2')">
                                    HRS
                                    <i class="icon-arrow-down22" ng-show="FI_Hrs_Sort =='-'"></i>
                                    <i class="icon-arrow-up22" ng-show="FI_Hrs_Sort =='+'"></i>
                                </th>
                                <th class="w-35" ng-click="SortDetails('FI','Location','FI-T2')">
                                    Location
                                    <i class="icon-arrow-down22" ng-show="FI_Location_Sort =='-'"></i>
                                    <i class="icon-arrow-up22" ng-show="FI_Location_Sort =='+'"></i>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr ng-repeat="item in FIT2Records">

                                <td class="w-35" ng-class="{'coldstorebg':item.result == 'Cold Store','drybg':item.result =='Dry','oogbg':item.is_oog ==true,'reeferbg':item.result =='Reefer'}">
                                    {{item.Container}}
                                </td>
                                <td class="w-30" text-center>{{item.DwellHrs}}</td>
                                <td class="w-35">{{item.Location}}</td>
