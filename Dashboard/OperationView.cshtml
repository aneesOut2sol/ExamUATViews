        <div class="col-lg-2 col-md-2">
            <div class="DashboardContainersSection">
                <div class="text-center">
                    <h5 class="DPWBold">Building / Mobile Scan</h5>
                </div>
                <div class="custom-table-header">
                    <table>
                        <thead>
                            <tr>
                                <th>Container</th>
                                <th class="w-30" ng-click="SortDetails('Exam','hrs')">
                                    HRS
                                    <i class="icon-arrow-down22" ng-show="Exam_Hrs_Sort =='-'"></i>
                                    <i class="icon-arrow-up22" ng-show="Exam_Hrs_Sort =='+'"></i>
                                </th>
                                <th class="w-35" ng-click="SortDetails('Exam','Location')">
                                    Location
                                    <i class="icon-arrow-down22" ng-show="Exam_Location_Sort =='-'"></i>
                                    <i class="icon-arrow-up22" ng-show="Exam_Location_Sort =='+'"></i>
                                </th>                              
                            </tr>
                        </thead>
                        <tbody>
                            <tr ng-repeat="item in Dashboard_Exam_List">
                                <td>
                                    {{item.Container}}
                                </td>
                                <td class="text-center">{{item.DwellHrs}}</td>
                                <td class="text-center">{{item.Location}}</td>
                                @*<td>
                                    <i style="color: #ff4565; " ng-if="item.RescanType =='MobileScan'" class="icon-flag3"></i>
                                    <i style="color: #141eeb; " ng-if="item.RescanType =='BuildingScan'" class="icon-flag3"></i>
                                </td>*@
                            </tr>
                        </tbody>
                    </table>
                </div>
                <div class="total-container-count-section">
