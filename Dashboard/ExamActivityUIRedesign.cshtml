                            <i class="icon-more2 cursor-pointer text-muted font-size-lg" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false" style="padding:5px;"></i>
                            <div class="dropdown-menu dropdown-menu-right shadow border-0" style="border-radius: 8px;">
                                <a class="dropdown-item py-2 text-success font-weight-bold" href="#" ng-click="OpenExcelModal('Waiting to Apply Seal')"><i class="icon-file-excel mr-2"></i> Export to Excel</a>
                                <a class="dropdown-item py-2 text-primary font-weight-bold" href="#" ng-click="OpenEmailModal('Waiting to Apply Seal')"><i class="icon-paperplane mr-2"></i> Send Email Report</a>
                                <a class="dropdown-item py-2 text-danger font-weight-bold" href="#" ng-click="PrintReport('Waiting to Apply Seal',UIWaitingtoApplySealRecords)"><i class="icon-file-pdf mr-2"></i> Print Report</a>
                            </div>
                        </div>
                    </div>
                    <div class="modern-panel-body">
                        <table class="modern-table">
                            <thead>
                                <tr>
                                    <th class="w-30">Container</th>
                                    <th class="w-30">Bayan</th>
                                    <th class="w-35">
                                        <span class="Dsc" ng-click="SortDetailsNewDetailsPage('UI','Location','Asc',$event,'UIWaitingtoApplySealRecords')">
                                            Location
                                            <i class="icon-arrow-down22"></i>

                                        </span>
                                        <span class="Asc" style="display:none;" ng-click="SortDetailsNewDetailsPage('UI','Location','Dsc',$event,'UIWaitingtoApplySealRecords')">
                                            Location
                                            <i class="icon-arrow-up22"></i>
                                        </span>
                                    </th>
                                    <th class="w-35">
                                        <span class="Dsc" ng-click="SortDetailsNewDetailsPage('UI','hrs','Asc',$event,'UIWaitingtoApplySealRecords')">
                                            Stage   Elapsed HRS
                                            <i class="icon-arrow-down22"></i>

                                        </span>
                                        <span class="Asc" style="display:none;" ng-click="SortDetailsNewDetailsPage('UI','hrs','Dsc',$event,'UIWaitingtoApplySealRecords')">
                                            Stage   Elapsed HRS
                                            <i class="icon-arrow-up22"></i>
                                        </span>
                                    </th>
                                    <th class="w-35">
                                        <span class="Dsc" ng-click="SortDetailsNewDetailsPage('UI','OverAll','Asc',$event,'UIWaitingtoApplySealRecords')">
                                            Overall HRS
                                            <i class="icon-arrow-down22"></i>

                                        </span>
                                        <span class="Asc" style="display:none;" ng-click="SortDetailsNewDetailsPage('UI','OverAll','Dsc',$event,'UIWaitingtoApplySealRecords')">
                                            Overall HRS
                                            <i class="icon-arrow-up22"></i>
                                        </span>
                                    </th>
                                    @if (showPkgHs)
                                    {
                                        <th>
                                            <span class="Dsc" ng-click="SortDetailsNewDetailsPage('UI','Palletized','Asc',$event,'UIWaitingtoApplySealRecords')">
                                                Palletized
                                                <i class="icon-arrow-down22"></i>

                                            </span>
                                            <span class="Asc" style="display:none;" ng-click="SortDetailsNewDetailsPage('UI','Palletized','Dsc',$event,'UIWaitingtoApplySealRecords')">
                                                Palletized
                                                <i class="icon-arrow-up22"></i>
                                            </span>
                                        </th>
                                        <th>Cargo Type</th>
                                    }
                                    <th>
                                        <span>
                                            @*LOC Sent*@
                                            Repack done notified
                                        </span>
                                    </th>

                                </tr>
                            </thead>
                            <tbody>
                                <tr ng-repeat="item in UIWaitingtoApplySealRecords" ng-click="OpenContainerEvnets(item.Container)" style="cursor:pointer;">

                                    <td class="w-35" ng-class="{
                                            'imprtbg': item.category === 'IMPRT' && !item.IsTransitContainer,
                                            'exprtbg': item.category === 'EXPRT' && !item.IsTransitContainer,
                                            'imprtbgTransit': item.category === 'IMPRT' && item.IsTransitContainer,
                                            'exprtbgTransit': item.category === 'EXPRT' && item.IsTransitContainer
                                        }">
                                        <div class="truncate tw-100px">{{item.Container}}</div>
                                    </td>
                                    <td ng-class="{'bgColdStore':item.result == 'Cold Store','bgoog':item.result == 'Others','bgdry':item.result =='Dry','bgReefer':item.result =='Reefer'}"> <div class="truncate">{{item.Bayan}}</div></td>
                                    <td class="w-35" ng-class="{'bgdogsniffing':item.InspectionType == 'Dog Sniffing','bgmobilescan':item.InspectionType == 'MobileScan','bgBuidling':item.InspectionType =='BuildingScan'}">
                                        <div class="truncate">{{item.Location}}</div>
                                    </td>
                                    <td class="w-30">
                                        <div ng-class="{'ColorRed':item.SLAExceding==true}" class="truncate">{{item.DwellHrs}}</div>
                                    </td>
                                    <td class="w-30">
                                        <div class="truncate"> <span ng-class="{'HighlightOverallHrs':HighlightOverAllHrs(item.OverallHrs)}">{{item.OverallHrs}}</span></div>
                                    </td>
                                    @if (showPkgHs)
                                    {
                                        <td>
                                            <span ng-show="item.packageType=='Pallette'" class="textGreen">Yes</span>
                                            <span ng-show="item.packageType=='NONPallette'" class="textRed">No</span>
                                        </td>
                                        <td>
                                            {{item.CargoType}}
                                        </td>
                                    }
                                    <td class="w-30">
                                        <div class="" ng-if="item.LOCSent && item.category =='IMPRT'">{{item.LOCTime | date:'dd/MM/yyyy HH:mm'}}</div>
                                        <div ng-if="!item.LOCSent && item.category =='IMPRT'">
                                            <span ng-if="item.FailedCount>0" class="text-danger">
                                                Failed({{item.FailedCount}})
                                                <i class="icon-info22" ng-if="item.FailureReason != null" title="{{item.FailureReason}}"></i>
                                            </span>
                                        </div>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    <div class="modern-panel-footer">
                        <div class="row">
                            <div class="col-md-6 col-6">
                                <h6 class="text-center"><b>Total</b></h6>
                            </div>
                            <div class="col-md-6 col-6">
                                <h6 class="text-center"><b>{{UIWaitingtoApplySealRecords.length}}</b></h6>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>

        <div class="BaseFilter">
            <div class="row">
                <div class="col-md-12 p-0">
                    <div>
                        <input type="checkbox" value="IMPRT" class="imprtbg" /> Import
                    </div>
                    <div>
                        <input type="checkbox" value="EXPRT" class="exprtbg" /> Export
                    </div>
                    <div>
                        <input type="checkbox" class="imprtbgTransit" value="IMPRT_Transit" /> Import Transit
                    </div>
                    <div>
                        <input type="checkbox" class="exprtbgTransit" value="EXPRT_Transit" /> Export Transit
                    </div>
                    <div>
                        <input type="checkbox" value="TRSHP" class="trshpbg" /> TRSHP
                    </div>
                    <div>
                        <input type="checkbox" class="bgColdStore" value="Cold Store" /> Cold Store
                    </div>
                    <div>
                        <input type="checkbox" class="bgdry" value="Dry" /> Dry
                    </div>
                    <div>
                        <input type="checkbox" class="bgoog" value="OOG" /> OOG
                    </div>
                    @*<div>
                            <input type="checkbox" class="bgReefer" value="Reefer" /> Reefer
                        </div>*@
                    <div>
                        <input type="checkbox" class="bgdogsniffing" value="Dog_sniffing" /> K-9
                    </div>
                    <div>
                        <input type="checkbox" class="Reexambg" value="Re_exam" /> Re Exam
                    </div>
                    <div>
                        <input type="checkbox" class="foodbg" value="Food" /> Food
                    </div>
                    <div>
                        <input type="checkbox" class="Forkliftbg" value="Forklift" /> Forklift
                    </div>
                    <div>
                        <input type="checkbox" class="Laborbg" value="Labor" /> Labour
                    </div>
                    <div>
                        <input type="checkbox" class="Mobilecranebg" value="Mobilecrane" />Mobile crane
                    </div>
                    <div>
                        <input type="checkbox" class="Nostripbg" value="Nostrip" />No strip
                    </div>
                    @*<div>
                            <input type="checkbox" class="UTCCSbg" value="UTC COLD Store" /> UTC-CS
                        </div>
                        <div>
                            <input type="checkbox" class="DPWCSbg" value="DPW ColdStore" /> DPW-CS
                        </div>*@
                    @*<div>
                            <input type="checkbox" class="bgmobilescan" value="MobileScan" /> Mobile Scan
                        </div>
                        <div>
                            <input type="checkbox" class="bgBuidling" value="BuildingScan" /> Building Scan
                        </div>*@
                    <div>
                        <input type="checkbox" class="ExceddingSLA" value="ExceedingSLA" /> Exceeding SLA
                    </div>

                    <div>
                        <input type="checkbox" class="bgDifficulties" value="Difficulties" /> DTS
                    </div>
                    <div>
                        <input type="checkbox" class="pallattebg" value="Pallatte" /> Pallet
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<script>
    var ssInstances = [];
    $(document).ready(function () {
        if ($('#FCargoType').length > 0) {
            ssInstances.push(new SlimSelect({
                select: '#FCargoType',
                placeholder: 'Select Cargo type',
                showSearch: true,
                allowDeselect: true,
            }));
        }
    });

    window.onload = function () {
        document.getElementById('minisidebar').className = 'sidebar-xs';
    };

    $('.date').bootstrapMaterialDatePicker({
        format: 'DD/MM/YYYY HH:mm',
        switchOnClick: false,
        nowButton: true,
    });

    function Hideheader() {
        $('.page-title').css('color', 'white');
        $("#btnFullscreen").addClass("d-none");
        $("#btnExitFullscreen").removeClass("d-none");

        const content = document.getElementById('MainDiv');
        if (content.requestFullscreen) content.requestFullscreen();
        else if (content.mozRequestFullScreen) content.mozRequestFullScreen();
        else if (content.webkitRequestFullscreen) content.webkitRequestFullscreen();
        else if (content.msRequestFullscreen) content.msRequestFullscreen();
    }

    document.addEventListener('fullscreenchange', function () {
        if (!document.fullscreenElement) {
            $('.page-title').css('color', '');
            $("#btnFullscreen").removeClass("d-none");
            $("#btnExitFullscreen").addClass("d-none");
        }
    });

    function showHeader() {
        $('.page-title').css('color', '');
        $("#btnFullscreen").removeClass("d-none");
        $("#btnExitFullscreen").addClass("d-none");

        if (document.exitFullscreen) document.exitFullscreen();
        else if (document.mozCancelFullScreen) document.mozCancelFullScreen();
        else if (document.webkitExitFullscreen) document.webkitExitFullscreen();
        else if (document.msExitFullscreen) document.msExitFullscreen();
    }
</script>
