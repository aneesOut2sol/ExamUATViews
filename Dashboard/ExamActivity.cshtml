
@{
    ViewBag.Title = "ExamActivity";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    .border-right {
        border-right: 1px solid black;
    }

    .DashboardDiv {
        font-family: 'Pilat Wide';
    }

    .DashboardContainersSection {
        border-radius: 11px;
        margin-top: 25px;
        box-shadow: 5px 12px 25px 0px rgba(0,0,0,0.1);
    }

        .DashboardContainersSection h5 {
            margin: 0;
            font-weight: 600;
        }

    .custom-table-header .icon-flag3 {
        font-size: 10px;
    }

    .custom-table-header {
        overflow-y: auto;
        overflow-x: hidden;
        height: 50vh;
        border-radius: 0px;
        box-shadow: 0px 10px 15px -3px rgba(0,0,0,0.1);
        padding: 8px;
        background: white;
        border-bottom: 0px;
        overflow: hidden;
    }

    .DashboardContainersSection:hover .custom-table-header {
        overflow: auto;
    }

    .Cutsom-Table-title {
        background: white;
        font-size: 17px !IMPORTANT;
        border-top-right-radius: 10px;
        border-top-left-radius: 10px;
        border-bottom: 1px solid #efefef94;
        padding: 6px;
    }

    table {
        width: 100%;
    }

    .custom-table-header thead {
        position: sticky;
        top: -8px;
        background: #ffffff;
        height: 40px;
        font-size: 10px;
        color: #8d8d8d;
        box-shadow: none;
        border-radius: 72px;
        color: black;
        border-bottom: 2px solid #00000021;
    }

        .custom-table-header thead th {
            text-align: center !important
        }



    .coldstorebg {
        background-color: #8b86d6 !important
    }

    .drybg {
        background-color: #c9c9c9 !important
    }

    .oogbg {
        background-color: #ff4565 !important;
        accent-color: #ff4565;
    }

    .reeferbg {
        background-color: #fbca34 !important;
        accent-color: #fbca34;
    }

    .imprtbg {
        background-color: #37ce8d !important;
        accent-color: #37ce8d;
    }

    .exprtbg {
        background-color: #ffc421 !important;
        accent-color: #ffc421;
    }

    .imprtbgTransit {
        background-color: #c0f5de !important;
        accent-color: #c0f5de;
    }

    .exprtbgTransit {
        background-color: #f3d78b !important;
        accent-color: #f3d78b;
    }

    .color-highlighter {
        width: 10px;
        height: 10px;
        border-radius: 30px;
        display: inline-block;
        margin-right: 2px;
    }

    .ch-coldstore {
        /*background-color: #8b86d6;*/
        accent-color: #8b86d6 !important
    }

    .ch-dry {
        accent-color: #e4e4e4 !important
    }

    .ch-oog {
        accent-color: #ff4565 !important
    }

    .ch-reefer {
        accent-color: #fbca34 !important
    }

    .ch-export {
        accent-color: #ffc421 !important
    }

    .ch-import {
        accent-color: #37ce8d !important
    }

    td {
        font-size: 10px;
        border-bottom: 1px solid #00000021;
        /*white-space:nowrap;*/
    }

    table tr td, th {
        background: #fff;
        padding: 4px 2px;
        width: fit-content;
    }

    .color-highlighter-section {
        font-size: 10px;
        height: 100px;
        font-weight: 800;
        overflow: auto
    }

    .total-container-count-section {
        background: #fefefec7;
        border: none;
        border-radius: -1px;
        border-bottom-right-radius: 12px;
        border-bottom-left-radius: 12px;
        padding: 10px;
    }

    .more-detail-section p {
        background: #fff;
        padding: 8px 18px;
        margin-top: 8px !important;
        border-radius: 6px;
        box-shadow: inset -1px -2px 5px 0px #999;
        width: fit-content;
        margin: auto;
        font-weight: 500;
        cursor: pointer;
    }

        .more-detail-section p:hover {
            box-shadow: 3px 0px 5px 0px #999;
        }

    .strikethrough {
        text-decoration: line-through;
        opacity: 0.5;
    }

    .yardcol {
        border: 1px solid #b2b2b2 !important;
        width: 25px;
        height: 25px;
    }

    .modal-dialog {
        min-width: 50%;
    }

    .yardblock {
        border: none;
        padding: 0;
        text-align: center;
        width: 25px;
    }

    .ExamView .DashboardContainersSection {
        display: block !important;
        margin: auto;
    }

    .tab {
        overflow: hidden;
    }

    .tabheading {
        padding: 10px;
        background: #00946b;
        color: white;
    }

    .tab button {
        border-top-right-radius: 10px;
        border-top-left-radius: 10px;
        background: #e9e9e9;
        padding: 15px;
        border: none;
        outline: none;
        cursor: pointer;
        transition: 0.3s;
        font-size: 13px;
    }

        .tab button:hover {
            background-color: #00946b;
            color: white;
            font-size: 13px;
        }

        .tab button.active {
            background-color: #00946b;
            color: white;
            font-size: 13px;
        }

    .tab button {
        width: 100%;
    }

    .tabcontent {
        display: none;
        padding: 0px 10px;
        border-top: none;
    }

    .BaseFilter {
        text-align: center;
        background: white;
        border-radius: 12px;
        box-shadow: 0px 0px 4px 1px inset #8080801f;
        margin-top: 16px;
        border: 1px solid #80808036;
    }

        .BaseFilter div {
            display: inline-block;
            margin-right: 14px;
            font-weight: 600;
            font-size: 10px !IMPORTANT;
            margin: 7px;
        }

        .BaseFilter input[type="checkbox"] {
            vertical-align: text-bottom;
            transform: scale(1.5);
            margin-right: 5px;
        }

            .BaseFilter input[type="checkbox"]:not(:checked) {
                appearance: none;
                height: 12px;
                width: 12px;
                border: 1px solid #00000026;
                border-radius: 18px;
                margin-right: 4px;
                vertical-align: top;
            }

    .custom-table-header::-webkit-scrollbar-track {
        display: none !important;
    }

    .custom-table-header::-webkit-scrollbar {
        width: 4px;
        height: 4px;
    }

    .custom-table-header::-webkit-scrollbar-thumb {
        border-radius: 8px;
        background-color: #aeaeae !important
    }

    .utilization {
        background: white;
        padding: 18px;
        border-radius: 11px;
        box-shadow: 5px 12px 25px 0px rgba(0,0,0,0.1);
    }

    .UHeader {
        font-size: 11px;
    }

    .progressp {
        height: 4px;
        width: 100%;
        background: #c9c9c9;
        margin-top: 8px;
        border-radius: 13px;
        overflow: hidden;
    }

    .inner {
        background: #3dc73d;
        height: 4px;
        border-radius: 27px;
    }

    .bgColdStore {
        background: #cbfece !important;
        accent-color: #cbfece !important;
    }

    .bgReefer {
        background: #ffd9d0 !important;
        accent-color: #ffd9d0 !important;
    }

    .bgdry {
        background: #d8d5ff !important;
        accent-color: #d8d5ff !important;
    }

    .bgdogsniffing {
        background: #ececec !important;
        accent-color: #ececec !important;
    }

    .bgmobilescan {
        background: #f3dafd !important;
        accent-color: #f3dafd !important;
    }

    .bgBuidling {
        background: #ebffd4 !important;
        accent-color: #ebffd4 !important;
    }

    .bgoog {
        background: #f6ffb9 !important;
        accent-color: #f6ffb9 !important;
    }

    .imprtbg {
        background-color: #37ce8d !important;
        accent-color: #37ce8d;
    }

    .exprtbg {
        background-color: #ffc421 !important;
        accent-color: #ffc421;
    }

    .Reexambg {
        accent-color: #acf5ffeb;
        background: #c8f5fbeb;
    }

    .ExcelReport {
        color: #28b176;
    }

    .foodbg {
        background: #c2ffa2;
        accent-color: #c2ffa2;
    }

    .UTCCSbg {
        background: #ffe4b1;
        accent-color: #ffe4b1;
    }

    .pallattebg {
        background: #c0c7fe;
        accent-color: #c0c7fe;
    }

    .DPWCSbg {
        background: #e7c5b9;
        accent-color: #e7c5b9;
    }

    .submain {
        position: absolute;
        height: 0px;
        width: 21.6%;
        display: none;
    }

    .contextMenu {
        cursor: pointer;
    }

    .submain .Context {
        position: relative;
        background: #ffffff;
        z-index: 999;
        font-size: 12px;
        width: fit-content;
        box-shadow: 13px 13px 30px -1px rgba(0,0,0,0.23);
        border-radius: 3px;
        right: 27px;
        float: right;
        border: 1px solid #dcdcdc;
    }

        .submain .Context ul {
            margin: 0px;
            padding: 0px;
        }

            .submain .Context ul li {
                list-style: none;
                padding: 9px 12px;
                text-align: left;
                border-bottom: 1px solid #cdcdcd59;
                cursor: pointer;
            }

    .submain .Head {
        border-bottom: 1px solid #a8a8a8;
        padding: 7px;
        font-weight: 600;
        text-align: left;
        background: #80808021;
    }

    .Context i {
        color: #464646 !important;
        font-size: 12px;
        margin-right: 7px;
    }

    .submain .Context ul li:hover {
        background: #efefef;
    }

    .MainBtn {
        margin-right: 18px;
        text-decoration: underline;
        cursor: pointer;
    }

    .icon-enlarge {
        font-size: 18px;
        cursor: pointer;
    }

    .icon-shrink6 {
        display: none;
        font-size: 18px;
        cursor: pointer;
        color: white !important;
    }

    .modal-content {
        background-color: #f4f2fa !important;
        border-radius: 16px !important;
        box-shadow: 0 2.8px 2.2px rgb(0 0 0 / 3%), 0 6.7px 5.3px rgb(0 0 0 / 5%), 0 12.5px 10px rgb(0 0 0 / 6%), 0 22.3px 17.9px rgb(0 0 0 / 7%), 0 41.8px 33.4px rgb(255 255 255 / 9%), 0 100px 80px rgb(255 255 255 / 12%);
    }

    .modal-header {
        text-align: center;
        border-bottom: none !important;
        justify-content: center !important;
    }

    .modal-title {
        color: #173a64;
        font-weight: bolder !important;
        font-size: 24px;
        padding-top: 12px;
        padding-bottom: 4px;
        display: inline-block;
    }

    .CloseModalBtn {
        background: #173a64 !IMPORTANT;
        color: #FFFFFF;
        line-height: 25px;
        position: absolute;
        right: -12px;
        text-align: center;
        top: -10px;
        width: 45px;
        text-decoration: none;
        font-weight: bold;
        box-shadow: 1px 1px 3px #000;
        transition: all .3s;
        height: 45px;
        border-radius: 50%;
        font-size: 25px !important;
        padding: 8px;
        cursor: pointer;
        z-index: 9999;
    }

    .bootstrap-tagsinput .tag:not([class*=bg-]) {
        background-color: #173a64;
        color: #fff;
    }

    .bootstrap-tagsinput {
        overflow-y: auto;
        cursor: pointer;
        height: 70px;
    }

    .windowmode tbody tr:nth-child(even) td,
    .mobileview tbody tr:nth-child(even) td {
        background: none !important;
    }

    .windowmode tbody tr:nth-child(even),
    .mobileview tbody tr:nth-child(even) {
        background-color: #f7f7ff !important;
    }

    .windowmode .table th, .windowmode .table td,
    .mobileview .table th, .mobileview .table td {
        border: none !important;
        white-space: nowrap;
    }

        .windowmode .table td:last-child,
        .mobileview .table td:last-child {
            border: none !important;
            white-space: pre-wrap;
        }


    .windowmode .table td, .windowmode .table tr,
    .mobileview .table td, .mobileview .table tr {
        border: none;
    }

    .windowmode {
        min-height: 200px;
        max-height: 300px;
        overflow-y: auto;
        overflow-x: visible !important;
        padding: 0px;
        width: 100%;
    }

    .mobileview {
        min-height: 200px;
        max-height: 300px;
        overflow-y: auto;
        overflow-x: visible !important;
        padding: 0px;
        width: 100%;
        background: #fff !important;
        display: none;
    }

    .mobileviewcontent {
        display: inline-block;
        position: relative;
        top: 10px;
        left: 5px;
        font-family: 'Pilat Wide';
    }

    .mobileview .card {
        margin-bottom: 18px !important;
    }

    .mobileview td {
        font-size: 10px;
        color: #898989
    }

    @@media(min-width: 300px) and (max-width: 790px) {
        .windowmode {
            display: none;
        }

        .mobileview {
            display: block;
        }
    }

    .BaseFilter div input:not(:checked)::before {
        content: attr(data-content);
        font-size: 6px;
        DISPLAY: flex;
        font-weight: 700;
        JUSTIFY-CONTENT: center;
        ALIGN-ITEMS: center;
        ALIGN-SELF: center;
    }

    .HighlightOverallHrs {
        color: red !important;
    }
    /* Main Container Styles */
    .area-monitor-card {
        background: #fff;
        border: 1px solid #dee2e6;
        border-radius: 8px;
        transition: all 0.3s ease;
        position: relative;
        cursor: default;
        min-width: 280px;
    }

        .area-monitor-card:hover {
            box-shadow: 0 10px 20px rgba(0,0,0,0.12);
            border-color: #007bff;
            z-index: 100;
        }

    /* Progress Bar Tweaks */
    .bar-height {
        height: 8px;
        border-radius: 5px;
    }

    /* The Hover Block List (Hidden by default) */
    .block-details-overlay {
        display: none;
        position: absolute;
        top: 100%;
        left: 0;
        width: 100%;
        background: #fff;
        border: 1px solid #007bff;
        border-top: none;
        border-radius: 0 0 8px 8px;
        box-shadow: 0 10px 20px rgba(0,0,0,0.12);
        padding: 10px;
        z-index: 1050;
        max-height: 250px;
        overflow-y: auto;
    }

    .area-monitor-card:hover .block-details-overlay {
        display: block;
    }

    /* Small Block Rows */
    .block-row {
        font-size: 0.8rem;
        padding: 4px 0;
        border-bottom: 1px solid #f8f9fa;
    }

        .block-row:last-child {
            border-bottom: none;
        }

    .dashboard-container {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 15px;
    }
    /* Set a standard base width for all cards so they align in one row */
    .card-wrapper {
        flex: 1 1 200px; /* Adjusts width based on screen size */
        max-width: 300px;
    }

    .noselect {
        user-select: none;
    }
</style>

