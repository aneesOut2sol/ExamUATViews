@if (System.Configuration.ConfigurationManager.AppSettings["ManagementOptionDashboard"] == "on")
{

    <div class="ng-cloak DashboardDiv" id="MainDiv" ng-cloak ng-controller="ExamActivityDashboardCtrl" ng-init="ExamActivityDashboard_Init('@System.Configuration.ConfigurationManager.AppSettings["ManagementOptionDashboard_RefreshTime"]')">
        <div class="page-header border-bottom-0">
            <div class="page-header-content header-elements-md-inline" style="padding:0px;">
                <div class="col-md-12 p-0">

                    <div class="dashboard-container">
                        <div class="page-title">
                            <h4> <span class="font-weight-semibold">Examination Details</span></h4>
                        </div>
                        <div class="card-wrapper" ng-repeat="area in ExamAreaFreeSlot">
                            <div class="area-monitor-card p-3"
                                 ng-mouseenter="area.showDetails = true"
                                 ng-mouseleave="area.showDetails = false">

                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <h6 class="font-weight-bold mb-0">{{area.Area}}</h6>
                                    <small class="text-muted">Total: <b>{{area.Total}}</b></small>
                                </div>

                                <div class="progress bar-height mb-2 bg-light">
                                    <div class="progress-bar"
                                         ng-class="getPercent(area.Total - area.Free, area.Total) > 85 ? 'bg-danger' : 'bg-primary'"
                                         style="width: {{getPercent(area.Total - area.Free, area.Total)}}%">
                                    </div>
                                </div>

                                <div class="d-flex justify-content-between small">
                                    <span>Occupied: <b>{{area.Occupied}}</b></span>
                                    <span>Free: <b class="text-success">{{ area.Free < 0 ? 0 : area.Free }}</b></span>
                                </div>

                                <div class="block-details-overlay" ng-show="area.showDetails">
                                    <div class="small font-weight-bold border-bottom pb-1 mb-2 text-primary">BLOCK BREAKDOWN</div>
                                    <div class="block-row d-flex justify-content-between" ng-repeat="block in area.BlockList">
                                        <span>{{block.Block}}</span>
                                        <span>F: <b class="text-success">{{ block.Free < 0 ? 0 : block.Free }}</b> / T: {{block.BlockTotal}}</span>
                                    </div>
                                </div>
                            </div>
                        </div>

